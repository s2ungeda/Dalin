procedure TTVSignal.CheckTotTradeQty(const AData: TSignalConfig);
var
  iRes :integer;
  dRemain: double;
begin
  iRes := CmpVal(FConfig.TradeTotQty, AData.TradeTotQty);
  // МіФЁАЁ ЕћИІЖЇИИ..
  if iRes <> 0 then
  begin
    if FSigOrders[aoEntry].Done then
    begin
      CheckReStart(aoEntry);
      //
      SendMessageToOwner(mtState, 0);

      DoLog(Format('ИёЧЅ МіЗЎ СѕАЁЗЮ [СјРд] РчАГ %s -> %s', [
        DoubleToStr(FConfig.TradeTotQty), DoubleToStr(AData.TradeTotQty)]));
    end else
    begin

      if GetSymbol(ekUpbit) <> nil then
      begin
        dRemain := GetRemainOrderQty(aoEntry);
        if dRemain < gAOConfig.GetMajorTradeSymbolLotSize(GetSymbol(ekUpbit).Spec.BaseCode) then
        begin
          FSigOrders[aoEntry].Done := true;
          FSigOrders[aoEntry].AllOrderCancels;

          SendMessageToOwner(mtResult, integer(srtEDone));

          DoLog(Format('ИёЧЅ МіЗЎ АЈМвЗЮ [СјРд] Stop %s -> %s', [
            DoubleToStr(FConfig.TradeTotQty), DoubleToStr(AData.TradeTotQty)]));
        end;
      end;

    end;
  end;

  FConfig.Assign(AData);
  FStgCode := AData.StgCode;
end;


function TTVSignal.CheckTurnOver: boolean;
var
  dTO: double;
begin
  Result := true;
  if FStgStatus = stgRun then
  begin

    if FConfig.TradeTotQty < EPSILON then Exit;

    dTO := ((FSigOrders[aoEntry].GetTotFilledQty + FSigOrders[aoExit].GetTotFilledQty) * 0.5) / FConfig.TradeTotQty * 100;
    FTORate := dTo;
    if dTO > gAOConfig.Result.TORate then
    begin
      DoLog(Format('ШИРќРВ УЪАњ  %s > %s (%s, %s)', [
        DoubleToStr(dTO), DoubleToStr(gAOConfig.Result.TORate),
        DoubleToStr(FSigOrders[aoEntry].AccFilledQty[MK]) ,
        DoubleToStr(FSigOrders[aoExit].AccFilledQty[MK])
        ]));
      Result := false;

      FStgStatus := stgTO;
//      FRun   := false;
      SendMessageToOwner(mtStgStatus, 0);
    end;
  end;
end;

