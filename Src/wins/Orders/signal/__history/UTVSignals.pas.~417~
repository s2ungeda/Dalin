function TTVSignal.GetOrderCKip(aoType: TAutoOrderType; FS: TMethodType; korEx: TExchangeKind): double;
var
  dFee : double;
begin
  Result := GetAdjustKip(aoType, FS);

  with App.Engine do
    case FS of
      mtF: dFee := ApiConfig.GetFee(ekBinance, eaFutUSDT, GetSymbol(ekBinance).Spec.SettleType, ftMaker);
      mtS: dFee := ApiConfig.GetFee(korEx, eaSpot, scKRW, ftMaker);
    end;

  case aoType of
    aoEntry: Result := Result - dFee;// ApiConfig.GetFee(ekBinance, eaFutUSDT, scUSDT, ftMaker);
    aoExit:  Result := Result + dFee;// ApiConfig.GetFee(korEx, eaSpot, scKRW, ftMaker);
  end;
end;


function TTVSignal.SelectCEXtoLiqOrder(aoType: TAutoOrderType; dQty : double; bLog: boolean) : TSelectCEX;
var
  dFeePrice, d: double;  e:TExchangeKind;
  dPrice : array [TExchangeKind] of double;
  iSide: Integer;
  bCanHit : boolean;
begin
  // СжЙЎМіЗЎАњ, АХЗЁМв МБХУ
  Result.init;
  d     := ifThenFloat(aoType = aoEntry, 99999990, EPSILON);
  iSide := ifThen(aoType = aoEntry, 1, -1);

  for e := ekUpbit to High(TExchangeKind) do
  begin
    dPrice[e] := 0;
    // ФЁДТ СжЙЎРЯЖЇДТ..
    if bLog then
    begin
      // БЙГЛ Taker СжЙЎРЬ АЁДЩЧбДй.
      bCanHit :=  CanHitOrder(e, iSide, dQty);
    end else
      bCanHit := true;

    if bCanHit then
    begin
      dPrice[e] := GetSymbol(e).CalcEstPrice(iSide, dQty);

      if aoType = aoEntry then
      begin
        dFeePrice := dPrice[e] + App.Engine.ApiConfig.GetFee(e, eaSpot, scKRW, ftTaker);
        if (dFeePrice > EPSILON) and (dFeePrice < d) then
        begin
          d := dFeePrice;//dPrice[e];
          Result.Price := dPrice[e];
          Result.ExKind:= e;
        end;
      end else
      begin
        dFeePrice := dPrice[e] - App.Engine.ApiConfig.GetFee(e, eaSpot, scKRW, ftTaker);
        if (dFeePrice > EPSILON) and (dFeePrice > d) then
        begin
          d := dFeePrice;//dPrice[e];
          Result.Price := dPrice[e];
          Result.ExKind:= e;
        end;
      end;
    end;

  end;

  if bLog then
    if Result.ExKind = ekBinance then
      DoLog('@1-1 ШФСжЙЎ АХЗЁМв -> X')
    else
      DoLog( Format('@1-1 ШФСжЙЎ АХЗЁМв -> %s  (%s, %s)', [TExchangeKindDesc[Result.ExKind],
        DoubleToStr(dPrice[ekUpbit]),  DoubleToStr(dPrice[ekBithumb]) ]));


end;

constructor TTVSignal.Create(aColl: TCollection);
var e: TExchangeKind;
  a : TAutoOrderType;
begin
  inherited Create(aColl);

  FStgStatus  := stgStop;

  FContents:= TList<TRqContent>.Create;
  FConfig.init;

  for a := aoEntry to High(TAutoOrderType) do
  begin
    FTimers[a]  := TCollection.Create(TOrderTimer);
    for e := ekBinance to High(TExchangeKind) do
    begin
      TOrderTimer.Create(FTimers[a],e,otPutTimer) ;
      TOrderTimer.Create(FTimers[a],e,otLiqTimer) ;
      TOrderTimer.Create(FTimers[a],e,otNxtTimer) ;
    end;
  end;

  for a := aoEntry to High(TAutoOrderType) do
  begin
    FResults[a]   := TList<TStgOrderItem>.Create;
    FLiqOrders[a] := TList<TLiqOrder>.Create;
    FSigOrders[a] := TSignalOrders.Create(Self, a);

    for e := ekBinance to High(TExchangeKind) do
      MsgCode[a, e] := '';
  end;

  // УЪБтШ­ ОЪДТ КЏМіЕщ..
  for e := ekBinance to High(TExchangeKind) do
    for var ss := stLong to High(TSideType) do
      FilledQty[e, ss] := 0;

  Init;
end;

destructor TTVSignal.Destroy;
begin

  ClearLiqOrders;
  
  for var a := aoEntry to High(TAutoOrderType) do
  begin
    FTimers[a].Free;
    FSigOrders[a].Free;
    FLiqOrders[a].Free;
    FResults[a].Free;
  end;

  FContents.Free;

  inherited;
end;


