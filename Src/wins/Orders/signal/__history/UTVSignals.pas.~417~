procedure TTVSignal.OnOrder(o: TOrder; eID: integer);
var
  e: TExchangeKind;
  aoType : TAutoOrderType;

  function IsNotNormal(a: TAutoOrderType) : boolean;
  begin
    Result := (FStgStatus <> stgRun) or (not FData[a].Switch) or (FSigOrders[a].Done);
  end;

begin
  if o.GroupNo <> FConfig.StgCode then Exit;
  if o.Symbol.Spec.BaseCode <> GetSymbol(ekUpbit).Spec.BaseCode then Exit;
  if o.Symbol.Spec.ExchangeType = ekBinance then
    if o.Symbol.Spec.SettleType <> GetSymbol(ekBinance).Spec.SettleType then Exit;
  if o.StgType <> stTVSignal then Exit;

  if o.Entry then
    aoType := aoEntry
  else
    aoType := aoExit;

  // e ДТ MK БтСиРИЗЮ МБХУ
  case o.Tag of
    PUT_ORD,
    DST_ORD : e := o.Symbol.Spec.ExchangeType;
    LIQ_ORD : e := TExchangeKind(o.TargetCEX);
    else Exit;
  end;

  case eID of
    ORDER_ACCEPTED : begin
        // ЛѓХТКЏАц СїРќПЁ ГЊАЃ MK СжЙЎРК ЙйЗЮ УыМвЧбДй.
        // On УМХЉ ЧиСІ, ПЯЗс ЕЦРЛЖЇЕЕ УыМв..
        if (o.Tag = PUT_ORD) and (IsNotNormal(aoType)) then
        begin
          DoLog(Format(' %s ЛѓХТ КЏАцЕШ СжЙЎ СЂМі -> УыМв : %s', [TAutoOrderTypeDesc[aoType], o.Represent]));
          if FSigOrders[aoType].ExOrders[e].Last.OrderList[MK].Count > 0 then
            FSigOrders[aoType].ExOrders[e].AllCancels
          else
            DoCancelOrder(o);
          Exit;
        end else
        if (o.Tag = PUT_ORD) and (not IsNotNormal(aoType)) then
        begin
          // СЄЛѓУГИЎИІ РЇЧи
          FSigOrders[aoType].ExOrders[e].OnOrder(o);
        end;
        // УМАс ПЊРќРЬ ПТАцПь...Next ИІ ИИЕщОюЙіИЎДТАцПьАЁ РеОюМ­..Exit ЧбДй.
        Exit;
      end;
    ORDER_REJECTED :
      begin
        DoLog(' АХКЮЕЪ : ' + o.Represent + ' -> '+o.RejectCode +','+o.RejectReason);

        if o.State in [osRejected, osFailed] then
          if (o.Tag = PUT_ORD) and FSigOrders[aoType].ExOrders[e].Find(o, MK) then
          begin
            if IsNotNormal(aoType) then
              FSigOrders[aoType].ExOrders[e].ClearOrder(o)
            else  begin
              SetTimer(aoType, otPutTimer, true, e);
              FSigOrders[aoType].ExOrders[e].RejectOrderProc(o);
            end;
          end
          else if (o.Tag = LIQ_ORD) and FSigOrders[aoType].FindAfterOrder(o) then
          begin
            var ot := FindTimer(aoType, e, otLiqTimer);
            if ot <> nil then
            begin
              ot.Interval := 200;
              ot.Enable   := true;
            end;
            AddLiqOrder(aoType, o);
            DoLog(' ШФСжЙЎ РчСжЙЎ ИЎНКЦЎПЁ УпАЁ');
            Exit;
          end
          else begin
            //
//            SendMessageToOwner(mtResult, integer(srtERJT) );
          end;
      end;

    ORDER_CHANGED :
      begin
        //  СЄСЄШФ ЙЋНМ УГИЎИІ..ЧиОпЧЯСі..???
        DoLog('СЄСЄЕЪ : ' + o.Represent);
        if (o.Tag = PUT_ORD) and (IsNotNormal(aoType)) then
        begin
          DoLog(Format(' %s ЛѓХТ КЏАцЕШ СжЙЎ СЄСЄ -> УыМв : %s', [TAutoOrderTypeDesc[aoType], o.Represent]));
          if FSigOrders[aoType].ExOrders[e].Last.OrderList[MK].Count > 0 then
            FSigOrders[aoType].ExOrders[e].AllCancels
          else
            DoCancelOrder(o);
        end else
          if e = ekBinance then
            o.ModifyCnt  := o.ModifyCnt + 1;

        Exit;
      end;
    ORDER_CANCELED :
      begin
        DoLog('УыМвЕЪ : ' + o.Represent);
        if o.State = osCanceled then
          case o.Tag of
            PUT_ORD : if FSigOrders[aoType].ExOrders[e].Find(o, MK) then
                      begin
//                        if (aoType = FActiveType) and (FState <> ssNone) then
//                          SetTimer(otPutTimer, true, e)
//                        else
                        if IsNotNormal(aoType) then
                          FSigOrders[aoType].ExOrders[e].ClearOrder(o)
                        else
                          SetTimer(aoType, otPutTimer, true, e);
                      end;
            LIQ_ORD : FSigOrders[aoType].ExOrders[e].ClearOrder(o);
            else Exit;
          end;
      end;

    ORDER_FILLED:
      begin

      end;
  end;

  // F/S NЙјТА СжЙЎ ПЯЗс ПЉКЮ УМХЉ..
  FSigOrders[aoType].ExOrders[e].IsDone;
end;

procedure TTVSignal.OnOrderTimer(aoType: TAutoOrderType);
var
  i, ii :Integer;
  OrdTimer: TOrderTimer;
  e: TExchangeKind;
begin

  for i := 0 to FTimers[aoType].Count-1 do
  begin
    OrdTimer := FTimers[aoType].Items[i] as TOrderTimer;
    e := OrdTimer.ExKind;

    if OrdTimer.Enable and OrdTimer.CheckTime then
      if OrdTimer.TimerType = otLiqTimer then
      begin
        // ШФ СжЙЎ НЧЦа ХИРЬИг
        CheckLiqOrder(aoType, e);
        OrdTimer.LastTick  := GetTickCount64;
      end else
      begin
        OrdTimer.Enable := false;

        if OrdTimer.TimerType = otPutTimer then
        begin
          // МБ СжЙЎ ХИРЬИг
            for ii := FSigOrders[aoType].ExOrders[e].Last.OrderList[MK].Count-1 downto 0 do
            begin
              var aOrder := FSigOrders[aoType].ExOrders[e].Last.OrderList[MK][ii];
              if (aOrder <> nil) and (aOrder.State in [osCanceled, osRejected, osFailed]) then begin
                DoLog(Format('%s %s Put Timer (%s) : Clear -> %s', [TAutoOrderTypeDesc[aoType],
                  TExchangeKindDesc[e], GetTickCount64.ToString,  aOrder.Represent ]));
                FSigOrders[aoType].ExOrders[e].Last.OrderList[MK].Delete(ii);
              end;
            end;
        end else
        if OrdTimer.TimerType = otNxtTimer then
        begin
          //
            FSigOrders[aoType].ExOrders[e].New;

            DoLog(Format('Next : %s %s %02d.th (%s) ', [
              ifThenStr(e = ekBinance,'F', 'S'), TExchangeKindDesc[e],
              FSigOrders[aoType].ExOrders[e].Count, GetTickCount64.ToString  ])
              );
        end;
      end;
  end;

  CheckSuspend(aoType);

  // ШИРќРВ ОјОжБтЗЮ Чд..
  //CheckTurnOver;
end;

