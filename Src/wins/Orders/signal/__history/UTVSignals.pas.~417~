function TTVSignal.FindTimer(a: TAutoOrderType; e: TExchangeKind;
  t: TOrderTimerType): TOrderTimer;
  var i:integer;
    ot:TOrderTimer;
begin
  Result := nil;
  for I := 0 to FTimers[a].Count-1 do
  begin
    ot := FTimers[a].Items[i] as TOrderTimer;
    if (ot.ExKind = e) and (ot.TimerType = t) then
    begin
      Result := ot;
      break;
    end;
  end;
end;

