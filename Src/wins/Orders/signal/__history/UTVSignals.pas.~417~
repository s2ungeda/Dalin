procedure TTVSignal.SetTimer(aoType: TAutoOrderType; otType: TOrderTimerType;
  bEnable: boolean; e: TExchangeKind);
var
  ot: TOrderTimer;
begin

  if not IsRun then Exit;

  ot := FindTimer(aoType, e, otType);
  if ot <> nil then
  begin
    if ot.Enable then Exit;
