function TTVSignal.GetSellAbleQty(FS: TMethodType; ordEx: TExchangeKind; var sMsg: string): double;
var
  dOrdQty, dTmp, dMinQty : double;
  iPre: integer;
  aAsset : TAsset;
begin
  sMsg := '';
  // ЧиПм АэЗСЧиМ­ УжМв СжЙЎ МіЗЎ
  Result := 0;
//  dMinQty := App.Engine.SymbolCore.CalcMinOrderQty(GetSymbol(ordEx), GetSymbol(ekBinance),
//    GetSymbol(ordEx).Asks[0].Price, -1);
//  if dMinQty <= 0 then begin sMsg :=MSG_CODE_QTE;  Exit; end;

  dMinQty := gAOConfig.GetMajorTradeSymbolLotSize(GetSymbol(ekBithumb).Spec.BaseCode);

  iPre   := Min(GetSymbol(ordEx).Spec.QtyPrecision, GetSymbol(ekBinance).Spec.QtyPrecision);

  // УЛЛъРЬЙЧЗЮ F ДТ..БЙГЛ ИХЕЕРмЗЎРЛ, S ДТ ЧиПм ИХМі ХфХЛРмЗЎРЛ
  // F : УЛЛъ ЧиПм ИХМі  -> БЙГЛ Taker ИХЕЕ ИІ РЇЧи ИХМі РмЗЎРЛ ХыЧи МіЗЎ БИЧд
  // S : УЛЛъ БЙГЛ ИХЕЕ  -> ЧиПм Taker ИХМі ИІ РЇЧи ИХЕЕ УбРмЗЎРЛ ХыЧи МіЗЎ БИЧд.
  case FS of
    mtF: dTmp := GetSymbol(ordEx).Bids[0].Volume * (FConfig.Input[FS].VolRate / 100);
    mtS: dTmp := GetSymbol(ekBinance).Asks.VolumeTotal * (FConfig.Input[FS].VolRate / 100);
  end;

  dOrdQty:= TruncDecimal(GetOrderExitQty(min(dTmp, FConfig.Input[FS].OrderQty)), iPre);

  if dOrdQty < dMinQty then
  begin
    sMsg := MSG_CODE_RQY;
    Exit (0);
  end;

  var dHasQty, dAvailableQty : double  ;

  try
    dHasQty := 0;  dAvailableQty := 0;

    aAsset  := GetAccount(ordEx).Assets.Find(GetSymbol(ordEx).Spec.BaseCode);
    if aAsset = nil then Exit;
    if aAsset.Available <= 0 then Exit;
    // ГЊАЁОп Чв ИХЕЕ СжЙЎ..( ЧиПм ИХМіСжЙЎ УМАс ЕЩАцПь..)
    dHasQty  := TTVSignals(Collection).GetOSExitBidOrderQty(ordEx);

    dAvailableQty := aAsset.Available - dHasQty;
    if dAvailableQty <= dMinQty then
      Result := 0
    else begin

      if CmpVal(dAvailableQty, dOrdQty) >= 0 then
        Result := dOrdQty
      else begin
        dOrdQty := TruncDecimal(dAvailableQty, iPre);
        Result  := ifThenFloat(dOrdQty < dMinQty, 0, dOrdQty);
      end;
    end;

  finally
    if Result = 0 then sMsg := MSG_CODE_BAL;

//    if Result > EPSILON then
//    App.Log(llDebug, 'orderqty', '(ИХЕЕ) %s : %s, %s, %s, %s, %s, %s', [ DoubleToStr(Result),
//      aAsset.Balance.ToString, dAvailableQty.ToString, dOrdQty.ToString,
//      dQty.ToString, dQty3.ToString, dQty2.ToString ] );
//
//    if Result <= EPSILON then
//      if aAsset <> nil then
//        FErrMsg := format('БЙГЛ РмАэ КЮСЗ %s, %s, %s, %s ', [
//          DoubleToStr(aAsset.Balance), DoubleToStr(dAvailableQty),
//          DoubleToStr(dOrdQty), DoubleToStr(dQty + dQty2 + dQty3) ]);
  end;
end;


function TTVSignal.GetMakerOrderPrice(e: TExchangeKind; iSide: integer;
  const dTmpPrice, dMin, dMax: double): double;
  var
    dPrice  : double;
    i: integer;
begin
  Result := -1;
    //
  dPrice := ifThenFloat(iSide > 0, dMax, dMin);

  while True do
  begin
    // ИХЕЕДТ 1ОП СѕАЁ.  ИХМіДТ 1ОП АЈМв
    dPrice:= TicksFromPrice(GetSymbol(e), dPrice, -1 * iSide );

    if iSide > 0 then
    begin
        // ИХМі
        if CmpVal(dPrice, dTmpPrice) <= 0 then
        begin
          Result := dPrice;
          break;
        end;
        if dPrice < dMin then break;

    end else
    begin
        // ИХЕЕСжЙЎАЁАнРЬДЯ АААХГЊ ХЋАХ..
        if CmpVal(dPrice, dTmpPrice) >= 0 then begin
          Result:= dPrice;
          break;
        end;
        if dPrice > dMax then break;

    end;
  end;
end;

function TTVSignal.GetSellCustomMakerOrderPrice(e: TExchangeKind; const dUnit,
  dTmpPrice, dMin, dMax: double): double;
  var
    iFactor, iPrice, iAskPrice, iSize: int64;
    dAskPrice  : double;
begin
  Result := -1;

  if e = ekBinance then
  begin
    // ЧиПмДТ ЦНЛчРЬСю АэСЄ..
    iFactor := Round(Power(10, GetSymbol(e).Spec.Precision));
    iSize   := Round(dUnit * iFactor);
  end else
    iFactor := Round(Power(10, GetPrecision(GetSymbol(e), dMin)));

  iPrice  := Round(dTmpPrice * iFactor);
    //
  dAskPrice:= dMin;
  while True do
  begin
    dAskPrice:= TicksFromPrice(GetSymbol(e), dAskPrice, 1);

    if e <> ekBinance then begin
      // БЙГЛДТ АЁАнИЖДй ЦНЛчРЬСюАЁ ДйИЃБтПЁ
      iFactor   := Round(Power(10, GetPrecision(GetSymbol(e), dAskPrice)));
      iAskPrice := Round(dAskPrice* iFactor);
      iSize     := Round(dUnit* iFactor);
    end else
      iAskPrice := Round(dAskPrice* iFactor);

    // ИХЕЕСжЙЎАЁАнРЬДЯ АААХГЊ ХЋАХ..
    if ((iAskPrice mod iSize) = 0) and (iAskPrice >= iPrice) then
    begin
      Result:= dAskPrice;
      break;
    end;

    if dAskPrice > dMax then break;
  end;

end;

