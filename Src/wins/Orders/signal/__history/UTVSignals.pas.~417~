function TTVSignal.GetLongCustomMakerOrderPrice(e: TExchangeKind; const dUnit,
  dTmpPrice, dMin, dMax: double): double;
  var
    dBidPrice: double;
    iSize, iVal, iPrice, iFactor: int64;
begin
  Result := -1;

  iPrice:= Round(dTmpPrice* Power(10, GetPrecision(GetSymbol(e), dTmpPrice)));
    //
  dBidPrice := dMax;
  while True do
  begin
    dBidPrice  := TicksFromPrice(GetSymbol(e), dBidPrice, -1);
    // АЁАнКАЗЮ МвМіСЁРЬ ДоЖѓСіБтПЁ ЗчЧСОШПЁМ­ЕЕ БИЧбДй.
    iFactor := Round(Power(10, GetPrecision(GetSymbol(e), dBidPrice)));
    iVal    := Round(dBidPrice* iFactor);
    iSize   := Round(dUnit* iFactor);

    // ИХМіРЬБтПЁ АААХГЊ РлРКАХ
    if ((iVal mod iSize) = 0) and (iPrice >= iVal) then
    begin
      Result := dBidPrice;
      break;
    end;

    if dBidPrice < dMin then break;
  end;
end;

function TTVSignal.GetLongMakerOrderPriceRange(var ordRng: TOrderRange;
  const dCkip, dEst: double; ordEx: TExchangeKind): boolean;
 var
    dVal, tmpPrice, dConst, dEx : double;
    iRes : integer;
begin
  Result := false;

  dEx :=  App.Engine.ApiManager.ExRate.Value;

  if ordEx = ekBinance then
    tmpPrice  := (100 * dEst) / (dEx * (dCkip + 100))
  else
    tmpPrice  := (dEst * dEx * (dCkip + 100)) / 100;

  if tmpPrice <= EPSILON then Exit;

  var dMin, dMax, dPrice, dSize : double;

  // ЧиПм ИХМі maker СжЙЎРК УЛЛъ F
  // БЙГЛ ИХМі maker СжЙЎРК СјРд S

  if ordEx = ekBinance then begin
    // ЧиПм
    dMax  := GetSymbol(ordEx).CalcTicksPrice(GetSymbol(ordEx).Asks[0].Price, -1);
    dConst    := gAOConfig.Result.PriceRangePer[scInter] / 100;
  end else
  begin
    // БЙГЛ АХЗЁМвСп ИХЕЕШЃАЁ -1 РЬ АЁРх ХЋАЊРЛ Max ЗЮ МБХУ
    dConst    := gAOConfig.Result.PriceRangePer[scDomes] / 100;
    var bu, bt : boolean;
    var du := GetSymbol(ekUpbit).CalcTicksPrice(GetSymbol(ekUpbit).Asks[0].Price, -1);
    if (du <= EPSILON) then bu := false else bu := true;
    var dt := GetSymbol(ekBithumb).CalcTicksPrice(GetSymbol(ekBithumb).Asks[0].Price, -1);
    if (dt <= EPSILON) then bt := false else bt := true;

    if (not bt) and (not bu) then Exit;
    if bt and bu then
      dMax  := Min(du, dt)
    else if bt then
      dMax  := dt
    else if bu then
      dMax  := du
    else Exit;
  end;

  dMin  := dMax * (1 - dConst);
  //
  ordRng.MaxPrice := dMax;
  ordRng.MinPrice := dMin;
  ordRng.TmpPrice := tmpPrice;
  //
  ordRng.EstPrice := dEst;
  ordRng.ExRate   := dEx;
  ordRng.CKip     := dCkip;
  ordRng.ExKind   := TExchangeKindShortDesc[ordEx];

//  if ordEx = ekBinance then
//    OrdRange[aoExit, S].Assign(ordRng)
//  else
//    OrdRange[aoEntry, F].Assign(ordRng);

  iRes := CmpVal(tmpPrice, dMax);

  if iRes >= 0 then
    // ИХМіАЁАнРЬ АэАЁКИДй ГєРИИщ
    ordRng.OrdPrice := dMax
  else
    if tmpPrice < dMin then
      Exit
    else begin
      // ЧиПм ИХМі maker СжЙЎРК УЛЛъ F
      // БЙГЛ ИХМі maker СжЙЎРК СјРд S
      var dUnit := gAOConfig.GetMajorTradeSymbolUnit(ordEx, GetSymbol(ordEx).Spec.BaseCode);
      if dUnit > 0 then
        // customunit РћПы
        ordRng.OrdPrice := GetLongCustomMakerOrderPrice(ordEx, dUnit, tmpPrice, dMin, dMax)
      else
        // ПјЗЁ ЗЮСї РћПы..
        ordRng.OrdPrice := GetMakerOrderPrice(ordEx, 1, tmpPrice, dMin, dMax);

      if ordRng.OrdPrice <= EPSILON then Exit;
    end;

  Result := true;
end;

