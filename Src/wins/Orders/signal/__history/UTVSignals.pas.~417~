procedure TTVSignal.SetEntryCondition(var ordCondition: TOrderCondition);
var
  dKip      : array [TMethodType] of double;
  e: TMethodType;
begin
  ordCondition.Result := false;
  try

    dKip[F] := GetKip(
      GetSymbol(ekUpbit).CalcEstPrice(1, FConfig.Input[F].OrderQty),
      GetSymbol(ekBinance).CalcTicksPrice(GetSymbol(ekBinance).Bids[0].Price, 1),
      App.Engine.ApiManager.ExRate.GetExRate
      );

    dKip[S] := GetKip(
      GetSymbol(ekUpbit).CalcTicksPrice(GetSymbol(ekUpbit).Asks[0].Price, -1),
      GetSymbol(ekBinance).CalcEstPrice(-1, FConfig.Input[S].OrderQty),
      App.Engine.ApiManager.ExRate.GetExRate
      );

    for e := F to High(TMethodType) do
      if (dKip[e] = WRONG_VALUE) then
        Exit;

    ordCondition.UpAvgKip := (dKip[F] + dKip[S]) * 0.5;
    ordCondition.Result := true;
  finally
  end;
end;


