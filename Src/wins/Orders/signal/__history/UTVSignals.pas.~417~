  Result := 0;
  dTmp :=  FAfterOrdOrderQty[fs];
  // ШФСжЙЎ МіЗЎПЁ УМАс МіЗЎРЛ ДѕЧд..
  AfterOrdOrderQty[fs] := dQty;

  if dUnit < 0 then begin
    Result  := FAfterOrdOrderQty[fs];
    FAfterOrdOrderQty[fs] := 0;
  end
  else begin
    // УжМвСжЙЎМіЗЎ ЙшМіЗЮ СжЙЎМіЗЎРЛ БИЧЯАэ ГЊИгСіИІ ШФСжЙЎМіЗЎПЁ МТЦУ...
    Result:= CalcOrderQty(AfterOrdOrderQty[fs], dUnit, dRemain);
    FAfterOrdOrderQty[fs] := dRemain
  end;

  TTVSignal(FOwner).DoLog(
    Format('@2-0 %s %s After Order Qty %s = %s + %s ->  Q:%s, R:%s', [
      ifThenStr(fs = F,'F','S'),  dUnit.ToString,
      DoubleToStr(dTmp + dQty), DoubleToStr(dTmp) , DoubleToStr(dQty),
      DoubleToStr(Result), DoubleToStr(FAfterOrdOrderQty[fs]) ])
  );
end;


