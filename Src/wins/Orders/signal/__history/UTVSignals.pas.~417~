function TTVSignal.CanHitOrder(ordEx: TExchangeKind; iSide: integer;
  qty: double): boolean;
var
  dAvailable, dOrderAmt : double;
  dFee, dHasToAmt, dQty3, dHasToQty, dAvailableQty, dHitPrice : double;
  aAsset : TAsset;
begin
  Result := false;
  dHitPrice := 0;   dHasToAmt := 0;

  if iSide > 0 then
  begin
      // ГЊАЁОпЧв ИХМі СжЙЎРЬ РжДТ АцПь- 1 ( ЧиПм ИХЕЕ СжЙЎРЬ РжДТАцПь )
      dHasToAmt := App.Engine.TradeCore.Orders[ekBinance].GetMustLongOrderAmt(stTVSignal, ordEx, eaSpot);
      dHitPrice := GetHitOrderPrice(GetSymbol(ordEx), 1, scDomes);
      dFee      := App.Engine.ApiConfig.GetStandardFee(ordEx, eaSpot);

      dAvailable  := GetAccount(ordEx).Available - dHasToAmt;

      if GetSymbol(ordEx).Spec.MinNotional >= dAvailable then
        Exit
      else begin
        dOrderAmt := (qty * dHitPrice)*(1+(dFee/100)) ;
        if CmpVal(dAvailable, dOrderAmt) >= 0 then
          Result := true;
      end;
  end else
  begin
      aAsset  := GetAccount(ordEx).Assets.Find(GetSymbol(ordEx).Spec.BaseCode);
      if aAsset = nil then Exit;
      if aAsset.Available < EPSILON then Exit;
      // ГЊАЁОп Чв ИХЕЕ СжЙЎ..( ЧиПм ИХМіСжЙЎ УМАс ЕЩАцПь..)
      dHasToQty  := TTVSignals(Collection).GetOSExitBidOrderQty(ordEx);

      dAvailableQty := aAsset.Available - dHasToQty;
      if CmpVal(dAvailableQty, qty) >= 0 then
        Result := true;
  end;
end;

procedure TTVSignal.CheckLiqOrder(aoType: TAutoOrderType; e: TExchangeKind);
var
  i: integer;
  aLiq: TLiqOrder;
  o: TOrder;
begin
  if not IsRun then Exit;

  for I := FLiqOrders[aoType].Count-1 downto 0 do
  begin
    aLiq  := FLiqOrders[aoType][i];
    if (aLiq.MKExKind = e) and (aLiq.CheckTime) then
    begin
      if FSigOrders[aoType].ExOrders[e].Last.ReLiquidOrder(aLiq.Target) then
      begin
        o := aLiq.Target;
        FLiqOrders[aoType].Delete(i);
        aLiq.Free;
        // ПЯЗс ЕЦДТСі УМХЉ../.
        SigOrders[aoType].ExOrders[e].IsDone;
      end;
    end;
  end;
end;

