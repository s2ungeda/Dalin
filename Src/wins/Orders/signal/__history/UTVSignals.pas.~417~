procedure TTVSignal.UpdateEntryQty(sEntryQty: string);
var
  dOld, dNew, dQty : double;
begin
  if not TryStrToFloat(sEntryQty, dQty) then Exit;

  if dQty < 0 then Exit;

  dOld  := GetEntryQty;

  try
    FSigOrders[aoEntry].SetAccFilledQty2(dQty)   ;
    FSigOrders[aoExit].SetAccFilledQty2(0)   ;

    dNew := GetEntryQty;

    if FSigOrders[aoExit].Done then
    begin
      if dNew > EPSILON then begin
        DoLog('RT МіЗЎ КЏШ­ЗЮ [УЛЛъ] РчАГ');
        CheckReStart(aoExit);
      end;
    end;

    if FSigOrders[aoEntry].Done then
    begin
      if FConfig.TradeTotQty > dNew + EPSILON then begin
        DoLog('RT МіЗЎ КЏШ­ЗЮ [СјРд] РчАГ');
        CheckReStart(aoEntry);
      end;
    end;

  finally
    DoLog(Format('RT МіЗЎ КЏШ­ %s -> %s', [DoubleToStr(dOld), DoubleToStr(dNew)]));
    SendMessageToOwner(mtResult, integer(srtEORD));
  end;
end;

