// СјРд ЧиПм ИХЕЕ
// УЛЛъ БЙГЛ ИХЕЕ
function TTVSignal.GetSellMakerOrderPriceRange(var ordRng : TOrderRange; const dCkip, dEst: double;
   e: TExchangeKind) : boolean;
  var
    dVal, tmpPrice, dConst, dEx : double;
    iRes : integer;
begin
  Result := false;

  dEx :=  App.Engine.ApiManager.ExRate.Value;
  // // ЧиПм ИХЕЕ, БЙГЛ ИХЕЕ
  if e = ekBinance then
    tmpPrice  := (100 * dEst) / (dEx * (dCkip + 100))
  else
    tmpPrice  := (dEst * dEx * (dCkip + 100)) / 100;

  if (tmpPrice <= EPSILON) or
    (GetSymbol(e).Bids[0].Price <= EPSILON) then Exit;

  var dMin, dMax, dPrice, dSize : double;

  if e = ekBinance then begin
    dMin  := GetSymbol(e).CalcTicksPrice(GetSymbol(e).Bids[0].Price, 1);
    dConst    := gAOConfig.Result.PriceRangePer[scInter] / 100;
  end else
  begin
    // БЙГЛ АХЗЁМвСп ИХМіШЃАЁ +1 РЬ АЁРх ХЋАЊРЛ Min ЗЮ МБХУ
    dConst    := gAOConfig.Result.PriceRangePer[scDomes] / 100;
    var bu, bt : boolean;
    var du := GetSymbol(ekUpbit).CalcTicksPrice(GetSymbol(ekUpbit).Bids[0].Price, 1);
    if (du <= EPSILON) then bu := false else bu := true;
    var dt := GetSymbol(ekBithumb).CalcTicksPrice(GetSymbol(ekBithumb).Bids[0].Price, 1);
    if (dt <= EPSILON) then bt := false else bt := true;

    if (not bt) and (not bu) then Exit;
    if bt and bu then
      dMin  := Max(du, dt)
    else if bt then
      dMin  := dt
    else if bu then
      dMin  := du
    else Exit;
  end;

  dMax  := dMin * (1 + dConst);
  //
  ordRng.MaxPrice := dMax;
  ordRng.MinPrice := dMin;
  ordRng.TmpPrice := tmpPrice;
  ordRng.Precision:= GetSymbol(e).Spec.Precision;
  ordRng.EstPrice := dEst;
  ordRng.ExRate   := dEx;
  ordRng.CKip     := dCkip;
  ordRng.ExKind   := TExchangeKindShortDesc[e];
  //
  // ЗЮБзПы..
//  if e = ekBinance then
//    OrdRange[aoEntry, F].Assign(ordRng)
//  else
//    OrdRange[aoExit, S].Assign(ordRng);

  iRes := CmpVal(dMin, tmpPrice);

  if iRes >= 0 then
    ordRng.OrdPrice := dMin
  else
    if tmpPrice > dMax then
      Exit
    else begin
      var dUnit := gAOConfig.GetMajorTradeSymbolUnit(e, GetSymbol(e).Spec.BaseCode);
      if dUnit > 0 then
        // customunit РћПы
        ordRng.OrdPrice := GetSellCustomMakerOrderPrice(e, dUnit, tmpPrice, dMin, dMax)
      else
        // ПјЗЁ ЗЮСї РћПы..
        ordRng.OrdPrice := GetMakerOrderPrice(e, -1, tmpPrice, dMin, dMax);

      if ordRng.OrdPrice <= EPSILON then Exit;
    end;

//  ordRng.OrdPrice:= GetSymbol(e).Asks[4].Price;

  Result := true;
end;

