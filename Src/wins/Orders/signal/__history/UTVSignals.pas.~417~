procedure TTVSignals.DoOrder(aDust: TDust);
var
  aAcnt : TAccount;
  aOrder: TOrder;
  dPrice: double;
begin

  aAcnt := nil;
  if aDust.Symbol.Spec.ExchangeType <> ekBinance then
    aAcnt := App.Engine.TradeCore.FindAccount(aDust.Symbol.Spec.ExchangeType)
  else
    aAcnt := App.Engine.TradeCore.FindAccount(aDust.Symbol.Spec.ExchangeType,
      TAccountMarketType( ifThen(aDust.Symbol.Spec.FutureType = ftCoin, integer(amFutureCm), integer(amFuture)))) ;

  if aAcnt = nil then Exit;

  dPrice := aDust.Symbol.GetHitOrderPrice(aDust.Side, aDust.OrdPrice);

  aOrder  := App.Engine.TradeCore.Orders[aDust.Symbol.Spec.ExchangeType].NewOrder(aAcnt,
    aDust.Symbol, aDust.Side, aDust.OrdQty, pcLimit, dPrice{aDust.OrdPrice}, tmGTC );

  if aOrder <> nil then
  begin
    aOrder.StgType  := stTVSignal;
    aOrder.Tag      := DST_ORD;
    aOrder.GroupNo  := aDust.GroupNo;
    App.Engine.TradeBroker.Send( aOrder );
    aDust.DecQty(aDust.OrdQty);
    TFrmTVSignals(FParent).OnNotifyDust(Self, aOrder);
//
//    TFrmPKIDXOrders(FParent).DoLog(Format('Dust СжЙЎ %s, Remain Qty : %s',[aOrder.Represent,
//      DoubleToStr(aDust.Qty)]), true);
  end;

end;

