procedure TTVSignal.OnFill(f: TFill);
var
  o: TOrder;
  aoType, aoType2: TAutoOrderType;
  e, e2 : TExchangeKind;
begin
  if f.Order = nil then Exit;
  o := f.Order as TOrder;

  if (o.StgType <> stTVSignal) or
    (o.GroupNo <> FConfig.StgCode) or
    (o.Symbol.Spec.BaseCode <> GetSymbol(ekUpbit).Spec.BaseCode) then
    Exit;

  if o.Symbol.Spec.ExchangeType = ekBinance then
    if o.Symbol.Spec.SettleType <> GetSymbol(ekBinance).Spec.SettleType then Exit;

  if o.Entry then begin
    aoType := aoEntry;
    aoType2:= aoExit;
  end
  else begin
    aoType := aoExit;
    aoType2:= aoEntry;
  end;

  case o.Tag of
    PUT_ORD : e := o.Symbol.Spec.ExchangeType;
    DST_ORD : ;
    LIQ_ORD : e := TExchangeKind(o.TargetCEX);
    else Exit;
  end;

  begin
    DoLog(Format('@1-0 %s Fill : %s %s %s ', [ ExKindToStr(o.Symbol.Spec.ExchangeType),
      ifThenStr(o.Tag = PUT_ORD,'PUT', ifThenStr(o.Tag = LIQ_ORD,'HIT', 'DST')), f.Represent, o.LocalNo ]));
    // УМАс ХыАш АќИЎ..
    FSigOrders[aoType].FillStatistics(o, f, e);

    case o.Tag of
      PUT_ORD : if FSigOrders[aoType].ExOrders[e].Find(o, MK) then
                begin
//                  РЏИЎЧб АХЗЁМв МБХУ ОШЧиЕЕ ЕШДй.
//                  case GetFS(e) of
//                    mtF: begin
//                      e2 := SelectCEXtoLiqOrder(aoType, f.Volume, true).ExKind;
//                      // АсАњАЊРЬ БЙГЛ АХЗЁМвОп ЧбДй.
//                      if e2 = ekBinance then
//                        e2 :=  TExchangeKind(o.TargetCEX);
//                      FSigOrders[aoType].ExOrders[e].OnOrderFill(f, e2);
//                    end;
//                    mtS: FSigOrders[aoType].ExOrders[e].OnOrderFill(f, TExchangekind(o.TargetCEX));
//                  end;

                  FSigOrders[aoType].ExOrders[e].OnOrderFill(f, TExchangekind(o.TargetCEX));
                              // МБСжЙЎ УМАс ЛчПюЕх
                  if gAOConfig.Result.UseFirstOrderFill then
                    PlaySound(0);
                end else
                  DoLog(Format('@1-2 СжЙЎРЛ УЃРЛМі ОјРН : %d', [FSigOrders[aoType].ExOrders[e].Count]) );
      //DST_ORD : Exit;
      LIQ_ORD :
        begin
          OnLiqFill(aoType, o);
          //FSigOrders[aoType].OnFill(o);// ExOrders[e].OnLiqNDustFill(f);
        end;
    end;

    if aoType = aoEntry then
      SendMessageToOwner(mtResult, integer(srtEORD))
    else
      SendMessageToOwner(mtResult, integer(srtXORD))  ;
  end;
  // F/S NЙјТА СжЙЎ ПЯЗс ПЉКЮ УМХЉ..
  FSigOrders[aoType].ExOrders[e].IsDone;

  // СјРд/УЛЛъ Done РЬ true РЮЕЅ УЛЛъ/СјРд УМАсРЬ РЯОюГЊИщ СјРд/УЛЛъ Done РЛ ЧЎОюСрОп ЧбДй.
  if FSigOrders[aoType2].Done then
  begin
    var dRemain := GetRemainOrderQty(aoType2);
    if dRemain > gAOConfig.GetMajorTradeSymbolLotSize(GetSymbol(ekUpbit).Spec.BaseCode) then
    begin
      CheckReStart(aoType2);

      DoLog(Format('%s УМАсЗЮ %s Done ЧиСІ (Remain:%s)', [
        TAutoOrderTypeDesc[aoType], TAutoOrderTypeDesc[aoType2], DoubleToStr(dRemain)]));
      SendMessageToOwner(mtResult, integer(srtETRY));
    end;
  end;

