procedure TTVSignal.ProcessExitF;
var
  dPrice, dQty: array [TExchangeKind] of double;
  e, es : TExchangeKind;
  dActiveQty, dEst   : double;
  ordRng : TOrderRange;
  aOrder : TOrder;
  res : TSelectCex;
  sMsg : string;
begin

  // active СжЙЎРЬ СИРч Чв ЖЇПЭ ОЦДвЖЇИІ БИКаЧиМ­. УГИЎ
  es := ekBinance;
  if FSigOrders[aoExit].ExOrders[es].Last.OrderList[MK].Count > 0 then begin
    dActiveQty  := FSigOrders[aoExit].ExOrders[es].Last.GetActiveOrderQty;
    if dActiveQty > EPSILON then
    begin
      res := SelectCEXtoLiqOrder(aoExit, dActiveQty);
      if res.ExKind = ekBinance then
      begin
        // НУММАЁ РЬЛѓЧЯИщ УыМв..
        //DoLog('Cancel НУММ РЬЛѓ');
        MsgCode[aoExit, ekBinance]  :=  MSG_CODE_CNL;
        FSigOrders[aoExit].ExOrders[es].Last.AllCancel;
        Exit;
      end;

      //dEst := GetSymbol(res.ExKind).CalcEstPrice(-1, dActiveQty);

      if GetLongMakerOrderPriceRange(ordRng, GetOrderCKip(aoExit, F, res.ExKind), res.Price, es) then begin
        if FSigOrders[aoExit].ExOrders[es].Last.CheckOrder(ordRng.OrdPrice) then begin
          MsgCode[aoExit, ekBinance]  :=  MSG_CODE_CNL;
          DoLog('Cancel Range Data : ' + ordRng.Represent);
        end;
      end else begin
        MsgCode[aoExit, ekBinance]  :=  MSG_CODE_CNL;
        FSigOrders[aoExit].ExOrders[es].Last.AllCancel;
        //DoLog('Cancel Range Fail : ' + ordRng.Represent);
      end;
    end else
      MsgCode[aoExit, ekBinance]  :=  MSG_CODE_HAV;
  end else
  begin
    if FSigOrders[aoExit].ExOrders[ekBinance].Suspend then Exit;

    // СжЙЎМіЗЎАњ, АХЗЁМв МБХУ
    dEst := 9999999999;   es := ekBinance;
    for e := ekUpbit to High(TExchangeKind) do
    begin
      dQty[e] := 0; dPrice[e] := 0;
      // БЙГЛ ИХЕЕ Taker СжЙЎРЬ АЁДЩЧбАЁ?
      dQty[e]   := GetSellAbleQty(F, e, sMsg);
      dPrice[e] := GetSymbol(e).CalcEstPrice(-1, dQty[e]);

      // РлРКГбРЛ АэИЅДй.
      if (dPrice[e] > EPSILON) and (dPrice[e] < dEst) then
      begin
        dEst  := dPrice[e];
        es    := e;
      end;
    end;
    // МБХУЕШ АХЗЁМвАЁ ОјДйИщ Exit;
    if es = ekBinance then
    begin
      MsgCode[aoExit, ekBinance]  := ifThenStr(sMsg.IsEmpty, MSG_CODE_BAL, sMsg);
//      SendMessageToOwner(mtResult, integer(srtXBAL));
      Exit;
    end;

    if GetLongMakerOrderPriceRange(ordRng, GetOrderCKip(aoExit, F, es), dEst, ekBinance) then
    begin
      aOrder := FSigOrders[aoExit].ExOrders[ekBinance].Last.DoOrder(GetAccount(ekBinance),
        GetSymbol(ekBinance), 1, ordRng.OrdPrice, dQty[es], aoExit, es);

      if aOrder <> nil then begin
        DoLog('Order Range Data : ' + ordRng.Represent);
        MsgCode[aoExit, ekBinance] := MSG_CODE_ORD;
      end;
    end else
      MsgCode[aoExit, ekBinance] := MSG_CODE_PRC;
  end;
end;


// БЙГЛ ИХЕЕ, ЧиПм ИХМі.
procedure TTVSignal.ProcessExitS(e:TExchangeKind);
var
  dTmp, dQty, dActiveQty, dEstPrice : double;
  ordRng : TOrderRange;
  aOrder : TOrder;
  sMsg   : string;
begin
  if FSigOrders[aoExit].ExOrders[e].Last.OrderList[MK].Count > 0 then begin
    dActiveQty  := FSigOrders[aoExit].ExOrders[e].Last.GetActiveOrderQty;
    if dActiveQty > EPSILON then
    begin
      dEstPrice:= GetSymbol(ekBinance).CalcEstPrice(1, dActiveQty);
      if dEstPrice <= EPSILON then
      begin
        MsgCode[aoExit, e]  :=  MSG_CODE_CNL;
        FSigOrders[aoExit].ExOrders[e].Last.AllCancel;
        Exit;
      end;

      if GetSellMakerOrderPriceRange(ordRng, GetOrderCKip(aoExit, S, e), dEstPrice, e) then
      begin
        if FSigOrders[aoExit].ExOrders[e].Last.CheckOrder(ordRng.OrdPrice) then begin
          DoLog('Cancel Range Data : ' + ordRng.Represent);
          MsgCode[aoExit, e]  :=  MSG_CODE_CNL;
        end;
      end else begin
        MsgCode[aoExit, e]  :=  MSG_CODE_CNL;
        FSigOrders[aoExit].ExOrders[e].Last.AllCancel;
      end;
    end else
      MsgCode[aoExit, e]  :=  MSG_CODE_HAV;

  end else
  begin
    if FSigOrders[aoExit].ExOrders[e].Suspend then Exit;

    dQty  :=  GetSellAbleQty(S, e, sMsg);
    if dQty <= EPSILON then
    begin
      MsgCode[aoExit, e]  := ifThenStr(sMsg.IsEmpty, MSG_CODE_BAL, sMsg);
//      SendMessageToOwner(mtResult, integer(srtXBAL));
      Exit;
    end;

    dEstPrice:= GetSymbol(ekBinance).CalcEstPrice(1, dQty);
    if dEstPrice <= EPSILON then
    begin
      MsgCode[aoExit, e]  :=  MSG_CODE_QTE;
      Exit;
    end;

    if GetSellMakerOrderPriceRange(ordRng, GetOrderCKip(aoExit, S, e), dEstPrice, e) then
    begin
      aOrder := FSigOrders[aoExit].ExOrders[e].Last.DoOrder(GetAccount(e),
        GetSymbol(e), -1, ordRng.OrdPrice, dQty, aoExit, ekBinance);
      if aOrder <> nil then begin
        DoLog('Order Range Data : ' + ordRng.Represent);
        MsgCode[aoExit, e] := MSG_CODE_ORD;
      end;
    end else
      MsgCode[aoExit, e] := MSG_CODE_PRC;
  end;

end;

