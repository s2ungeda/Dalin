// bTaker = true -> dPrice ДТ HitPrice
// bTaker = true : СјРд, F
//          false: СјРд, S
function TTVSignal.CalcBuyAbleQty(bTaker: boolean; ordEx: TExchangeKind; var sMsg: string): double;
var
  dMinQty, dTmp, dDef, dOrdQty: double;
  iPre: integer;
begin
  sMsg := '';
  Result := 0;

  dMinQty := gAOConfig.GetMajorTradeSymbolLotSize(GetSymbol(ekBithumb).Spec.BaseCode);
  if dMinQty < 0 then Exit;

  iPre    := Min(GetSymbol(ordEx).Spec.QtyPrecision, GetSymbol(ekBinance).Spec.QtyPrecision);

  if bTaker then begin
    // СјРд, F -> БЙГЛПЁ ИХМі taker СжЙЎ РЛ ГЛОп ЧЯДЯ. БЙГЛ ИХЕЕ ШЃАЁ РмЗЎКёИІ БИЧбДй.
    dTmp  := GetSymbol(ordEx).Asks[0].Volume * (FConfig.Input[F].VolRate / 100);
    dDef  := FConfig.Input[F].OrderQty;
  end else
  begin
    // СјРд, S -> ЧиПмПЁ ИХЕЕ taker СжЙЎ РЛ ГЛОп ЧЯДЯ. ЧиПм ИХМіХфХЛРмЗЎ РмЗЎКёИІ БИЧбДй.
    dTmp := GetSymbol(ekBinance).Bids.VolumeTotal * (FConfig.Input[S].VolRate / 100);
    dDef  := FConfig.Input[S].OrderQty;
  end;
    // Пј СжЙЎМіЗЎ МвМіСЁ КИСЄ
  dOrdQty:= TruncDecimal(GetOrderEntryQty(min(dTmp,dDef)), iPre);

  if dOrdQty < dMinQty then begin
    sMsg :=  MSG_CODE_RQY;
    Exit;
  end;

  Result := dOrdQty;
end;

function TTVSignal.GetBuyAbleQty(bTaker: boolean; ordEx: TExchangeKind; dPrice: double; var sMsg: string): double;
var
  dMinQty, dOrdQty, dAvailable: double;
  dOrderAmt, denom, dTmp, dDef: double;
  iPre  : integer;

begin
  // ЧиПм АэЗСЧиМ­ УжМв СжЙЎ МіЗЎ
  sMsg := '';
  Result := 0;

  dMinQty := gAOConfig.GetMajorTradeSymbolLotSize(GetSymbol(ekBithumb).Spec.BaseCode);
  if dMinQty < 0 then Exit;

  iPre    := Min(GetSymbol(ordEx).Spec.QtyPrecision, GetSymbol(ekBinance).Spec.QtyPrecision);

  if bTaker then begin
    // СјРд, F -> БЙГЛПЁ ИХМі taker СжЙЎ РЛ ГЛОп ЧЯДЯ. БЙГЛ ИХЕЕ ШЃАЁ РмЗЎКёИІ БИЧбДй.
    dTmp  := GetSymbol(ordEx).Asks[0].Volume * (FConfig.Input[F].VolRate / 100);
    dDef  := FConfig.Input[F].OrderQty;
  end else
  begin
    // СјРд, S -> ЧиПмПЁ ИХЕЕ taker СжЙЎ РЛ ГЛОп ЧЯДЯ. ЧиПм ИХМіХфХЛРмЗЎ РмЗЎКёИІ БИЧбДй.
    dTmp := GetSymbol(ekBinance).Bids.VolumeTotal * (FConfig.Input[S].VolRate / 100);
    dDef  := FConfig.Input[S].OrderQty;
  end;
    // Пј СжЙЎМіЗЎ МвМіСЁ КИСЄ
  dOrdQty:= TruncDecimal(GetOrderEntryQty(min(dTmp,dDef)), iPre);

  // БЙГЛ ИХМі АЁДЩ МіЗЎ
  OrdQtyResult[ordEx] := Format('%s: %s, %s, %s, %s, %s(%s-%s)', [TExchangeKindShortDesc[ordEx],
    DoubleToStr(FConfig.TradeTotQty),
    DoubleToStr(dDef),
    DoubleToStr(dMinQty),
    DoubleToStr(dTmp),
    DoubleToStr(GetEntryQty),
    DoubleToStr(FSigOrders[aoEntry].AccFilledQty[MK]),
    DoubleToStr(FSigOrders[aoExit].AccFilledQty[MK]) ] );

  if dOrdQty < dMinQty then begin
    sMsg :=  MSG_CODE_RQY;
    Exit;
  end;

  var dFee, dReservedAmt : double;
  dReservedAmt := 0;
  // ГЊАЁОпЧв ИХМі СжЙЎРЬ РжДТ АцПь- 1 ( ЧиПм ИХЕЕ СжЙЎРЬ РжДТАцПь )
  dReservedAmt:= App.Engine.TradeCore.Orders[ekBinance].GetMustLongOrderAmt(stTVSignal, GetSymbol(OrdEx));
  dAvailable  := GetAccount(ordEx).Available - dReservedAmt;

  try
    if GetSymbol(ordEx).Spec.MinNotional >= dAvailable then
      Result := 0
    else begin
      // standard fee - СжЙЎГОЖЇДТ РЯЙн МіМіЗсЗЮ АшЛъ.
      with App.Engine.ApiConfig do dFee:= GetStandardFee(ordEx, eaSpot);

      dOrderAmt := (dOrdQty * dPrice)*(1+(dFee/100)) ;
      if CmpVal(dAvailable, dOrderAmt) >= 0 then
        Result := dOrdQty
      else begin
        // СжЙЎАЁДЩ БнОзСпПЁМ­ УжДыЧбСжЙЎ ИЙРЬ ГЛБт РЇЧи..
        denom   := dPrice * (1 + dFee);
        dOrdQty := TruncDecimal(CalcDiv(dAvailable, denom), iPre);
        if dOrdQty > dMinQty then
          Result := dOrdQty//CeilDecimal(dMaxQty, iPre)
        else
          Result := 0;
      end;
    end;

  finally
    AvlAmtResult[ordEx]  := Format('%s : %s, %s, %s, (%s)', [TExchangeKindShortDesc[ordEx],
      DoubleToStr(GetAccount(ordEx).Balance, 0),
      DoubleToStr(dAvailable, 0),
      DoubleToStr(dOrderAmt, 0),
      DoubleToStr(dReservedAmt, 0)
      ]);
    if Result = 0 then sMsg := MSG_CODE_AMT;
  end;

end;

