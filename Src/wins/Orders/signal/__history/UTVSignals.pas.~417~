procedure TTVSignal.ProcessEntryF;
begin
  if FSigORders[aoEntry].ExOrders[ekBinance].Last.OrderList[MK].Count > 0 then
    ProcessEntryF_CheckOrder
  else
    ProcessEntryF_DoOrder ;
end;

procedure TTVSignal.ProcessEntryF_CheckOrder;
var
  dActiveQty, dPrice : double;
  //rSelect : TSelectCEX;
  ordRng : TOrderRange;
  e: TExchangeKind;
  i: Integer;
begin
  dActiveQty := FSigOrders[aoEntry].ExOrders[ekBinance].Last.GetActiveOrderQty;
  if dActiveQty > EPSILON then
  begin
    i := FSigOrders[aoEntry].ExOrders[ekBinance].Last.GetTargetCEX;
    if i < 0 then
    begin
      DoLog('Oopps !! ХИФЯ АХЗЁМвИІ ИјУЃРН');
      Exit;
    end;
    e := TExchangeKind(i);
    dPrice := GetSymbol(e).CalcEstPrice(1, dActiveQty);

//    rSelect := SelectCEXtoLiqOrder(aoEntry, dActiveQty);
//    if rSelect.ExKind = ekBinance then
//    begin
//      MsgCode[aoEntry, ekBinance]  :=  MSG_CODE_CNL;
//      FSigOrders[aoEntry].ExOrders[ekBinance].AllCancels;
//      Exit;
//    end;

    //if GetSellMakerOrderPriceRange(ordRng, GetOrderCKip(aoEntry, F, rSelect.ExKind), rSelect.Price) then
    if GetSellMakerOrderPriceRange(ordRng, GetOrderCKip(aoEntry, F, e), dPrice) then
    begin
      if FSigOrders[aoEntry].ExOrders[ekBinance].Last.CheckOrder(ordRng.OrdPrice) then
      begin
        MsgCode[aoEntry, ekBinance]  :=  MSG_CODE_CNL;
        DoLog('Cancel Range Data : ' + ordRng.Represent);
      end;
    end else begin
      MsgCode[aoEntry, ekBinance]  :=  MSG_CODE_CNL;
      FSigOrders[aoEntry].ExOrders[ekBinance].AllCancels;
    end;
  end else
    MsgCode[aoEntry, ekBinance]  :=  MSG_CODE_HAV;

end;

procedure TTVSignal.ProcessEntryF_DoOrder;
var
  dPrice, dQty, dTmp : array [TExchangeKind] of double;
  e, es : TExchangeKind;
  dEst : double;
  ordRng : TOrderRange;
  aOrder  : TOrder;
  ss: string;
begin

  if FSigOrders[aoEntry].ExOrders[ekBinance].Suspend then Exit;

  // СжЙЎМіЗЎАњ, АХЗЁМв МБХУ
  dEst := 0.0;   es := ekBinance;  ss := '';
  for e := ekUpbit to High(TExchangeKind) do
  begin
    dTmp[e] := 0; dQty[e] := 0; dPrice[e] := 0;

    dTmp[e]   := GetHitOrderPrice(GetSymbol(e), 1, scDomes);
    // БЙГЛ Taker СжЙЎРЬ АЁДЩЧбДй.
    dQty[e]   := GetBuyAbleQty(true, e, dTmp[e], ss);
    dPrice[e] := GetSymbol(e).CalcEstPrice(1, dQty[e]);

    if (dPrice[e] > EPSILON) and (dPrice[e] > dEst) then
    begin
      dEst  := dPrice[e];
      es    := e;
    end;
  end;

  // МБХУЕШ АХЗЁМвАЁ ОјДйИщ Exit;
  if es = ekBinance then
  begin
    MsgCode[aoEntry, ekBinance] := ifThenStr(ss = '', MSG_CODE_AMT, ss);
    Exit;
  end;

  // СжЙЎАЁАнАњ Range
  if GetSellMakerOrderPriceRange(ordRng, GetOrderCKip(aoEntry, F, es), dEst) then
  begin
    aOrder := FSigOrders[aoEntry].ExOrders[ekBinance].Last.DoOrder(GetAccount(ekBinance),
      GetSymbol(ekBinance), -1, ordRng.OrdPrice, dQty[es], aoEntry, es);

    if aOrder <> nil then  begin
      DoLog('Order Range Data : ' + ordRng.Represent);
      MsgCode[aoEntry, ekBinance] := MSG_CODE_ORD;
    end;
  end else
    MsgCode[aoEntry, ekBinance] := MSG_CODE_PRC;
end;

procedure TTVSignal.ProcessEntryS(e:TExchangeKind);
begin
  if FSigOrders[aoEntry].ExOrders[e].Last.OrderList[MK].Count > 0 then
    ProcessEntryS_CheckOrder(e)
  else
    ProcessEntryS_DoOrder(e);
end;

procedure TTVSignal.ProcessEntryS_CheckOrder(e: TExchangeKind);
var
  dActiveQty, dEst : double;
  ordRng : TOrderRange;
begin
  dActiveQty  := FSigOrders[aoEntry].ExOrders[e].Last.GetActiveOrderQty;
  if dActiveQty > EPSILON then
  begin
    // binance short estprice
    dEst:= GetSymbol(ekBinance).CalcEstPrice(-1, dActiveQty);
    if dEst <= EPSILON then
    begin
      MsgCode[aoEntry, e]  :=  MSG_CODE_CNL;
      FSigOrders[aoEntry].ExOrders[e].AllCancels;
      Exit;
    end;
    //
    if GetLongMakerOrderPriceRange(ordRng, GetOrderCKip(aoEntry, S, e), dEst, e) then
    begin
      if FSigOrders[aoEntry].ExOrders[e].Last.CheckOrder(ordRng.OrdPrice) then
      begin
        MsgCode[aoEntry, e]  :=  MSG_CODE_CNL;
        DoLog('Cancel Range Data : ' + ordRng.Represent);
      end;
    end else begin
      MsgCode[aoEntry, e]  :=  MSG_CODE_CNL;
      FSigOrders[aoEntry].ExOrders[e].AllCancels;
    end;
  end else
    MsgCode[aoEntry, e]  :=  MSG_CODE_HAV;
end;

procedure TTVSignal.ProcessEntryS_DoOrder(e: TExchangeKind);
var
  dQty, dEst : double;
  ordRng : TOrderRange;
  aOrder : TOrder;
  sMsg: string;
begin
  if FSigOrders[aoEntry].ExOrders[e].Suspend then Exit;
  // БЙГЛ Maker СжЙЎРЬ АЁДЩЧбДй.
  dQty     := GetBuyAbleQty(false, e, GetSymbol(e).Bids[0].Price, sMsg);
  if dQty <= EPSILON then
  begin
    MsgCode[aoEntry, e] := ifThenStr(sMsg.IsEmpty, MSG_CODE_AMT, sMsg);
//    SendMessageToOwner(mtResult, integer(srtEBAL));
    Exit;
  end;

  dEst:= GetSymbol(ekBinance).CalcEstPrice(-1, dQty);
  if dEst <= EPSILON then
  begin
    MsgCode[aoEntry, e]   := MSG_CODE_QTE;
    Exit;
  end;

  if GetLongMakerOrderPriceRange(ordRng, GetOrderCKip(aoEntry, S, e), dEst, e) then
  begin
    aOrder := FSigOrders[aoEntry].ExOrders[e].Last.DoOrder(GetAccount(e),
      GetSymbol(e), 1, ordRng.OrdPrice, dQty, aoEntry, ekBinance);
    if aOrder <> nil then begin
      DoLog('Order Range Data : ' + ordRng.Represent);
      MsgCode[aoEntry, e] := MSG_CODE_ORD;
    end;
  end else
    MsgCode[aoEntry, e] := MSG_CODE_PRC;
end;

