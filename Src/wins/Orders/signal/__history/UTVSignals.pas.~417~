procedure TTVSignal.CheckNextOrder(aoType: TAutoOrderType; e: TExchangeKind);
var
  dRemain, dTotFilledQty: double;
begin
  // РќУМ УМАсЗЎРЛ КёБГЧЯПЉ ДйРН СжЙЎРЬ ГЊАЁЕЕ ЕЩСі ЦЧДм.

  dRemain := GetRemainOrderQty(aoType);
  if dRemain < gAOConfig.GetMajorTradeSymbolLotSize(GetSymbol(ekUpbit).Spec.BaseCode) then
  begin
    FSigOrders[aoType].Done := true;
    FSigOrders[aoType].AllOrderCancels;

    case aoType of
      aoEntry: SendMessageToOwner(mtResult, integer(srtEDone));
      aoExit: SendMessageToOwner(mtResult, integer(srtXDone));
    end;

    DoLog(Format('** %s Done -> Filled : %s | %s,  Remain : %s', [TAutoOrderTypeDesc[aoType],
       DoubleToStr(FSigOrders[aoType].GetAccFilledQty(0)),
       DoubleToStr(FSigOrders[aoType].GetAccFilledQty(1)),
       DoubleToStr(dRemain)]));
  end else
  begin
    FSigOrders[aoType].ExOrders[e].New;

    DoLog(Format('Next : %s %s %02d.th ', [
      ifThenStr(e = ekBinance,'F', 'S'), TExchangeKindDesc[e],
      FSigOrders[aoType].ExOrders[e].Count ])
      );
  end;
end;

procedure TTVSignal.CheckReStart(aoType: TAutoOrderType);
var
  e : TExchangeKind;
  i : Integer;
  aOrder: TOrder;
  ot: TOrderTimer;
begin

  FSigOrders[aoType].Done  := false;

  for e := ekBinance to High(TExchangeKind) do
    for I := 0 to FSigOrders[aoType].ExOrders[e].Last.OrderList[MK].Count -1 do
    begin
      aOrder := FSigOrders[aoType].ExOrders[e].Last.OrderList[MK][i];
      case aOrder.State of
        osSrvRjt, osRejected, osCanceled, osConfirmed, osFailed:
          begin
            ot := FindTimer(aoType, e, otPuttimer);
            if (ot <> nil) and (not ot.Enable) then
            begin
              DoLog('----- УыМв/АХКЮ ХИРЬИг РчАГ --------');
              SetTimer(aoType, otPuttimer, true, e);
            end;
          end;
        osFilled:
          begin
            ot := FindTimer(aoType, e, otNxtTimer);
            if (ot <> nil) and (not ot.Enable) then
            begin
              DoLog('----- УМАс ХИРЬИг РчАГ --------');
              SetTimer(aoType, otNxtTimer, true, e);
            end;
          end;
      end;
    end;
end;

