{ TSelectCEX }

procedure TSelectCEX.init;
begin
  OrdQty  := 0;
  Price   := 0;
  ExKind  := ekBinance;
end;

{ TLiqOrder }

function TLiqOrder.CheckTime: boolean;
begin
  if GetTickCount64 > Tick + gAOConfig.Result.ReTryInterval then
    Result := true
  else
    Result := false;
end;

constructor TLiqOrder.Create(aOrder: TOrder);
begin
  Target:= aOrder;
  Tick  := GetTickCount64;
  MKExKind:= TExchangeKind(aOrder.TargetCEX);
end;

end.
