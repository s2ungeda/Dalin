function TFrmTVSignals.ParseData(AData: string; aColl: TRqContents): boolean;
var
  aVal: TJSONValue;
  aArr: TJsonArray;
  aObj: TJsonObject;
  bRes: boolean;
  sTmp, sCode, stgName: string;
  i: Integer;
  id: int64;
  bAdd: boolean;
//  aData: TRqContent;
  Signal: TSignalRecord;
  Strategy: string;
  CurrentLatest: TDictionary<string, TSignalRecord>;
  CurrentID, LastID: Int64;
begin
  aVal  := TJsonObject.ParseJSONValue(AData);
  id    := 0;

  if aVal = nil then Exit;

  CurrentLatest := TDictionary<string, TSignalRecord>.Create;

  try
    try
      bRes := aVal.GetValue<boolean>('success');
      if not bRes then Exit;

      aArr := (aVal as TJsonObject).GetValue('data') as TJsonArray;

      sCode:= GetCode;
      // БтКЛ ГЛИВ ТїМјРЬДй.
      for I := aArr.Count-1 downto 0 do
      begin
        aObj  := aArr.Items[i] as TJsonObject;

        Signal.ID := aObj.GetValue<int64>('id');
        Signal.StrategyName := aObj.GetValue<string>('strategy_name');
        Signal.CoinSymbol := aObj.GetValue<string>('coin_symbol');
        Signal.SignalTime := aObj.GetValue<string>('signal_time');
        Signal.SignalType := aObj.GetValue<string>('signal_type');
        Signal.Quantity := aObj.GetValue<string>('quantity');
        Signal.Price := aObj.GetValue<string>('price');
        Signal.PositionType := aObj.GetValue<string>('position_type');
        Signal.Direction := aObj.GetValue<string>('direction');
        Signal.ReceivedAt := aObj.GetValue<string>('received_at');

        Strategy := Signal.StrategyName;

        if not CurrentLatest.ContainsKey(Strategy) then
          CurrentLatest.Add(Strategy, Signal)
        else if CurrentLatest[Strategy].ID < Signal.ID then
          CurrentLatest[Strategy] := Signal;
      end;

      // ЛѕЗЮПю НХШЃ ШЎРЮ
      for Signal in CurrentLatest.Values do
      begin
        Strategy  := Signal.StrategyName;
        CurrentID := Signal.ID;

        if not FLastKnownIDs.TryGetValue(Strategy, LastID) then
          LastID := 0;

        if CurrentID > LastID then
        begin
          FLastKnownIDs.AddOrSetValue(Strategy, CurrentID);

          with aColl.New(CurrentID) do
          begin
            StgName := Strategy;
            SigTime := GetStrToTime(Signal.SignalTime);
            SigType := Signal.SignalType;
            SigKimp := StrToFloatDef(Signal.Price, 1000000) / 1000000;
          end;

        end;
      end;
      bRes := true;
    except
    end;

  finally
    aVal.Free;
    CurrentLatest.Free;
  end;

  Result := bRes;
end;

