function TFrmTVSignals.SetSymbols: boolean;
var
  aSymbol : array [TExchangeKind] of TSymbol;
  i: TExchangeKind;
  aSCType :TSettleCurType;
begin
  Result := false;

  if edtCode.Text = '' then
  begin
    Exit;
  end;

  case cbSettleType.ItemIndex of
    0 : aSCType := scUSDT;
    1 : aSCType := scUSDC;
  end;

  for I := ekBinance to High(TExchangeKind) do begin

    if i = ekBinance then
      aSymbol[i]  := App.Engine.SymbolCore.BaseSymbols.FindSymbol(edtCode.Text, i, eaFutUsdt, aSCType)
    else
      aSymbol[i]  := App.Engine.SymbolCore.BaseSymbols.FindSymbol(edtCode.Text, i);

    if aSymbol[i] = nil then
    begin
      ShowMessage('ЧиДчСОИёРЛ УЃРЛМі ОјРН');
      Exit;
    end;
  end;

  try
    for I := ekBinance to High(TExchangeKind) do
    begin
      if FSymbols[i] <> nil then
        App.Engine.QuoteBroker.Brokers[i].Cancel(Self, FSymbols[i]);

      App.Engine.QuoteBroker.Brokers[i].Subscribe(Self, aSymbol[i], QuoteProc);
      FSymbols[i] := aSymbol[i];
    end;
    // ЦїСіМЧ СЖШИ
    App.Engine.ApiManager.ExManagers[ekBinance].RequestPosition(FSymbols[ekBinance]);
    Result := true;
  except
  end;
end;

procedure TFrmTVSignals.LoadEnv(aStorage: TStorage);
var
  I, iRow, iCnt: integer;
  j : TMethodType;

  a: TAutoOrderType;
  e: TExchangeKind;

  aSig : TTVSignal;
  bEnt, bExit: boolean;
begin
  if aStorage = nil then Exit;
  // main
  with aStorage do
  begin

    Panel3.Height := FieldByName('p3H').AsIntegerDef(Panel3.Height);

    edtCode.Text            := FieldByName('Code').AsString;
    cbSettleType.ItemIndex  := FieldByName('SCType').AsInteger;
    edtTmpQty.Text          := FieldByName('OrdQty').AsString;
    edtSigCntLimit.Text     := FieldByName('SigCntLimit').AsStringDef('10');

//    edtRateF.Text := FieldByName('RateF').AsStringDef('50');
//    edtRateS.Text := FieldByName('RateS').AsStringDef('50');

    iCnt  := FieldByName('SignalCount').AsInteger;

    sg.RowCount := iCnt + 2;

    if sg.RowCount > 2 then
      sg.FixedRows  := 2;

    var ss := FieldByName('ColWidths').AsString;

    if not ss.IsEmpty then
    begin
      var sts := ss.Split(['|']);
      for I := 0 to High(sts) do
        if not sts[i].IsEmpty then
          sg.ColWidths[i] := sts[i].ToInteger;
    end;

    for I := 0 to iCnt-1 do
    begin
      iRow := i+2;

      aSig  := FTVSignals.New;

      var cfg : TSignalConfig;
      cfg.StgCode := FieldByName('StdCode_'+i.ToString).AsString;
      aSig.StgCode  := cfg.StgCode;

      for j := F to High(TMethodType) do begin
//        cfg.Input[j].Delay    :=  FieldByName(Format('Delay_%d_%d', [integer(j), i])).AsInteger;
        cfg.Input[j].OrderQty :=  StrToFloatDef(FieldByName(Format('OrdQty_%d_%d', [integer(j), i])).AsString, 0);
        //cfg.Input[j].KipAdjust:=  StrToFloatDef(FieldByName(Format('KipAdjust_%d_%d', [integer(j), i])).AsString, 0);
        cfg.Input[j].VolRate  :=  StrToInt(FieldByName(Format('VolRate_%d_%d', [integer(j), i])).AsStringDef('80'));
      end;

      cfg.Method      := FieldByName(Format('Method_%d', [i])).AsInteger;
      cfg.KipAdjust   := StrToFloatDef(FieldByName(Format('KipAdjust_%d', [i])).AsString, 0);
      cfg.TradeTotQty := StrToFloatDef(FieldByName(Format('TradeTotQty_%d', [i])).AsString, 0);

//      cfg.DelayKipMin := FieldByName(Format('DelayKipMin_%d', [i])).AsInteger;
//      cfg.DelayKip    := StrToFloatDef(FieldByName(Format('DelayKip_%d', [i])).AsString, 0);

      //aSig.UpdateEntryQty(FieldByName(Format('EntryTotQty_%d', [i])).AsString);

      aSig.Config.Assign(cfg);

      AddSignal(aSig, iRow);

      // ЛѓХТАЊ РњРх
      for a := aoEntry to High(TAutoOrderType) do
      begin
        //aSig.Data[a].SetBaseKip(StrToFloatDef(FieldByName(Format('BaseKip_%d_%d', [i, integer(a)])).AsString, 0));
        aSig.SetBaseKip(a, StrToFloatDef(FieldByName(Format('BaseKip_%d_%d', [i, integer(a)])).AsString, 0));
        aSig.SigOrders[a].AccFilledQty[MK]  := StrToFloatDef(FieldByName(Format('AccFilledQty_%d_%d', [i, integer(a)])).AsString, 0);

        for e := ekBinance to High(TExchangeKind) do
        begin
          aSig.SigOrders[a].ExOrders[e].SetSumFiiledQtyNRealKip(
            StrToFloatDef(FieldByName(Format('SumFilledQty_%d_%d_%d', [i, integer(a), integer(e)])).AsString, 0),
            0, //StrToFloatDef(FieldByName(Format('SumRealKip_%d_%d_%d', [i, integer(a), integer(e)])).AsString, 0),
            StrToFloatDef(FieldByName(Format('SumExRate_%d_%d_%d', [i, integer(a), integer(e)])).AsString, 0)
            );
          aSig.SigOrders[a].ExOrders[e].MTFilledQty[MK]:= StrToFloatDef(FieldByName(Format('MTFilledQty_MK_%d_%d_%d', [i, integer(a), integer(e)])).AsString, 0);
          aSig.SigOrders[a].ExOrders[e].MTFilledQty[TK]:= StrToFloatDef(FieldByName(Format('MTFilledQty_TK_%d_%d_%d', [i, integer(a), integer(e)])).AsString, 0);

          for var ls := stLong to High(TSideType) do
          begin
            aSig.SigOrders[a].ExOrders[e].KipData[ls].SetValue(
            StrToFloatDef( FieldByName(Format('AvgPrice_%d_%d_%d_%d', [i, integer(a), integer(e), integer(ls)])).AsString , 0),
            StrToFloatDef( FieldByName(Format('FilledQty_%d_%d_%d_%d', [i, integer(a), integer(e), integer(ls)])).AsString, 0)) ;
          end;
        end;
      end;

      for e := ekBinance to High(TExchangeKind) do
      begin
        aSig.FilledQty[e,stLong] := StrToFloatDef(FieldByName(
          Format('FilledQty_%d_%d_%d', [i, integer(e), integer(stLong)])).AsString, 0);
        aSig.FilledQty[e,stShort]:= StrToFloatDef(FieldByName(
          Format('FilledQty_%d_%d_%d', [i, integer(e), integer(stShort)])).AsString, 0);
      end;

      UpdateSingalData(aSig);

      if FieldByName(Format('EntryOn_%d', [i])).AsBoolean then
      begin
        sg.Objects[ECOL[0], iRow] := Pointer(CKON);
        aSig.OnOff(aoEntry, true);
      end;

      if FieldByName(Format('ExitOn_%d', [i])).AsBoolean then
      begin
        sg.Objects[XCOL[0], iRow] := Pointer(CKON);
        aSig.OnOff(aoExit, true);
      end;

      if (FSignal = nil) and (aSig <> nil) then
        FSignal := aSig;

    end;
  end;

end;

