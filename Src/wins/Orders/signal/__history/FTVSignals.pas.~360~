procedure TFrmTVSignals.DisplayAllKip;
var
  dTmpKip, dTmpKip2, dQty, dEx: double;
  dUpEnAvgKip, dUpExAvgKip, dBtEnAvgKip, dBtExAvgKip: double;
  dPrice : double;
begin

  if not TryStrToFloat(edtTmpQty.Text, dQty) then Exit;

  dEx :=  App.Engine.ApiManager.ExRate.Value;
  if dEx < EPSILON then Exit;

  //---------------------------------------------------------------------------------------------//
  // ОїКёЦЎ СјРд F
  dTmpKip := GetKip(FSymbols[ekUpbit].CalcEstPrice(1, dQty), FSymbols[ekBinance].CalcTicksPrice(FSymbols[ekBinance].Bids[0].Price, 1), dEx);
  if dTmpKip = WRONG_VALUE then Exit;

  // ОїКёЦЎ СјРд S
  dTmpKip2:= GetKip(FSymbols[ekUpbit].CalcTicksPrice(FSymbols[ekUpbit].Asks[0].Price, -1), FSymbols[ekBinance].CalcEstPrice(-1, dQty), dEx);
  if dTmpKip2 = WRONG_VALUE then Exit;

  // ОїКёЦЎ СјРд ЦђБе
  SetRKip(ekUpbit, aoEntry, F, dTmpKip);
  SetRKip(ekUpbit, aoEntry, S, dTmpKip2);
  dUpEnAvgKip := (dTmpKip + dTmpKip2) / 2;

  // КјНц СјРд F
  dTmpKip := GetKip(FSymbols[ekBithumb].CalcEstPrice(1, dQty),  FSymbols[ekBinance].CalcTicksPrice(FSymbols[ekBinance].Bids[0].Price, 1), dEx);
  if dTmpKip = WRONG_VALUE then Exit;

  // КјНц СјРд S
  dTmpKip2:= GetKip(FSymbols[ekBithumb].CalcTicksPrice(FSymbols[ekBithumb].Asks[0].Price, -1), FSymbols[ekBinance].CalcEstPrice(-1, dQty), dEx);
  if dTmpKip2 = WRONG_VALUE then Exit;

  // КјНц СјРд ЦђБе
  SetRKip(ekBithumb, aoEntry, F, dTmpKip);
  SetRKip(ekBithumb, aoEntry, S, dTmpKip2);

  dBtEnAvgKip := (dTmpKip + dTmpKip2) / 2;

  plUpEntryKip.Caption  := Format('%.3f', [dUpEnAvgKip]);
  plBtEntryKip.Caption  := Format('%.3f', [dBtEnAvgKip]);
  plEnDiff.Caption  := Format('%.3f', [dUpEnAvgKip - dBtEnAvgKip]);

  if dUpEnAvgKip > dBtEnAvgKip then
  begin
    plBtEntryKip.Color  := clRed;
    plBtEntryKip.Font.Color := clWhite;
    plUpEntryKip.Color  := clBtnFace;
    plUpEntryKip.Font.Color := clRed;
  end else
  begin
    plBtEntryKip.Color  := clBtnFace;
    plBtEntryKip.Font.Color := clRed;
    plUpEntryKip.Color  := clRed;
    plUpEntryKip.Font.Color := clWhite;
  end;
  //---------------------------------------------------------------------------------------------//

  // ОїКёЦЎ УЛЛъ F
  dTmpKip := GetKip(FSymbols[ekUpbit].CalcEstPrice(-1, dQty),  FSymbols[ekBinance].CalcTicksPrice(FSymbols[ekBinance].Asks[0].Price, -1), dEx);
  if dTmpKip = WRONG_VALUE then Exit;

  // ОїКёЦЎ УЛЛъ S
  dTmpKip2:= GetKip(FSymbols[ekUpbit].CalcTicksPrice(FSymbols[ekUpbit].Bids[0].Price, 1), FSymbols[ekBinance].CalcEstPrice(1, dQty), dEx);
  if dTmpKip2 = WRONG_VALUE then Exit;

  // ОїКёЦЎ УЛЛъ ЦђБе
  SetRKip(ekUpbit, aoExit, F, dTmpKip);
  SetRKip(ekUpbit, aoExit, S, dTmpKip2);
  dUpExAvgKip := (dTmpKip + dTmpKip2) / 2;

  // КјНц УЛЛъ F
  dTmpKip := GetKip(FSymbols[ekBithumb].CalcEstPrice(-1, dQty),  FSymbols[ekBinance].CalcTicksPrice(FSymbols[ekBinance].Asks[0].Price, -1), dEx);
  if dTmpKip = WRONG_VALUE then Exit;

  // КјНц УЛЛъ S
  dTmpKip2:= GetKip(FSymbols[ekBithumb].CalcTicksPrice(FSymbols[ekBithumb].Bids[0].Price, 1), FSymbols[ekBinance].CalcEstPrice(1, dQty), dEx);
  if dTmpKip2 = WRONG_VALUE then Exit;

  // КјНц УЛЛъ ЦђБе
  SetRKip(ekBithumb, aoExit, F, dTmpKip);
  SetRKip(ekBithumb, aoExit, S, dTmpKip2);
  dBtExAvgKip := (dTmpKip + dTmpKip2) / 2;

  plUpExitKip.Caption  := Format('%.3f', [dUpExAvgKip]);
  plBtExitKip.Caption  := Format('%.3f', [dBtExAvgKip]);
  plEXDiff.Caption  := Format('%.3f', [dUpExAvgKip - dBtExAvgKip]);

  if dUpExAvgKip < dBtExAvgKip then
  begin
    plBtExitKip.Color  := clBlue;
    plBtExitKip.Font.Color := clWhite;
    plUpExitKip.Color  := clBtnFace;
    plUpExitKip.Font.Color := clBlue;
  end else
  begin
    plBtExitKip.Color  := clBtnFace;
    plBtExitKip.Font.Color := clBlue;
    plUpExitKip.Color  := clBlue;
    plUpExitKip.Font.Color := clWhite;
  end;

end;

