  if ( Receiver <> Self ) or ( DataObj = nil ) then Exit;

  case Integer(EventID) of
    ORDER_ACCEPTED,
    ORDER_REJECTED,
    ORDER_CANCELED,
    ORDER_CHANGED: FTVSignals.OnOrder(DataObj as TOrder, Integer(EventID));
