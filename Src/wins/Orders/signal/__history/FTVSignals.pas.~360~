function TFrmTVSignals.GetKipAvg(dFJa, dFMo, dSJa, dSMo, dEx: double): double;
var
  dF, dS: double;
begin
  if (dFMo <= EPSILON) or (dSMo <= EPSILON) then
    Exit (WRONG_VALUE);

  dF := ((dFJa / (dFMo * dEx)) -1) * 100;
  dS := ((dSJa / (dSMo * dEx)) -1) * 100;

  Result := (dF + dS)/2;
end;

