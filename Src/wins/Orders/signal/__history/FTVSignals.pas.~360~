procedure TFrmTVSignals.sgMouseDown(Sender: TObject; Button: TMouseButton;
  Shift: TShiftState; X, Y: Integer);
  var
    aVal, aCol, aRow: integer;
    aoType : TAutoOrderType;
begin
//
//  with sg do
//    if  goEditing in Options then
//      Options := Options - [goEditing];

  aRow := FSelectedRow;
  sg.MouseToCell(X, Y, aCol, FSelectedRow) ;

  if FSelectedRow >= 2 then
  begin
//    if ACol in [0.. then
    if aCol = CFG_COL then begin
      FDown := true;
      aVal := integer(sg.Objects[aCol, FSelectedRow]);
      if (aVal = CKOFF) or (aVal = 0) then
        sg.Objects[aCol, FSelectedRow] := Pointer(CKON);
    end else
    if aCol in [ECOL[0], XCOL[0]] then begin

      if aCol = ECOL[0] then
        aoType := aoEntry
      else
        aoType := aoExit;

      aVal := integer(sg.Objects[aCol, FSelectedRow]);
      if aVal = CKON then begin
        if sg.Objects[OBJ_COL, FSelectedRow] <> nil then begin
          sg.Objects[aCol, FSelectedRow] := Pointer(CKOFF);
          TTVSignal(sg.Objects[OBJ_COL, FSelectedRow]).OnOff(aoType, false);
        end;
      end
      else if (aVal = CKOFF) or (aVal = 0) then begin
        if sg.Objects[OBJ_COL, FSelectedRow] <> nil then begin
//          if sg.Cells[1, FSelectedRow] = '' then
//          begin
//            ShowMessage('РќЗЋИэРЬ ОјРН');
//            Exit;
//          end;
          sg.Objects[aCol, FSelectedRow] := Pointer(CKON);
          TTVSignal(sg.Objects[OBJ_COL, FSelectedRow]).OnOff(aoType, true);
        end;
      end;
    end else
    // НЧЧр ЙіЦА
    if aCol = EXE_COL then
    begin
      aVal := integer(sg.Objects[EXE_COL, FSelectedRow]);
      if aVal = CKON then
      begin
        // Stop УГИЎ
        Stop(TTVSignal(sg.Objects[OBJ_COL, FSelectedRow]), FSelectedRow);
      end else
      if (aVal = CKOFF) or (aVal = 0) then
      begin
        // Run УГИЎ
        Run(FSelectedRow);
      end;
    end else
    // НЧЧр УМХЉ ЙкНК
    if aCol = 0 then
    begin
      aVal := integer(sg.Objects[RUN_COL, FSelectedRow]);
      if aVal = CKON then
      begin
        if integer(sg.Objects[EXE_COL, FSElectedRow]) <> CKON then
          sg.Objects[RUN_COL, FSelectedRow] := Pointer(CKOFF);
      end else
      if (aVal = CKOFF) or (aVal = 0) then
      begin
        sg.Objects[RUN_COL, FSelectedRow] := Pointer(CKON);
      end;
    end;

    FSelectedCol := aCol;
  end else
  if (FSelectedRow <= 1) and (aCol = 0) then
  begin
    aVal := integer(sg.Objects[RUN_COL, 1]);
    if aVal = CKON then
    begin
      sg.Objects[RUN_COL, 1] := Pointer(CKOFF);
      DoCheckAllRunColl(false);
    end else
    if (aVal = CKOFF) or (aVal = 0) then
    begin
      // All Run УГИЎ
      sg.Objects[RUN_COL, 1] := Pointer(CKON);
      DoCheckAllRunColl(true);
    end;
  end;

  InvalidateRowEx(sg, aRow);
  InvalidateRowEx(sg, FSelectedRow);

end;

