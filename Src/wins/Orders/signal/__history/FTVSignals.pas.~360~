procedure TFrmTVSignals.OnTimer(Sender: TObject);
var
  sRes, sCode: string;
  bRes: boolean;
  i: integer;

begin
  if edtCode.Text = '' then Exit;

  try
    try
      rq.Params.Clear;

  //    rq.Resource := '/get-lastest.php?'+ edtCode.Text;
      rq.Method := rmGET;

      sCode := GetCode;

      rq.AddParameter('coin', sCode, TRESTRequestParameterKind.pkGETorPOST);//pkREQUESTBODY);
      rq.AddParameter('count', '20',TRESTRequestParameterKind.pkGETorPOST);//pkREQUESTBODY);

      rq.Execute;

      if rq.Response.StatusCode <> 200 then
      begin
        bRes := false;
        sRes := Format('%d:%s,%s', [rq.Response.StatusCode, rq.Response.StatusText, rq.Response.Content]);

        TThread.Queue(nil,
        procedure
        begin
          stsLog.Panels[3].Text := sRes;
        end);

      end else
      begin
        bRes := true;
        sRes := rq.Response.Content;
      end;

      if bRes then begin
        FNwContent.Clear;
        if ParseData(sRes, FNwContent) then
          if FNwContent.Count > 0 then
          begin

            TThread.Synchronize(nil,
              procedure begin
                if ckSig.Checked then
                  FTVSignals.OnSignals(FNwContent);
              end
            );
            PostMessage(Handle, WM_DATA_RECEIVED, 0, 0);
          end;
      end;

      PostMessage(Handle, WM_LOG, 0, 0);
    except on e: exception do
      begin
        var s := e.Message;
        TThread.Queue(nil,
        procedure
        begin
          stsLog.Panels[3].Text := s;
        end);
      end;
    end;

  finally
    inc(FCount);
  end;

end;

