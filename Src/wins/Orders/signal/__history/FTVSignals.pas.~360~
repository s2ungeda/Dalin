  if FDown then
  begin
    sg.MouseToCell(X, Y, aCol, aRow) ;
    if (FSelectedCol <> aCol) or (FSelectedRow <> aRow) then
    begin
      FDown := false;
      iVal  := integer(sg.Objects[FSelectedCol, FSelectedRow]);
      if iVal = CKON then
      begin
        sg.Objects[FSelectedCol, FSelectedRow] := Pointer(CKOFF);
        InvalidateCell(sg, FSelectedCol, FSelectedRow);
      end;
    end;
  end;
