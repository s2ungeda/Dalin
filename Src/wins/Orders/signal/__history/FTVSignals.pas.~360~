procedure TFrmTVSignals.WMSignalState(var Msg: TMessage);
var
  aSignal: TTVSignal;
  aState : TSignalState;
  iRow   : integer;
begin
  if Msg.WParam <= 0 then Exit;

  aSignal := TTVSignal(Msg.WParam);

  iRow  := sg.Cols[OBJ_COL].IndexOfObject(aSignal);
  if iRow > 0 then begin
    aState := TSignalState(Msg.LParam);

    case aState of
      ssEntry: begin
        UpdateSiganlContent(aSignal, iRow, true) ;
      end;
      ssExit : begin
        UpdateSiganlContent(aSignal, iRow, false);
      end;
//      ssEnd :  // РќЗЋ ШИРќРВ АЩЗШРЛЖЇ
//        if aSignal.Run then
//        begin
//          Stop(aSignal, iRow);
//          stsLog.Panels[5].Text := Format('%s ШИРќРВ СІЧбРИЗЮ Stop', [aSignal.StgCode]);
//        end;
    end;

    sg.Objects[ENT_COL, iRow] := Pointer(0);
    sg.Objects[STA_COL, iRow] := Pointer(STA_VAL + Msg.LParam);
    InvalidateRow(sg, iRow);
  end;
end;

