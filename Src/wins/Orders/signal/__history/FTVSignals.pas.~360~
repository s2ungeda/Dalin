procedure TFrmTVSignals.ChangeAllState(ival: integer);
begin
  sg.BeginUpdate;
  try
    for var I := 0 to sg.RowCount-1 do
      ChangeState(i, ival);
  finally
    sg.EndUpdate;
  end;
end;

procedure TFrmTVSignals.ChangeState(iRow, ival: Integer);
begin
  sg.Objects[STA_COL, iRow] := Pointer(ival);
end;

procedure TFrmTVSignals.ChangeStateColor(aSignal:TTVSignal; rtType:TSigResultType);
var
  iRow : integer;
  bRefresh: boolean;
begin
  if aSignal = nil then Exit;

  iRow := sg.Cols[OBJ_COL].IndexOfObject(aSignal);
  if iRow < 1 then Exit;

  bRefresh  := false;

  case rtType of
    srtERJT:   // АХКЮЗЮ РЮЧи suspend
      begin
        bRefresh := true;
        ChangeState(iRow, STA_VAL + 10);
      end;
    srtERSM:   // Resume
      begin
        bRefresh := true;
        ChangeState(iRow, STA_VAL + integer(aSignal.State) );
      end;
    srtXRJT:
      begin
        bRefresh := true;
        ChangeState(iRow, STA_VAL + 20);
      end;
    srtXRSM:
      begin
        bRefresh := true;
        ChangeState(iRow, STA_VAL + integer(aSignal.State) );
      end;
  end;

  if bRefresh then
    InvalidateRow(sg, iRow);

end;

procedure TFrmTVSignals.WMSignalResult(var Msg: TMessage);
var
  rtType : TSigResultType;
  aSignal: TTVSignal;
  bRefresh: boolean;
  iRow: integer;
begin
  if Msg.WParam <= 0 then Exit;

  aSignal := TTVSignal(Msg.WParam);
  rtType  := TSigResultType(Msg.LParam);
  bRefresh:= false;

  stsLog.Panels[3].Text  :=  '';

  case rtType of
    srtEORD, srtXORD: bRefresh  := true;
    srtEFILL: begin
      PutFillLog(aSignal, aoEntry) ;
      bRefresh  := true;
    end;
    srtEBAL: stsLog.Panels[3].Text  := 'БЙГЛИХМіБнОзКЮСЗ';
    // АХКЮ Suspend <-> Resume
    srtERJT, srtXRJT, srtERSM, srtXRSM: ChangeStateColor(aSignal, rtType);
    //
    srtERSK: stsLog.Panels[3].Text  := 'СјРдИЎНКХЉСІЧб';
    srtEDone, srtXDone: begin
      iRow := sg.Cols[OBJ_COL].IndexOfObject(aSignal);
      sg.Objects[ENT_COL, iRow] := pointer(CKON)  ;
    end;

    srtXFILL: begin
      PutFillLog(aSignal, aoExit) ;
      bRefresh := true;
    end;
    srtXBAL: stsLog.Panels[3].Text  := 'БЙГЛИХЕЕРмАэКЮСЗ';
