procedure TFrmTVSignals.CheckSignalTurnover;
var
  iLimit, i, iCnt: integer;
begin
  stsLog.Panels[5].Text := '';

  if not TryStrToInt(edtSigCntLimit.Text, iLimit) then Exit;

  if FSigTimeList.Count < iLimit then Exit;

  for I := 0 to FSigTimeList.Count-1 do
  begin
    if MinutesBetween(now, FSigTimeList[i]) > (24 * 60) then
      break;
  end;

  if i > iLimit then
  begin
    var ss := Format('%s НУБзГЮ ШНМі СІЧбРИЗЮ СОЗс %d > %s (%s)', [edtCode.Text, i, edtSigCntLimit.Text,
      FormatDateTime('hh:nn:ss', now)
      ]);
    App.Log(llInfo, ss);
    stsLog.Panels[5].Text := ss;

    StopAll;
    CheckBox1.Checked := false;
  end;
end;

