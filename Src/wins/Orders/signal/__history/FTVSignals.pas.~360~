procedure SetData(sg: TStringGrid; var iCol: integer; iRow: integer; sData: string);
begin
  with sg do
    Cells[iCol, iRow] := sData;
  inc(iCol);
end;

procedure TFrmTVSignals.UpdateSiganlContent(aSignal: TTVSignal;
  iRow: integer; bEntry: boolean);
  var
    iCol : integer;
    aoType: TAutoOrderType;
begin
  if bEntry then begin
    iCol  := ECOL[0] + 1;
    aoType:= aoEntry;
  end
  else begin
    iCol  := XCOL[0] + 1;
    aoType:= aoExit;
  end;

  with sg do
    SetData(sg, iCol, iRow, Format('%.2f', [aSignal.Data[aoType].BaseKip]));
end;

procedure TFrmTVSignals.UpdateSignalConfig(aItem: TTVSignal; iRow: integer);
var
  iCol: integer;
  sTmp: string;
begin

  iCol := 1;
  with sg do begin

    SetData(sg, iCol, iRow, aItem.Config.StgCode);

//    SetData(sg, iCol, iRow, aItem.Config.Input[F].Delay.ToString);
    SetData(sg, iCol, iRow, aItem.Config.Input[F].OrderQty.ToString);
//    SetData(sg, iCol, iRow, aItem.Config.Input[F].KipAdjust.ToString);

//    SetData(sg, iCol, iRow, aItem.Config.Input[S].Delay.ToString);
    SetData(sg, iCol, iRow, aItem.Config.Input[S].OrderQty.ToString);
//    SetData(sg, iCol, iRow, aItem.Config.Input[S].KipAdjust.ToString);

    SetData(sg, iCol, iRow, aItem.Config.KipAdjust.ToString);
//    SetData(sg, iCol, iRow, aItem.Config.DelayKip.ToString);

    SetData(sg, iCol, iRow, ifThenStr(aItem.Config.Method = 0, 'A',
      ifThenStr(aItem.Config.Method = 1, 'F', 'S')));

    SetData(sg, iCol, iRow, aItem.Config.TradeTotQty.ToString);
  end;

end;

procedure TFrmTVSignals.UpdateSingalData(aSignal: TTVSignal);
var
  iRow : integer;
  dTmp : double;
begin
  iRow := sg.Cols[OBJ_COL].IndexOfObject(aSignal);
     {
     'FS', 'ИёЧЅСјРдЗЎ', 'RTСјРдЗЎ', 'УМАсТї',  // 8
     'МГСЄ',                                    // 12
     'Run', 'BaseKip', 'SigKip', 'ДЉРћМіЗЎ','AvgKip',  // 13
     }
  if iRow > 0 then
    with sg do
    begin
      Cells[ECOL[0]+1, iRow] := Format('%.2f', [aSignal.Data[aoEntry].BaseKip]);
      Cells[XCOL[0]+1, iRow] := Format('%.2f', [aSignal.Data[aoExit].BaseKip]);

      //dNetQty := aSignal.GetEntryQty;// SigOrders[aoEntry].GetTotFilledQty - aSignal.SigOrders[aoExit].GetTotFilledQty;
      Cells[CFG_COL-2, iRow] := DblToStrEx(aSignal.GetEntryQty, 3);

      Cells[CFG_COL-1, iRow] := DblToStrEx(aSignal.GetDifFilledQty, 3);

      // АХЗЁМвРЧ MTFilledQty[MK] РЧ Че
      dTmp  := aSignal.SigOrders[aoEntry].GetTotFilledQty;
      // ДЉРћ УМАс
      Cells[ECOL[0]+2, iRow] := DblToStrEx(dTmp, 2);
      // AvgKip
      var d1 := aSignal.GetAvgKip(aoEntry);
      Cells[ECOL[0]+3, iRow] := Format('%.3f', [d1]);
      var e1 := aSignal.GetAvgExRate(aoEntry);
      Cells[ECOL[0]+4, iRow] := Format('%.1f', [e1]);

      dTmp  := aSignal.SigOrders[aoExit].GetTotFilledQty;
      // ДЉРћУМАс
      Cells[XCOL[0]+2, iRow] := DblToStrEx(dTmp, 2);
      // AvgKip
      var d2 := aSignal.GetAvgKip(aoExit);
      Cells[XCOL[0]+3, iRow] := Format('%.3f', [d2]);

      var e2 := aSignal.GetAvgExRate(aoExit);
      Cells[XCOL[0]+4, iRow] := Format('%.1f', [e2]);

      Cells[XCOL[1]+1, iRow] := Format('%.2f', [aSignal.Data[aoExit].BaseKip - aSignal.Data[aoEntry].BaseKip]);
      Cells[XCOL[1]+2, iRow] := Format('%.2f', [d2 - d1]);
      Cells[XCOL[1]+3, iRow] := Format('%.1f', [e2 - e1]);
    end;
end;

procedure TFrmTVSignals.PutContent(aData: TRqContent; iRow:integer);
begin

  with sgContent do
  begin
    Cells[0, iRow] := FormatDateTime('dd hh:nn:ss', aData.Time);
    Cells[1, iRow] := aData.StgName;
    Cells[2, iRow] := aData.SigType;
    Cells[3, iRow] := aData.SigKimp.ToString;
    Cells[4, iRow] := aData.TID.ToString;
//    var a := FRqContent.New(aData.TID);
//    a.CopyData(aData);

  end;

  if aData.SigType = 'buy' then
    FSigTimeList.Add(aData.Time);
end;


procedure TFrmTVSignals.PutFillLog(aSignal: TTVSignal; aoType: TAutoOrderType);
var
  aSymbol: TSymbol;
  aOrder : TOrder;
  aItem  : TStgOrderItem;
  I: integer;
begin
  InsertLine(sgFillLog, 1);

  with sgFillLog do
  begin
    Cells[0, 1] := FormatDateTime('dd hh:nn:ss', now);
    Cells[1, 1] := aSignal.Config.StgCode;

    if aSignal.Results[aoType].Last <> nil then
    begin
      aItem :=  aSignal.Results[aoType].Last;

      Cells[2, 1] := ifThenStr(aItem.AOType = aoEntry,'СјРд','УЛЛъ');
      Cells[3, 1] := Format('%.2f', [aSignal.Data[aItem.AOType].CalcKip[aItem.Method]]);
      Cells[4, 1] := Format('%.2f', [aItem.Kip]);

      Objects[EX_COL, 1]  := Pointer(IfThen(aItem.AOType = aoEntry, 100, 200));
//      Objects[FS_COL, 1]  := Pointer(IfThen(aItem.Method = mtF, 100, 200));
      if aItem.OrderList[MK].Count > 0 then
      begin
        if aItem.OrderList[TK].Count > 0 then
          aSymbol := aItem.OrderList[TK].Last.Symbol
        else
          aSymbol := nil;

        aOrder := aItem.OrderList[MK].Last;
        if aOrder <> nil then
        begin

          ////
          if aOrder.Side < 0 then begin
            Cells[5,1]  := '+ '+ aOrder.Symbol.PriceToStr(aOrder.AvgPrice);
            if aSymbol <> nil then
              Cells[6,1]  := aSymbol.PriceToStr(aItem.AvgPrice);
          end
          else begin
            if aSymbol <> nil then
              Cells[5,1]  := aSymbol.PriceToStr(aItem.AvgPrice);
            Cells[6,1]  := '+ '+ aOrder.Symbol.PriceToStr(aOrder.AvgPrice);
          end;
          ////
        end;
      end;

      if aOrder <> nil then
      begin
        Cells[7, 1] := Format('%s', [doubleToStr(min(aOrder.FilledQty, aItem.FilledQty))]);
        Cells[8, 1] := TExShortDesc[aItem.GetPutExKind];
        Cells[9, 1] := aItem.GetLiqExKindToStr;
        Cells[10,1] := Format('%.2f', [aOrder.ExRate]);
        Cells[11,1] := DblToStrEx(aOrder.FilledQty - aItem.FilledQty, 3);
      end;

    end;

    if (FixedRows <= 0) and (RowCount >= 2)  then
      FixedRows := 1;
  end;
end;

procedure TFrmTVSignals.WMAfterOrderNotify(var Msg: TMessage);
var
  aSignal: TTVSignal;
  aOrder : TOrder;
begin
  if (Msg.WParam <= 0) or (Msg.LParam <= 0) then Exit;

  aSignal := TTVSignal(Msg.WParam);
  aOrder  := TOrder(msg.LParam);
{
  'НУАЂ','РќЗЋФкЕх','ЛѓХТ','АХЗЁМв',' ',
  'ЙцЧт','ЦђБеАЁ', 'УМАсЗЎ','ШЏРВ');
}
  sgFillLog.BeginUpdate;
  try
    InsertLine(sgFillLog, 1);

    with sgFillLog do
    begin
      Cells[0, 1] := FormatDateTime('dd hh:nn:ss', now);
      Cells[1, 1] := aSignal.Config.StgCode;
      Cells[2, 1] := TExchangeKindDesc[aOrder.Symbol.Spec.ExchangeType];
      Cells[3, 1] := IfThen(aOrder.Entry, 'СјРд','УЛЛъ');

      Objects[EX_COL, 1]  := Pointer(IfThen(aOrder.Entry, 100, 200));

      case aOrder.Symbol.Spec.ExchangeType of
        ekBinance: Cells[4, 1] := 'S' ;
        else Cells[4, 1] := 'F';
      end;

      Cells[5, 1] := aOrder.SideToStr;
      Cells[6, 1] := doubleToStr(aOrder.AvgPrice);
      Cells[7, 1] := doubleToStr(aOrder.FilledQty);
      Cells[8, 1] := aOrder.ExRate.ToString;

      if (FixedRows <= 0) and (RowCount >= 2)  then
        FixedRows := 1;
    end;

  finally
    sgFillLog.EndUpdate;
  end;



end;

procedure TFrmTVSignals.WMDataReceived(var Msg: TMessage);
var
  i: integer;
  aSig: TTVSignal;
  id: string;
begin

//  sgContent.BeginUpdate;
  try
    with  FNWContent do
    for I := 0 to Count-1 do
    begin
      aSig := FTVSignals.Find(Contents[i].StgName);

      id := Contents[i].TID.ToString;
      var iRow := sgContent.Cols[4].IndexOf(id);
      if iRow >= 0 then
        continue;

      if aSig <> nil then begin
        InsertLine(sgContent, 1);
        PutContent(Contents[i], 1);
      end;

      if (sgContent.RowCount > 1) and (sgContent.FixedRows < 1) then
        sgContent.FixedRows := 1;

    end;
  finally
//    sgContent.EndUpdate;
  end;
end;

