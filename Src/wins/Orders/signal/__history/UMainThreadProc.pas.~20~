unit UMainThreadProc;

interface

uses
  System.Classes, System.SysUtils, System.SyncObjs, System.DateUtils,
  System.Generics.Collections, Windows,

  USignalTypes, UTVSignals, USymbols, UOrders, UFills,

  UApiTypes
  ;

type

  TMainThread = class(TThread)
  private
    { Private declarations }
    FEvent  : TEvent;
    FCount, FIndex: integer;
    FInterval: integer;
    FOnLog: TGetStrProc;
    FOnTimer: TProc;
    FEnable: boolean;

    FSignalQ: TThreadedQueue<TEngineEvent>;
    FSignals: TTVSignals;
    FTarget: HWND;

    function IsRun: boolean;

    procedure SetInterval(const Value: integer);
    procedure DoLog(s:string);
    procedure SetEnable(const Value: boolean);
    procedure Stop;

    procedure OnSignal(s: TRqContent);
    procedure OnQuote(a:TSymbol; aType: TEngineEventKind); overload;
    procedure OnOrder(o: TOrder ; iEventID: integer);
    procedure OnFill(f: TFill);


  protected
    procedure Execute; override;
    procedure TerminatedSet; override;
  public
    constructor Create(aHandle: HWND; a: TTVSignals);
    destructor Destroy; override;

    function IsLive : boolean;

    procedure OnSignals(aSignals: TRqContents);
    procedure OnQuote(a: TSymbol; bDomestic: boolean); overload;
    procedure PushOrder(o: TOrder ; iEventID: integer);
    procedure PushFill(o: TOrder ; iEventID: integer);

    procedure OnOrderTimer;
    procedure OnPause;

    property Interval : integer read FInterval write SetInterval;
    property OnLog : TGetStrProc read FOnLog write FOnLog;
    property OnTimer: TProc read FOnTimer write FOnTimer;
    property Enable: boolean read FEnable write SetEnable;
    property Target : HWND read FTarget;

    property Signals : TTVSignals read FSignals;
    // 데이터 받으 Q
    // 1. signal
    property SignalQ : TThreadedQueue<TEngineEvent> read FSignalQ;
    // 2. 시세
    // 3. 주문

  end;

implementation

uses
  GApp,
  System.Diagnostics
  , UTypes
  ;


{ TMainThread }

constructor TMainThread.Create(aHandle: HWND; a: TTVSignals);
begin

  FSignals  := a;
  FTarget   := aHandle;

  FInterval := 500;
  FOnTimer  := nil;
  FEnable   := false;

  FSignalQ  := TThreadedQueue<TEngineEvent>.Create(50000 ,0, 10);

  inherited Create(false);
  FreeOnTerminate := false;
  Priority  := tpNormal;

  FEvent    := TEvent.Create(nil, False, False, '');

  FIndex  := 0;
  FCount  := 0;

//  Resume;
end;

destructor TMainThread.Destroy;
begin
  FSignalQ.Free;
  FEvent.Free;
  inherited;
end;

procedure TMainThread.DoLog(s: string);
begin
  if Assigned(FOnLog) then
    FOnLog(s);
end;

procedure TMainThread.Execute;
var Res : TWaitResult;
  s : TEngineEvent;
  nProc  : integer;
  t0    : TStopwatch;
begin
  { Place thread code here }

  while not Terminated do
  begin

    try
      case FSignalQ.PopItem(s) of
        wrTimeout:
          begin
            // 로그 업데이트
            //OnEventTimer;
          end;
        wrSignaled:
          begin
            // 3) 버스트 드레인: 들어온 김에 가능한 많이 처리
            t0 := TStopwatch.StartNew;
            nProc := 0;

            repeat
              try
                case s.Kind of
                  ekDomesticBook : OnQuote(s.Book, ekDomesticBook);
                  ekOverseasBook : OnQuote(s.Book, ekOverseasBook);
                  ekOrderUpdate  : OnOrder(s.Order, s.EventID);
                  ekSignal       : OnSignal(s.Signal);
                  ekFill         : OnFill(s.Fill);
                end;
                Inc(nProc);
              except
                on E: Exception do
                begin
                  // 예외를 삼키지 말고 최소한 로그
                  App.Log(llError, 'MainThread.OnEvent failed: ' + E.ClassName + ' ' + E.Message);
                end;
              end;

              // 3-1) 시간/개수 가드: 너무 오래 붙잡지 않기
              if (nProc >= 100) or (t0.ElapsedMilliseconds >= 10) then
                Break;

              // 3-2) 종료 이벤트가 켜졌으면 즉시 탈출
              if FEvent.WaitFor(0) = wrSignaled then
                Break;

              // 3-3) 큐에 남은 것 더 있으면 타임아웃 0으로 추가 드레인
              res := FSignalQ.PopItem(s);
            until res <> wrSignaled;

            // 4) 버스트 한 턴 처리가 끝난 뒤에 주기성 작업 1회
            OnOrderTimer;
          end;
      end;
    except
    end;

    if FEvent.WaitFor(1) = wrSignaled then
      break;
  end;
end;

function TMainThread.IsLive: boolean;
begin
  Result := Terminated;
end;

function TMainThread.IsRun: boolean;
begin
  Result := false;
end;

procedure TMainThread.OnFill(f: TFill);
var
  I: Integer;
begin
  for I := 0 to FSignals.Count-1 do
    if FSignals.TVSignal[i] <> nil then
      FSignals.TVSignal[i].OnFill(f);
end;

procedure TMainThread.OnOrder(o: TOrder; iEventID: integer);
var
  I: Integer;
begin
  for I := 0 to FSignals.Count-1 do
  begin
    if FSignals.TVSignal[i] <> nil then
      FSignals.TVSignal[i].OnOrder(o, iEventID);
  end;
end;

procedure TMainThread.OnOrderTimer;
var
  I: Integer;
begin
  for I := 0 to FSignals.Count-1 do
  begin
    if FSignals.TVSignal[i] <> nil then
      FSignals.TVSignal[i].OnOrderTimer;
  end;
end;

procedure TMainThread.OnPause;
var
  I: Integer;
begin
// 다 취소..

  for I := 0 to FSignals.Count-1 do
  begin
    if FSignals.TVSignal[i] <> nil then
      FSignals.TVSignal[i].Pause;
  end;

end;

procedure TMainThread.OnQuote(a: TSymbol; aType: TEngineEventKind);
var
  I: Integer;
  e: TExchangeKind;
begin

  for e := ekBinance to High(TExchangeKind) do
    if FSignals.Symbol[e] = nil then Exit;

  for I := 0 to FSignals.Count-1 do
    try
      if FSignals.TVSignal[i] <> nil then
        FSignals.TVSignal[i].OnQuote(a, aType);
    except
    end;
end;

procedure TMainThread.OnQuote(a: TSymbol; bDomestic: boolean);
begin
  if bDomestic then
    FSignalQ.PushItem(EvQuote(a, ekDomesticBook))
  else
    FSignalQ.PushItem(EvQuote(a, ekOverseasBook));
end;

procedure TMainThread.OnSignal(s: TRqContent);
var
  aSignal : TTVSignal;
begin
  aSignal := FSignals.Find(s.StgName);
  if aSignal = nil then Exit;

  aSignal.OnSignal(s);
end;

procedure TMainThread.OnSignals(aSignals: TRqContents);
var
  I: Integer;
begin
  for I := 0 to aSignals.Count-1 do
    FSignalQ.PushItem(EvSignal(aSignals.Contents[i]));
end;

procedure TMainThread.PushFill(o: TOrder; iEventID: integer);
begin
  if o.Fills.LastFill <> nil then
    FSignalQ.PushItem(EvFill(o.Fills.LastFill, iEventID));
end;

procedure TMainThread.PushOrder(o: TOrder; iEventID: integer);
begin
  FSignalQ.PushItem(EvOrder(o, iEventID));
end;

procedure TMainThread.SetEnable(const Value: boolean);
begin
  FEnable := Value;
end;

procedure TMainThread.SetInterval(const Value: integer);
begin
  FInterval := Value;
end;

procedure TMainThread.Stop;
begin
  Terminate;
end;


procedure TMainThread.TerminatedSet;
begin
  FEvent.SetEvent;
end;

end.



