unit UMainThreadProc;

interface

uses
  System.Classes, System.SysUtils, System.SyncObjs, System.DateUtils,
  System.Generics.Collections, Windows,

  USignalTypes, UTVSignals, USymbols, UOrders, UFills,

  UApiTypes
  ;

// 시세 종목 개수 정의 (3개 종목)
const
  SYMBOL_COUNT = 3;

type
  // TSymbol에서 이 인덱스 값(0, 1, 2)을 얻어올 수 있다고 가정합니다.
  TSymbolIndex = 0..SYMBOL_COUNT-1;

  TMainThread = class(TThread)
  private
    { Private declarations }
    FEvent  : TEvent;
    FCount, FIndex: integer;
    FInterval: integer;
    FOnLog: TGetStrProc;
    FOnTimer: TProc;
    FEnable: boolean;

    // [핵심] High Priority Queue: 명령어(Signal, Order, Fill) 처리 전용
    FCmdQ : TThreadedQueue<TEngineEvent>;

    // [핵심] Low Priority 시세 처리: 스냅샷 캐시 (3개 종목)
    FLatestQuotes: array[TSymbolIndex] of TSymbol;
    FHasNewQuote: array[TSymbolIndex] of boolean;
    FQuoteUpdateLock: TCriticalSection;

    FSignals: TTVSignals;
    FTarget: HWND;

    // TSymbol에서 인덱스를 얻는 가상 함수 (실제 구현 필요)
    function GetSymbolIndex(a: TSymbol): TSymbolIndex;

    function IsRun: boolean;
    procedure SetInterval(const Value: integer);
    procedure DoLog(s:string);
    procedure SetEnable(const Value: boolean);
    procedure Stop;

    procedure OnSignal(s: TRqContent);
    procedure OnQuote(a:TSymbol; aType: TEngineEventKind); overload;
    procedure OnOrder(o: TOrder ; iEventID: integer);
    procedure OnFill(f: TFill);

    // 이벤트 처리 통합 함수 (내부용)
    procedure ProcessEvent(const s: TEngineEvent);
    procedure ProcessSnapshotQuotes; // 스냅샷 시세 처리 함수

  protected
    procedure Execute; override;
    procedure TerminatedSet; override;
  public
    constructor Create(aHandle: HWND; a: TTVSignals);
    destructor Destroy; override;

    function IsLive : boolean;

    procedure OnSignals(aSignals: TRqContents);
    procedure OnQuote(a: TSymbol; bDomestic: boolean); overload;
    procedure PushOrder(o: TOrder ; iEventID: integer);
    procedure PushFill(o: TOrder ; iEventID: integer);

    procedure OnOrderTimer;
    procedure OnPause;

    property Interval : integer read FInterval write SetInterval;
    property OnLog : TGetStrProc read FOnLog write FOnLog;
    property OnTimer: TProc read FOnTimer write FOnTimer;
    property Enable: boolean read FEnable write SetEnable;
    property Target : HWND read FTarget;

    property Signals : TTVSignals read FSignals;
    property CmdQ  : TThreadedQueue<TEngineEvent> read FCmdQ;

  end;

implementation

uses
  GApp,
  System.Diagnostics
  , UTypes
  ;

{ TMainThread }

// TSymbol에서 배열 인덱스를 얻는 Placeholder
function TMainThread.GetSymbolIndex(a: TSymbol): TSymbolIndex;
begin
  // TODO: TSymbol 객체 내부에서 종목별로 0, 1, 2 인덱스를 반환하는 실제 로직 필요
  Result := 0;
end;


constructor TMainThread.Create(aHandle: HWND; a: TTVSignals);
var
  I: Integer;
begin
  FSignals  := a;
  FTarget   := aHandle;

  FInterval := 500;
  FOnTimer  := nil;
  FEnable   := false;

  // High Priority Queue 초기화: 명령/주문은 절대 놓치면 안 되므로 PushTimeout을 길게 줍니다.
  FCmdQ := TThreadedQueue<TEngineEvent>.Create(10000, 1000, 5);

  // 스냅샷 구조 초기화
  FQuoteUpdateLock := TCriticalSection.Create;
  for I := Low(TSymbolIndex) to High(TSymbolIndex) do
  begin
    FHasNewQuote[I] := False;
    // TSymbol 초기화 로직 (필요시)
  end;

  inherited Create(false);
  FreeOnTerminate := false;
  Priority  := tpNormal;

  FEvent    := TEvent.Create(nil, False, False, '');

  FIndex  := 0;
  FCount  := 0;
end;

destructor TMainThread.Destroy;
begin
  FQuoteUpdateLock.Free;
  FCmdQ.Free;

  FEvent.Free;
  inherited;
end;

procedure TMainThread.DoLog(s: string);
begin
  if Assigned(FOnLog) then
    FOnLog(s);
end;

// 이벤트 처리 로직 (CmdQ 이벤트)
procedure TMainThread.ProcessEvent(const s: TEngineEvent);
begin
  try
    case s.Kind of
      ekOrderUpdate  : OnOrder(s.Order, s.EventID);
      ekSignal       : OnSignal(s.Signal);
      ekFill         : OnFill(s.Fill);
      // 시세 이벤트는 ProcessSnapshotQuotes에서 처리하므로 여기서 제외
    end;
  except
    on E: Exception do
      App.Log(llError, 'MainThread.ProcessEvent failed: ' + E.ClassName + ' ' + E.Message);
  end;
end;

// [핵심] 시세 스냅샷 처리 로직
procedure TMainThread.ProcessSnapshotQuotes;
var
  I: TSymbolIndex;
begin
  FQuoteUpdateLock.Enter;
  try
    for I := Low(TSymbolIndex) to High(TSymbolIndex) do
    begin
      if FHasNewQuote[I] then
      begin
        // 최신 호가를 꺼내 처리
        // TSymbol 객체 자체에 Domestic/Overseas 타입 정보가 있다고 가정하고 처리합니다.
        OnQuote(FLatestQuotes[I], true);

        FHasNewQuote[I] := False; // 처리했으므로 플래그 리셋
      end;
    end;
  finally
    FQuoteUpdateLock.Leave;
  end;
end;

procedure TMainThread.Execute;
var
  s : TEngineEvent;
begin
  while not Terminated do
  begin
    // ---------------------------------------------------------
    // 1단계: [High Priority] 명령/주문 큐 대기 및 처리 (최적화된 2번 방식)
    // ---------------------------------------------------------
    // 10ms 동안 대기하며 명령을 기다립니다. 명령 수신 시 즉시 깨어나 처리.
    if FCmdQ.PopItem(s) = wrSignaled then
    begin
      ProcessEvent(s);

      // 큐에 남은 명령어는 대기 없이 즉시 처리하여 모두 비웁니다 (Burst Drain).
      while FCmdQ.PopItem(s) = wrSignaled do
      begin
        ProcessEvent(s);
      end;
      // 명령 처리를 마쳤으니, 다시 루프 처음으로 돌아가 대기 (CPU 부하 감소)
      Continue;
    end;

    // ---------------------------------------------------------
    // 2단계: [Low Priority] 시세 스냅샷 처리
    // ---------------------------------------------------------
    // 명령이 없어 대기 시간이 경과했을 때만 시세의 최신 상태를 읽어 처리합니다.
    ProcessSnapshotQuotes;

    // ---------------------------------------------------------
    // 3단계: 주기적 작업 및 종료 체크
    // ---------------------------------------------------------
    OnOrderTimer; // 주기적 작업 수행

    if FEvent.WaitFor(0) = wrSignaled then
      Break;
  end;
end;

function TMainThread.IsLive: boolean;
begin
  Result := not Terminated;
end;

function TMainThread.IsRun: boolean;
begin
  Result := not Terminated;
end;

// ... (OnFill, OnOrder, OnOrderTimer, OnPause 등 기존 핸들러 코드는 동일) ...

procedure TMainThread.OnFill(f: TFill);
var
  I: Integer;
begin
  for I := 0 to FSignals.Count-1 do
    if FSignals.TVSignal[i] <> nil then
      FSignals.TVSignal[i].OnFill(f);
end;

procedure TMainThread.OnOrder(o: TOrder; iEventID: integer);
var
  I: Integer;
begin
  for I := 0 to FSignals.Count-1 do
  begin
    if FSignals.TVSignal[i] <> nil then
      FSignals.TVSignal[i].OnOrder(o, iEventID);
  end;
end;

procedure TMainThread.OnOrderTimer;
var
  I: Integer;
begin
  for I := 0 to FSignals.Count-1 do
  begin
    if FSignals.TVSignal[i] <> nil then
      FSignals.TVSignal[i].OnOrderTimer;
  end;
end;

procedure TMainThread.OnPause;
var
  I: Integer;
begin
  for I := 0 to FSignals.Count-1 do
  begin
    if FSignals.TVSignal[i] <> nil then
      FSignals.TVSignal[i].Pause;
  end;
end;

procedure TMainThread.OnQuote(a: TSymbol; aType: TEngineEventKind);
var
  I: Integer;
  e: TExchangeKind;
begin
  for e := ekBinance to High(TExchangeKind) do
    if FSignals.Symbol[e] = nil then Exit;

  for I := 0 to FSignals.Count-1 do
    try
      if FSignals.TVSignal[i] <> nil then
        FSignals.TVSignal[i].OnQuote(a, aType);
    except
    end;
end;

// [핵심] OnQuote Producer: 큐에 넣지 않고 스냅샷 배열에 직접 덮어쓰기
procedure TMainThread.OnQuote(a: TSymbol; bDomestic: boolean);
var
  Idx: TSymbolIndex;
begin
  FQuoteUpdateLock.Enter;
  try
    Idx := GetSymbolIndex(a); // 종목별 인덱스 획득

    // 최신 데이터로 덮어씌움 (Conflation)
    FLatestQuotes[Idx] := a;
    FHasNewQuote[Idx] := True; // 처리할 데이터가 있음을 표시
  finally
    FQuoteUpdateLock.Leave;
  end;
end;

procedure TMainThread.OnSignal(s: TRqContent);
var
  aSignal : TTVSignal;
begin
  aSignal := FSignals.Find(s.StgName);
  if aSignal = nil then Exit;

  aSignal.OnSignal(s);
end;

procedure TMainThread.OnSignals(aSignals: TRqContents);
var
  I: Integer;
begin
  for I := 0 to aSignals.Count-1 do
    FCmdQ.PushItem(EvSignal(aSignals.Contents[i])); // CmdQ에 Push
end;

procedure TMainThread.PushFill(o: TOrder; iEventID: integer);
begin
  if o.Fills.LastFill <> nil then
    FCmdQ.PushItem(EvFill(o.Fills.LastFill, iEventID)); // CmdQ에 Push
end;

procedure TMainThread.PushOrder(o: TOrder; iEventID: integer);
begin
  FCmdQ.PushItem(EvOrder(o, iEventID)); // CmdQ에 Push
end;

procedure TMainThread.SetEnable(const Value: boolean);
begin
  FEnable := Value;
end;

procedure TMainThread.SetInterval(const Value: integer);
begin
  FInterval := Value;
end;

procedure TMainThread.Stop;
begin
  Terminate;
  FEvent.SetEvent;
end;

procedure TMainThread.TerminatedSet;
begin
  FEvent.SetEvent;
end;

end.
