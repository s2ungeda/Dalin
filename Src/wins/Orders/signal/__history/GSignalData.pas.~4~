unit GSignalData;

interface

uses
  System.SysUtils, System.Classes, System.SyncObjs, System.Generics.Collections
  , UTypes
  ;

var
  ReservQty : array [TAutoOrderType] of TDictionary<string, TDictionary<string, double>>;

  procedure Update(a: TAutoOrderType; const Code, Stg: string; Qty: double);
  procedure Remove(a: TAutoOrderType; const Code, Stg: string); overload;
  procedure Remove(a: TAutoOrderType; const Code: string); overload;

  function GetCodes(a: TAutoOrderType; const Code: string; var Outs: TArray<string>): boolean;

implementation

uses
  Math
  ;

procedure Init;
begin
  for var I := aoEntry to High(TAutoOrderType) do
    ReservQty[i] := TDictionary<string, TDictionary<string, double>>.Create;
end;

procedure Fin;
begin
  for var I := aoEntry to High(TAutoOrderType) do
    if ReservQty[i] <> nil then
      ReservQty[i].Free;
end;

procedure Update(a: TAutoOrderType; const Code, Stg: string; Qty: double);
var
  Value : TDictionary<string, double>;
begin
  if not ReservQty[a].TryGetValue(Code, Value) then
  begin
    Value := TDictionary<string, double>.Create;
    Value.Add(Stg, Qty);
    ReservQty[a].Add(Code, Value);
  end else
  begin
    Value.AddOrSetValue(Stg, Qty);
  end;
end;

procedure Remove(a: TAutoOrderType; const Code, Stg: string);
var
  Value : TDictionary<string, double>;
begin
  if ReservQty[a].TryGetValue(Code, Value) then
  begin
    Value.Remove(Stg);
    Value.Free;
  end;
end;

procedure Remove(a: TAutoOrderType; const Code: string);
var
  Pair: TPair<string, TDictionary<string, double>>;
  bFind: boolean;
begin
  for Pair in ReservQty[a] do
    if Code = Pair.Key then
    begin
      FreeAndNil(Pair.Value);
      bFind := true;
      break;
    end;

  if bFind then
    ReservQty[a].Remove(Code);
end;

// 인자외에 다른 코드가 있다면 넘겨줌..
function GetCodes(a: TAutoOrderType; const Code: string; var Outs: TArray<string>): boolean;
var
  Pair: TPair<string, TDictionary<string, double>>;
  i: Integer;
begin
  i := 0;
  SetLength(Outs, i);
  for Pair in ReservQty[a] do
    if Code <> Pair.Key then
    begin
      inc(i);
      SetLength(Outs, i);
      Outs[i-1] := Pair.Key;
    end;
end;

initialization
  Init;

finalization
  Fin;

end.
