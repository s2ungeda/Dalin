unit uAutoOrderManager;

interface

uses
  System.SysUtils, System.Classes, Vcl.ExtCtrls;

type
  // 재개 방식
  TResumeMode = (rmAuto, rmManual);

  // 주문 상태
  TOrderState = (
    osIdle,           // 대기 중
    osOrdering,       // 주문 발주 중
    osWaitRetry,      // 재시도 대기 중
    osPaused          // 일시 중지 (연속 거부)
  );

  // 설정
  TOrderSettings = record
    RetryInterval: Integer;      // 재시도 간격 (초)
    MaxRejectCount: Integer;     // 최대 연속 거부 횟수
    ResumeMode: TResumeMode;     // 재개 방식
    AutoResumeDelay: Integer;    // 자동 재개 시간 (초)
  end;

  // 이벤트 타입
  TOrderEvent = procedure(Sender: TObject) of object;
  TStateChangeEvent = procedure(Sender: TObject; OldState, NewState: TOrderState) of object;
  TRejectEvent = procedure(Sender: TObject; RejectCount: Integer) of object;

  TAutoOrderManager = class
  private
    FSettings: TOrderSettings;
    FState: TOrderState;
    FRejectCount: Integer;        // 연속 거부 횟수
    FRetryTimer: TTimer;          // 재시도 타이머
    FResumeTimer: TTimer;         // 자동 재개 타이머

    // 이벤트
    FOnSendOrder: TOrderEvent;           // 주문 발주 요청
    FOnStateChange: TStateChangeEvent;   // 상태 변경
    FOnReject: TRejectEvent;             // 거부 발생
    FOnPaused: TOrderEvent;              // 일시 중지됨
    FOnResumed: TOrderEvent;             // 재개됨

    procedure SetState(Value: TOrderState);
    procedure RetryTimerEvent(Sender: TObject);
    procedure ResumeTimerEvent(Sender: TObject);
    procedure DoSendOrder;
  public
    constructor Create;
    destructor Destroy; override;

    // 설정
    procedure ApplySettings(const ASettings: TOrderSettings);
    function GetSettings: TOrderSettings;

    // 주문 제어
    procedure StartOrder;           // 최초 주문 시작
    procedure OnOrderAccepted;      // 체결 성공 콜백
    procedure OnOrderRejected;      // 거부 콜백
    procedure ManualResume;         // 수동 재개
    procedure Stop;                 // 정지

    // 상태 조회
    property State: TOrderState read FState;
    property RejectCount: Integer read FRejectCount;

    // 이벤트
    property OnSendOrder: TOrderEvent read FOnSendOrder write FOnSendOrder;
    property OnStateChange: TStateChangeEvent read FOnStateChange write FOnStateChange;
    property OnReject: TRejectEvent read FOnReject write FOnReject;
    property OnPaused: TOrderEvent read FOnPaused write FOnPaused;
    property OnResumed: TOrderEvent read FOnResumed write FOnResumed;
  end;

function OrderStateToStr(AState: TOrderState): string;

implementation

function OrderStateToStr(AState: TOrderState): string;
begin
  case AState of
    osIdle:      Result := '대기';
    osOrdering:  Result := '주문 중';
    osWaitRetry: Result := '재시도 대기';
    osPaused:    Result := '일시 중지';
  else
    Result := '알 수 없음';
  end;
end;

{ TAutoOrderManager }

constructor TAutoOrderManager.Create;
begin
  inherited Create;

  FState := osIdle;
  FRejectCount := 0;

  // 기본 설정
  FSettings.RetryInterval := 3;
  FSettings.MaxRejectCount := 5;
  FSettings.ResumeMode := rmAuto;
  FSettings.AutoResumeDelay := 30;

  // 재시도 타이머
  FRetryTimer := TTimer.Create(nil);
  FRetryTimer.Enabled := False;
  FRetryTimer.OnTimer := RetryTimerEvent;

  // 자동 재개 타이머
  FResumeTimer := TTimer.Create(nil);
  FResumeTimer.Enabled := False;
  FResumeTimer.OnTimer := ResumeTimerEvent;
end;

destructor TAutoOrderManager.Destroy;
begin
  FRetryTimer.Free;
  FResumeTimer.Free;
  inherited;
end;

procedure TAutoOrderManager.SetState(Value: TOrderState);
var
  OldState: TOrderState;
begin
  if FState <> Value then
  begin
    OldState := FState;
    FState := Value;
    if Assigned(FOnStateChange) then
      FOnStateChange(Self, OldState, Value);
  end;
end;

procedure TAutoOrderManager.ApplySettings(const ASettings: TOrderSettings);
begin
  FSettings := ASettings;
  FRetryTimer.Interval := FSettings.RetryInterval * 1000;
  FResumeTimer.Interval := FSettings.AutoResumeDelay * 1000;
end;

function TAutoOrderManager.GetSettings: TOrderSettings;
begin
  Result := FSettings;
end;

procedure TAutoOrderManager.DoSendOrder;
begin
  SetState(osOrdering);
  if Assigned(FOnSendOrder) then
    FOnSendOrder(Self);
end;

procedure TAutoOrderManager.StartOrder;
begin
  FRejectCount := 0;
  FRetryTimer.Enabled := False;
  FResumeTimer.Enabled := False;
  DoSendOrder;
end;

procedure TAutoOrderManager.OnOrderAccepted;
begin
  // 체결 성공 - 카운터 리셋, 대기 상태로
  FRejectCount := 0;
  FRetryTimer.Enabled := False;
  FResumeTimer.Enabled := False;
  SetState(osIdle);
end;

procedure TAutoOrderManager.OnOrderRejected;
begin
  Inc(FRejectCount);

  if Assigned(FOnReject) then
    FOnReject(Self, FRejectCount);

  // 연속 거부 횟수 초과?
  if FRejectCount >= FSettings.MaxRejectCount then
  begin
    // 일시 중지
    FRetryTimer.Enabled := False;
    SetState(osPaused);

    if Assigned(FOnPaused) then
      FOnPaused(Self);

    // 자동 재개 모드면 타이머 시작
    if FSettings.ResumeMode = rmAuto then
    begin
      FResumeTimer.Interval := FSettings.AutoResumeDelay * 1000;
      FResumeTimer.Enabled := True;
    end;
  end
  else
  begin
    // 재시도 대기
    SetState(osWaitRetry);
    FRetryTimer.Interval := FSettings.RetryInterval * 1000;
    FRetryTimer.Enabled := True;
  end;
end;

procedure TAutoOrderManager.RetryTimerEvent(Sender: TObject);
begin
  FRetryTimer.Enabled := False;
  DoSendOrder;
end;

procedure TAutoOrderManager.ResumeTimerEvent(Sender: TObject);
begin
  FResumeTimer.Enabled := False;
  FRejectCount := 0;

  if Assigned(FOnResumed) then
    FOnResumed(Self);

  DoSendOrder;
end;

procedure TAutoOrderManager.ManualResume;
begin
  if FState = osPaused then
  begin
    FResumeTimer.Enabled := False;
    FRejectCount := 0;

    if Assigned(FOnResumed) then
      FOnResumed(Self);

    DoSendOrder;
  end;
end;

procedure TAutoOrderManager.Stop;
begin
  FRetryTimer.Enabled := False;
  FResumeTimer.Enabled := False;
  FRejectCount := 0;
  SetState(osIdle);
end;

end.
