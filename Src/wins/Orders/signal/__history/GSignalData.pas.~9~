unit GSignalData;

interface

uses
  System.SysUtils, System.Classes, System.SyncObjs, System.Generics.Collections
  , UTypes, UApiTypes, USignalTypes
  , USymbols
  ;

Type

  TSymbolArr = array [TExchangeKind] of TSymbol;

  TStrategy = class
  private
    FCode:    string;
    FBuyQty:  Double;
    FSellQty: Double;
  public
    constructor Create(const ACode: string = '');
    property Code:    string read FCode    write FCode;
    property BuyQty:  Double read FBuyQty  write FBuyQty;
    property SellQty: Double read FSellQty write FSellQty;
  end;

  // 코인코드
  TCoinCode = class
  private
    FCode:       string;
    FSymbols:    TSymbolArr;
    FStrategies: TObjectDictionary<string, TStrategy>;
    function  GetSymbol(AExchange: TExchangeKind): TSymbol;
    procedure SetSymbol(AExchange: TExchangeKind; AValue: TSymbol);
    function  GetStrategyCount: Integer;
  public
    constructor Create(const ACode: string = '');
    destructor  Destroy; override;

    // 전략 CRUD
    function  AddStrategy(AStrategy: TStrategy): Boolean; overload;
    function  AddStrategy(const ACode: string): TStrategy; overload;
    procedure RemoveStrategy(const ACode: string);
    function  GetStrategy(const ACode: string): TStrategy;   // 없으면 nil
    function  HasStrategy(const ACode: string): Boolean;
    function  Strategies: TDictionary<string, TStrategy>.TValueCollection;  // 순회용 스냅샷

    property Code: string read FCode write FCode;
    property Symbols[AExchange: TExchangeKind]: TSymbol
      read GetSymbol write SetSymbol;
    property StrategyCount: Integer read GetStrategyCount;
  end;


  TCoinCodeList = class(TObjectList<TCoinCode>);
  TCoinCodeMap  = class(TObjectDictionary<string, TCoinCode>);

var
   Coins: TCoinCodeMap;


   function AddCoin(const ACode: string): TCoinCode;
   procedure RemoveStrategy(const ACode1, ACode2: string);

implementation

uses
  Math
  ;

procedure Init;
begin
  Coins := TCoinCodeMap.Create([doOwnsValues]);
end;

procedure Fin;
begin
  Coins.Free;
end;


function AddCoin(const ACode: string): TCoinCode;
begin
  if not Coins.TryGetValue(ACode, Result) then
  begin
    Result  := TCoinCode.Create(ACode);
    Coins.Add(ACode, Result);
  end;
end;

procedure RemoveStrategy(const ACode1, ACode2 : string);
var
  ACoin: TCoinCode;
begin
  if Coins.TryGetValue(ACode1, ACoin) then
    ACoin.RemoveStrategy(ACode2);
end;

