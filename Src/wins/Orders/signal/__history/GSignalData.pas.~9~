// 인자외에 다른 코드가 있다면 넘겨줌..
{
function GetCodes(a: TAutoOrderType; const Code: string; var Outs: TArray<string>): boolean;
var
  Pair: TPair<string, TDictionary<string, double>>;
  i: Integer;
begin
  i := 0;
  SetLength(Outs, i);
  for Pair in ReservQty[a] do
    if Code <> Pair.Key then
    begin
      inc(i);
      SetLength(Outs, i);
      Outs[i-1] := Pair.Key;
    end;
end;
   }

{ TStrategy }

constructor TStrategy.Create(const ACode: string);
begin
  inherited Create;
  FCode    := ACode;
  FBuyQty  := 0;
  FSellQty := 0;
end;

{ TCoinCode }

constructor TCoinCode.Create(const ACode: string);
var
  ek: TExchangeKind;
begin
  inherited Create;
  FCode := ACode;
  for ek := Low(TExchangeKind) to High(TExchangeKind) do
    FSymbols[ek] := nil;
  FStrategies := TObjectDictionary<string, TStrategy>.Create([doOwnsValues]);
end;

destructor TCoinCode.Destroy;
begin
  FStrategies.Free;   // doOwnsValues로 전략들도 함께 해제
  inherited;
end;

function TCoinCode.GetSymbol(AExchange: TExchangeKind): TSymbol;
begin
  Result := FSymbols[AExchange];
end;

procedure TCoinCode.SetSymbol(AExchange: TExchangeKind; AValue: TSymbol);
begin
  if FSymbols[AExchange] <> AValue then
  begin
    FSymbols[AExchange] := AValue;
  end;
end;

// 인스턴스 직접 추가 (소유권 이전). 중복 코드면 false, 인자도 해제.
function TCoinCode.AddStrategy(AStrategy: TStrategy): Boolean;
begin
  Result := (AStrategy <> nil) and (not FStrategies.ContainsKey(AStrategy.Code));
  if Result then
    FStrategies.Add(AStrategy.Code, AStrategy)
  else
    AStrategy.Free;   // 중복이면 책임지고 해제 (nil은 안전)
end;

// 코드로 생성 + 추가, 생성된 인스턴스 반환. 중복이면 nil.
function TCoinCode.AddStrategy(const ACode: string): TStrategy;
begin
  if not FStrategies.TryGetValue(ACode, Result) then
  begin
    Result := TStrategy.Create(ACode);
    FStrategies.Add(ACode, Result);
  end;
end;

procedure TCoinCode.RemoveStrategy(const ACode: string);
begin
  FStrategies.Remove(ACode);
end;

function TCoinCode.GetStrategy(const ACode: string): TStrategy;
begin
  if not FStrategies.TryGetValue(ACode, Result) then
    Result := nil;
end;

function TCoinCode.HasStrategy(const ACode: string): Boolean;
begin
  Result := FStrategies.ContainsKey(ACode);
end;

function TCoinCode.Strategies: TDictionary<string, TStrategy>.TValueCollection;
begin
  Result := FStrategies.Values;
end;

function TCoinCode.GetStrategyCount: Integer;
begin
  Result := FStrategies.Count;
end;

initialization
  Init;

finalization
  Fin;

end.
