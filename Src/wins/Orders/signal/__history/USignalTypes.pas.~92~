{ TSignalConfig }

function GetExFee(fs: TMethodType; osCEX, krCEX: TExchangeKind): double;
var  dBaseFee: double;
  exFee: double;
begin

  dBaseFee  := GetBaseFee;

  with  App.Engine do
    case fs of
      mtF: exFee := ApiConfig.GetFee(osCEX, eaFutUsdt, scUSDT, ftMaker) +
                    ApiConfig.GetFee(krCEX, eaSpot,    scKrw,  ftTaker);
      // 국내 Maker  해외 Taker
      mtS: exFee := ApiConfig.GetFee(osCEX, eaFutUsdt, scUSDT, ftTaker) +
                    ApiConfig.GetFee(krCEX, eaSpot,    scKrw,  ftMaker);
    end;

  Result := exFee - dBaseFee;
end;

function EvSignal(const aContent: TRqContent) : TEngineEvent;
begin
  Result.Kind :=  ekSignal;
  Result.EventID  := 0;
  REsult.Signal   := aContent;
end;

function EvQuote(const aSymbol: TSymbol; aEvKind: TEngineEventKind) : TEngineEvent;
begin
  Result.Kind := aEvKind;
  Result.EventID  := 0;
  Result.Book     := aSymbol;
end;

function EvOrder(const aOrder: TOrder; iEvent: integer) : TEngineEvent;
begin
  Result.Kind := ekOrderUpdate;
  Result.EventID  := iEvent;
  Result.Order    := aOrder;
end;

function EvFill(const aFill: TFill; iEvnet: integer) : TEngineEvent;
begin
  Result.Kind := ekFill;
  Result.EventID  := iEvnet;
  Result.Fill   := aFill;
end;

function GetBaseFee: double;
begin
  Result := App.Engine.ApiConfig.GetFee(ekBinance,eaFutUsdt,scUSDT, ftMaker) +
            App.Engine.ApiConfig.GetFee(ekUpbit,  eaSpot,   scKrw,  ftTaker);
end;

function GetKip(dJa, dMo, dEx: double): double;
var
  dF, dS: double;
begin
  if ((dEx * dMo) <= EPSILON) or (dJa <= EPSILON) then
    Exit (WRONG_VALUE);

  Result := ((dJa / (dMo * dEx)) -1) * 100;
end;

function GetFS(e: TExchangeKind): TMethodType;
begin
  case e of
    ekBinance: Result := F;
    else Result := S;
  end;
end;

procedure TSignalConfig.Assign(const sc: TSignalConfig);
var
  i: TMethodType;
begin
  StgCode := sc.StgCode;
  for i := mtF to High(TMethodType) do
  begin
//    Input[i].Delay    := sc.Input[i].Delay;
    Input[i].OrderQty := sc.Input[i].OrderQty;
    Input[i].VolRate  := sc.Input[i].VolRate;
  end;

  Method  := sc.Method;

  TradeTotQty := sc.TradeTotQty;

//  DelayKipMin := sc.DelayKipMin;
//  DelayKip    := sc.DelayKip;
  KipAdjust   := sc.KipAdjust;
end;

procedure TSignalConfig.init;
var
  I: TMethodType;
begin
  StgCode := '';

  for I := mtF to high(TMethodType) do
  begin
//    Input[i].Delay    := 1;
    Input[i].OrderQty := 0;
    Input[i].VolRate  := 80;
  end;

  Method  := 0;

  KipAdjust   := 0;
//  DelayKipMin := 240;
//  DelayKip    := 0;

  TradeTotQty := 0;
end;

function TSignalConfig.MaxOrderQty: double;
begin
  Result := Max(Input[mtF].OrderQty, Input[mtS].OrderQty);
end;

procedure TSignalConfig.SetBaseKip(const E, X: double);
begin
  BaseKip[aoEntry]  := E;
  BaseKip[aoExit]   := X;
end;

{ TRqContent }

procedure TRqContent.CopyData(const src: TRqContent);
begin
  Time    := src.Time;
  Content := src.Content;
  Result  := src.Result;

  StgName := src.StgName;
  SigTime := src.SigTime;
  SigType := src.SigType;
  SigKimp := src.SigKimp;
end;

constructor TRqContent.Create(bRes: boolean; AStr: string);
begin
  Result  := bRes;
  Content := AStr;
  Time   := now;
end;

{ TRqContents }

constructor TRqContents.Create;
begin
  inherited Create(TRqContent);
end;

destructor TRqContents.Destroy;
begin

  inherited;
end;

function TRqContents.GetContents(i: integer): TRqContent;
begin
  if (i < 0) or (i >= Count) then
    Result := nil
  else
    REsult := Items[i] as TRqContent;
end;

function TRqContents.New(id: int64): TRqContent;
begin
  Result  := Add as TRqContent;
  Result.TID  := id;
  Result.Time := now;
end;

{ TSignalData }

procedure TSignalData.AddVolume(dVol: double);
begin
  F_AccVol  := F_AccVol + dVol;
end;

procedure TSignalData.Clear;
begin
  BaseKip := 0;

  F_AccVol:= 0;
  F_AvgKip:= 0;
  CalcKip[mtF] := 0;
  CalcKip[mtS] := 0;

  SetRKip(mtF, ekBinance, 0);
  SetRKip(mtF, ekUpbit, 0);
  SetRKip(mtF, ekBithumb, 0);

  SetRKip(mtS, ekBinance, 0);
  SetRKip(mtS, ekUpbit, 0);
  SetRKip(mtS, ekBithumb, 0);
end;


procedure TSignalData.SetBaseKip(const b: double);
begin
  BaseKip := b;
end;

procedure TSignalData.SetRKip(fs:TMethodType; e:TExchangeKind; const value: double);
begin
  Rkip[fs, e] := value;
end;

