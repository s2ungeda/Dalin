{ TOrderRange }

procedure TOrderRange.Assign(const src: TOrderRange);
begin
  MinPrice  := src.MinPrice;
  MaxPrice  := src.MaxPrice;
  TmpPrice  := src.TmpPrice;

  EstPrice  := src.EstPrice;
  ExRate    := src.ExRate;
  CKip      := src.CKip;
end;

class function TOrderRange.New: TOrderRange;
begin
  Result.OrdPrice := 0;
  Result.MaxPrice := 0;
  Result.MinPrice := 0;
  Result.TMpPrice := 0;
end;

function TOrderRange.Represent: string;
begin
  Result := Format('%s - Min : %s, Max : %s, Prc : %s (%s)  (%s, %.2f, %.2f) ', [ ExKind,
    DoubleToSTr(MinPrice),  DoubleToSTr(MaxPrice), DoubleToSTr(OrdPrice),  DoubleToSTr(TMpPrice),
    DoubleToSTr(EstPRice),  ExRate, CKip
  ]);
end;

