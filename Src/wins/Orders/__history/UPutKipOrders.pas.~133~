procedure TPutKipOrderItem.GetShortOrderPrice;
var
  aSCType :TSymbolCountryType;
  dKip, dStartPrice, dPrice, dLimitPrice : double;
  bFind : boolean;
begin

  aSCType := TSymbolCountryType(ifThen(FIsEntry, 1, 0));

  if not GetKip(dKip) then Exit;

  dStartPrice := FSymbols[aSCType].Bids[0].Price;
  if FIsEntry then
    dPrice    := FEstPrice[ptLong] / (dKip / 100 + 1) / App.Engine.ApiManager.ExRate.Value
  else
    dPrice    := (FEstPrice[ptLong] * App.Engine.ApiManager.ExRate.Value) * (dKip / 100 + 1) ;

  if CmpVal(dPrice, dStartPrice) <= 0  then
  begin
    // ИХЕЕ 1ШЃАЁ КИДй ХЉДйИщ...ИХЕЕ1ШЃАЁ - 1Tick
    FOrdPrice[ptShort] := TicksFromPrice(FSymbols[aSCType], dStartPrice, 1);
    Exit;
  end;

  dLimitPrice := dStartPrice * (1 + 10 / 100);

  bFind := false;
  // dStartPrice ~ dLimitPrice ЛчРЬПЁ СжЙЎ АЁАнРЛ БИЧбДй.
  // dStartPrice <= dPrice < dLimitPrice
  if (CmpVal(dPrice, dLimitPrice ) < 0 ) and (CmpVal(dStartPrice, dPrice) <= 0) then
    while CmpVal(dStartPrice, dLimitPrice) < 0 do
    begin
      if CmpVal(dStartPrice, dPrice) >= 0 then
      begin
        bFind := true;
        break;
      end;
      dStartPrice  := TicksFromPrice(FSymbols[aSCType], dStartPrice, 1 );
    end;
  FOrdPrice[ptShort]  := ifThenFloat( bFind, dStartPrice, 0 );
  FCalcPrice[ptShort] := dPrice;
end;

  // СјРд - БЙГЛ ИХМі Ord , ЧиПм ИХЕЕ Est
  //      - ЧиПм ИХЕЕ Ord , БЙГЛ ИХМі Est
  // УЛЛъ - БЙГЛ ИХЕЕ ord , ЧиПм ИХМі Est
  //      - ЧиПм ИХМі Ord , БЙГЛ ИХЕЕ Est

procedure TPutKipOrderItem.ProcessOrder( EstSymbol : TSymbol; EstType : TPositionType;
  bEstCheck : boolean; OrdSymbol: TSymbol; OrdType : TPositionType);
  var
    iSide : Integer;
begin

  if EstType = ptLong then
    iSide := 1
  else
    iSide := -1;

  FEstPrice[EstType]  :=   EstSymbol.CalcEstPrice(iSide, KipData.OrderQty);

  if bEstCheck then
    if CheckZero(FEstPrice[EstType]) then
    begin
      CheckEstPrice(OrdType);
      Exit;
    end;

  if OrdType = ptLong then
    GetLongOrderPrice
  else
    GetShortOrderPrice;

  if OrdSymbol = FSymbols[scInter] then
    if not CheckPriceRange then
    begin
      DoLog('СжЙЎАЁАн ЙќРЇ РЬЛѓ');
      if Assigned(FOnKipNotify) then
        FOnKipNotify(Self, RANG_STR );
      Exit;
    end;

  if not CheckZero(FOrdPrice[OrdType]) then CheckOrder(OrdType);
end;


  {
     СјРд
     ЧиПм НУММ ->  БЙГЛ ИХМі Est - >           -> ЧиПм ИХЕЕ Ord -> Check Ord   Side : A
                   ЧиПм ИХЕЕ Est - > Check Est -> БЙГЛ ИХМі Ord -> Check Ord   Side : B
     БЙГЛ НУММ ->  БЙГЛ ИХМі Est - > Check Est -> ЧиПм ИХЕЕ Ord -> Check Ord   Side : A
                   ЧиПм ИХЕЕ Est - >           -> БЙГЛ ИХМі Ord -> Check Ord   Side : B

     УЛЛъ
     ЧиПм НУММ ->  ЧиПм ИХМі Est - > Check Est -> БЙГЛ ИХЕЕ Ord -> Check Ord   Side : A
                   БЙГЛ ИХЕЕ Est - >           -> ЧиПм ИХМі Ord -> Check Ord   Side : B
     БЙГЛ НУММ ->  ЧиПм ИХМі Est - >           -> БЙГЛ ИХЕЕ Ord -> Check Ord   Side : A
                   БЙГЛ ИХЕЕ Est - > Check Est -> ЧиПм ИХМі Ord -> Check Ord   Side : B


     est СОИё, ord СОИё, Check Est ПЉКЮ, est type,  ord type,

  }

procedure TPutKipOrderItem.OnQuote(aSymbol : TSymbol; bOS: boolean);
begin
  if FCount >= (FKipData.RepeatCnt + 1) then Exit;

  if App.Engine.ApiManager.ExRate.Value <= 1 then
  begin
    // И№Еч СжЙЎ УыМв...
    Exit;
  end;

  if FIsEntry then begin
    if bOS then begin
      case FKipData.Side of
        0 : begin
          ProcessOrder(FSymbols[scDomes], ptLong, false, FSymbols[scInter], ptShort);
          ProcessOrder(FSymbols[scInter], ptShort, true, FSymbols[scDomes], ptLong);
        end;
            // БЙГЛ ИХМі Est - >           -> ЧиПм ИХЕЕ Ord -> Check Ord   Side : A
        1 : ProcessOrder(FSymbols[scDomes], ptLong, false, FSymbols[scInter], ptShort);
            // ЧиПм ИХЕЕ Est - > Check Est -> БЙГЛ ИХМі Ord -> Check Ord   Side : B
        2 : ProcessOrder(FSymbols[scInter], ptShort, true, FSymbols[scDomes], ptLong);
      end;
    end else
    begin
      case FKipData.Side of
        0 : begin
          ProcessOrder(FSymbols[scDomes], ptLong, true, FSymbols[scInter], ptShort);
          ProcessOrder(FSymbols[scInter], ptShort, false, FSymbols[scDomes], ptLong);
        end;
           //  БЙГЛ ИХМі Est - > Check Est -> ЧиПм ИХЕЕ Ord -> Check Ord   Side : A
        1 : ProcessOrder(FSymbols[scDomes], ptLong, true, FSymbols[scInter], ptShort);
           //  ЧиПм ИХЕЕ Est - >           -> БЙГЛ ИХМі Ord -> Check Ord   Side : B
        2 : ProcessOrder(FSymbols[scInter], ptShort, false, FSymbols[scDomes], ptLong);
      end;
    end;
  end else begin
    if bOS then begin
      case FKipData.Side of
        0 : begin
          ProcessOrder(FSymbols[scInter], ptLong, true, FSymbols[scDomes], ptShort);
          ProcessOrder(FSymbols[scDomes], ptShort, false, FSymbols[scInter], ptLong);
        end;
          // ЧиПм ИХМі Est - > Check Est -> БЙГЛ ИХЕЕ Ord -> Check Ord   Side : A
        1 : ProcessOrder(FSymbols[scInter], ptLong, true, FSymbols[scDomes], ptShort);
          // БЙГЛ ИХЕЕ Est - >           -> ЧиПм ИХМі Ord -> Check Ord   Side : B
        2 : ProcessOrder(FSymbols[scDomes], ptShort, false, FSymbols[scInter], ptLong);
      end;
    end else
    begin
      case FKipData.Side of
        0 : begin
          ProcessOrder(FSymbols[scInter], ptLong, true, FSymbols[scDomes], ptShort);
          ProcessOrder(FSymbols[scDomes], ptShort, false, FSymbols[scInter], ptLong);
        end;
          // ЧиПм ИХМі Est - >           -> БЙГЛ ИХЕЕ Ord -> Check Ord   Side : A
        1 : ProcessOrder(FSymbols[scInter], ptLong, true, FSymbols[scDomes], ptShort);
          // БЙГЛ ИХЕЕ Est - > Check Est -> ЧиПм ИХМі Ord -> Check Ord   Side : B
        2 : ProcessOrder(FSymbols[scDomes], ptShort, false, FSymbols[scInter], ptLong);
      end;
    end;
  end;

  Exit;



  GetLongOrderPrice;
  GetShortOrderPrice;

  if not CheckPriceRange then
  begin
    DoLog('СжЙЎАЁАн ЙќРЇ РЬЛѓ');
    if Assigned(FOnKipNotify) then
      FOnKipNotify(Self, RANG_STR );
    Exit;
  end;
  // ЧиПм НУММ -> СјРд ИХЕЕ,  УЛЛъ ИХМі УМХЉ
  // БЙГЛ НУММ -> СјРд ИХМі,  УЛЛъ ИХЕЕ УМХЉ
  case FKipData.Side of
   0 : begin
        if not CheckZero(FOrdPrice[ptShort]) then
          CheckOrder(ptShort);
        if not CheckZero(FOrdPrice[ptLong]) then
          CheckOrder(ptLong);
      end;
   1 : if not CheckZero(FOrdPrice[ptShort]) then CheckOrder(ptShort);
   2 : if not CheckZero(FOrdPrice[ptLong]) then CheckOrder(ptLong);
  end;

end;

