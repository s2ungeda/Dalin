function TPutKipOrderItem.DoOrder(aSCType: TSymbolCountryType;
  const iSide: integer; const dPrice, dQty: double): TOrder;
begin
  Result := nil;

  Result := App.Engine.TradeCore.Orders[ FSymbols[aSCType].Spec.ExchangeType ].NewOrder(
        FAccounts[aSCType], FSymbols[aSCType], iSide, dQty, pcLimit, dPrice, tmGTC
      );

  if Result = nil then Exit;

  Result.GroupNo  := FName;
  Result.StgType  := stPutKipOrder;
  Result.Tag      := LIQ_ORD;

  App.Engine.TradeBroker.Send(Result);

  TPutKipOrders( Collection ).SetTime;

  DoLog(Format('%s Hit СжЙЎ %s | %s', [ EntryToStr, Result.RepresentWithEx,
    Result.Symbol.PriceToStr( ifThenFloat(iSide > 0, Result.Symbol.Bids[0].Price, Result.Symbol.Asks[0].Price)) ] ));

  DebugLog(1);
end;

procedure TPutKipOrderItem.DoOrder(aType: TPositionType);
var
  aOrder : TOrder;
  bAble  : boolean;
  stLog  : string;

  aAcnt : TAccount;
  aSymbol : TSymbol;
  dPrice, dEstPrice  : double;
  iSide  : integer;
  tmVal  : TTimeInForce;
begin

  if TPutKipOrders( Collection ).IsWaiting then Exit;

  stLog := 'СжЙЎАЁДЩБнОз';

  bAble := false;
  if FIsEntry then begin
    if aType = ptLong then begin
      // ЧиПмТЪ ИХЕЕ АЁДЩЧбСі УМХЉ..
      bAble := CheckBalance_Os(ptShort, true);
      if bAble then
        bAble := CheckBalance_KrBid(false);
    end else
    begin
      // БЙГЛ ИХМі АЁДЩЧбСі УМХЉ
      bAble :=  CheckBalance_KrBid(true);
      if bAble then
        bAble := CheckBalance_Os(aType, false);
    end;
  end else begin
    if aType = ptLong then begin
      // БЙГЛ ИХЕЕ АЁДЩЧбСі УМХЉ
      bAble := CheckBalance_KrAsk;
      if bAble then
        bAble := CheckBalance_Os(aType, false);
    end else
    begin
      // ЧиПм ИХМі АЁДЩЧбСі УМХЉ
      bAble := CheckBalance_Os(ptLong, true);
      if bAble then
        bAble := CheckBalance_KrAsk;
      stLog := 'РмАэ';
    end;
  end;

  if not bAble then
  begin
    //DoLog( Format('%s %s %s КЮСЗ', [ EntryToStr, ifThenStr(aType = ptLong, 'ИХМі', 'ИХЕЕ'), stLog ]));
    if Assigned(FOnKipNotify) then
      FOnKipNotify(Self, BAL_STR);
    Exit;
  end;


  if FIsEntry then
  begin

    if aType = ptLong then begin
      aAcnt   := FAccounts[scDomes];
      aSymbol := FSymbols[scDomes];
      dPrice  := FOrdPrice[ptLong];
      dEstPrice := FEstPrice[ptShort];
      iSide   := 1;
      tmVal   := tmGTC;
    end else begin
      aAcnt   := FAccounts[scInter];
      aSymbol := FSymbols[scInter];
      dPrice  := FOrdPrice[ptShort];
      dEstPrice := FEstPrice[ptLong];
      iSide   := -1;
      tmVal   := tmGTX;
    end;

  end else
  begin

    if aType = ptShort then begin
      aAcnt   := FAccounts[scDomes];
      aSymbol := FSymbols[scDomes];
      dPrice  := FOrdPrice[ptShort];
      dEstPrice := FEstPrice[ptLong];
      iSide   := -1;
      tmVal   := tmGTC;
    end else begin
      aAcnt   := FAccounts[scInter];
      aSymbol := FSymbols[scInter];
      dPrice  := FOrdPrice[ptLong];
      dEstPrice := FEstPrice[ptShort];
      iSide   := 1;
      tmVal   := tmGTX;
    end;
  end ;

  if (aAcnt = nil) or (aSymbol = nil) then Exit;

  if not App.Engine.TradeCore.CheckLimitOrder( aAcnt, aSymbol, iSide, dPrice, FKipData.OrderQty, ORD_AUTO) then
  begin
    DoLog( '=========== АјХы ИЎНКХЉ СІЧбПЁ АЩИВ ===============', true );
    if Assigned(FOnKipNotify) then
      FOnKipNotify(Self, RSK_STR);
    Exit;
  end;

  aOrder := App.Engine.TradeCore.Orders[ aSymbol.Spec.ExchangeType ].NewOrder(
    aAcnt, aSymbol, iSide, FKipData.OrderQty, pcLimit, dPrice, tmVal
  );

  aOrder.ReduceOnly := FKipData.ReduceOnly;

  if (aOrder<> nil) then
  begin

    KipItem[aType].SetOrder(aOrder);
    aOrder.StgType   := stPutKipOrder;
    aOrder.GroupNo   := FName;
    aOrder.Tag       := PUT_ORD;

    App.Engine.TradeBroker.Send( aOrder );
//    FFirstOrder := true;
//    inc( FCount );
    // СжИЃИЃ СжЙЎ ГЊАЁДТАЭРЛ ИЗБт РЇЧи..ИЖСіИЗ СжЙЎ НУАЃРЛ МТЦУ.
    TPutKipOrders( Collection ).SetTime;

    if Assigned(FOnKipNotify) then
      FOnKipNotify(Self, ORD_STR);

    DoLog( Format('%s Put СжЙЎ %s (%.2f) - %s, %s', [ ifThenStr( FIsEntry,'СјРд','УЛЛъ'),
      aOrder.SideToStr, FKipData.Kip, aOrder.RepresentWithEx ,
      aSymbol.PriceToStr(ifThenFloat(atype=ptLong, aSymbol.Bids[0].Price, aSymbol.Asks[0].Price))] ) );

    DebugLog(0);
  end;

end;

