              DoLog('--------------- УЛЛъ СжЙЎ НЧЦа !!!----------------');
            end else
            begin
              KipItem[aType].LiqOrds.Add(rOrder);
            end;
          end;

        end else
        begin
          // УЛЛъСжЙЎ?.

        end;
      end;
  end;

  // kip report
  // УМАс ХыСі(УыМвХыСі РЯЖЇ КЮКаУМАсРЬ РжДйИщ ЛѓХТДТ osFilled) РЬАэ ДыГѕРК СжЙЎ ЛѓХТАЁ osFilled РЯЖЇ
