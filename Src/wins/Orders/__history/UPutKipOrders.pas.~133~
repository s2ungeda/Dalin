procedure TPutKipOrderItem.IsDone(aType2 : TPositionType);
var
  aOType : TAutoOrderType;
  dPrice, dFillQty : double;
  aSymbol  : Tsymbol;

begin
  if not KipItem[aType2].IsDone then Exit;

  DoLog(Format('------------ %d.th  %s %s %s РќЗЎ УМАс-------------- %s', [
    FCount, EntryTostr, ifThenStr(aType2 = ptLong, 'ИХМі', 'ИХЕЕ'),
    ifThenStr(KipItem[aType2].Order.Tag = PUT_ORD, 'PUT','HIT'),
    KipItem[aType2].RsltStr ]) );
  // РќЗЎ УМАс НУ report
  aoType  := GetAOType;
  KipItem[aType2].CalcFillAvgKip;

  dPrice  := 0;
  if FSymbols[scDomes] <> nil then
  begin
    aSymbol := App.Engine.SymbolCore.Tethers[FSymbols[scDomes].Spec.ExchangeType];
    if aSymbol <> nil then
      dPrice := ifThenFloat(FIsEntry, aSymbol.Bids[0].Price, aSymbol.Asks[0].Price);
  end;

  KipItem[aType2].CalcIdxPk(dPrice);

  with (Collection as TPutKipOrders) do
  begin
//    KipReport[aoType].KipFillAvg.KipFill    := KipReport[aoType].KipFillAvg.KipFill + (KipItem[aType2].Kip * KipItem[aType2].Order.FilledQty);
//    KipReport[aoType].KipFillAvg.FilledQty  := KipReport[aoType].KipFillAvg.FilledQty + KipItem[aType2].Order.FilledQty;

    // УМАсТїАЁ ЙпЛ§ЧвМі РжРИЙЧЗЮ ЧзЛѓ РлРКГбРЛ ЛчПыЧбДй.
    dFillQty := min(KipItem[aType2].Order.FilledQty,  KipItem[aType2].FilledQty);
    KipReport[aoType].KipFillAvg.KipFill    := KipReport[aoType].KipFillAvg.KipFill + (KipItem[aType2].Kip * dFillQty);
    KipReport[aoType].KipFillAvg.FilledQty  := KipReport[aoType].KipFillAvg.FilledQty + dFillQty;

    DoLog( Format('[%.2f] %s УМАс -> %.2f(%.4n|%.4n), %.2f, (%.8f | %.8f) ', [ FKipData.Kip, EntryToStr,
      CalcDiv(KipReport[aoType].KipFillAvg.KipFill, KipReport[aoType].KipFillAvg.FilledQty),
      KipReport[aoType].KipFillAvg.KipFill, KipReport[aoType].KipFillAvg.FilledQty,
      KipItem[aType2].Kip, KipItem[aType2].Order.FilledQty, KipItem[aType2].FilledQty ]) );
  end;

  DebugLog(2);

  if Assigned(FOnKipDoneNotify) then
    FOnKipDoneNotify(KipItem[aType2]);

  inc(FCount);

  if Assigned(FOnKipNotify) then
    FOnKipNotify(Self, ORD_STR );

  if FCount < (FKipData.RepeatCnt + 1) then begin
    FillTimer[aType2].Enabled := true;
  end
  else begin
    ClearOrders;
    if Assigned(FOnKipNotify) then
      FOnKipNotify(Self, DONE_STR );
  end;
end;

