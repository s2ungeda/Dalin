procedure TPutKipOrderItem.CalclEstPrice(bOS: boolean);
begin
  if bOS then begin
    if FIsEntry then begin     // БЙГЛ ИХМіАЁИІ БИЧЯБт РЇЧи ЧиПм ИХЕЕ EstPrice
      FEstPrice[ptShort] := FSymbols[scInter].CalcEstPrice(-1, KipData.OrderQty);
    end
    else begin                 // БЙГЛ ИХЕЕАЁИІ БИЧЯБт РЇЧи ЧиПм ИХМі EstPrice
      FEstPrice[ptLong]  := FSymbols[scInter].CalcEstPrice(1, KipData.OrderQty);
    end;
  end else
  begin
    if FIsEntry then begin     // СјРд ИХЕЕ
      FEstPrice[ptLong] := FSymbols[scDomes].CalcEstPrice(1, KipData.OrderQty);
    end
    else begin                 // УЛЛъ ИХМі
      FEstPrice[ptShort]:= FSymbols[scDomes].CalcEstPrice(-1, KipData.OrderQty);
    end;
  end;
end;

function TPutKipOrderItem.CheckPriceRange: boolean;
var
  dMPrice : double;
  iVal : integer;
begin
  Result := false;
  if FIsEntry then
  begin
    // ЙйРЬГННК ИХЕЕ СжЙЎРЬ ГЪЙЋ ГЗРКСі УМХЉ
    if CmpVal(FOrdPrice[ptShort], (FSymbols[scInter] as TFuture).MarkPrice * FSymbols[scInter].Spec.MultiplierDown) < 0 then
    begin
      DoLog(Format('ИХЕЕСжЙЎАЁАнРЬ%s < %s (%s, %s%%) КИДй ГЗРН', [FSymbols[scInter].PriceToStr(FOrdPrice[ptShort]),
        FSymbols[scInter].PriceToStr((FSymbols[scInter] as TFuture).MarkPrice * FSymbols[scInter].Spec.MultiplierDown),
        FSymbols[scInter].PriceToStr((FSymbols[scInter] as TFuture).MarkPrice),
        FSymbols[scInter].QtyToStr(FSymbols[scInter].Spec.MultiplierDown)
        ]));
      Exit;
    end;

  end else
  begin
    if CmpVal(FOrdPrice[ptLong], (FSymbols[scInter] as TFuture).MarkPrice * FSymbols[scInter].Spec.MultiplierUp) > 0 then
    begin
      DoLog(Format('ИХМіСжЙЎАЁАнРЬ%s > %s (%s, %s%%) КИДй ГєРН', [ FSymbols[scInter].PriceToStr(FOrdPrice[ptLong]),
        FSymbols[scInter].PriceToStr((FSymbols[scInter] as TFuture).MarkPrice * FSymbols[scInter].Spec.MultiplierUp),
        FSymbols[scInter].PriceToStr((FSymbols[scInter] as TFuture).MarkPrice),
        FSymbols[scInter].QtyToStr(FSymbols[scInter].Spec.MultiplierUp)
        ]));
      Exit;
    end;
  end;

  Result := true;
end;

function TPutKipOrderItem.CheckBalance: boolean;
var
  aAsset : array [TSymbolCountryType] of TAsset;
  dAmt, dAmt2, dQty, dQty2, dOrderQty, dFee, dAvailable, dOrderAmt : double;
  aPos   : TPosition;
  aAcnt  : TAccount;
  res : TValueRelationship;
  stLog : string;
  aSpItem : TSPObject;
  iLeverage : integer;
  dBalance : array [TSymbolCountryType] of double;
begin

  Result := false;

  try
     // БЙГЛ ПјШ­...ЙйРЬГННК usdt
    if ( FAccounts[scDomes].Asset = nil ) or ( FAccounts[scInter].Asset = nil )
      or ( TPutKipOrders(Collection).Positions[scInter] = nil )
      then Exit (false);

    dBalance[scDomes] := FAccounts[scDomes].Balance;
    dBalance[scInter] := FAccounts[scInter].Balance;

    if FIsEntry then
    begin
      // СжЙЎАЁДЩБнОз БИЧЯБт
      with App.Engine.TradeCore.Orders[FAccounts[scDomes].ExchangeKind] do
        dAmt := GetAcceptOrderAmt(FAccounts[scDomes], 1) +
                GetUnAcceptOrderAmt(FAccounts[scDomes], 1);

      dFee:= App.Engine.ApiConfig.ExchangeInfo[integer(FAccounts[scDomes].ExchangeKind)].ApiInfo[FSymbols[scDomes].Spec.ExApiType].TradeFee;
      // ГЊАЁОпЧв ИХМі СжЙЎРЬ РжДТ ЦФОЧ( sp УЛЛъ СжЙЎ )
      aSpItem := App.Engine.StgManager.SPObject.Find( FSymbols[scDomes].Spec.ExchangeType, FSymbols[scDomes].Code );
      dQty := 0.0;  dAmt2 := 0.0;
      if aSpItem <> nil then begin
        aAcnt := App.Engine.TradeCore.FindAccount(aSpItem.SubEx);
        with App.Engine.TradeCore.Orders[aSpItem.SubEx] do
        begin
          dQty := GetActiveOrderQty(aAcnt, stSPOrder, -1) +
                  GetUnActiveOrderQty(aAcnt, stSPOrder, -1);
          dAmt2 := (dQty * FOrdPrice[ptLong] )*(1+(dFee/100));
        end;
      end;

      //dAvailable  := FAccounts[scDomes].Asset.Balance - dAmt - dAmt2;
      dAvailable  := dBalance[scDomes] - dAmt - dAmt2;
      dOrderAmt := (FKipData.OrderQty * FOrdPrice[ptLong])*(1+(dFee/100)) ;
      res  := CompareValue( dAvailable, dOrderAmt );
      if res <= 0 then
      begin
  //      stLog := '-40';//'УЛЛъ : СжАХЗЁМв СжЙЎАЁДЩ БнОз КЮСЗ';
        Exit (false);
      end;

      stLog := Format('СјРд : %s ИХМіАЁДЩБнОз -> %.0n < %.0n ( %.0n - %.0n - %.0n )', [ ExKindToStr(FAccounts[scDomes].ExchangeKind),
        dOrderAmt, dAvailable, dBalance[scDomes], dAmt, dAmt2] );

      // ЦђАЁМеРЭ
      dAmt  := App.Engine.TradeCore.Positions[FAccounts[scInter].ExchangeKind].GetOpenPL( FAccounts[scInter] );
      // ИЖСј
      dAmt2 := App.Engine.TradeCore.Positions[FAccounts[scInter].ExchangeKind].GetTotInitMargin(FAccounts[scInter]);

      //dAvailable:= FAccounts[scInter].Asset.Balance + dAmt - dAmt2;
      dAvailable:= dBalance[scInter] + dAmt - dAmt2;
      dFee:= App.Engine.ApiConfig.ExchangeInfo[ integer(FAccounts[scInter].ExchangeKind) ].ApiInfo[FSymbols[scInter].Spec.ExApiType].TradeFee;
      iLeverage := ifThen(TPutKipOrders(Collection).Positions[scInter].Leverage <= 0, 1, TPutKipOrders(Collection).Positions[scInter].Leverage );
      dOrderAmt := ((FKipData.OrderQty * FOrdPrice[ptShort] * FSymbols[scInter].Spec.PointValue) / iLeverage)*(1+(dFee/100)) ;

      res  := CompareValue( dAvailable, dOrderAmt );
      if res <= 0 then
      begin
        Exit (false);
      end;

      DoLog(Format('%s %s ИХЕЕАЁДЩБнОз -> %.4n < %.4n ( %.4n + %.4n - %.4n )', [ stLog, ExKindToStr( FAccounts[scInter].ExchangeKind),
        dOrderAmt, dAvailable, dBalance[scInter], dAmt, dAmt2 ]));

    end else
    begin

      aAsset[scDomes]  := FAccounts[scDomes].Assets.Find( FSymbols[scDomes].Spec.BaseCode);
      if aAsset[scDomes] = nil then Exit;
      if aAsset[scDomes].Balance <= 0 then Exit;
      if TPutKipOrders(Collection).Positions[scInter].Volume >= 0 then Exit;
      // ГЊАЁОпЧв ИХЕЕ СжЙЎРЬ РжДТ ЦФОЧ( sp СјРд СжЙЎ )
      dQty  := 0;   dQty2 := 0;
      aSpItem := App.Engine.StgManager.SPObject.Find( FSymbols[scDomes].Spec.ExchangeType, FSymbols[scDomes].Code );
      if aSpItem <> nil then begin
        aAcnt := App.Engine.TradeCore.FindAccount(aSpItem.SubEx);
        with App.Engine.TradeCore.Orders[aSpItem.SubEx] do
          dQty := GetActiveOrderQty(aACnt, FSymbols[scDomes], 1 ) +
                  GetUnActiveOrderQty(aACnt, FSymbols[scDomes], 1 );
      end;
      // ГЊАЁ РжДТ ИХЕЕ СжЙЎ..
      with App.Engine.TradeCore.Orders[FAccounts[scDomes].ExchangeKind] do
        dQty2:= GetActiveOrderQty(FAccounts[scDomes], FSymbols[scDomes], -1 ) +
                GetUnActiveOrderQty(FAccounts[scDomes], FSymbols[scDomes], -1 );

      dAmt := FKipData.OrderQty + dQty + dQty2;
      res := CompareValue( aAsset[scDomes].Balance, dAmt );
      if res < 0 then
      begin
  //     stLog := '50';
  //        format('СјРд : СжАХЗЁМв ИХМі РмАэ КЮСЗ %4n < %.4n + %.4n + %.4n)', [
  //         aAsset.Balance, dOrderQty, dQty, dQty2   ]);
        Exit;
      end;

      stLog := Format('УЛЛъ : %s ИХМіРмАэ %.4n > %.4n (%.4n + %.4n + %.4n)', [ ExKindToStr(FAccounts[scInter].ExchangeKind),
        aAsset[scDomes].Balance, dAmt, FKipData.OrderQty, dQty, dQty2 ]);

      //dQty  := abs(TPutKipOrders(Collection).Positions[scInter].Volume);

      with App.Engine.TradeCore.Orders[FAccounts[scInter].ExchangeKind] do
        dQty  := GetActiveOrderQty(FAccounts[scInter], FSymbols[scInter], -1 ) +
                GetUnActiveOrderQty(FAccounts[scInter], FSymbols[scInter], -1 );

      dOrderQty := dQty + FKipData.OrderQty;
      res  := CompareValue( abs(TPutKipOrders(Collection).Positions[scInter].Volume), dOrderQty  );
      if res < 0 then
      begin
        Exit;
      end;

      DoLog( Format('%s %s ИХМіРмАэ %.4n > %.4n ( %.4n + %.4n )', [ stLog, ExKindToStr(FAccounts[scInter].ExchangeKind),
        abs(TPutKipOrders(Collection).Positions[scInter].Volume), dOrderQty, dQty,  FKipData.OrderQty ]));

    end;

    Result := true;

  finally
    //if not Result then DoLog(stLog);
  end;

end;

function TPutKipOrderItem.CheckBalance_KrAsk: boolean;
var
  aAsset : TAsset;
  dQty, dQty2, dAmt : double;
  aSpItem : TSPObject;
  aAcnt : TAccount;
begin
  try
    Result := false;
    aAsset  := FAccounts[scDomes].Assets.Find( FSymbols[scDomes].Spec.BaseCode);
    if aAsset = nil then Exit;
    if aAsset.Balance <= 0 then Exit;
    if TPutKipOrders(Collection).Positions[scInter].Volume >= 0 then Exit;
    // ГЊАЁОпЧв ИХЕЕ СжЙЎРЬ РжДТ ЦФОЧ( sp СјРд СжЙЎ )
    dQty  := 0;   dQty2 := 0;
    aSpItem := App.Engine.StgManager.SPObject.Find( FSymbols[scDomes].Spec.ExchangeType, FSymbols[scDomes].Code );
    if aSpItem <> nil then begin
      aAcnt := App.Engine.TradeCore.FindAccount(aSpItem.SubEx);
      with App.Engine.TradeCore.Orders[aSpItem.SubEx] do
        dQty := GetActiveOrderQty(aACnt, FSymbols[scDomes], 1 ) +
                GetUnActiveOrderQty(aACnt, FSymbols[scDomes], 1 );
    end;
    // ГЊАЁ РжДТ ИХЕЕ СжЙЎ..
    with App.Engine.TradeCore.Orders[FAccounts[scDomes].ExchangeKind] do
      dQty2:= GetActiveOrderQty(FAccounts[scDomes], FSymbols[scDomes], -1 ) +
              GetUnActiveOrderQty(FAccounts[scDomes], FSymbols[scDomes], -1 );

    dAmt := FKipData.OrderQty + dQty + dQty2;
    if CmpVal(aAsset.Balance, dAmt) < 0 then
    begin
  //     stLog := '50';

      Exit;
    end;
    Result := true;
  finally
    if not Result then
    if aAsset = nil then
      DoLog(format('%s asset is nil', [FSymbols[scDomes].Spec.BaseCode]),true);
//    else
//      DoLog( format('%s, ИХЕЕ -> Kr Bal РмАэ КЮСЗ %s < %s + sp(%s) + %s | Os РмАэ КЮСЗ %s)', [
//        EntryToStr, DoubleToStr(aAsset.Balance),FKipData.OrderQty.ToString,
//        DoubleToStr(dQty), DoubleToStr(dQty2),
//        DoubleToStr(TPutKipOrders(Collection).Positions[scInter].Volume) ]) );
  end;
end;

function TPutKipOrderItem.CheckBalance_KrBid(bHit : boolean): boolean;
var
  dQty, dQty2, dAmt, dAmt2, dFee, dAvailable, dOrderAmt, dPrice : double;
  aSpItem : TSPObject;
  aAcnt : TAccount;
begin
  Result := false;
  try
    dAvailable := 0;
    dOrderAmt  := 0;    dAmt2 := 0;    dAmt := 0;
    // СжЙЎАЁДЩБнОз БИЧЯБт
    with App.Engine.TradeCore.Orders[FAccounts[scDomes].ExchangeKind] do
      dAmt := GetAcceptOrderAmt(FAccounts[scDomes], 1) +
              GetUnAcceptOrderAmt(FAccounts[scDomes], 1);

    dFee:= App.Engine.ApiConfig.ExchangeInfo[integer(FAccounts[scDomes].ExchangeKind)].ApiInfo[FSymbols[scDomes].Spec.ExApiType].TradeFee;

    if bHit then
      dPrice := FEstPrice[ptLong]
    else
      dPrice := FOrdPrice[ptLong];

    // ГЊАЁОпЧв ИХМі СжЙЎРЬ РжДТ ЦФОЧ( sp УЛЛъ СжЙЎ )
    aSpItem := App.Engine.StgManager.SPObject.Find( FSymbols[scDomes].Spec.ExchangeType, FSymbols[scDomes].Code );
    dQty := 0.0;  dAmt2 := 0.0;
    if aSpItem <> nil then begin
      aAcnt := App.Engine.TradeCore.FindAccount(aSpItem.SubEx);
      with App.Engine.TradeCore.Orders[aSpItem.SubEx] do
      begin
        dQty := GetActiveOrderQty(aAcnt, stSPOrder, -1) +
                GetUnActiveOrderQty(aAcnt, stSPOrder, -1);
        dAmt2 := (dQty * dPrice )*(1+(dFee/100));
      end;
    end;

    dAvailable  := FAccounts[scDomes].Balance - dAmt - dAmt2;
    dOrderAmt := (FKipData.OrderQty * dPrice)*(1+(dFee/100)) ;
    if CmpVal(dAvailable, dOrderAmt) <= 0 then
    begin
  //      stLog := '-40';//'УЛЛъ : СжАХЗЁМв СжЙЎАЁДЩ БнОз КЮСЗ';
      Exit;
    end;
    Result := true;
  finally
    if not Result then
      DoLog( format('Kr Bal : %s, ИХМі, %s | СжЙЎАЁДЩБнОз %s > %s (%s-%s-%s)  )', [
        EntryToStr, ifThenStr(bHit, 'hit', 'put'),
        DoubleToStr(dOrderAmt), DoubleToStr(dAvailable),
        DoubleToStr(FAccounts[scDomes].Balance),
        DoubleToStr(dAmt), DoubleToStr(dAmt2) ]) );
  end;
end;

function TPutKipOrderItem.CheckBalance_Os(aType : TPositionType; bHit : boolean) : boolean;
var
  dAmt, dAvailable, dFee, dOrderAmt, dim, dOrdedQty, dQty, dPrice : double;
  iLeverage, iSide : integer;
  aPos : TPosition;
  bOrder  : boolean;
  stLog   : string;
begin
  Result := false;
  bOrder := false;

  dOrdedQty := 0;
  dOrderAmt := 0;
  dAvailable:= 0;

  try
    aPos := (Collection as TPutKipOrders).Positions[scInter];
    iSide := ifThen(aType = ptLong, 1, -1);

    if aPos <> nil then
    begin
      if FKipData.ReduceOnly then
      begin
        if ((aType = ptLong) and (aPos.Side >= 0)) or
          ((aType = ptShort) and (aPos.Side <= 0)) then Exit;

        if ((aType = ptLong) and (aPos.Side < 0)) or
          ((aType = ptShort) and (aPos.Side > 0)) then Exit (true);
      end else
      begin
        with App.Engine.TradeCore.Orders[FAccounts[scInter].ExchangeKind] do
          dOrdedQty:= GetActiveOrderQty(FAccounts[scInter], FSymbols[scInter], iSide) +
                  GetUnActiveOrderQty(FAccounts[scInter], FSymbols[scInter], iSide);
        // ЙнДыЦїСіМЧ МіЗЎРЬ РжДТСі..
        if aType = ptLong then
        begin
          dQty  := aPos.Volume + dOrdedQty + FKipData.OrderQty;
          if dQty <= 0 then bOrder := true;
        end else
        begin
          dQty  := aPos.Volume - (dOrdedQty + FKipData.OrderQty);
          if dQty >= 0 then bOrder := true;
        end;
      end;
    end;

    if bOrder then
    begin
      // ЙнДы ЦїСіМЧ МіЗЎРЬ СИРч
      Exit (true);
    end else
    begin
      //
      dAvailable:= FAccounts[scInter].Available;
      dFee:= App.Engine.ApiConfig.ExchangeInfo[ integer(FAccounts[scInter].ExchangeKind) ].ApiInfo[FSymbols[scInter].Spec.ExApiType].TradeFee;
      iLeverage := ifThen(aPos.Leverage <= 0, 1, aPos.Leverage );

      if bHit then
        dPrice := FEstPrice[aType]
      else
        dPrice := FOrdPrice[aType];

      dim := FKipData.OrderQty * abs(min(0, iSide *(FSymbols[scInter] as TFuture).MarkPrice - dPrice));
      dAmt := ((FKipData.OrderQty * dPrice * FSymbols[scInter].Spec.PointValue) / iLeverage) + dim;
      if aType = ptShort then
        dAmt := dAmt + (dim / iLeverage);
      dOrderAmt := dAmt *(1 + (dFee / 100)) ;

      if CmpVal(dAvailable, dOrderAmt) <= 0 then
      begin
        Exit ;
      end;
    end;
    Result := true;

  finally

    if not Result  then
    begin
      stLog := Format('OS Bal : %s, %s, %s, %s, %s | P  %s, %s, %s | A %s < %s ',  [ EntryToStr,
        ifThenStr(aType = ptLong, 'ИХМі', 'ИХЕЕ'), ifThenStr(bHit, 'hit', 'put'),
        ifThenStr(FKipData.ReduceOnly, 'Reduce', 'not Re'),
        ifThenStr(bOrder, 'РмАэ', 'БнОз'),
        aPos.SideToStr, DoubleToStr(aPos.Volume),  DoubleToStr(dOrdedQty),
        DoubleToStr(dAvailable),  DoubleToStr(dOrderAmt)  ]) ;

      DoLog(stLog);
    end;
  end;

end;

function TPutKipOrderItem.CheckKipValue(aType: TPositionType): boolean;
var
  dTmp : double;
  dEstPrice : array [TPositionType] of double;
begin
  Result := false;
  try

    if aType = ptLong then begin
      dEstPrice[ptLong]   := KipItem[ptLong].Order.Price;
      dEstPrice[ptShort]  := FEstPrice[ptShort];
    end
    else begin
      dEstPrice[ptLong]   := FEstPrice[ptLong];
      dEstPrice[ptShort]  := KipItem[ptShort].Order.Price;
    end;

    if FIsEntry then begin
      dTmp  := dEstPrice[ptShort] * App.Engine.ApiManager.ExRate.Value;
      if CheckZero( dTmp ) then
        FKipValue := 0
      else begin
        FKipValue := (dEstPrice[ptLong] - dTmp) / dTmp * 100;
        if FKipData.Kip - DOUBLE_EPSILON > FKipValue then
          Result := true;
      end;
    end else
    begin
      dTmp  := dEstPrice[ptLong] * App.Engine.ApiManager.ExRate.Value;
      if CheckZero( dTmp ) then
        FKipValue := 0
      else begin
        FKipValue := (dEstPrice[ptShort] - dTmp) / dTmp * 100;
        if FKipValue - DOUBLE_EPSILON > FKipData.Kip then
          Result := true;
      end;
    end;

  except
  end;
end;

procedure TPutKipOrderItem.CheckEstPrice(aType : TPositionType);
begin
  if KipItem[aType].Order = nil then
    Exit
  else if (KipItem[aType].Order <> nil) and (KipItem[aType].Order.IsCancelAble) then
  begin
    DoLog(Format('%s %s %s EstPrice is Zero', [ EntryToStr
      , ifThenStr(KipItem[aType].Order.Symbol.Spec.ExchangeType = ekBinance,'БЙГЛ', 'ЧиПм')
      , ifThenStr(aType = ptLong, 'ИХЕЕ', 'ИХМі')
      ] ) );
    DoCancelOrder(KipItem[aType].Order);
  end;
end;

procedure TPutKipOrderItem.CheckOrder(aType : TPositionType);
var
  s1, s2 : string;
begin

  if KipItem[aType].Order = nil then begin
    // new order
    DoOrder(aType);
  end
  else if (KipItem[aType].Order <> nil) and (KipItem[aType].Order.IsCancelAble) then
  begin
    // БтСИ СжЙЎ АЁАнРЬ ОЦСї KIP ЙќРЇ ОШПЁ РжДйИщ УыМв ОШЧбДй.
    // if CheckKipValue(aType) then Exit;
    s1 := KipItem[aType].Order.Symbol.PriceToStr(KipItem[aType].Order.Price);
    s2 := KipItem[aType].Order.Symbol.PriceToStr(FOrdPrice[aType]);

    //if CmpVal(KipItem[aType].Order.Price, FOrdPrice[aType]) <> 0 then begin
    if s1 <> s2 then
      DoLog(Format('%s %s %s СжЙЎАЁ КЏШ­ : %s -> %s', [ EntryToStr
        , TExchangeKindDesc[KipItem[aType].Order.Symbol.Spec.ExchangeType]
        , ifThenStr(aType = ptLong, 'ИХМі', 'ИХЕЕ')
        , KipItem[aType].Order.Symbol.PriceToStr(KipItem[aType].Order.Price )
        , KipItem[aType].Order.Symbol.PriceToStr(FOrdPrice[aType])] ) );

      if KipItem[aType].Order.Symbol.Spec.ExApiType = eaFutUsdt then
        DoChange(KipItem[aType].Order, FOrdPrice[aType])
      else
        DoCancelOrder(KipItem[aType].Order);
    end;
  end;
end;


constructor TPutKipOrderItem.Create(aColl: TCollection);
var
  i  : TPositionType;
begin
  inherited Create( aColl );

  FDone      := false;

  for I := ptLong to High(TPositionType) do
  begin
    PKItems[i]   := TPutKipItems.Create;
    LegTimer[i]  := TTimer.Create(nil);
    LegTimer[i].Tag := integer(i);
    LegTimer[i].Interval := 1000;
    LegTimer[i].Enabled  := false;
    LegTimer[i].OnTimer  := OnTimer;

    LegTimerLiq[i]  := TTimer.Create(nil);
    LegTimerLiq[i].Tag := integer(i);
    LegTimerLiq[i].Interval := 1000;
    LegTimerLiq[i].Enabled  := false;
    LegTimerLiq[i].OnTimer  := OnTimerLiq;

    FillTimer[i]  := TTimer.Create(nil);
    FillTimer[i].Tag := integer(i);
    FillTimer[i].Interval := 1000;
    FillTimer[i].Enabled  := false;
    FillTimer[i].OnTimer  := OnFillTimer;

    StopTimer := TTimer.Create(nil);
    StopTimer.Enabled := false;
    StopTimer.Interval := 1000;
    StopTimer.OnTimer  := OnStopTimer;
  end;
end;

