procedure TPutKipOrders.CheckDust;
var
  i, ifTick, isTick : integer;
  aDust : TDust;
  bRes  : boolean;
begin

  if not tryStrToInt(TFrmPutKipOrder(FParent).edtFutOrdTick.Text, ifTick) then Exit;
  if not tryStrToInt(TFrmPutKipOrder(FParent).edtSpotOrdTick.Text,isTick) then Exit;

  for I := 0 to FDusts.Count-1 do
  begin
    aDust := FDusts.Dust[i];
    if aDust.Qty <= EPSILON then continue;

    bRes := false;
    if aDust.Symbol.Spec.Market = mtFutures then
      bRes := aDust.IsOrder(ifTick)
    else if aDust.Symbol.Spec.Market = mtSpot then
      bRes := aDust.IsOrder(isTick);

    if bRes then
    begin
      DoOrder(aDust);
    end;

  end;
end;

