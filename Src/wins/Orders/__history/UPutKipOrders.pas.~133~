procedure TPutKipOrders.OnConfig(aCfg: TPKConfig);
var
  I: Integer;
begin
  for I := 0 to Count-1 do
    if GetKipOrders(i).Run then
      GetKipOrders(i).SetConfig(aCfg);// 
end;

procedure TPutKipOrders.OnOrder(aOrder: TOrder; iEventID : integer);
var
  aItem : TPutKipOrderItem;
begin
  if aOrder.StgType <> stPutKipOrder then Exit;

  if aOrder.Tag = DST_ORD then
  begin
    if aOrder.State = osRejected then begin
      FDusts.AddDust(aOrder.Symbol, aOrder.Side, aOrder.OrderQty);
      TFrmPutKipOrder(FParent).DoLog(Format('Dust СжЙЎАХКЮ: %s, Remain Qty : %s',[aOrder.Represent,
        DoubleToStr(FDusts.GetDust(aOrder.Symbol, aOrder.Side))]), true);
    end;
  end else
  begin
    aItem := Find( aOrder.GroupNo );
    if aItem <> nil then
      aItem.OnOrder( aOrder, iEventID );
  end;
end;

procedure TPutKipOrders.OnPause;
var
  I: Integer;
begin
  for I := 0 to Count-1 do
    if GetKipOrders(i).Run then
      GetKipOrders(i).OnPause;
end;

procedure TPutKipOrders.OnQuote(aSymbol: TSymbol; bOS : boolean);
var
  I: Integer;
begin
  for I := 0 to Count-1 do
    if GetKipOrders(i).Run then
      GetKipOrders(i).OnQuote(aSymbol, bOS);
end;

procedure TPutKipOrders.OnReduceOnly(bReduce: boolean);
var
  I: Integer;
begin
  for I := 0 to Count-1 do
    if not GetKipOrders(i).FIsEntry then
      GetKipOrders(i).OnReduceOnly( bReduce );
end;


procedure TPutKipOrders.SetPosition(aType : TSymbolCountryType; aAccount: TAccount; aSymbol: TSymbol);
begin

  if aSymbol.Spec.Market = mtSpot then Exit;

  FPositions[aType] := App.Engine.TradeCore.FindPosition(aAccount, aSymbol);
  if FPositions[aType] = nil then
    FPositions[aType] := App.Engine.TradeCore.NewPosition(aAccount, aSymbol);
end;


procedure TPutKipOrders.SetTime;
begin
  EnterCriticalSection(CriticalSection);
  try
    FLastGetTime := now;
  finally
    LeaveCriticalSection(CriticalSection);
  end;
end;

initialization
  InitializeCriticalSection(CriticalSection);

finalization
  DeleteCriticalSection(CriticalSection);

end.



