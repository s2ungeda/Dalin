procedure TFrmPutKipOrder.OnKipNotify(Sender: TObject; Value: string);
var
  aItem : TPutKipOrderItem;
  sts   : TArray<string>;
  iRow  : integer;
  aCheck: TCheckBox;
begin
  aItem := TPutKipOrderItem( Sender );
  // name 규칙 PK_XRP_UP_EN_1
  sts   := aItem.Name.Split(['_']);
  if Length(sts) > 4 then
    if TryStrToInt( sts[4], iRow ) then
    begin

      if Value = ORD_STR then
      begin
        var aEdit : TEdit;
        if aItem.IsEntry then
          aEdit := TEdit(FindComponent('edtEnDoneCount_'+IntToStr(iRow+1)))
        else
          aEdit := TEdit(FindComponent('edtExDoneCount_'+IntToStr(iRow+1)));

        if aEdit <> nil then
        begin
          aEdit.Text  := (aItem.Count -1).ToString;

          if (TPanel(aEdit.Parent).Color = clRed) or (TPanel(aEdit.Parent).Color = clLime) then
            TPanel(aEdit.Parent).Color := clYellow;
        end;

      end else
      begin

        aCheck := nil;
        if aItem.IsEntry then
          aCheck := TCheckBox(FindComponent('cbEnOn_'+IntToStr(iRow+1)))
        else
          aCheck := TCheckBox(FindComponent('cbExOn_'+IntToStr(iRow+1)));

        if aCheck <> nil then
        begin
          if Value = STOP_STR then
            aCheck.Enabled := true
          else if Value = RJCT_STR then
            Tpanel(aCheck.Parent).Color := clGray
          else if Value = BAL_STR then
            Tpanel(aCheck.Parent).Color := clRed
          else if Value = RANG_STR then
            Tpanel(aCheck.Parent).Color := clLime
          else begin
            aCheck.Checked := false;
            if Value = DONE_STR then
              Tpanel(aCheck.Parent).Color := clSkyblue
            else if Value = RSK_STR then
              Tpanel(aCheck.Parent).Color := clBlue;
          end;
        end;

      end;
    end;

end;

