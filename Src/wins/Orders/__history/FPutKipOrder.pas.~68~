procedure TFrmPutKipOrder.CalcEstPrice;
var
  dQty, dQty2, dTmp : double;
begin
{
  // 진입
  국내 매수호가, 국내 매수 EstPrice
  해외 매도호가, 해외 매도 EstPrice;
}
  if TryStrToFloat( edtEnInputQty.Text, dQty ) then
  begin
    if dQty > 0 then
    begin
      FKrEstPrice[ptLong] := FSymbols[scDomes].CalcEstPrice( 1, dQty);
      FOsEstPrice[ptShort]:= FSymbols[scInter].CalcEstPrice(-1, dQty);

      if FKrEstPrice[ptLong] <= 0 then
        FKrEstPrice[ptLong] := FSymbols[scDomes].CalcEstPrice( 1, dQty);
      if FOsEstPrice[ptShort] <= 0 then
        FOsEstPrice[ptShort]:= FSymbols[scInter].CalcEstPrice(-1, dQty);

    end;
  end;

{
  // 청산
  국내 매도호가, 국내 매도 EstPrice
  해외 매수호가, 해외 매수 EstPrice
}
  if TryStrToFloat( edtEXInputQty.Text, dQty ) then
  begin
    if dQty > 0 then
    begin
      FKrEstPrice[ptShort]:= FSymbols[scDomes].CalcEstPrice(-1, dQty);
      FOsEstPrice[ptLong] := FSymbols[scInter].CalcEstPrice(1,  dQty);

      if FOsEstPrice[ptLong] <= 0 then
        FOsEstPrice[ptLong] := FSymbols[scInter].CalcEstPrice(1,  dQty);

      if FKrEstPrice[ptShort] <= 0 then
        FKrEstPrice[ptShort]:= FSymbols[scDomes].CalcEstPrice(-1, dQty);

    end;
  end;

end;

procedure TFrmPutKipOrder.CalcKipPrice;

begin
  if App.Engine.ApiManager.ExRate.Value <= 1 then
    Exit;
  // 진입
  if (CheckZero(FOsEstPrice[ptShort]) or CheckZero(FSymbols[scInter].Asks[0].Price)) then begin
    FKipPrice[aoEntry] := 0;
    FKipIndex[aoEntry] := 0;
  end
  else begin
    //1. 국내 매수호가, 해외 매도 EstPrice
    //2. 국내 매수 EstPrice, 해외 매도호가
    FKipPrice[aoEntry] := ((FSymbols[scDomes].Bids[0].Price / (FOsEstPrice[ptShort] * App.Engine.ApiManager.ExRate.Value)) - 1) * 100;

    if ((App.Engine.SymbolCore.Tethers[FSymbols[scDomes].Spec.ExchangeType] <> nil) and
      (App.Engine.SymbolCore.Tethers[FSymbols[scDomes].Spec.ExchangeType].Bids[0].Price > EPSILON)) then
    begin
      FKipIndex[aoEntry] := FKipPrice[aoEntry] - ((
        App.Engine.SymbolCore.Tethers[FSymbols[scDomes].Spec.ExchangeType].Bids[0].Price/
        App.Engine.ApiManager.ExRate.Value) * 100 - 100);
    end else
      FKipIndex[aoEntry] := 0.0;
  end;

  // 청산
  if (CheckZero(FOsEstPrice[ptLong]) or CheckZero(FSymbols[scInter].Bids[0].Price)) then begin
    FKipPrice[aoExit]:= 0;
    FKipIndex[aoExit] := 0;
  end
  else begin
    // 1. 국내 매도호가, 해외 매수 EstPrice;
    // 2. 국내 매도 EstPrice, 해외 매수호가
    FKipPrice[aoExit] := ((FSymbols[scDomes].Asks[0].Price / (FOsEstPrice[ptLong] * App.Engine.ApiManager.ExRate.Value)) - 1) * 100;

    if ((App.Engine.SymbolCore.Tethers[FSymbols[scDomes].Spec.ExchangeType] <> nil) and
      (App.Engine.SymbolCore.Tethers[FSymbols[scDomes].Spec.ExchangeType].Asks[0].Price > EPSILON)) then
    begin
      FKipIndex[aoExit] := FKipPrice[aoEntry] - ((
        App.Engine.SymbolCore.Tethers[FSymbols[scDomes].Spec.ExchangeType].Asks[0].Price/
        App.Engine.ApiManager.ExRate.Value) * 100 - 100);
    end else
      FKipIndex[aoExit] := 0.0;
  end;

end;

