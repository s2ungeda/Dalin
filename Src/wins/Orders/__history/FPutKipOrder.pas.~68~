procedure TFrmPutKipOrder.TradeProc(Sender, Receiver: TObject; DataID: Integer;
  DataObj: TObject; EventID: TDistributorID);
begin
  if ( Receiver <> Self ) or ( DataObj = nil ) then Exit;

  case Integer(EventID) of
    ORDER_ACCEPTED,
    ORDER_REJECTED,
    ORDER_CANCELED,
    ORDER_CHANGED,
    ORDER_FILLED: FKipOrders.OnOrder(DataObj as TOrder, Integer(EventID));

    POSITION_UPDATE : OnPosition( DataObj as TPosition);
  end;
end;

