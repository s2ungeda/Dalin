procedure TFrmPutKipOrder.OnNotifyDone(Sender: TObject);
var
  aItem : TPutKipItem;
  ss : string;
  aSymbol : TSymbol;
begin
  if Sender = nil then Exit;
  aItem := Sender as TPutKipItem;

  InsertLine(sgOrders, 1);

  with sgOrders do
  begin
    Cells[0, 1] := FormatDateTime('dd hh:nn:ss', now);
    Cells[2, 1] := Format('%.2f', [aItem.KipValue]);

    if aItem.Order = nil then Exit;

    if aItem.Order.Symbol = FSymbols[scDomes] then
      aSymbol := FSymbols[scInter]
    else
      aSymbol := FSymbols[scDomes];

    if aItem.Order.Side < 0 then begin
      Cells[3,1]  := '+ '+ aItem.Order.Symbol.PriceToStr(aItem.Order.AvgPrice);
      if aSymbol <> nil then
        Cells[4,1]  := aSymbol.PriceToStr(aItem.AvgPrice);
    end
    else begin
      if aSymbol <> nil then
        Cells[3,1]  := aSymbol.PriceToStr(aItem.AvgPrice);
      Cells[4,1]  := '+ '+ aItem.Order.Symbol.PriceToStr(aItem.Order.AvgPrice);
    end;

    Cells[1, 1] := ifThenStr(aItem.IsEntry,'E','X');//+aItem.Idx.ToString;

    Cells[5, 1] := Format('%.2f', [aItem.Order.ExRate]);
    Cells[6, 1] := Format('%.2n', [aItem.TPrice]);

    Cells[7, 1] := Format('%s', [doubleToStr(min(aItem.Order.FilledQty, aItem.FilledQty))]);
    Cells[8, 1] := Format('%.2f', [aItem.Kip]);
    Cells[9, 1] := Format('%.2f', [aItem.IdxPk]);

    Cells[10, 1] := Format('%s', [doubleToStr(aItem.Order.FilledQty - aItem.FilledQty)]);
  end;
end;

