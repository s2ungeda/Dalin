end;

procedure TFrmPutKipOrder.DoLegginLog(idx : integer; stLog : string);
begin
  if (FLogFlag[idx] = 0) or (FLogFlag[idx] mod 60 = 0) then begin
    inc(FLogFlag[idx]);
    DoLog(stLog, true);
  end;
end;

function TFrmPutKipOrder.CheckProcTime : boolean;
var
  tNow : TDateTime;
  bResult : boolean;
  dmavg, dPer, dDisp   : double;
  iPeriod, iDelay1, iDelay2, iDelay3, iDly, iExDly : integer;

  function IsLimitTime( dtStart, dtEnd, dtNow : TDateTime ) : boolean;
  var
    s, e, n : TDateTime;
  begin

    Result := true;

    s := Frac( dtStart ); e := Frac( dtEnd );  n := Frac( dtNow );

    if e < s then
    begin
      if ( n >= s) or ( n <= e ) then
        Result := false;
    end else
    begin
      if (n >= s ) and ( n <= e ) then
        Result := false;
    end;

  end;

begin

  Result := false;
  tNow := now;

  if ckLimitTime1.Checked then
    if not IsLimitTime( dtLimitStart1.Time, dtLimitEnd1.Time, tNow ) then
      Exit;

  if ckLimitTime2.Checked then
    if not IsLimitTime( dtLimitStart2.Time, dtLimitEnd3.Time, tNow ) then
      Exit;

  if ckLimittime3.Checked then
    if not IsLimitTime( dtLimitStart3.Time, dtLimitEnd3.Time, tNow ) then
      Exit;

  // 환이격도.
  if not TryStrToInt( edtMoveAvgPeriod.Text, iPeriod ) then Exit;
  if not TryStrToFloat(edtExDisparity.Text, dPer) then Exit;
  if not TryStrToInt(edtSiseDelay.Text, iDly) then Exit;
  if not TryStrToInt(edtExDelay.Text, iExDly) then Exit;


  dmavg := App.Engine.ApiManager.ExRate.GetAvgExRate( iPeriod);
  if CheckZero(dmavg) then
    Exit
  else begin
    dDisp := abs(App.Engine.ApiManager.ExRate.GetExRate - dmavg) / dmavg * 100;
    if dDisp >= dPer then
    begin
      DoLegginLog(0, Format('환이격도 상승  %.2f ( %.2f|%.2f ) ', [dDisp ,dmavg, App.Engine.ApiManager.ExRate.GetExRate ]) );
//      DoLog( Format('환이격도 상승  %.2f ( %.2f|%.2f ) ', [dDisp ,dmavg, App.Engine.ApiManager.ExRate.GetExRate ] ), true );
      gbExRate.Color  := clYellow;
      Exit;
    end;
  end;

  gbExRate.Color  := panel1.Color;// clBtnFace;
  InitLogFlag(0);

  iDelay1 := App.Engine.ApiManager.ExManagers[ekBinance].QuoteSock[cbFutType.ItemIndex+1].DelaySec;
  iDelay2 := App.Engine.ApiManager.ExManagers[FExKind[ptLong]].QuoteSock[0].DelaySec;
  iDelay3 := SecondsBetween(now, App.Engine.ApiManager.ExRate.LastTime );

  if (iDelay1 > iDly) or (iDelay2 > iDly) then begin
    DoLegginLog(1, Format('%s 시세 딜레이 (%d,%d) > %d', [ExKindToStr( FExKind[ptShort] ), iDelay1, iDelay2, iDly ] ));
//    DoLog( Format('%s 시세 딜레이 (%d,%d) > %d', [ExKindToStr( FExKind[ptShort] ), iDelay1, iDelay2, iDly ] ), true);
    gbDelay.Color := clYellow;
    Exit;
  end;
  InitLogFlag(1);

  if iDelay3 > iExDly then
  begin
    DoLegginLog(2, Format('환율 딜레이 %d > %d', [iDelay3, iExDly ] ));
//    DoLog( Format('환율 딜레이 %d > %d', [iDelay3, iExDly ] ), true);
    gbDelay.Color := clYellow;
    Exit;
  end;
  gbDelay.Color  := panel1.Color;
  InitLogFlag(2);

  Result := true;

end;

function TFrmPutKipOrder.CreateNStart( bEntry : boolean; iTag : integer ) : boolean;
var
  stTmp, stName : string;
  aItem  : TPutKipOrderItem;

  dQty, dKip : double;
  iRep, iInter, iSide: integer;

  bReduce, bRes : boolean;
  dInt  : TDecimalHelper;
begin
  stTmp  := ifThenStr( bEntry , 'En', 'Ex' );

  bREs := TryStrToFloat( TEdit( FindComponent( 'edt'+stTmp+'Kip_'+IntToStr(iTag+1) ) ).Text, dKip )
      and TryStrToFloat( TEdit( FindComponent( 'edt'+stTmp+'OrderQty_'+IntToStr(iTag+1) ) ).Text, dQty )
      and TryStrToInt( TEdit( FindComponent( 'edt'+stTmp+'Count_'+IntToStr(iTag+1) ) ).Text, iRep )
      //and TryStrToInt( TEdit( FindComponent( 'edt'+stTmp+'Interval_'+IntToStr(iTag+1) ) ).Text, iInter )
      ;
  iSide :=  TComboBox( FindComponent( 'cb'+stTmp+'Side_'+IntToStr(iTag+1) ) ).ItemIndex;

  if not bRes then
  begin
    ShowMessage( '입력값이 잘못 됐음');
    Exit (false );
  end;

  if iRep <= 0 then
  begin
    ShowMessage( '입력값이 잘못 됐음');
    Exit (false );
  end;

  if dQty < FMinQty then
  begin
    ShowMessage('최소 주문수량보다 작음');
    Exit (false);
  end;

  if (FSymbols[scDomes] = nil) or (FSymbols[scInter] = nil) then
  begin
    ShowMessage( '종목선택을 먼저');
    Exit (false );
  end;

  // 바이낸스 소수점 단위 체크..
  dInt.convert(dQty);
  if dInt.Precision > FSymbols[scInter].Spec.QtyPrecision  then
  begin
    ShowMessage( '주문수량 소수점 개수는 ' +  FSymbols[scInter].Spec.QtyPrecision.ToString );
    Exit (false );
  end;

  stName := Format('%s_%s', [MakeName, stTmp] );

  if bEntry then
    bReduce := false
  else
    bReduce := cbReduceOnly.Checked;

  aItem  := FKipOrders.New(stName, iTag);
  if aItem <> nil then
  begin
    aItem.KipData.SetKipData(dQty, dKip, iSide, iRep, bReduce );
    aItem.KipData.SetConfig( FConfig );
    aItem.OnNotify    := OnLogNotify;
    aItem.OnKipNotify := OnKipNotify;
    aItem.OnKipDontNotify := OnNotifyDone;
    aItem.SetSymbol( Self, bEntry, FSymbols );
    aItem.Start;
  end else
  begin
    ShowMessage( '해당 unit 을 실행 할 수 없음');
    Exit (false );
  end;

  Result := true;

  TEdit( FindComponent( 'edt'+stTmp+'DoneCount_'+IntToStr(iTag+1) ) ).Text := '0';

  if Result then
    SetEnableUnitContorls( bEntry, iTag, false );
end;

function TFrmPutKipOrder.Stop( bEntry : boolean; iTag : integer ) : TPutKipOrderItem;
var
  sTmp, stName : string;
begin
  sTmp := Format('%s_%s', [MakeName, ifThenStr(bEntry , 'En', 'Ex')] );
  stName := Format('PK_%s_%d', [sTmp, iTag] );
  Result := FKipOrders.Find(stName);

  if Result <> nil then
    Result.Stop;
end;

procedure TFrmPutKipOrder.SetEnableUnitContorls( bEntry : boolean; iTag : integer;
  bEnable : boolean );
var
  stTmp : string;
  I: Integer;
begin
  stTmp  := ifThenStr( bEntry , 'En', 'Ex' );

  TEdit( FindComponent( 'edt'+stTmp+'Kip_'+IntToStr(iTag+1) ) ).Enabled     := bEnable;
  TEdit( FindComponent( 'edt'+stTmp+'OrderQty_'+IntToStr(iTag+1) )).Enabled := bEnable;
  TEdit( FindComponent( 'edt'+stTmp+'Count_'+IntToStr(iTag+1) )).Enabled    := bEnable;
  TComboBox( FindComponent( 'cb'+stTmp+'Side_'+IntToStr(iTag+1) )).Enabled  := bEnable;

  if bEnable then
  begin
    for I := 0 to FKipOrders.Count-1 do
      if FKipOrders.KipOrders[i].Run then
        Exit;
  end;

  edtCode.Enabled := bEnable;
  cbBuyEx.Enabled := bEnable;
  cbSellEx.Enabled:= bEnable;
  Button1.Enabled := bEnable;
  cbFutType.Enabled := bEnable;

  DustTimer.Enabled := not bEnable;

  if DustTimer.Enabled then
    FKipOrders.Dusts.Clear;

end;

