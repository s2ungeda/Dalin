unit FKipOrderConfig;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants, System.Classes, Vcl.Graphics,
  Vcl.Controls, Vcl.Forms, Vcl.Dialogs, Vcl.StdCtrls, Vcl.Mask, Vcl.ExtCtrls,

  UOrderParams
  ;

type
  TFrmKipOrderConfig = class(TForm)
    Button1: TButton;
    Button2: TButton;
    GroupBox1: TGroupBox;
    edtRetryCount: TLabeledEdit;
    edtRetryInterval: TLabeledEdit;
    LabeledEdit1: TLabeledEdit;
    edtOrderInterval: TLabeledEdit;
    procedure Button2Click(Sender: TObject);
    procedure Button1Click(Sender: TObject);
  private
    FConfig: TKipConfig;
    { Private declarations }
  public
    { Public declarations }

    function Open( aCfg : TKipConfig ) : boolean;

    property Config : TKipConfig read FConfig;
  end;

var
  FrmKipOrderConfig: TFrmKipOrderConfig;

implementation

{$R *.dfm}

{ TFrmKipOrderConfig }

procedure TFrmKipOrderConfig.Button1Click(Sender: TObject);
begin

  TryStrToInt( edtRetryCount.Text,  FConfig.ReTryCount );
  TryStrToInt( edtRetryInterval.Text, FConfig.ReTryInterval );
  TryStrToInt( edtOrderInterval.Text, FConfig.OrderInterval );

  if FConfig.OrderInterval <= 0 then
  begin
    ShowMessage('진입청산 인터벌 값은 0 보다 커야 함');
    ModalResult := mrRetry;
    Exit;
  end;

  ModalResult := mrOK;
end;

procedure TFrmKipOrderConfig.Button2Click(Sender: TObject);
begin
  ModalResult := mrCancel;
end;

function TFrmKipOrderConfig.Open( aCfg : TKipConfig ): boolean;
begin

  edtRetryCount.Text    := IntToStr( aCfg.ReTryCount );
  edtRetryInterval.Text := IntTostr( aCfg.ReTryInterval );
  edtOrderInterval.Text := IntToStr( aCfg.OrderInterval );

  Result :=  (ShowModal = mrOK);
end;

end.
