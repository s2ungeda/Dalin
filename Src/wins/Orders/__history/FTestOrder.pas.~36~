procedure TFrmTestOrder.TimerEnable( bEnable : boolean );
begin

  if bEnable then
  begin
    bntimer.Enabled := bEnable;
    sleep(2000);
    upTimer.Enabled := bEnable;
    sleep(2000);
    btTimer.Enabled := bEnable;
  end else
  begin
    bntimer.Enabled := bEnable;
    upTimer.Enabled := bEnable;
    btTimer.Enabled := bEnable;
  end;
end;

procedure TFrmTestOrder.Edit1KeyDown(Sender: TObject; var Key: Word;
  Shift: TShiftState);
  var
    sCode : string;
  I: TExchangeKind;
begin
  if Key = VK_RETURN then
  begin
    for I := ekBinance to High(TExchangeKind) do
    begin
      if FSymbols[i] <> nil then
        App.Engine.QuoteBroker.Brokers[i].Cancel( self, FSymbols[i] );

      FSymbols[i] := App.Engine.SymbolCore.BaseSymbols.FindSymbol(edit1.Text, i,
        TMarketType(ifThen(i=ekBinance, integer(mtFutures), integer(mtSpot)) ) );
