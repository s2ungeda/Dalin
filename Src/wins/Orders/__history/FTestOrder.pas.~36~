procedure TFrmTestOrder.FormCreate(Sender: TObject);
var
  I: TExchangeKind;
begin
  for I := ekBinance to High(TExchangeKind) do
  begin
    FResult[i]  := TCollection.Create(TOrderSpeedItem);
    FReport[i]  := TSpeedItems.Create;
    FSymbols[i] := nil;
    FCount[i]   := 0;
    FOrders[i]  := TOrderList.Create;
    if i = ekBinance then
      FAccounts[i]:= App.Engine.TradeCore.FindAccount(i,amFuture)
    else
      FAccounts[i]:= App.Engine.TradeCore.FindAccount(i);
  end;

  App.Engine.TradeBroker.Subscribe( Self, TradeProc);
end;

procedure TFrmTestOrder.FormDestroy(Sender: TObject);
var
  I: TExchangeKind;
begin
  for I := ekBinance to High(TExchangeKind) do begin
    FResult[i].Free;
    FOrders[i].Free;
    FReport[i].Free;
    App.Engine.QuoteBroker.Brokers[i].Cancel( self);
  end;

  App.Engine.TradeBroker.Unsubscribe(Self);
end;

