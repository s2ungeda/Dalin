procedure TFrmTestOrder.bnTimerTimer(Sender: TObject);
var
  aExType : TExchangeKind;
  aOrder  : TOrder;
  dQty, dPrice  : double;
  stLog : string;
begin

  aOrder := nil;
  aExType := TExchangeKind(TComponent(Sender).Tag);

  case aExType of
    ekBinance: if not cbBinance.Checked then Exit;
    ekUpbit: if not cbUpbit.Checked then Exit;
    ekBithumb: if not cbBithumb.Checked then Exit;
  end;

  try

    if FOrders[aExType].Count > 0 then
    begin
      DoCancelOrder( aExType );
      Exit;
    end;

    stLog := '계좌나 종목 nil';
    if (FAccounts[aExtype] = nil) or (FSymbols[aExType] = nil) then Exit;

    stLog := 'bids 카운터 < 9';
    if FSymbols[aExType].Bids.Count < 10 then Exit;
    stLog := 'bid.price = 0';
    if CheckZero(FSymbols[aExType].Bids[9].Price) then Exit;
    dPrice  := TicksFromPrice( FSymbols[aExType], FSymbols[aExType].Bids[9].Price, -50);
    stLog := '주문가격 0 ';
    if CheckZero(dPrice) then Exit;

    if aExType = ekBinance then
      dQty := 0.003
    else
      dQty := 0.0003;

    aOrder := App.Engine.TradeCore.Orders[aExType].NewOrder( FAccounts[aExType], FSymbols[aExType],
      1, dQty, pcLimit, dPrice, tmGTC);

    stLog := '주문이 nil';
    if aOrder <> nil then
    begin
      aOrder.StgType := stTest;
      App.Engine.TradeBroker.Send( aOrder );
      FOrders[aExType].Add( aOrder );
    end;
  finally
    if aOrder = nil then begin
      stBar.Panels[1].Text := ExKindToStr(aExType) +  ' 주문 실패';
      App.Log(llError, 'test_order', '%s 주문 실패 -> %s', [ExKindToStr(aExType), stLog]);
    end
    else begin
      stBar.Panels[1].Text := ExKindToStr(aExType) +  ' 주문성공';
//      cbStart.Checked := false;
    end;
  end;

end;

procedure TFrmTestOrder.Button1Click(Sender: TObject);
var
  I: TExchangeKind;   J, idx : integer;
  aItem : TOrderSpeedItem;
  si : TSpeedItem;

  sKey : string;

begin
  //
  for I := ekBinance to High(TExchangeKind) do
    FReport[i].Clear;

  for I := ekBinance to High(TExchangeKind) do
  begin
    for J := 0 to FResult[i].Count-1 do
    begin
      aItem := FResult[i].Items[j] as TOrderSpeedItem;
      sKey  := FormatDateTime('mm-dd hh', aItem.DateTime);
      si := FReport[i].Find(sKey);
      if aItem.State = 0 then
        idx := 2
      else
        idx := ifThen( aItem.OrderType = otNormal, 0, 1);

      si.SetData( aItem.Speed, idx );
    end;
  end;


  for I := ekbinance to High(TExchangeKind) do
