procedure TFrmTestOrder.OnOrder(aOrder: TOrder);
var
  i : TExchangeKind;
  j: Integer;
  ord : TOrder;
  aItem : TOrderSpeedItem;
begin

  if aOrder.StgType <> stTest then Exit;

  i := aOrder.Account.ExchangeKind;

  aItem := nil;
  if (aOrder.OrderType = otNormal) and (aOrder.State = osActive) then begin
    aItem := FResult[i].Add as TOrderSpeedItem;
    aItem.Speed := aOrder.NewRecvTime - aOrder.NewTime;//  MilliSecondsBetween( aOrder.EventTime, aOrder.SentTime);
    aItem.State := 1;
  end
  else if (aOrder.OrderType = otCancel) and (aOrder.State = osCanceled) then begin
    aItem := FResult[i].Add as TOrderSpeedItem;
    aItem.Speed := aOrder.CnlRecvTime - aOrder.CnlTime;// MilliSecondsBetween( aOrder.CancelTime, aOrder.SentTime);
    aItem.State := 1;
  end
  else if (aOrder.State in [osRejected, osFailed]) then begin
    aItem := FResult[i].Add as TOrderSpeedItem;
    if aOrder.OrderType = otCancel then
      aItem.Speed := aOrder.RjtRecvTime - aOrder.CnlTime
    else
      aItem.Speed := aOrder.RjtRecvTime - aOrder.NewTime;
    aItem.State := 0;
  end;


  if aItem <> nil then
  begin
    aItem.DateTime  := now;
    aItem.ExKind    := i;
    aItem.OrderType := aOrder.OrderType;
  end;

  if ( aOrder.OrderType = otNormal) and (aOrder.State = osActive) and (not aOrder.Modify) then
  begin
    // 주문 접수 오면 바로 취소 주문..
    DoCancelOrder( aOrder );
  end;

  for j := FOrders[i].Count-1 downto 0 do
  begin
    ord := FOrders[i].Orders[j];
    if ord.State in [osRejected, osFilled, osCanceled]  then
      FOrders[i].Delete(j);
  end;

end;

procedure TFrmTestOrder.SaveEnv(aStorage: TStorage);
begin

end;

procedure TFrmTestOrder.DoCancelOrder(aExType: TExchangeKind);
var
  aOrder : TOrder;
begin
  for aOrder in FOrders[aExtype] do
    if (aOrder.State = osActive) and ( not aOrder.Modify ) then
      DoCancelOrder( aOrder );
end;

procedure TFrmTestOrder.DoCancelOrder(aOrder: TOrder);
begin
  App.Engine.TradeCore.Orders[aOrder.Account.ExchangeKind].NewCancelOrder(aOrder, aOrder.ActiveQty);
  App.Engine.TradeBroker.Send(aOrder);
end;

procedure TFrmTestOrder.TradeProc(Sender, Receiver: TObject; DataID: Integer;
  DataObj: TObject; EventID: TDistributorID);
begin
  if (Self <> Receiver) or (DataObj=nil) then Exit;

  case Integer(EventID) of
    ORDER_ACCEPTED,
    ORDER_REJECTED,
    ORDER_CANCELED,
    ORDER_FILLED: OnOrder(DataObj as TOrder);

//    POSITION_UPDATE : OnPosition( DataObj as TPosition);
  end;
end;

{ TSpeedItems }

constructor TSpeedItems.Create;
begin
  inherited Create( TSpeedItem );
end;

destructor TSpeedItems.Destroy;
begin

  inherited;
end;

function TSpeedItems.Find(sKey: string): TSpeedItem;
var
  I: Integer;
  aItem : TSpeedItem;
begin
  Result := nil;

  for I := Count-1 downto 0 do
  begin
    aItem := Items[i] as TSpeedItem;
    if aItem.key = sKey then
    begin
      Result := aItem;
      break;
    end;
  end;

  if Result = nil then begin
    Result := Add as TSpeedItem;
    Result.key  := sKey;
  end;

end;

{ TSpeedItem }

// 0 신규  1 취소
constructor TSpeedItem.create(aColl: TCollection);
var
  I: Integer;
begin
  inherited Create(aColl);

  for I := 0 to 2 do
  begin
    minv[i]  := 9999999;
    maxv[i]  := 0;
    avg[i]   := 0;
    cnt[i]   := 0;
    sss[i]   := 0;
  end;
end;

procedure TSpeedItem.SetData(val: integer; i : integer);
begin
  minv[i] := min( minv[i], val );
  maxv[i] := max( maxv[i], val );
  inc(sss[i], val);
  inc(cnt[i] );
  avg[i] := sss[i] div cnt[i];
end;

end.
