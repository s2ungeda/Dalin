procedure TFrmTestOrder.Button2Click(Sender: TObject);
var
  aItem : TOrderSpeedItem;
  I: TExchangeKind;
  j: Integer;
  tNow : TDateTime;
begin
  aItem := nil;

  Randomize;

  tNow := now;

  for I := ekBinance to High(TExchangeKind) do
  begin

    for j := 0 to 1000 do
    begin
      aItem := FResult[i].Add as TOrderSpeedItem;
      aItem.Speed := Random(300);

      aItem.DateTime  := IncMinute( tNow, 5* j );
      aItem.ExKind    := i;
      if j mod 2 = 0 then
        aItem.OrderType := otNormal
      else
        aItem.OrderType := otCancel;
    end;
  end;

end;

