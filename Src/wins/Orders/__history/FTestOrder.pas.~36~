                                          '취소, %04d, %04d, %04d, %d,'+
                                          '거부, %04d, %04d, %04d, %d',
        [ ExKindToStr(i), si.key, si.minv[0], si.maxv[0], si.avg[0], si.cnt[0],
                                  si.minv[1], si.maxv[1], si.avg[1], si.cnt[1],
                                  si.minv[2], si.maxv[2], si.avg[2], si.cnt[2]
                                  ]    );
    end;
  end;

