procedure TPKIdxOrderItem.CalclEstPrice(bOS: boolean);
begin
  if bOS then begin
    if FIsEntry then begin     // БЙГЛ ИХМіАЁИІ БИЧЯБт РЇЧи ЧиПм ИХЕЕ EstPrice
      FEstPrice[ptShort] := FSymbols[scInter].CalcEstPrice(-1, GetSafeMarginQty(FSymbols[scInter]));
    end
    else begin                 // БЙГЛ ИХЕЕАЁИІ БИЧЯБт РЇЧи ЧиПм ИХМі EstPrice
      FEstPrice[ptLong]  := FSymbols[scInter].CalcEstPrice(1, GetSafeMarginQty(FSymbols[scInter]));
    end;
  end else
  begin
    if FIsEntry then begin     // СјРд ИХЕЕ
      FEstPrice[ptLong] := FSymbols[scDomes].CalcEstPrice(1, GetSafeMarginQty(FSymbols[scDomes]));
    end
    else begin                 // УЛЛъ ИХМі
      FEstPrice[ptShort]:= FSymbols[scDomes].CalcEstPrice(-1, GetSafeMarginQty(FSymbols[scDomes]));
    end;
  end;
end;

function TPKIdxOrderItem.CheckPriceRange: boolean;
var
  dMPrice : double;
  iVal : integer;
begin
  Result := false;
  if FIsEntry then
  begin
    // ЙйРЬГННК ИХЕЕ СжЙЎРЬ ГЪЙЋ ГЗРКСі УМХЉ
    if CmpVal(FOrdPrice[ptShort], (FSymbols[scInter] as TFuture).MarkPrice * FSymbols[scInter].Spec.MultiplierDown) < 0 then
    begin
      DoLog(Format('ИХЕЕСжЙЎАЁАнРЬ%s < %s (%s, %s%%) КИДй ГЗРН', [FSymbols[scInter].PriceToStr(FOrdPrice[ptShort]),
        FSymbols[scInter].PriceToStr((FSymbols[scInter] as TFuture).MarkPrice * FSymbols[scInter].Spec.MultiplierDown),
        FSymbols[scInter].PriceToStr((FSymbols[scInter] as TFuture).MarkPrice),
        FSymbols[scInter].QtyToStr(FSymbols[scInter].Spec.MultiplierDown)
        ]));
      Exit;
    end;

  end else
  begin
    if CmpVal(FOrdPrice[ptLong], (FSymbols[scInter] as TFuture).MarkPrice * FSymbols[scInter].Spec.MultiplierUp) > 0 then
    begin
      DoLog(Format('ИХМіСжЙЎАЁАнРЬ%s > %s (%s, %s%%) КИДй ГєРН', [ FSymbols[scInter].PriceToStr(FOrdPrice[ptLong]),
        FSymbols[scInter].PriceToStr((FSymbols[scInter] as TFuture).MarkPrice * FSymbols[scInter].Spec.MultiplierUp),
        FSymbols[scInter].PriceToStr((FSymbols[scInter] as TFuture).MarkPrice),
        FSymbols[scInter].QtyToStr(FSymbols[scInter].Spec.MultiplierUp)
        ]));
      Exit;
    end;
  end;

  Result := true;
end;

function TPKIdxOrderItem.CheckBalance_KrAsk(dOrdQty:double): boolean;
var
  aAsset : TAsset;
  dQty, dQty2, dQty3, dAmt : double;
  aSpItem : TSPObject;
  aAcnt : TAccount;
begin
  try
    Result := false;
    dQty  := 0;   dQty2 := 0;  dQty3 := 0;

    aAsset  := FAccounts[scDomes].Assets.Find(FSymbols[scDomes].Spec.BaseCode);
    if aAsset = nil then Exit;
    if aAsset.Balance <= 0 then Exit;
    //if TPKIdxOrders(Collection).Positions[scInter].Volume >= 0 then Exit;
    // ГЊАЁОпЧв ИХЕЕ СжЙЎРЬ РжДТ ЦФОЧ( sp СјРд СжЙЎ )

    aSpItem := App.Engine.StgManager.SPObject.Find( FSymbols[scDomes].Spec.ExchangeType, FSymbols[scDomes].Code );
    if aSpItem <> nil then begin
      aAcnt := App.Engine.TradeCore.FindAccount(aSpItem.SubEx);
      with App.Engine.TradeCore.Orders[aSpItem.SubEx] do
        dQty := GetActiveOrderQty(aACnt, FSymbols[scDomes], 1 ) +
                GetUnActiveOrderQty(aACnt, FSymbols[scDomes], 1 );
    end;

    // ГЊАЁОп Чв ИХЕЕ СжЙЎ..( ЧиПм ИХМіСжЙЎ УМАс ЕЩАцПь..)
    dQty3  := TPKIdxOrders(Collection).GetOSExitBidOrderQty;

    // ГЊАЁ РжДТ ИХЕЕ СжЙЎ..
    with App.Engine.TradeCore.Orders[FAccounts[scDomes].ExchangeKind] do
      dQty2:= GetActiveOrderQty(FAccounts[scDomes], FSymbols[scDomes], -1 ) +
              GetUnActiveOrderQty(FAccounts[scDomes], FSymbols[scDomes], -1 );

    dAmt := dOrdQty + dQty + dQty2 + dQty3;
    if CmpVal(aAsset.Balance, dAmt) < 0 then
    begin
      Exit;
    end;
    Result := true;
  finally
    if not Result then
      if aAsset <> nil then
        FErrMsg := format('БЙГЛ РмАэ КЮСЗ %s < %s ', [
          DoubleToStr(aAsset.Balance), DoubleToStr(dOrdQty + dQty + dQty2 + dQty3) ]);
  end;
end;

function TPKIdxOrderItem.GetHitOrderPrice(iSide: integer; scType : TSymbolCountryType): double;
var
  iTick : integer;
begin
  iTick := IfThen(scType = scDomes, gAOConfig.Result.STick, gAOConfig.Result.FTick);

  if iSide > 0 then
    Result := TicksFromPrice(FSymbols[scDomes], FSymbols[scType].Asks[0].Price , iTick)
  else
    Result := TicksFromPrice(FSymbols[scDomes], FSymbols[scType].Bids[0].Price , -iTick)
end;

function TPKIdxOrderItem.CheckBalance_KrBid(dOrdQty:double; bHit : boolean): boolean;
var
  dQty, dQty2, dAmt, dAmt2, dAmt3, dFee, dAvailable, dOrderAmt, dPrice, dHitPrice : double;
  aSpItem : TSPObject;
  aAcnt : TAccount;
  iTick : integer;
begin
  Result := false;
  try
    dAvailable := 0;
    dOrderAmt  := 0;  dAmt3 := 0;  dAmt2 := 0;    dAmt := 0;      dQty2 := 0;
    // СжЙЎАЁДЩБнОз БИЧЯБт
    with App.Engine.TradeCore.Orders[FAccounts[scDomes].ExchangeKind] do
      dAmt := GetAcceptOrderAmt(FAccounts[scDomes], 1) +
              GetUnAcceptOrderAmt(FAccounts[scDomes], 1);

    dFee:= App.Engine.ApiConfig.ExchangeInfo[integer(FAccounts[scDomes].ExchangeKind)].//ApiInfo[FSymbols[scDomes].Spec.ExApiType].TradeFee;
      GetTradeFee(FSymbols[scDomes].Spec.ExApiType, FSymbols[scDomes].Spec.SettleType, ftMaker);

    // ГЊАЁОпЧв ИХМі СжЙЎРЬ РжДТ АцПь- 1 ( ЧиПм ИХЕЕ СжЙЎРЬ РжДТАцПь )
    dQty2     := TPKIdxOrders(Collection).GetOSEntryAskOrderQty;
    dHitPrice := GetHitOrderPrice(1, scDomes);

    if dQty2 > EPSILON  then
      dAmt3 := (dQty2 * dHitPrice) * (1 + (dFee / 100));

    if bHit then
      dPrice := dHitPrice
    else
      dPrice := FOrdPrice[ptLong];

    // ГЊАЁОпЧв ИХМі СжЙЎРЬ РжДТ ЦФОЧ -2 ( sp УЛЛъ СжЙЎ )
    aSpItem := App.Engine.StgManager.SPObject.Find( FSymbols[scDomes].Spec.ExchangeType, FSymbols[scDomes].Code );
    dQty := 0.0;  dAmt2 := 0.0;
    if aSpItem <> nil then begin
      aAcnt := App.Engine.TradeCore.FindAccount(aSpItem.SubEx);
      with App.Engine.TradeCore.Orders[aSpItem.SubEx] do
      begin
        dQty := GetActiveOrderQty(aAcnt, stSPOrder, -1) +
                GetUnActiveOrderQty(aAcnt, stSPOrder, -1);
        dAmt2:= (dQty * dPrice )*(1+(dFee/100));
      end;
    end;

    dAvailable  := FAccounts[scDomes].Balance - dAmt - dAmt2 - dAmt3;
    dOrderAmt := (dOrdQty * dPrice)*(1+(dFee/100)) ;
    if CmpVal(dAvailable, dOrderAmt) <= 0 then
    begin
  //      stLog := '-40';//'УЛЛъ : СжАХЗЁМв СжЙЎАЁДЩ БнОз КЮСЗ';
      Exit;
    end;
    Result := true;
  finally
    if not Result then
      FErrMsg := format('БЙГЛ АЁДЩБнОз %s > %s (%s-%s-%s)  )', [
        DoubleToStr(dOrderAmt), DoubleToStr(dAvailable),
        DoubleToStr(FAccounts[scDomes].Balance),
        DoubleToStr(dAmt), DoubleToStr(dAmt2) ]) ;
  end;
end;

