        end;
           //  БЙГЛ ИХМі Est - > Check Est -> ЧиПм ИХЕЕ Ord -> Check Ord   Side : A
        1 : ProcessOrder(FSymbols[scDomes], ptLong, true, FSymbols[scInter], ptShort);
           //  ЧиПм ИХЕЕ Est - >           -> БЙГЛ ИХМі Ord -> Check Ord   Side : B
        2 : ProcessOrder(FSymbols[scInter], ptShort, false, FSymbols[scDomes], ptLong);
      end;
    end;
  end else begin
    if bOS then begin
      case FPIData.Method of
        0 : begin
          ProcessOrder(FSymbols[scInter], ptLong, true, FSymbols[scDomes], ptShort);
          ProcessOrder(FSymbols[scDomes], ptShort, false, FSymbols[scInter], ptLong);
        end;
          // БЙГЛ ИХЕЕ Est - >           -> ЧиПм ИХМі Ord -> Check Ord   Side : B
        1 : ProcessOrder(FSymbols[scDomes], ptShort, false, FSymbols[scInter], ptLong);
          // ЧиПм ИХМі Est - > Check Est -> БЙГЛ ИХЕЕ Ord -> Check Ord   Side : A
        2 : ProcessOrder(FSymbols[scInter], ptLong, true, FSymbols[scDomes], ptShort);
      end;
    end else
    begin
      case FPIData.Method of
        0 : begin
          ProcessOrder(FSymbols[scInter], ptLong, true, FSymbols[scDomes], ptShort);
          ProcessOrder(FSymbols[scDomes], ptShort, false, FSymbols[scInter], ptLong);
        end;
          // БЙГЛ ИХЕЕ Est - > Check Est -> ЧиПм ИХМі Ord -> Check Ord   Side : B
        1 : ProcessOrder(FSymbols[scDomes], ptShort, false, FSymbols[scInter], ptLong);
          // ЧиПм ИХМі Est - >           -> БЙГЛ ИХЕЕ Ord -> Check Ord   Side : A
        2 : ProcessOrder(FSymbols[scInter], ptLong, true, FSymbols[scDomes], ptShort);

      end;
    end;
  end;
end;

procedure TPKIdxOrderItem.OnStopTimer(Sender: TObject);
var
  I: TPositionType;
  iRes, iCnt : integer;
begin

  try

    iRes := 0; iCnt := 0;
    for I := ptLong to High(TPositionType) do
      if (KipItem[i].Order <> nil) then
      begin
        inc(iCnt);
        if not (KipItem[i].Order.State in [osReady, osSent, osActive]) then
          inc(iRes);
      end;

    if (iRes = iCnt) {and (iCnt > 0)} then begin
      StopTimer.Enabled := false;
      DoLog('ALL CANCEL');
      if Assigned(FOnKipNotify) then
        FOnKipNotify(Self, STOP_STR );
    end
    else
      ClearOrders;

  finally
    inc(FSpotTimerCount);

    if FSpotTimerCount > 5 then
    begin
      FSpotTimerCount := 0;
      StopTimer.Enabled := false;
      DoLog('.......А­СІ СОЗс.......');
      if Assigned(FOnKipNotify) then
        FOnKipNotify(Self, STOP_STR );
    end;
  end;
end;

