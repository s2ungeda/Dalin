procedure TPKIdxOrders.CheckDust;
var
  i : integer;
  aDust : TDust;
  bRes  : boolean;
begin

  for I := 0 to FDusts.Count-1 do
  begin
    aDust := FDusts.Dust[i];
    if aDust.Qty <= EPSILON then continue;

    bRes := false;
    if aDust.Symbol.Spec.Market = mtFutures then
      bRes := aDust.IsOrder(gAOConfig.Result.FTick)
    else if aDust.Symbol.Spec.Market = mtSpot then
      bRes := aDust.IsOrder(gAOConfig.Result.STick);

    if bRes then
    begin
      DoOrder(aDust);
    end;

  end;
end;

