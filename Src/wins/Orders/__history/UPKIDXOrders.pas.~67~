procedure TPKIdxOrders.OnOrder(aOrder: TOrder; iEventID : integer);
var
  aItem : TPKIdxOrderItem;
begin
  if aOrder.StgType <> stPKIdxOrder then Exit;

  if aOrder.Tag = DST_ORD then
  begin
    if aOrder.State = osRejected then begin
      FDusts.AddDust(aOrder.Symbol, aOrder.Side, aOrder.OrderQty);
      App.Log(llInfo, 'Dust СжЙЎАХКЮ: %s, Remain Qty : %s',[aOrder.Represent,
        DoubleToStr(FDusts.GetDust(aOrder.Symbol, aOrder.Side))]);
    end else
      TFrmPKIDXOrders(FParent).OnNotifyDust(Self, aOrder);
  end else
  begin
    aItem := Find( aOrder.GroupNo );
    if aItem <> nil then
      aItem.OnOrder( aOrder, iEventID );
  end;
end;

procedure TPKIdxOrders.OnPause;
var
  I: Integer;
begin
  for I := 0 to Count-1 do
    if GetKipOrders(i).Run then
      GetKipOrders(i).OnPause;
end;

