    for I := 0 to Count-1 do
    begin
      if KipOrders[i].IsEntry <> bEntry then continue;

      if bEntry then
      begin
        if KipOrders[i].PIData.PK < aData.PK then begin
          bBrk:= true;
          break;
        end;
      end else
      begin
        if KipOrders[i].PIData.PK > aData.PK then begin
          bBrk:= true;
          break;
        end;
      end;
    end;

    if bBrk then
      REsult := Insert(i) as TPKIdxOrderItem
    else
      Result := Add as TPKIdxOrderItem;

    Result.Name := Format('PKIDX_%s_%d', [sDiv, iTag]);
    Result.Idx  := iTag;
  end;
end;

function TPKIdxOrders.New(sDiv: string; iTag: integer): TPKIdxOrderItem;
begin
  Result := Find(Format('PKIDX_%s_%d', [sDiv, iTag]));
  if Result = nil then
  begin
    Result := Add as TPKIdxOrderItem;
    Result.Name := Format('PKIDX_%s_%d', [sDiv, iTag]);
    Result.Idx  := iTag;
  end;
end;

