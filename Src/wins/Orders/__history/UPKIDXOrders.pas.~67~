function TPKIdxOrderItem.BnFutOrderAmt(aOrder : TOrder): double;
var
  aPos : TPosition;
begin
  Result := 0;
  aPos := App.Engine.TradeCore.FindPosition(aOrder.Account, aOrder.Symbol);

  if aPos <> nil then
    Result := CalcBnFutOrderAmt(aPos, aOrder.Side, aOrder.ActiveQty, aOrder.Price);
end;

function TPKIdxOrderItem.CalcBnFutOrderAmt(aPos: TPosition; iSide: integer; const dQty, dPrice: double): double;
var
  dFee, dim, dAmt : double;
begin
  dFee  := App.Engine.ApiConfig.ExchangeInfo[integer(aPos.Account.ExchangeKind) ].//ApiInfo[aPos.Symbol.Spec.ExApiType].TradeFee;
    GetTradeFee(aPos.Symbol.Spec.ExApiType, aPos.Symbol.Spec.SettleType, ftMaker);
  dim   := dQty * abs(min(0, iSide * ((aPos.Symbol as TFuture).MarkPrice - dPrice)));
  dAmt  := (dQty * dPrice * aPos.Symbol.Spec.PointValue / aPos.Leverage) + dim;
  if iSide < 0 then
    dAmt := dAmt + (dim / aPos.Leverage);
  Result :=  dAmt * (1 + (dFee / 100)) ;
end;

function TPKIdxOrderItem.CheckBalance_OsAsk(dOrdQty:double; bHit: boolean): boolean;
var
  dAvailable, dQty, dAmt, dOrderedAmt, dTotAmt, dPrice : double;
  i : Integer;
  aPos : TPosition;
  aOrder: TOrder;
begin

  Result := false;
  aPos := (Collection as TPKIdxOrders).Positions[scInter];
  if aPos = nil then Exit;

  try
    dAvailable:= FAccounts[scInter].Available;
    // 1. ГЊАЁ РжДТ СжЙЎ БнОз БИЧЯБт
    dOrderedAmt:= 0;
    with App.Engine.TradeCore.Orders[FAccounts[scInter].ExchangeKind] do
      for I := 0 to ActiveOrders.Count-1 do
      begin
        aOrder  := ActiveOrders.Orders[i];
        if (aOrder <> nil) and (aOrder.Account = FAccounts[scInter]) and (aOrder.Side < 0) then
          dOrderedAmt := dOrderedAmt + BnFutOrderAmt(aOrder);
      end;

    with App.Engine.TradeCore.Orders[FAccounts[scInter].ExchangeKind] do
      for I := 0 to NewOrders.Count-1 do
      begin
        aOrder  := NewOrders.Orders[i];
        if (aOrder <> nil) and (aOrder.Account = FAccounts[scInter]) and (aOrder.Side < 0) then
          dOrderedAmt := dOrderedAmt + BnFutOrderAmt(aOrder);
      end;

    // 2. ГЊАЁОпИИ ЧЯДТ МіЗЎ (БЙГЛ ИХМі СжЙЎ УМАсНУ)
    dQty   := TPKIdxOrders(Collection).GetDomesOrderQty(FIsEntry, ptLong);
    dPrice := GetHitOrderPrice(-1, scInter);
    dAmt   := CalcBnFutOrderAmt(aPos, -1, dQty, dPrice);

    if not bHit then
      dPrice := FOrdPrice[ptShort];

    // 3. ГЊАЁОп ЕЧДТ МіЗЎ
    dTotAmt := CalcBnFutOrderAmt(aPos, -1, dOrdQty, dPrice) + dOrderedAmt + dAmt;

    if CmpVal(dAvailable, dTotAmt) <= 0 then
    begin
      Exit ;
    end;
    Result := true;
  finally
    if not Result then
      FErrMsg := Format('ЧиПм %s > %s', [DoubleToStr(dTotAmt), DoubleToStr(dAvailable)]);
  end;

end;

function TPKIdxOrderItem.CheckBalance_OsBid(dOrdQty:double): boolean;
var
  dQty, dQty2 : double;
  aPos : TPosition;
  //
  i : integer;
  dAvailable, dOrderedAmt, dTotAmt, dPrice, dAmt : double;
  aOrder : TOrder;
begin
  Result := false;
  aPos := (Collection as TPKIdxOrders).Positions[scInter];
  if aPos = nil then Exit;

  if gAOConfig.Result.UseReduce then
  begin
      // УЛЛъ..ReduceOnly СжЙЎ
      if aPos.Side >= 0 then Exit;
      // РЬЙЬ РмАэ МіЗЎИИХ­ ГЊАЁ РжДйИщ. reduce only СжЙЎРК АХКЮГЊБтПЁ
      // 1. Reduce Only ЗЮ ГЊАЁ РжДТ СжЙЎ МіЗЎРЛ БИЧбДй.
      dQty := TPKIdxOrders(Collection).GetOSReduceOrderQty(FIsEntry, ptLong);
      // 2. Reduce Only ЗЮ ГЊАЁОп Чв СжЙЎ МіЗЎРЛ БИЧбДй. (БЙГЛ УЛЛъ ИХЕЕ СжЙЎ МіЗЎ)
      dQty2:= TPKIdxOrders(Collection).GetDomesOrderQty(FIsEntry, ptShort);
      // 3. РЬЙЬ ЦїСіМЧ МіЗЎИИХ­ СжЙЎРЬ ГЊАЁ РжРИИщ Exit;
      if (dQty + dQty2) > abs(aPos.Volume) then begin
        FErrMsg := Format('ЧиПм Reduec-Only : %s > %s', [ aPos.Symbol.QtyToStr(dQty + dQty2),
          aPos.Symbol.QtyToStr(aPos.Volume)]);
        Exit;
      end
      else
        Result := true;
  end else begin

      dAvailable:= FAccounts[scInter].Available;
      // 1. ГЊАЁ РжДТ СжЙЎ БнОз БИЧЯБт
      dOrderedAmt:= 0;  dQty2 := 0;
      with App.Engine.TradeCore.Orders[FAccounts[scInter].ExchangeKind] do
        for I := 0 to ActiveOrders.Count-1 do
        begin
          aOrder  := ActiveOrders.Orders[i];
          if (aOrder <> nil) and (aOrder.Account = FAccounts[scInter]) and (aOrder.Side > 0) then
          begin
            dQty2 := dQty2 + aORder.ActiveQty;
            dOrderedAmt := dOrderedAmt + BnFutOrderAmt(aOrder);
          end;
        end;

      with App.Engine.TradeCore.Orders[FAccounts[scInter].ExchangeKind] do
        for I := 0 to NewOrders.Count-1 do
        begin
          aOrder  := NewOrders.Orders[i];
          if (aOrder <> nil) and (aOrder.Account = FAccounts[scInter]) and (aOrder.Side > 0) then
          begin
            dQty2 := dQty2 + aOrder.OrderQty;
            dOrderedAmt := dOrderedAmt + BnFutOrderAmt(aOrder);
          end;
        end;

      // 2. ГЊАЁОпИИ ЧЯДТ МіЗЎ (БЙГЛ ИХЕЕ СжЙЎ УМАсНУ)
      dQty   := TPKIdxOrders(Collection).GetDomesOrderQty(FIsEntry, ptShort);
      dPrice := GetHitOrderPrice(1, scInter);
      dAmt   := CalcBnFutOrderAmt(aPos, 1, dQty, dPrice);
      // ЦїСіМЧ УМХЉ
      if (dQty + dQty2 + dOrdQty + aPos.Volume) <= 0 then Exit (true);
      // 3. ГЊАЁОп ЕЧДТ БнОз
      dTotAmt := CalcBnFutOrderAmt(aPos, 1, dOrdQty, FOrdPrice[ptLong]) + dOrderedAmt + dAmt;

      try
        if CmpVal(dAvailable, dTotAmt) <= 0 then
        begin
          Exit ;
        end;
        Result := true;
      finally
        if not Result then
          FErrMsg := Format('ЧиПм БнОз(%s <= %s) | Pos (%s > %s) ',
            [ doubleToStr(dAvailable), doubleToStr(dTotAmt),
              doubleToStr(dQty + dQty2 + dOrdQty), doubleToStr(aPos.Volume)  ]);
      end;
  end;

end;

function TPKIdxOrderItem.CalcKip(estType, ordType: TPositionType): double;
begin
  Result  := 0;
  if FIsEntry then
  begin
    if (FSymbols[scInter].Asks[0].Price <= EPSILON) or (FEstPrice[EstType] <= EPSILON) then Exit;

    if (OrdType = ptLong) then // СјРд БЙГЛ ИХМі..
      Result := ((FSymbols[scDomes].Bids[0].Price / (FEstPrice[EstType]* App.Engine.ApiManager.ExRate.Value)) - 1) * 100
    else
      Result := ((FEstPrice[EstType] / (FSymbols[scInter].Asks[0].Price* App.Engine.ApiManager.ExRate.Value)) - 1) * 100;
  end else
  begin

    if (FSymbols[scInter].Bids[0].Price <= EPSILON) or (FEstPrice[EstType] <= EPSILON) then Exit;

    if (OrdType = ptLong) then // ЧиПм ИХМі..
      Result := ((FEstPrice[EstType]/ (FSymbols[scInter].Bids[0].Price * App.Engine.ApiManager.ExRate.Value)) - 1) * 100
    else
      Result := ((FSymbols[scDomes].Asks[0].Price / (FEstPrice[EstType]* App.Engine.ApiManager.ExRate.Value)) - 1) * 100;
  end;
end;

function TPKIdxOrderItem.CheckCondition(estType, ordType: TPositionType): boolean;
var
  dGap, dKip, dIdx, dAvg: double;
  function calcidx : double;
  begin
    Result := (FTether.GetCustomIndex / App.Engine.ApiManager.ExRate.Value) * 100 - 100;
  end;
begin
  Result := false;
  try
    if (FPIData.bPK) and (FPIData.bPI) then
    begin
      dKip := CalcKip(estType, ordType);
      if FIsEntry then
      begin
        if dKip > FPIData.PK then Exit;
        dIdx := dKip - calcidx;//FTether.GetCustomIndex;
        if dIdx > FPIData.PI then Exit;
      end else
      begin
        if FPIData.PK > dKip then Exit;
        dIdx := dKip - calcidx;//FTether.GetCustomIndex;
        if FPIData.PI > dIdx then Exit;
      end;
    end else
    if (FPIData.bPK) and (not FPIData.bPI) then
    begin
      dKip := CalcKip(estType, ordType);
      if FIsEntry then
      begin
        if dKip > FPIData.PK then Exit;
      end else
      begin
        if FPIData.PK > dKip then Exit;
      end;
    end else
    if (not FPIData.bPK) and (FPIData.bPI) then
    begin
      dIdx := CalcKip(estType, ordType) - calcidx;//FTether.GetCustomIndex;
      if FIsEntry then
      begin
        if dIdx > FPIData.PI then Exit;
      end else
      begin
        if FPIData.PI > dIdx then Exit;
      end;
    end;
  except
    Result := false;
    Exit;
  end;

  if FPIData.bED then
  begin
    dAvg := TPKIdxOrders(Collection).MATerm.Average;
    //dKip := ((Tether.GetCustomIndex - dAvg) / dAvg) * 100;
    dKip := Tether.GetCustomIndex - dAvg;
    if FIsEntry then
    begin
      if dKip > FPIData.ED then Exit;
    end else begin
      if dKip < FPIData.ED then Exit;
    end;
  end;

  Result := True;
end;

function TPKIdxOrderItem.CheckKipValue(aType: TPositionType): boolean;
var
  dTmp : double;
  dEstPrice : array [TPositionType] of double;
begin
  Result := false;
  try

    if aType = ptLong then begin
      dEstPrice[ptLong]   := KipItem[ptLong].Order.Price;
      dEstPrice[ptShort]  := FEstPrice[ptShort];
    end
    else begin
      dEstPrice[ptLong]   := FEstPrice[ptLong];
      dEstPrice[ptShort]  := KipItem[ptShort].Order.Price;
    end;

    if FIsEntry then begin
      dTmp  := dEstPrice[ptShort] * App.Engine.ApiManager.ExRate.Value;
      if CheckZero( dTmp ) then
        FKipValue := 0
      else begin
        FKipValue := (dEstPrice[ptLong] - dTmp) / dTmp * 100;
        if FPIData.PK - DOUBLE_EPSILON > FKipValue then
          Result := true;
      end;
    end else
    begin
      dTmp  := dEstPrice[ptLong] * App.Engine.ApiManager.ExRate.Value;
      if CheckZero( dTmp ) then
        FKipValue := 0
      else begin
        FKipValue := (dEstPrice[ptShort] - dTmp) / dTmp * 100;
        if FKipValue - DOUBLE_EPSILON > FPIData.PK then
          Result := true;
      end;
    end;

  except
  end;
end;

