// СжЙЎ МіЗЎРК БЙГЛ АХЗЁМв БтСиРИЗЮ АшЛъ
// ЧиПм МіЗЎЕЕ БЙГЛ АХЗЁМв БтСиРИЗЮ ЛъСЄ
// ПРРдЗТ ЙцСіИІ РЇЧиМ­ УЙСжЙЎРЛ ИЗОвДТЕЅ.. ОШБзЗЁЕЕ ЕШДй..СжЙЎАЁДЩБнОзРЬ ГВОЦ РжРИИщ ЙЋСЖАЧ ГЊАЁОп ЧбДй.
function TPKIdxOrderItem.GetBuyOrderQty(aType: TPositionType; bHit: boolean) : double;
var
  dQty, dMinQty, dMaxQty, dQty2, dOrdQty, dAmt, dAmt2, dAmt3, dFee,
  denom, dAvailable, dAvailable2, dOrderAmt, dPrice, dHitPrice : double;

  aSpItem : TSPObject;
  aAcnt : TAccount;
  iSide, iPre, iTick : integer;

begin

  if aType = ptLong then begin
    iSide :=  1;
  end
  else begin
    iSide := -1;
  end;
  // ЧиПм АэЗСЧиМ­ УжМв СжЙЎ МіЗЎ
  dMinQty := App.Engine.SymbolCore.CalcMinOrderQty(FSymbols[scDomes], FSymbols[scInter],
    FSymbols[scDomes].Bids[0].Price, iSide);

  if dMinQty <= 0 then Exit (0);
  // МвМіСЁ РкИЎ ЧЪПф
  iPre   := Min(FSymbols[scDomes].Spec.QtyPrecision, FSymbols[scInter].Spec.QtyPrecision);
  // Пј СжЙЎМіЗЎ МвМіСЁ КИСЄ
  dOrdQty:= TruncDecimal(GetOrderQty, iPre);

  if dOrdQty < dMinQty then
    Exit (0);

  try
    dAvailable := 0;  dMaxQty := 0;
    dOrderAmt  := 0;  dAmt3 := 0;  dAmt2 := 0;    dAmt := 0;      dQty2 := 0;  dHitPrice := 0;
    // СжЙЎАЁДЩБнОз БИЧЯБт
    with App.Engine.TradeCore.Orders[FAccounts[scDomes].ExchangeKind] do
      dAmt := GetAcceptOrderAmt(FAccounts[scDomes], 1) +
              GetUnAcceptOrderAmt(FAccounts[scDomes], 1);

    // Taker fee
    with  App.Engine.ApiConfig do
      dFee:= ExchangeInfo[integer(FAccounts[scDomes].ExchangeKind)].GetTradeFee(
        FSymbols[scDomes].Spec.ExApiType, FSymbols[scDomes].Spec.SettleType, ftTaker
      );
    // ГЊАЁОпЧв ИХМі СжЙЎРЬ РжДТ АцПь- 1 ( ЧиПм ИХЕЕ СжЙЎРЬ РжДТАцПь )
    dQty2     := TPKIdxOrders(Collection).GetOSEntryAskOrderQty;
    if dQty2 > EPSILON  then
    begin
      dHitPrice := GetHitOrderPrice(1, scDomes);
      dAmt3     := (dQty2 * dHitPrice) * (1 + (dFee / 100));
    end;

    if bHit then begin
      if dQty2 <= EPSILON then
        dPrice := GetHitOrderPrice(1, scDomes)
      else
        dPrice := dHitPrice;
    end  else
      dPrice := FOrdPrice[ptLong];

    // ГЊАЁОпЧв ИХМі СжЙЎРЬ РжДТ ЦФОЧ -2 ( sp УЛЛъ СжЙЎ )
    aSpItem := App.Engine.StgManager.SPObject.Find(FSymbols[scDomes].Spec.ExchangeType, FSymbols[scDomes].Code );
    dQty := 0.0;  dAmt2 := 0.0;
    if aSpItem <> nil then begin
      aAcnt := App.Engine.TradeCore.FindAccount(aSpItem.SubEx);
      with App.Engine.TradeCore.Orders[aSpItem.SubEx] do
      begin
        dQty := GetActiveOrderQty(aAcnt, stSPOrder, -1) +
                GetUnActiveOrderQty(aAcnt, stSPOrder, -1);
        dAmt2:= (dQty * dPrice )*(1+(dFee/100));
      end;
    end;

    if not bHit then
      with  App.Engine.ApiConfig do
        dFee:= ExchangeInfo[integer(FAccounts[scDomes].ExchangeKind)].GetTradeFee(
          FSymbols[scDomes].Spec.ExApiType, FSymbols[scDomes].Spec.SettleType, ftMaker
        );

    dAvailable  := FAccounts[scDomes].Balance - dAmt - dAmt2 - dAmt3;
    if FSymbols[scDomes].Spec.MinNotional >= dAvailable then
      Result := 0
    else begin
      // РмАэПЁМ­ 0.1% ТїАЈ
      dAvailable2 := dAvailable * (1 - 0.001);
      // НЧСІ РдЗТ ПРЗљНУ А­СІЗЮ 0.05 ММЦУ..
      if dFee <= EPSILON then
        dFee := 0.05;
      dOrderAmt := (dOrdQty * dPrice)*(1+(dFee/100)) ;

      if CmpVal(dAvailable2, dOrderAmt) >= 0 then
        Result := dOrdQty
      else begin
        // МіМіЗс ЙнПЕЧб СжЙЎАЁАн..
        denom := dPrice * (1 + dFee);

        dMaxQty := TruncDecimal(dAvailable2 / denom, iPre);
        if dMaxQty >= dMinQty then
          Result := dMaxQty//CeilDecimal(dMaxQty, iPre)
        else
          Result := 0;
      end;
    end;

  finally
    if Result > EPSILON then
      App.Log(llDebug, 'orderqty', '(ИХМі) %s : %s, %s(%s), fee:%s, %s, %s, %s, %s, %s', [ DoubleToStr(Result),
        FAccounts[scDomes].Balance.ToString, dAvailable2.ToString, dAvailable.ToString,
        dFee.ToString,
        dOrdQty.ToString, dAmt.ToString, dAmt2.ToString, dAmt3.ToString, dMaxQty.ToString ] );

    if Result <= 0 then
      FErrMsg := format('БЙГЛ АЁДЩБнОз %s > %s (%s-%s-%s)  )', [
        DoubleToStr(dOrderAmt), DoubleToStr(dAvailable),
        DoubleToStr(FAccounts[scDomes].Balance),
        DoubleToStr(dAmt), DoubleToStr(dAmt2) ]) ;
  end;
end;

