function TPKIdxOrderItem.GetSellOrderQty: double;
var
  aAsset : TAsset;
  dQty, dQty2, dQty3, dAmt, dAvailableQty : double;
  aSpItem : TSPObject;
  aAcnt : TAccount;

  dMinQty, dOrdQty : double;
