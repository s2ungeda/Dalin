begin

  // ЧиПм АэЗСЧиМ­ УжМв СжЙЎ МіЗЎ
  dMinQty := App.Engine.SymbolCore.CalcMinOrderQty(FSymbols[scDomes], FSymbols[scInter],
    FSymbols[scDomes].Asks[0].Price, -1);

  if dMinQty <= 0 then Exit (0);
  // МвМіСЁ РкИЎ ЧЪПф
  iPre   := Min(FSymbols[scDomes].Spec.QtyPrecision, FSymbols[scInter].Spec.QtyPrecision);
  // Пј СжЙЎМіЗЎ МвМіСЁ КИСЄ
  dOrdQty:= TruncDecimal(GetOrderQty, iPre);

  if dOrdQty < dMinQty then
    Exit (0);

  try

    Result := 0;
    dQty  := 0;   dQty2 := 0;  dQty3 := 0;

    aAsset  := FAccounts[scDomes].Assets.Find(FSymbols[scDomes].Spec.BaseCode);
    if aAsset = nil then Exit;
    if aAsset.Balance <= 0 then Exit;
    //if TPKIdxOrders(Collection).Positions[scInter].Volume >= 0 then Exit;
    // ГЊАЁОпЧв ИХЕЕ СжЙЎРЬ РжДТ ЦФОЧ( sp СјРд СжЙЎ )

    aSpItem := App.Engine.StgManager.SPObject.Find( FSymbols[scDomes].Spec.ExchangeType, FSymbols[scDomes].Code );
    if aSpItem <> nil then begin
      aAcnt := App.Engine.TradeCore.FindAccount(aSpItem.SubEx);
      with App.Engine.TradeCore.Orders[aSpItem.SubEx] do
        dQty := GetActiveOrderQty(aACnt, FSymbols[scDomes], 1 ) +
                GetUnActiveOrderQty(aACnt, FSymbols[scDomes], 1 );
    end;

    // ГЊАЁОп Чв ИХЕЕ СжЙЎ..( ЧиПм ИХМіСжЙЎ УМАс ЕЩАцПь..)
    dQty3  := TPKIdxOrders(Collection).GetOSExitBidOrderQty;

    // ГЊАЁ РжДТ ИХЕЕ СжЙЎ..
    with App.Engine.TradeCore.Orders[FAccounts[scDomes].ExchangeKind] do
      dQty2:= GetActiveOrderQty(FAccounts[scDomes], FSymbols[scDomes], -1 ) +
              GetUnActiveOrderQty(FAccounts[scDomes], FSymbols[scDomes], -1 );

    dAvailableQty := aAsset.Balance - (dQty + dQty2 + dQty3);
    if dAvailableQty <= dMinQty then
      Result := 0
    else begin
      if CmpVal(dAvailableQty, dOrdQty) >= 0 then
        Result := dOrdQty
      else
        Result := TruncDecimal(dAvailableQty, iPre);
    end;

  finally

    if Result > EPSILON then
    App.Log(llDebug, 'orderqty', '(ИХЕЕ) %s : %s, %s, %s, %s, %s, %s', [ DoubleToStr(Result),
      aAsset.Balance.ToString, dAvailableQty.ToString, dOrdQty.ToString,
      dQty.ToString, dQty3.ToString, dQty2.ToString ] );

    if Result <= EPSILON then
      if aAsset <> nil then
        FErrMsg := format('БЙГЛ РмАэ КЮСЗ %s, %s, %s, %s ', [
          DoubleToStr(aAsset.Balance), DoubleToStr(dAvailableQty),
          DoubleToStr(dOrdQty), DoubleToStr(dQty + dQty2 + dQty3) ]);
  end;

end;

procedure TPKIdxOrderItem.GetShortOrderPrice;
var
  aSCType :TSymbolCountryType;
  dKip, dStartPrice, dPrice, dLimitPrice : double;
  bFind : boolean;
begin

  aSCType := TSymbolCountryType(ifThen(FIsEntry, 1, 0));

  if not GetKip(dKip) then Exit;

  dStartPrice := FSymbols[aSCType].Bids[0].Price;
  if FIsEntry then
    dPrice    := FEstPrice[ptLong] / (dKip / 100 + 1) / App.Engine.ApiManager.ExRate.Value
  else
    dPrice    := (FEstPrice[ptLong] * App.Engine.ApiManager.ExRate.Value) * (dKip / 100 + 1) ;

  if CmpVal(dPrice, dStartPrice) <= 0  then
  begin
    // ИХЕЕ 1ШЃАЁ КИДй ХЉДйИщ...ИХЕЕ1ШЃАЁ - 1Tick
    FOrdPrice[ptShort] := TicksFromPrice(FSymbols[aSCType], dStartPrice, 1);
    Exit;
  end;

  dLimitPrice := dStartPrice * (1 + 10 / 100);

  bFind := false;
  // dStartPrice ~ dLimitPrice ЛчРЬПЁ СжЙЎ АЁАнРЛ БИЧбДй.
  // dStartPrice <= dPrice < dLimitPrice
  if (CmpVal(dPrice, dLimitPrice ) < 0 ) and (CmpVal(dStartPrice, dPrice) <= 0) then
    while CmpVal(dStartPrice, dLimitPrice) < 0 do
    begin
      if CmpVal(dStartPrice, dPrice) >= 0 then
      begin
        bFind := true;
        break;
      end;
      dStartPrice  := TicksFromPrice(FSymbols[aSCType], dStartPrice, 1 );
    end;
  FOrdPrice[ptShort]  := ifThenFloat( bFind, dStartPrice, 0 );
  FCalcPrice[ptShort] := dPrice;
end;

  // СјРд - БЙГЛ ИХМі Ord , ЧиПм ИХЕЕ Est
  //      - ЧиПм ИХЕЕ Ord , БЙГЛ ИХМі Est
  // УЛЛъ - БЙГЛ ИХЕЕ ord , ЧиПм ИХМі Est
  //      - ЧиПм ИХМі Ord , БЙГЛ ИХЕЕ Est

procedure TPKIdxOrderItem.ProcessOrder( EstSymbol : TSymbol; EstType : TPositionType;
  bEstCheck : boolean; OrdSymbol: TSymbol; OrdType : TPositionType);
  var
    iSide : Integer;
    dKip, dIdx: double;
begin

  if FDone[OrdType] then Exit;

  if EstType = ptLong then
    iSide := 1
  else
    iSide := -1;

  FEstPrice[EstType] := EstSymbol.CalcEstPrice(iSide, GetSafeMarginQty(EstSymbol));

  if bEstCheck then
    if CheckZero(FEstPrice[EstType]) then
    begin
      CheckEstPrice(OrdType);
      Exit;
    end;

  if not CheckCondition(estType, ordType) then
  begin
    if KipItem[ordType].Order <> nil then
      DoCancelOrder(KipItem[ordType].Order);
    Exit;
  end;

  if OrdType = ptLong then
    GetLongOrderPrice
  else
    GetShortOrderPrice;

  if OrdSymbol = FSymbols[scInter] then
    if not CheckPriceRange then
    begin
      DoLog('СжЙЎАЁАн ЙќРЇ РЬЛѓ');
      if Assigned(FOnKipNotify) then
        FOnKipNotify(Self, RANG_STR );
      Exit;
    end;

  if not CheckZero(FOrdPrice[OrdType]) then CheckOrder(OrdType);
end;


  {
     СјРд
     ЧиПм НУММ ->  БЙГЛ ИХМі Est - >           -> ЧиПм ИХЕЕ Ord -> Check Ord   Side : A
                   ЧиПм ИХЕЕ Est - > Check Est -> БЙГЛ ИХМі Ord -> Check Ord   Side : B
     БЙГЛ НУММ ->  БЙГЛ ИХМі Est - > Check Est -> ЧиПм ИХЕЕ Ord -> Check Ord   Side : A
                   ЧиПм ИХЕЕ Est - >           -> БЙГЛ ИХМі Ord -> Check Ord   Side : B

     УЛЛъ
     ЧиПм НУММ ->  ЧиПм ИХМі Est - > Check Est -> БЙГЛ ИХЕЕ Ord -> Check Ord   Side : A
                   БЙГЛ ИХЕЕ Est - >           -> ЧиПм ИХМі Ord -> Check Ord   Side : B
     БЙГЛ НУММ ->  ЧиПм ИХМі Est - >           -> БЙГЛ ИХЕЕ Ord -> Check Ord   Side : A
                   БЙГЛ ИХЕЕ Est - > Check Est -> ЧиПм ИХМі Ord -> Check Ord   Side : B


     est СОИё, ord СОИё, Check Est ПЉКЮ, est type,  ord type,

  }

