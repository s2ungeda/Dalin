procedure TPKIdxOrderItem.OnOrder(aOrder: TOrder; iEventID : integer);
var
  aType, aType2 : TPositionType;
  aoType: TAutoOrderType;
  iTick, iSide   : integer;
  aSCType : TSymbolCountryType;
  dQty, dTmp, dConQty, dDustQty : double;
begin

  if not IsRun then Exit;
  if aOrder.GroupNo <> FName then Exit;
  if aOrder.Symbol.Spec.BaseCode <> FSymbols[scDomes].Spec.BaseCode then Exit;

  if aOrder.Side > 0 then begin
    aType := ptLong; aType2 := ptShort;
  end  else begin
    aType := ptShort;aType2 := ptLong;
  end;
  // УыМв
  case iEventID of
    ORDER_REJECTED :
      begin
        DoLog('АХКЮЕЪ : ' + aOrder.Represent);
//        DoLog('АХКЮ СОИё: ' + FSymbols[scInter].Code);
        if (aOrder.State = osRejected) and (aOrder.Tag = PUT_ORD) and (KipItem[aType].Order = aOrder) then
        begin
          if aOrder.Symbol = FSymbols[scInter] then
            // ЙйРЬГННКДТ РЮХЭЙњ ОјРЬ ЙйЗЮ СжЙЎ ГЊАЁОп ЕЧМ­..
            KipItem[aType].SetOrder(nil)
// ДыБт ОјРЬ ЙйЗЮ СжЙЎ
          else
//            if FPIData.CommData.ReTryInterval > 100 then
              LegTimer[aType].Enabled := true;
//            else
//              KipItem[aType].SetOrder(nil);
        end
        else if (aOrder.State = osRejected) and (aOrder.Tag = LIQ_ORD) and (KipItem[aType2].LiqOrds.FindOrder(aOrder) <> nil) then
        begin
          if aOrder.ModifyCnt < gAOConfig.Result.ReTryCount then begin
            LegTimerLiq[aType2].Interval  := gAOConfig.Result.ReTryInterval;
            LegTimerLiq[aType2].Enabled := true;
            Exit;
          end
          else begin
            if Assigned(FOnKipNotify) then
              FOnKipNotify(Self, RJCT_STR);
          end;
        end;
      end;
    ORDER_CHANGED :
      begin
        //  СЄСЄШФ ЙЋНМ УГИЎИІ..ЧиОпЧЯСі..???
        DoLog('СЄСЄЕЪ : ' + aOrder.Represent);
        if aOrder.Symbol.Spec.ExchangeType = ekBinance then
          aOrder.ModifyCnt  := aOrder.ModifyCnt + 1;
      end;
    ORDER_CANCELED :
      begin
        DoLog('УыМвЕЪ : ' + aOrder.Represent);
        case aOrder.Tag of
          PUT_ORD : if (KipItem[aType].Order = aOrder) and (aOrder.State = osCanceled) then
                      if aOrder.Symbol = FSymbols[scInter] then
                        // ЙйРЬГННКДТ РЮХЭЙњ ОјРЬ ЙйЗЮ СжЙЎ ГЊАЁОп ЕЧМ­..
                        KipItem[aType].SetOrder(nil)
                      else
// ЕєЗЙРЬ ОјРН
//                        if FKipData.Config.Cfg.UseOrdInterval then
//                          LegTimer[aType].Enabled := true
//                        else
                          KipItem[aType].SetOrder(nil);

          LIQ_ORD : if aOrder.State = osCanceled then
                      KipItem[aType2].DeleteLiqOrder(aOrder);
        end;
      end;
    ORDER_FILLED :
      begin
        var dPrice : double;   dPrice  := 0;
        var bOrder : boolean;  bOrder  := true;

        DoLog(Format('%s %s Fill : %s %s ', [ EntryToStr, ExKindToStr(aOrder.Symbol.Spec.ExchangeType),
          ifThenStr(aOrder.Tag = PUT_ORD,'PUT','HIT'), aOrder.Fills.LastFill.Represent ]));

        if FIsEntry then
          aoType := aoEntry
        else
          aoType := aoExit;

        with (Collection as TPKIdxOrders) do
        begin
          KipReport[aoType].AccFilledQty[aType] := KipReport[aoType].AccFilledQty[aType] + abs(aOrder.Fills.LastFill.Volume);
          KipReport[aoType].TradeAmt[aType]     := KipReport[aoType].TradeAmt[aType] + aOrder.Fills.LastFill.Price * abs(aOrder.Fills.LastFill.Volume);
        end;

        IF KipItem[aType].Order = aOrder THEN
          PKItems[aType].FilledQty  := PKItems[aType].FilledQty + abs(aOrder.Fills.LastFill.Volume);

        if KipItem[aType].Order = aOrder then
        begin
          // ФЁДТ СжЙЎ..
          if aOrder.Symbol = FSymbols[scDomes] then begin
            aSCType := scInter;
            iTick   := gAOConfig.Result.FTick;
          end
          else begin
            aSCType := scDomes;
            iTick   := gAOConfig.Result.STick;
          end;

          if aOrder.Side > 0 then begin
            dPrice  := TicksFromPrice(FSymbols[aSCType], FSymbols[aSCType].Bids[0].Price , -iTick);
            iSide   := -1;
          end
          else begin
            dPrice  := TicksFromPrice(FSymbols[aSCType], FSymbols[aSCType].Asks[0].Price, iTick);
            iSide   := 1;
          end;

          //----------------------------------------------
          dDustQty  := (Collection as TPKIdxOrders).Dusts.GetDust(FSymbols[aSCType], iSide);
          dTmp      := aOrder.Fills.LastFill.Volume + dDustQty;
          //dTmp  :=  aOrder.Fills.LastFill.Volume + PKItems[aType].DustQty;

          if aSCType = scInter then begin
            // 1. БЙГЛ КЮКа УМАсНУ, ЧиПмПЭ МвМіСЁРЬ ДйИЃБтЖЋНУ  ИТУпБт РЇЧЯ ГыПРПРПРЗТ...
            dQty := TruncDecimal(dTmp, FSymbols[scInter].Spec.QtyPrecision);
            if not CheckZero(dTmp - dQty) then
              DoLog( Format('+++++ МвМіСЁРИЗЮ РЮЧб МіЗЎ КЏАц :  %s -> %s +++++',[ doubleToStr(dTmp), DoubleToStr(dQty)]), true);
            // 2. ЧиПм Limit АЁАн КИСЄ..
            dPrice := FSymbols[scInter].GetHitOrderPrice(iSide, dPrice);
          end
          else
            dQty := dTmp;

          if not FSymbols[aSCType].IsOrderAble(dPrice, dQty) then
          begin
            DoLog( Format('+++++ Dust ЙпЛ§ (%s > %s(%s), TotD(%s)) +++++ ', [
              FSymbols[aSCType].Spec.MinNotional.ToString, doubleToStr(dPrice * dQty),
              doubleToStr(dQty),  doubleToStr(dTmp)] ));
            //PKItems[aType].SetDust(dTmp);
            (Collection as TPKIdxOrders).Dusts.SetDust(FSymbols[aSCType], iSide, dTmp);
            KipItem[aType].SetDust(aOrder.Fills.LastFill.Volume);
            // РќЗЎУМАсРЬ ЕЦДТСі УМХЉ ЧиОп ЧЯБтПЁ Exit ИІ ЧЯСі ОЪДТДй.
            //Exit;
            bOrder := false;
          end;

          // СжЙЎМіЗЎРЬ Dust РЬИщ ЦаНК..
          if bOrder then
          begin
//            if dDustQty > 0 then
//            begin
//              DoLog( Format('+++++ Dust АЈМв (%s) +++++', [ doubleToStr(dTmp-dQty) ]));
//              (Collection as TPKIdxOrders).Dusts.SetDust(FSymbols[aSCType], iSide, dTmp - dQty);
//              //PKItems[aType].SetDust(dTmp-dQty);
//            end;
            if ((dTmp - dQty) > EPSILON) or (dDustQty > EPSILON) then
            begin
              DoLog( Format('+++++ Dust Change (%s -> %s) +++++ ', [doubleToStr(dDustQty), doubleToStr(dTmp-dQty)] ));
              // УМАсМіЗЎ + Dust - СжЙЎМіЗЎ
              (Collection as TPKIdxOrders).Dusts.SetDust(FSymbols[aSCType], iSide, dTmp-dQty);
              // УМАс МіЗЎ - СжЙЎМіЗЎ
              KipItem[aType].SetDust(aOrder.Fills.LastFill.Volume-dQty);
            end;
            //----------------------------------------------
            var rOrder : TOrder; rOrder := nil;
            rOrder := DoOrder(aSCType, iSide, dPrice, dQty);
            if rOrder = nil then
            begin
              DoLog('--------------- УЛЛъ СжЙЎ НЧЦа !!!----------------');
            end else
            begin
              KipItem[aType].LiqOrds.Add(rOrder);
            end;
          end;

          // МБСжЙЎ УМАс ЛчПюЕх
          if gAOConfig.Result.UseFirstOrderFill then
            PlaySound(gAOConfig.Result.FillSound);

        end else
        begin
          // УЛЛъСжЙЎ?.

        end;
      end;
  end;

  // kip report
  // УМАс ХыСі(УыМвХыСі РЯЖЇ КЮКаУМАсРЬ РжДйИщ ЛѓХТДТ osFilled) РЬАэ ДыГѕРК СжЙЎ ЛѓХТАЁ osFilled РЯЖЇ
//  if (aOrder.Tag = LIQ_ORD) and (aOrder.Side > 0) then
//    aType := ptShort
//  else if (aOrder.Tag = LIQ_ORD) and (aOrder.Side < 0) then
//    aType := ptLong
//  else if (aOrder.Tag = PUT_ORD) and (aOrder.Side > 0) then
//    aType := ptLong
//  else if (aOrder.Tag = PUT_ORD) and (aOrder.Side < 0) then
//    aType := ptShort
//  else Exit;

  IsDone(ptLong);
  IsDone(ptShort);

end;

function GetPosVolSum(aPos: TPosition): string;
var
  aAss: TAsset;
  dSum : double;
  I: TExchangeKind;
  aAcnt: TAccount;
begin
  //  БЙГЛ РмАэЕщРЛ ДѕЧбДй.
//  App.Engine.TradeCore.fin
  dSum := aPos.Volume;
  for I := ekUpbit to High(TExchangeKind) do
  begin
    aAcnt := App.Engine.TradeCore.FindAccount(i);
    if aAcnt = nil then Continue;
    aAss  := aAcnt.Assets.Find(aPos.Symbol.Spec.BaseCode);
    if aAss = nil then continue;
    dSum := dSum + aAss.Balance;
  end;

  // УМАсТїДТ 4РкИЎ
  Result  := Format('%.4n', [dSum]);
//  Re
end;

procedure TPKIdxOrderItem.IsDone(aType2 : TPositionType);
var
  aOType : TAutoOrderType;
  dTotOrdQty, dTotFilledQty, dFillQty, dGap : double;
  iRes : integer;
begin
  if not KipItem[aType2].IsDone then Exit;

  var aPos := TPKIdxOrders(Collection).Positions[scInter];
  var sRes := GetPosVolSum(aPos);

  DoLog(Format('------------ %d.th  %s %s %s РќЗЎ УМАс-------------- %s (%s) ', [
    FCount, EntryTostr, ifThenStr(aType2 = ptLong, 'ИХМі', 'ИХЕЕ'),
    ifThenStr(KipItem[aType2].Order.Tag = PUT_ORD, 'PUT','HIT'),
    KipItem[aType2].RsltStr, sRes ]) );
  // РќЗЎ УМАс НУ report
  aoType  := GetAOType;
  KipItem[aType2].CalcFillAvgKip;

  KipItem[aType2].CalcCustomIdx(FTether.GetCustomIndex);

  with (Collection as TPKIdxOrders) do
  begin
//    KipReport[aoType].KipFillAvg.KipFill    := KipReport[aoType].KipFillAvg.KipFill + (KipItem[aType2].Kip * KipItem[aType2].Order.FilledQty);
//    KipReport[aoType].KipFillAvg.FilledQty  := KipReport[aoType].KipFillAvg.FilledQty + KipItem[aType2].Order.FilledQty;

    // УМАсТїАЁ ЙпЛ§ЧвМі РжРИЙЧЗЮ ЧзЛѓ РлРКГбРЛ ЛчПыЧбДй.
    dFillQty := min(KipItem[aType2].Order.FilledQty,  KipItem[aType2].FilledQty);
    KipReport[aoType].KipFillAvg.KipFill    := KipReport[aoType].KipFillAvg.KipFill + (KipItem[aType2].Kip * dFillQty);
    KipReport[aoType].KipFillAvg.IdxFill    := KipReport[aoType].KipFillAvg.IdxFill + (KipItem[aType2].IdxPk * dFillQty);
    KipReport[aoType].KipFillAvg.FilledQty  := KipReport[aoType].KipFillAvg.FilledQty + dFillQty;

    DoLog( Format('[%.2f] %s УМАс -> %.2f(%.4n|%.4n), %.2f, (%.8f | %.8f) ', [ FPIData.PK, EntryToStr,
      CalcDiv(KipReport[aoType].KipFillAvg.KipFill, KipReport[aoType].KipFillAvg.FilledQty),
      KipReport[aoType].KipFillAvg.KipFill, KipReport[aoType].KipFillAvg.FilledQty,
      KipItem[aType2].Kip, KipItem[aType2].Order.FilledQty, KipItem[aType2].FilledQty ]) );
  end;

  DebugLog(2);

  if Assigned(FOnKipDoneNotify) then
    FOnKipDoneNotify(KipItem[aType2]);

  inc(FCount);

  if Assigned(FOnKipNotify) then
    FOnKipNotify(Self, ORD_STR );
  // ШНМі УМХЉ --> Уб СжЙЎМіЗЎ УМХЉРИЗЮ КЏАц.
  dTotOrdQty    := FPIData.OrderQty * FPIData.RepeatCnt;
  //dTotFilledQty := PKItems[ptLong].TotFilledQty + PKItems[ptShort].TotFilledQty;
  dTotFilledQty := PKItems[ptLong].FilledQty + PKItems[ptShort].FilledQty;

  dGap := Min(FPIData.OrderQty, dTotOrdQty - dTotFilledQty);

  if dGap <= 0 then begin
    FDone[ptLong] := true;  FDone[ptShort] := true;
    DoLog(Format('1. ** %s %s Done -> O : %.2f, F : %.2f  M : %.2f', [
       EntryTostr, ifThenStr(aType2 = ptLong, 'ИХМі', 'ИХЕЕ'),
       dTotOrdQty, dTotFilledQty, dGap]));
  end
  else if dGap > 0 then
  begin
    if not KipItem[aType2].Order.Symbol.IsOrderAble(FOrdPrice[aType2], dGap) then
    begin
      //FDone[aType2] := true;
      FDone[ptLong] := true;  FDone[ptShort] := true;
      DoLog(Format('2. ** %s %s Done -> O : %.2f, F : %.2f  M : %.2f', [
         EntryTostr, ifThenStr(aType2 = ptLong, 'ИХМі', 'ИХЕЕ'),
         dTotOrdQty, dTotFilledQty, dGap]));
    end;
  end;

  if FDone[ptLong] and FDone[ptShort] then
  begin
    if Assigned(FOnKipNotify) then
      FOnKipNotify(Self, DONE_STR );
  end else
  begin
    OnFillTimer(FillTimer[aType2]);
  end;

  Exit;

//  if iRes <= 0 then
//    bDone := true
//  else begin
//    // ГВРК МіЗЎРЬ Dust РЬИщ ГЁГНДй.
//    KipItem[aType2].Order.Symbol.IsOrderAble(FOrdPrice[aType2], dTotOrdQty-dTotFilledQty )
//
//    if not FSymbols[aSCType].IsOrderAble(dPrice, dQty) then
//          begin
//  end;

end;

