procedure TPKIdxOrderItem.OnTimerLiq(Sender: TObject);
var
  aType : TPositionType;
  i, iTick : integer;
  aOrder, rOrd : TOrder;
  aSCType : TSymbolCountryType;
  dPrice  : double;
  aList   : TList;
begin
  // АХКЮ СжЙЎПЁ ЕєЗЙРЬ..ХИРЬИг
  aList   :=  TList.Create;
  with (Sender as TTimer) do
    try
      aType := TPositionType(Tag);
      for i:= KipItem[aType].LiqOrds.Count-1 downto 0 do begin
        aOrder := KipItem[aType].LiqOrds.Orders[i];
        if aOrder.State = osRejected then
        begin
          if aOrder.ModifyCnt < gAOConfig.Result.ReTryCount then
          begin
            if aOrder.Symbol = FSymbols[scDomes] then begin
              aSCType := scDomes;
              iTick   := gAOConfig.Result.FTick;
            end
            else begin
              aSCType := scInter;
              iTick   := gAOConfig.Result.STick;
            end;

            if aOrder.Side > 0 then
              dPrice  := TicksFromPrice(FSymbols[aSCType], FSymbols[aSCType].Asks[0].Price, iTick)
            else
              dPrice  := TicksFromPrice(FSymbols[aSCType], FSymbols[aSCType].Bids[0].Price, -iTick);

            if not FSymbols[aSCType].IsOrderAble(dPrice, aOrder.OrderQty) then
            begin
              DoLog( Format('+++++ timer Dust ЙпЛ§ (%s > %s) +++++ ', [
                FSymbols[aSCType].Spec.MinNotional.ToString, doubleToStr(dPrice * aOrder.OrderQty)] ));

              (Collection as TPKIdxOrders).Dusts.SetDust(FSymbols[aSCType], aOrder.Side, aOrder.OrderQty);
              KipItem[aType].SetDust(aOrder.OrderQty);

              continue;
            end;

            rOrd := DoOrder(aSCType, aOrder.Side, dPrice, aOrder.OrderQty);
            if rOrd <> nil then
            begin
              rOrd.ModifyCnt  := aOrder.ModifyCnt + 1;
              aList.Add(rOrd);
              DoLog(Format('%d.th Hit СжЙЎ %s', [rOrd.ModifyCnt, rOrd.Represent]) );
              KipItem[aType].LiqOrds.Delete(i);
            end else
              DoLog('--------------- ХИРЬИгЗЮ Hit СжЙЎ Л§МК НЧЦа !!!----------------');
          end;
        end;
      end;

      for I := 0 to aList.Count-1 do
        KipItem[aType].LiqOrds.Add(aList.Items[i]);

    finally
      Enabled := false;
      aList.Free;
    end;
end;

