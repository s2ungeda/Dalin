unit FWithdrawConfig;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants, System.Classes, Vcl.Graphics,
  Vcl.Controls, Vcl.Forms, Vcl.Dialogs, Vcl.StdCtrls, Vcl.Mask, Vcl.ExtCtrls,

  UApiTypes, USymbols, USPItems,
  UAccounts
  ;

type
  TFrmWithdrawConfig = class(TForm)
    Button1: TButton;
    Button2: TButton;
    Panel1: TPanel;
    edtAddress2: TLabeledEdit;
    edtAddress: TLabeledEdit;
    cbNetType: TComboBox;
    Label3: TLabel;
    edtMin: TLabeledEdit;
    Label1: TLabel;
    edtSP: TLabeledEdit;
    edtQty: TLabeledEdit;
    Label2: TLabel;
    edtFee: TLabeledEdit;
    edtRate: TLabeledEdit;
    procedure Button1Click(Sender: TObject);
    procedure edtQtyKeyPress(Sender: TObject; var Key: Char);
    procedure edtSPKeyPress(Sender: TObject; var Key: Char);
    procedure edtRateChange(Sender: TObject);
    procedure FormCreate(Sender: TObject);
    procedure edtFeeChange(Sender: TObject);
  private
    FSymbol: TSymbol;
    FParam : TSPWithdrawParam;
    FAccount: TAccount;
    FAsset: TAsset;
    { Private declarations }
    procedure SetRateQty;
  public
    { Public declarations }
    function Open(aSymbol: TSymbol; aParam : TSPWithdrawParam; bManual : boolean = false): boolean;

    property Symbol : TSymbol read FSymbol write FSymbol;
    property Param  : TSPWithdrawParam read FParam;
    property Account: TAccount read FAccount;
    property Asset  : TAsset   read FAsset;
  end;

var
  FrmWithdrawConfig: TFrmWithdrawConfig;

implementation

uses
  GApp
  ;

{$R *.dfm}

procedure TFrmWithdrawConfig.Button1Click(Sender: TObject);
var
  i : integer;
begin
  FParam.nettype  := cbNetType.Items[cbNetType.ItemIndex];
  FParam.qty      := edtQty.Text;
  FParam.addr1    := edtAddress.Text;
  FParam.addr2    := edtAddress2.Text;

  if not TryStrtoInt( edtMin.Text, i ) then
  begin
    ShowMessage('분 입력 바람');
    ModalResult := mrNone;
    Exit;
  end;

  if i < 2 then
  begin
    ShowMessage('분 은 2 이상 입력 바람');
    ModalResult := mrNone;
    Exit;
  end;

  FParam.minTerm  := StrToInt(edtMin.Text);

  if edtMin.Text = '' then
    FParam.spValue := -0.5
  else
    FParam.spValue  := StrToFloat(edtSP.Text);

  ModalResult := mrOK;
end;

procedure TFrmWithdrawConfig.edtFeeChange(Sender: TObject);
begin
  SetRateQty;
end;

procedure TFrmWithdrawConfig.edtQtyKeyPress(Sender: TObject;
  var Key: Char);
begin
  if not (CharInSet(Key , ['0'..'9','.',#8])) then
    Key := #0;
end;

procedure TFrmWithdrawConfig.edtRateChange(Sender: TObject);
begin
  //
  SetRateQty;
end;

procedure TFrmWithdrawConfig.edtSPKeyPress(Sender: TObject; var Key: Char);
begin
  if not (CharInSet(Key , ['-','0'..'9','.',#8])) then
    Key := #0;
end;

procedure TFrmWithdrawConfig.FormCreate(Sender: TObject);
begin
  FAccount  := nil;
  FAsset    := nil;
end;

function TFrmWithdrawConfig.Open(aSymbol : TSymbol; aParam : TSPWithdrawParam; bManual : boolean): boolean;
var
  idx, i : integer;
begin

  if aSymbol = nil then
  begin
    ShowMessage('종목을 먼저 선택하세요');
    Exit;
  end;

  idx := 0;
  if aSymbol <> nil then
  begin

    for i:=0 to aSymbol.NetworkList.Count-1 do
    begin
      cbNetType.AddItem(aSymbol.NetworkList.Network[i].Name, nil );
      if aParam.nettype = aSymbol.NetworkList.Network[i].Name then
        idx := i;
    end;
  end else
    if aParam.netType <> '' then
      cbNetType.AddItem(aParam.netType, nil );

  if cbNetType.Items.Count > 0 then
    cbNetType.ItemIndex := idx;

  edtQty.Text := aParam.qty;
  edtAddress.Text := aParam.addr1;
  edtAddress2.Text  := aParam.addr2;

  edtMin.Text := aParam.minTerm.toString;
  edtSP.Text  := Format('%.2f', [ aParam.spValue]);

  if aSymbol <> nil then
  begin
    FAccount  := App.Engine.TradeCore.FindAccount( aSymbol.Spec.ExchangeType, amSpot );
    if FAccount <> nil then
      FAsset  := FAccount.Assets.Find( aSymbol.Code );
  end;

  SetRateQty;

  if bManual then
    Button1.Caption := '수동출금';

  Result :=  (ShowModal = mrOK);
end;

procedure TFrmWithdrawConfig.SetRateQty;
var
  iRate : integer;
  dTmp, dFee, dQty  : double;
begin

  if FAsset = nil then Exit;

  if not TryStrToINt(edtRate.Text, iRate) then
    iRate := 100;

  if not TryStrToFloat(edtFee.Text, dFee) then
    dFee  := 0.0;

  dTmp := (FAsset.Balance * iRate / 100) - dFee;

  if dTmp > 0 then
    edtQty.Text  := Format('%.8n', [dTmp]);

end;

end.
