procedure TAutoModifyOrder.WatchOrder(aParam: TSPParam; aMgQuote : TMergedQuote);
var
  res  : TValueRelationship;
  bCnl : boolean;
  sReason : string;

  askPrice, bidPrice : double;
  askVolume, bidVolume : double;
begin

  try

    if FOrder = nil then Exit;

    bCnl := false;

    if FOrder.State = osActive then
    begin
      if (not FOrder.Modify) and (FCount < aParam.AutoModifyCount) then
      begin
        if FOrder.Side > 0 then
        begin

          if aParam.UseHogaMerge then begin
            bidPrice  := aMgQuote.Bids[0].Price;
            askVolume := aMgQuote.Asks[0].Volume;
          end else
          begin
            bidPrice  := FOrder.Symbol.Bids[0].Price;
            askVolume := FOrder.Symbol.Asks[0].Volume;
          end;

          //res := CompareValue( FOrder.Price, FOrder.Symbol.Bids[0].Price );
          res := CompareValue( FOrder.Price, bidPrice );
          // ИХМі ШЃАЁПЭ ААРЛЖЇ
          if res = 0 then
          begin
            if (aParam.MinVolume*3 > askVolume) then begin
              sReason := Format('ИХЕЕШЃАЁ РмЗЎ АЈМв %.4f > %.4f', [aParam.MinVolume*3, askVolume]) ;
              bCnl := true;
            end;
          end else
          if res < 0 then begin
          // ИХМі ШЃАЁКИДй РлРЛЖЇ
            sReason := Format('АЁАн ЙаИВ %s', [ FOrder.Symbol.PriceToStr(bidPrice) ]);
            bCnl := true;
          end;

        end else
        begin

          if aParam.UseHogaMerge then begin
            askPrice  := aMgQuote.Asks[0].Price;
            bidVolume := aMgQuote.Bids[0].Volume;
          end else
          begin
            askPrice  := FOrder.Symbol.Asks[0].Price;
            bidVolume := FOrder.Symbol.Bids[0].Volume;
          end;

          res := CompareValue( FOrder.Price, askPrice );
          // ИХЕЕ ШЃАЁПЭ ААРЛЖЇ
          if res = 0 then
          begin
            if (aParam.MinVolume*3 > bidVolume) then begin
              sReason := Format('ИХМіШЃАЁ РмЗЎ АЈМв %.4f > %.4f', [aParam.MinVolume*2, bidVolume]) ;
              bCnl := true;
            end;
          end else
          if res > 0 then begin
          // ИХЕЕ ШЃАЁКИДй ХЌЖЇ
            sReason := Format('АЁАн ЙаИВ %s', [ FOrder.Symbol.PriceToStr(askPrice) ]);
            bCnl := true;
          end;

        end;

        if bCnl then
        begin

          App.Engine.TradeCore.Orders[ FOrder.Account.ExchangeKind].NewCancelOrder( FOrder, FOrder.ActiveQty);
          App.Engine.TradeBroker.Send( FOrder );

          inc(FCount);

          if Assigned(FOnLog) then
            FOnLog(Self, Format('%s %s СЄСЄРЛ РЇЧб СжЙЎ %d.th УыМв : %s, %s, %s (%s)', [ ExKindToStr( FOrder.Account.ExchangeKind ),
             FOrder.SideToStr, FCount,
             FOrder.Symbol.PriceToStr( FOrder.Price ), FOrder.Symbol.QtyToStr( FOrder.ActiveQty),
             FOrder.OrderNo, sReason
             ] ));
        end;

      end;
    end else
    if FOrder.State = osFilled then
    begin
      FDone := true;
      Exit;
    end;

  finally
    if FCount = FParam.AutoModifyCount then FDone := true;
  end;

end;

{ TModifyOrderList }

procedure TModifyOrderList.CheckOrder;
var
  i : integer;
  aOrder : TOrder;
begin

  for I := Count-1 downto 0 do begin
    aOrder := TAutoModifyOrder(Items[i]).Order;
    if aOrder <> nil then
      if not (aOrder.State in [osReady, osSent, osSrvAcpt, osActive]) then
      begin
        TAutoModifyOrder(Items[i]).Free;
        Delete(i);
      end;
  end;

end;

constructor TModifyOrderList.Create(aParent: TObject);
begin
  FParent := aParent;
end;

destructor TModifyOrderList.Destroy;
var
  I: Integer;
begin
  for I := Count-1 downto 0 do
    TAutoModifyOrder(Items[i]).Free;
  inherited;
end;

function TModifyOrderList.Find(aOrder: TOrder): TAutoModifyOrder;
var
  i : integer;
begin
  Result := nil;

  for I := Count-1 downto 0 do
    if TAutoModifyOrder(Items[i]).Order = aOrder then
    begin
      Result := TAutoModifyOrder(Items[i]);
      break;
    end;
end;

function TModifyOrderList.New(aParam: TSPParam; aNotify: TTextNotifyEvent): TAutoModifyOrder;
begin
  Result := TAutoModifyOrder.Create( aParam, aNotify);
  Add( Result );
end;

procedure TModifyOrderList.WatchOrder(aParam: TSPParam; aMgQuote : TMergedQuote );
var
  i : integer;
begin

  for I := Count-1 downto 0 do
    TAutoModifyOrder(Items[i]).WatchOrder(aParam, aMgQuote);

end;

end.
