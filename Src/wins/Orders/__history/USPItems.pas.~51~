{ TSpOrderUnit }

procedure TSpOrderUnit.CheckOrderList(aType: TSPType);
var
  i : integer;
begin
  i := 0;
  while i <= OrderList[aType].Count - 1 do
  begin
    if not (OrderList[aType].Orders[i].State  in [osReady, osSent, osSrvAcpt, osActive]) then
      OrderList[aType].Delete(i)
    else
      inc(i);
  end;
end;

constructor TSpOrderUnit.Create;
begin
  OrderList[spMajor] := TOrderList.Create;
  OrderList[spSub] := TOrderList.Create;

  BasePrice := 0;
  OrderPrice:= 0;

  BasePriceStr := '';
  OrderPriceStr:= '';
end;

destructor TSpOrderUnit.Destroy;
begin
  OrderList[spMajor].Free;
  OrderList[spSub].Free;
  inherited;
end;

