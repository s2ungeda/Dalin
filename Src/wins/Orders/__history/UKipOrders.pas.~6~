unit UKipOrders;

interface

uses
  System.Classes, System.DateUtils, System.SysUtils

  , UOrders
  , UTypes
  ;

type

  TKipOrder = class( TCollectionItem )
  private
    FDone: boolean;
    FMakeTime: TDateTime;
//    FCount: integer;
  public
    Orders : array [TPositionType] of TOrder;
    PrevOrders: array [TPositionType] of TOrder;
    constructor Create( aColl : TCollection ); override;
    procedure CheckState;
    procedure UpdateOrder( aOrder : TOrder );

    property  MakeTime : TDateTime read FMakeTime;
    property  Done     : boolean read FDone;
//    property  Count    : integer read FCount write FCount;
  end;

  TKipOrders = class( TCollection )
  private
    FIsEntry: boolean;
    FCount: integer;
    function GetKipOrder(i: integer): TKipOrder;
    function GetKip: TKipOrder;
  public
    constructor Create( bEntry : boolean ); overload;
    destructor Destroy; override;

    function New( aBuy, aSell : TOrder ) : TKipOrder;

    property IsEntry : boolean read FIsEntry ;

    property KipOrders[i: integer] : TKipOrder read GetKipOrder;
    property Kip : TKipOrder read GetKip;
    property Count : integer read FCount write FCount;
  end;

implementation

{ TKipOrder }

procedure TKipOrder.CheckState;
begin
  if not FDone then
  begin
    if ( Orders[ptLong].State = osFilled ) and ( Orders[ptShort].State = osFilled ) then
      FDone := true;
  end;
  // ХИРЬИг УМХЉ..АХКЮ ЕШ СжЙЎРЬ РжРИИщ ЙйЗЮ РчСјРд..
end;

constructor TKipOrder.Create(aColl: TCollection);
begin
  inherited Create(aColl);
  Orders[ptLong] := nil;
  Orders[ptShort] := nil;

  PrevOrders[ptLong]  := nil;
  PrevOrders[ptShort] := nil;

  FDone := false;
  FMakeTime := now;
end;

procedure TKipOrder.UpdateOrder(aOrder: TOrder);
var
  aPosType : TPositionType;
begin
  if aOrder.Side > 0 then
    aPosType := ptLong
  else
    aPosType := ptShort;

  PrevOrders[aPosType]  := Orders[aPosType];
  Orders[aPosType]  := aOrder;
end;

{ TKipOrders }


constructor TKipOrders.Create(bEntry: boolean);
begin
  inherited Create( TKipOrder );
  FIsEntry := bEntry;
  FCount := -1;
end;

destructor TKipOrders.Destroy;
begin

  inherited;
end;

function TKipOrders.GetKip: TKipOrder;
begin
  Result := GetKipOrder( FCount-1 );
end;

function TKipOrders.GetKipOrder(i: integer): TKipOrder;
begin
  if (i<0 ) or ( i>=Count) then
    Result := nil
  else
    Result := Items[i] as TKipOrder;
end;

function TKipOrders.New(aBuy, aSell: TOrder): TKipOrder;
begin
  Result := Add as TKipOrder;
  Result.Orders[ptLong]   := aBuy;
  Result.Orders[ptShort]  := aSell;
end;

end.
