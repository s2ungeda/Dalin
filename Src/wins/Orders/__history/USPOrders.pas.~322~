function TSPOrders.GetTotTradeRate: double;
var
  I: Integer;
  aSP : TSPOrder;
  dSum, dPOs: double;
begin
  Result := 0;  dSum := 0;  dPos := 0;
  for I := 0 to Count-1 do
  begin
    aSP := GetSPOrders(i);
    if aSP <> nil then  begin
      if aSP.Run then
        dPos := aSP.BasePosQty;
      dSum := dSum + aSP.AccVolume[spMajor];
    end;
  end;

  if CheckZero( dPos ) then
    Result := 0
  else
    Result := dSum / dPos * 100;
end;

