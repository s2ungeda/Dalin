function TSPOrders.IsWaiting(sType : TSPType): boolean;
var
  iTime : integer;
begin

  Result := false;

  iTime := MilliSecondsBetween( now, LastGetTime[sType] );
  if iTime > 100 then
    Result := true;

end;

procedure TSPOrders.SetTime(sType : TSPType);
