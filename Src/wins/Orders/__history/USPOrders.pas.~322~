function TSPOrder.GetAccVolumeGap: double;
begin
  if (FPositions[spSub] = nil) or (FPositions[spMajor] = nil) then
    Result := 0
  else
    Result := abs(FPositions[spSub].BuyVol + FPositions[spMajor].BuyVol -
      FPositions[spSub].SellVol - FPositions[spMajor].SellVol);
end;

function TSPOrder.GetActiveOrderQty( aType : TAutoOrderType; sType : TSPType; iSide : integer ) : double;
var
  aOrder : TOrder;
  i : integer;
begin
  Result := 0.0;
  for I := 0 to FOrderUnit[aType].OrderList[sType].Count-1 do
  begin
    aOrder :=  FOrderUnit[aType].OrderList[sType].Orders[i];
    if aOrder <>nil then
      if ( aOrder.Side = iSide ) and  (aOrder.State = osActive) then
        Result := Result + aOrder.ActiveQty
      else if ( aOrder.Side = iSide ) and (aOrder.State in [osReady, osSent, osSrvAcpt] ) then
        Result := Result + aOrder.OrderQty;
  end;
end;



function TSPOrder.CheckEntryLimit( var dOrderQty : double ): boolean;
var
  aAsset : TAsset;
  dAvailable, dOrderPrice, dOrderAmt,
    dQty, dQty2, dAmt, dAmt2, dTmp, dFee, dRate : double;
  i : integer;
  stLog, stTmp : string;
  res : TValueRelationship;
begin
  Result := false;

  try
    // 1. 주문가능 금액을 구하고 그 금액으로 주문가능 계약수를 구한다.
    with App.Engine.TradeCore.Orders[FAccounts[spSub].ExchangeKind] do
    begin
      // 섭거래소 나가 있는 매수 미접수/미체결 주문 금액도 도 포함해서 ..체크
      dAmt := GetAcceptOrderAmt(FAccounts[spSub], 1) ;
      dAmt2:= GetUnAcceptOrderAmt(FAccounts[spSub], 1);
    end;

    dAvailable  := FAccounts[spSub].Asset.Balance - dAmt - dAmt2;
    //-------------------
    dTmp := Floor(dAvailable / FOrderPrice[aoEntry] * 10000) / 10000;
    dOrderQty := Min( dOrderQty, dTmp);

    if ( FBasePrice[aoEntry] * dOrderQty ) <= MIN_ORD_AMT then
    begin
      stLog := '30';// format('진입 : 최소주문가능금액보 커야 함 %.8f', [dOrderQty] ) ;
      Exit;
    end;

//    dTmp := SimpleRoundTo(dAvailable / FOrderPrice[aoEntry] , -4 );
//    if ((dTmp * FOrderPrice[aoEntry]) > MIN_ORD_AMT) and ( dTmp < dOrderQty ) then
//    begin
////      DoLog( format('진입 : 주문수량 교체 %.4n -> %.4n  (%.0n / %s)  ',
////        [ dOrderQty, dTmp, dAvailable, FSymbols[spSub].PriceToStr(FOrderPrice[aoEntry]) ] ) );
//      stTmp :=  format('주문수량 교체 %.4n -> %.4n', [ dOrderQty, dTmp] );
//      dOrderQty := dTmp;
//    end;
    //-------------------
    dFee:= App.Engine.ApiConfig.ExchangeInfo[ integer(FAccounts[spSub].ExchangeKind) ].ApiInfo[FSymbols[spSub].Spec.ExApiType].TradeFee;
    dOrderAmt   := (FOrderPrice[aoEntry] * dOrderQty) * ( 1+(dFee/100))  ;

    res  := CompareValue( dAvailable, dOrderAmt );
    if res <= 0 then
    begin
      stLog := '40';
//      format('진입 : 서브거래소 주문가능 금액 부족 %.0n > %.0n (%.0n, %.0n, %.0n) ', [
//        dOrderAmt,  dAvailable,  FAccounts[spSub].Asset.Balance, dAmt, dAmt2 ]);
      Exit;
    end;

    // 메인 매도 주문이니 잔고 가 있어야 한다..
    aAsset  := FAssets[spMajor];// FAccounts[spMajor].Assets.Find(FParam.Code);
    if aAsset = nil then begin stLog :='50'{'진입 : 주거래소 매도 잔고없음'}; Exit; end;

    dQty := 0;    dQty2 := 0;
    // 섭거래소 나가 있는 매수 주문도 포함해서 ..체크
    with App.Engine.TradeCore.Orders[FAccounts[spSub].ExchangeKind] do
      dQty := GetActiveOrderQty(FAccounts[spSub], FSymbols[spSub], 1 ) +
              GetUnActiveOrderQty(FAccounts[spSub], FSymbols[spSub], 1 );
    // 주거래소 나가 있는 매도 주문도 포함해서 ..체크
    with App.Engine.TradeCore.Orders[FAccounts[spMajor].ExchangeKind] do
      dQty2:= GetActiveOrderQty(FAccounts[spMajor], FSymbols[spMajor], -1 ) +
              GetUnActiveOrderQty(FAccounts[spMajor], FSymbols[spMajor], -1 );

    res := CompareValue( aAsset.Balance, dOrderQty + dQty + dQty2 );
    //if aAsset.Balance < FParam.EntryQty then begin
    if res < 0 then
    begin
      stLog := '50';
//        format('진입 : 주거래소 매수 잔고 부족 %4n < %.4n + %.4n + %.4n)', [
//         aAsset.Balance, dOrderQty, dQty, dQty2   ]);
      Exit;
    end;

    stTmp := Format('진입 : 주거래소 매수잔고 ( %.4n > %.4n + %.4n + %.4n)  ',
      [ aAsset.Balance, dOrderQty, dQty, dQty2 ]);

    // 서브 거래서 잔고 한도 체크..
    aAsset  := FAssets[spSub];// FAccounts[spSub].Assets.Find(FParam.Code);
    if aAsset = nil then
      aAsset  := FAccounts[spSub].Assets.New( FParam.Code, FAccounts[spSub] );

    // 매수잔고 + 미체결주문 + 나가야할주문 > 매수잔고 한도
    //dQty  := App.Engine.TradeCore.Orders[FAccounts[spSub].ExchangeKind].GetActiveOrderQty(FAccounts[spSub], FSymbols[spSub], 1);
    // 진입, 서브거래소, 매수  주문 수량을 가져와라.
    // dQty := GetActiveOrderQty( aoEntry, spSub, 1 );
    //dTmp := FParam.LimitEntryPos - FPositions[spSub].Volume - dQty;
//    dTmp := FParam.LimitQty - FPositions[spSub].Volume - dQty;
//    res  := CompareValue( dTmp, dOrderQty  );
//    if res < 0 then
//    begin
//      stLog := '60';//'진입 : 한도';
//      Exit;
//    end;

    // subBal / TotBal * LimitRate
    dQty  := GetActiveOrderQty( aoEntry, spSub, 1 );
    dTmp  := ifThen( Volumes[spSub] < 0, 0.0, Volumes[spSub]);

    dRate := ( FParam.HavingEntryQty + dTmp + dQty + dOrderQty) / (FAssets[spMajor].Balance + FAssets[spSub].Balance)*100;// FParam.LimitRate;
    res   := CompareValue( FParam.LimitRate, dRate  );
    if res < 0 then
    begin
      stLog := '60';
      Exit;
    end;

    DoLog( Format('%s  서브 주문가능금액 -> %.0n < %.0n (%.0n, %.0n, %.0n) , %.0n%% ', [ stTmp,
        dOrderAmt,  dAvailable,  FAccounts[spSub].Asset.Balance, dAmt, dAmt2, dRate ]), false );

    Result := true;
  finally
    if (not Result) and Assigned( FOnSPNotify2 ) then
      FOnSPNotify2( Self, stLog );
//    if not Result then
//      DoLog( stLog  );
  end;
end;

function TSPOrder.CheckLiquidLimit(var dOrderQty : double ): boolean;
var
  aAsset : TAsset;
  dAvailable, dOrderPrice, dOrderAmt, dQty, dFee, dRate,
    dTmp, dAmt, dAmt2 : double;
  i : integer;
  stLog, stTmp : string;
  res : TValueRelationship;
begin
  Result := false;

  try
    // 주거래소 주문가능 금액 체크
    // 1. 잔고 -> balance
    // 2. 나가 있는 주문, 나가려고 하는 주문 -> 주거래소 미접수, 미체결
    // 3. 나가야 되는 주문.. -> 섭거래소 청산 주문..

    // 2번 체크
    with App.Engine.TradeCore.Orders[FAccounts[spMajor].ExchangeKind] do
      dAmt := GetAcceptOrderAmt(FAccounts[spMajor], 1) +
              GetUnAcceptOrderAmt(FAccounts[spMajor], 1);

    // 3번 체크
    dFee:= App.Engine.ApiConfig.ExchangeInfo[ integer(FAccounts[spMajor].ExchangeKind) ].ApiInfo[FSymbols[spMajor].Spec.ExApiType].TradeFee;
    with App.Engine.TradeCore.Orders[FAccounts[spSub].ExchangeKind] do
    begin
      dQty := GetActiveOrderQty(FAccounts[spSub], stSPOrder, -1) +
               GetUnActiveOrderQty(FAccounts[spSub], stSPOrder, -1);
//      dAmt2 := GetActiveOrderAmt(FAccounts[spSub], stSPOrder, -1) +
//              GetUnActiveOrderAmt(FAccounts[spSub], stSPOrder, -1);
      dAmt2 := (dQty * FBasePrice[aoExit])*(1+(dFee/100));
    end;

    // 주거래소 주문가능 금액
    dAvailable  := FAccounts[spMajor].Asset.Balance - dAmt - dAmt2;
    // 주문가능 금액
    dTmp := Floor(dAvailable / FBasePrice[aoExit] * 10000) / 10000;
    dOrderQty := Min( dOrderQty, dTmp);

    if ( FBasePrice[aoExit] * dOrderQty ) <= MIN_ORD_AMT then
    begin
      stLog := '-30';//format('청산 : 최소주문가능금액보 커야 함 %.8f', [dOrderQty]);
      Exit;
    end;

    dOrderAmt := (FOrderPrice[aoExit] * dOrderQty)*(1+(dFee/100)) ;
    res  := CompareValue( dAvailable, dOrderAmt );
    if res <= 0 then
    begin
      stLog := '-40';//'청산 : 주거래소 주문가능 금액 부족';
      Exit;
    end;

    // 서브 매도 주문이니 잔고 가 있어야 한다..
    aAsset  := FAssets[spSub];//FAccounts[spSub].Assets.Find(FParam.Code);
    if aAsset = nil then begin stLog := '-50'{'청산 : 서브거래소 매도 잔고 없음'}; Exit; end;

    dQty := 0;
    // 섭거래소 나가 있는 매도 주문도 포함해서 ..체크
    with App.Engine.TradeCore.Orders[FAccounts[spSub].ExchangeKind] do
    begin
      dQty := GetActiveOrderQty(FAccounts[spSub], FSymbols[spSub], -1 ) +
              GetUnActiveOrderQty(FAccounts[spSub], FSymbols[spSub], -1 );
    end;
    res := CompareValue( aAsset.Balance, dOrderQty + dQty );

    //res := CompareValue( aAsset.Balance, dOrderQty );
    //if aAsset.Balance < FParam.LiquidQty  then
    if res < 0 then
    begin
      stLog := '-50';// '청산 : 서브거래소 매수 잔고 부족';
      Exit;
    end;

    stTmp := Format('청산 : 섭거래소 매수잔고 ( %.4f > %.4f + %.4f )',
      [ aAsset.Balance, dOrderQty, dQty ]);

    // 메인거래소 한도 체크
    // --------------- 비율로 수정 후 한도 체크 --------------------------------
    dQty := GetActiveOrderQty( aoExit, spMajor, 1 );
    dTmp  := ifThen( Volumes[spMajor] < 0, 0.0, Volumes[spMajor]);
    dRate := (FParam.HavingLiquidQty + dTmp + dQty + dOrderQty) / (FAssets[spMajor].Balance + FAssets[spSub].Balance) * 100;
    res  := CompareValue( FParam.LimitRate, dRate  );
    if res < 0 then
    begin
      stLog := '-60';
      Exit;
    end;
    // --------------- 비율로 수정 후 한도 체크 --------------------------------

    DoLog( Format('%s : 주거래소 주문가능금액 -> %.0n < %.0n (%.0n, %.0n, %.0n, %.2f), %.0n%% ', [stTmp,
      dOrderAmt,  dAvailable,  FAccounts[spMajor].Asset.Balance, dAmt, dAmt2, dFee, dRate]), false);

    Result := true;
  finally
    if (not Result) and Assigned( FOnSPNotify2 ) then
      FOnSPNotify2( Self, stLog );
    // 화면표시 X,   파일에만 남김.
//    if not Result then
//      DoLog(stLog );
  end;
end;

function TSPOrder.CheckMajorAvailableAmt( dOrderPrice, dOrderQty : double ) : boolean;
var
  dAmt, dAmt2, dQty, dOrderAmt, dAvailable, dFee : double;
  res : TValueRelationship;
begin

  with App.Engine.TradeCore.Orders[FAccounts[spMajor].ExchangeKind] do
    dAmt := GetAcceptOrderAmt(FAccounts[spMajor], 1) +
            GetUnAcceptOrderAmt(FAccounts[spMajor], 1);
  // 3번 체크
  dFee:= App.Engine.ApiConfig.ExchangeInfo[ integer(FAccounts[spMajor].ExchangeKind) ].ApiInfo[FSymbols[spMajor].Spec.ExApiType].TradeFee;
  with App.Engine.TradeCore.Orders[FAccounts[spSub].ExchangeKind] do
  begin
    dAmt2 := GetActiveOrderAmt(FAccounts[spSub], stSPOrder, -1) +
            GetUnActiveOrderAmt(FAccounts[spSub], stSPOrder, -1);
    //dAmt2 := (dQty * dOrderPrice)*(1+(dFee/100));
  end;

  dAvailable  := FAccounts[spMajor].Asset.Balance - dAmt - dAmt2;

  dOrderAmt := (dOrderPrice * dOrderQty)*(1+(dFee/100)); ;
  res  := CompareValue( dAvailable, dOrderAmt );

  if res <= 0 then begin
    Exit (false);
  end;

  Result := true;
end;

function TSPOrder.CheckMajorAvailableBalance( dOrderQty : double ) : boolean;
var
  dQty, dQty2 : double;
  res : TValueRelationship;
begin
  // 섭거래소 나가 있는 매수 주문도 포함해서 ..체크
  with App.Engine.TradeCore.Orders[FAccounts[spSub].ExchangeKind] do
    dQty := GetActiveOrderQty(FAccounts[spSub], FSymbols[spSub], 1 ) +
            GetUnActiveOrderQty(FAccounts[spSub], FSymbols[spSub], 1 );
    // 주거래소 나가 있는 매도 주문도 포함해서 ..체크
  with App.Engine.TradeCore.Orders[FAccounts[spMajor].ExchangeKind] do
    dQty2:= GetActiveOrderQty(FAccounts[spMajor], FSymbols[spMajor], -1 ) +
            GetUnActiveOrderQty(FAccounts[spMajor], FSymbols[spMajor], -1 );

  res := CompareValue( FAssets[spMajor].Balance, dOrderQty + dQty + dQty2 );

  if res < 0 then begin
    Exit (false);
  end;

  Result := true;
end;


procedure TSPOrder.SetReady( aType : TAutoOrderType; bValue : boolean) ;
begin
  if FParam.UseMdodifyDelay then
  begin
    FTimer[aType].Interval  := Round(FParam.ModifyDelaySec * 1000);
    FTimer[aType].Enabled := true;
    FLastOrdQty[aType]    := 0;
//    DoLog( Format('--- %s Flag=false 타이머 시작 (%d) ---' , [ ifthenStr(aType=aoEntry,'진입','청산'),
//       FOrderUnit[aType].OrderList[spSub].Count] ) , true );
  end
  else begin
    FReady[aType] := bValue;
    FLastOrdQty[aType]    := 0;
    DoLog( Format('%s 섭주문 재개 (%d / %d)  No timer' , [ ifthenStr(aType=aoEntry,'진입','청산'),
       FOrderUnit[aType].OrderList[spSub].Count, FOrderUnit[aType].OrderList[spMajor].Count ]) , true );
  end;
end;

procedure TSPOrder.OnOrder(aOrder: TOrder; iEventID : integer);
var
  dPrice : double;
  iTick  : integer;
  aNewOrder : TOrder;
  aModOrder : TAutoModifyOrder;
begin

  if aOrder.GroupNo <> FName then
  begin
    Exit;
  end;

  // 매수, 매도, 종목에 따라 처리 분기
  if aOrder.Symbol = FSymbols[spMajor] then
  begin
    var aType : TAutoOrderType;
    if aOrder.Side > 0 then
      aType := aoExit
    else
      aType := aoEntry;

    case aOrder.OrderType of
      otNormal:
        case aOrder.State of
          osActive:
            begin
            //  FModifyOrderList[aoEntry].New( FParam, OnModifyOrderLog ).SetOrder( aOrder, true )  ;
            end;
          osSrvRjt,
          osRejected:
            begin
              DoLog( Format('주거래소 %s 주문 거부 : %s, %s, %s, %s', [ aOrder.OrderTypeToStr,
                ifThenStr(aType=aoEntry,'진입','청산'),
                ifThenStr(aOrder.Side >0 , '매수','매도'), aOrder.Symbol.PriceToStr( aOrder.Price ),
                aOrder.Symbol.QtyToStr( aOrder.OrderQty ) ] ), true);

              // 거부면 어떻게 하지?...
              if aOrder.OrderType = otNormal then begin
                if aOrder.Side > 0  then
                  MustOrdQty[ptLong] := MustOrdQty[ptLong] + aOrder.OrderQty
                else
                  MustOrdQty[ptShort] := MustOrdQty[ptShort] + aOrder.OrderQty;

                DoLog( Format('거부로 인한 체결차 발생 -> (S:%s,L:%s)', [
                  FSymbols[spMajor].QtyToStr(MustOrdQty[ptShort])
                  , FSymbols[spMajor].QtyToStr(MustOrdQty[ptLong]) ])  , true);
              end;
            end;
        end;

      otCancel:
        if aOrder.State in [osCanceled, osFilled] then
        begin
          // 취소한 주문이 주거래소 체결시키기 위한 주문이면
          // 바로 주문을 낸다.
          aModOrder := FModifyOrderList[aType].Find(aOrder);
          if aModOrder <> nil then
          begin

            var dOrdPrice : double;
            // 체결 되게
            if aOrder.Side > 0 then begin
              if FParam.UseHogaMerge then
                dOrdPrice := FMgQuotes[spMajor].Asks[0].Price
              else
                dOrdPrice := FSymbols[spMajor].Asks[0].Price;
            end else
            begin
              if FParam.UseHogaMerge then
                dOrdPrice := FMgQuotes[spMajor].Bids[0].Price
              else
                dOrdPrice := FSymbols[spMajor].Bids[0].Price;
            end;

            // 체결 안되게
//            if aOrder.Side > 0 then begin
//              if FParam.UseHogaMerge then
//                dOrdPrice := FMgQuotes[spMajor].Bids[0].Price
//              else
//                dOrdPrice := FSymbols[spMajor].Bids[0].Price;
//            end else
//            begin
//              if FParam.UseHogaMerge then
//                dOrdPrice := FMgQuotes[spMajor].Asks[0].Price
//              else
//                dOrdPrice := FSymbols[spMajor].Asks[0].Price;
//            end;

            if aModOrder.Count >= FParam.AutoModifyCount then begin
              if aType = aoEntry then
                iTick := FParam.AutoModifyLastTick * -1
              else
                iTick := FParam.AutoModifyLastTick;

              dPrice := TicksFromPrice( aOrder.Symbol, dOrdPrice, iTick)
            end
            else
              dPrice := dOrdPrice;

            aNewOrder := DoOrder( aOrder.Account, aOrder.Symbol, aOrder.Side, dPrice, aOrder.CanceledQty, aType = aoEntry);
            if aNewOrder <> nil then begin
              DoLog(format('%s : 주거래소로 정정 %d.th 주문', [ ifThenStr(aType=aoEntry,'진입','청산'), aModOrder.Count]), true);
              FOrderUnit[aType].OrderList[spMajor].Add( aNewOrder );
              aModOrder.SetOrder( aNewOrder, true);
            end;
          end;
        end;
    end;

    FModifyOrderList[aType].CheckOrder;

  end else
  if aOrder.Symbol = FSymbols[spSub] then
  begin
    if aOrder.Side > 0  then begin
      //if not FParam.UseEntry then Exit;
      // 진입...까는 주문
      CheckAutoPutOrder( aoEntry, aOrder );
      FLastOrdQty[aoEntry]  := aOrder.ActiveQty + aOrder.FilledQty;
    end else
    begin
      //if not FParam.UseLiquid then Exit;
      // 청산...까는 주문
      CheckAutoPutOrder( aoExit, aOrder );
      FLastOrdQty[aoExit]  := aOrder.ActiveQty + aOrder.FilledQty;
    end;
  end
  else
    Exit;
end;

procedure TSPOrder.OnFill(aOrder: TOrder);
var
  ord, newOrd : TOrder;
  i   : integer;
  dQty, dFillQty  : double;
  aType : TAutoOrderType;
  sType : TSPType;
  bOrder : boolean;
begin

  // 매수, 매도, 종목에 따라 처리 분기
  if aOrder.Symbol = FSymbols[spMajor] then
  begin
    if aOrder.Side > 0  then begin
      // 청산...치는 주문
      aType := aoExit;
    end else
    begin
      // 진입.. 치는 주문
      aType := aoEntry;
    end;
    sType := spMajor;
  end
  else if aOrder.Symbol = FSymbols[spSub] then
  begin
    if aOrder.Side > 0  then begin
      // 진입...까는 주문
      //CheckAutoPutOrder( aoEntry, aOrder );
      aType := aoEntry;
    end else
    begin
      // 청산...까는 주문
      //CheckAutoPutOrder( aoExit, aOrder );
      aType := aoExit;
    end;
    sType := spSub;
  end else
    Exit;

  ord := FOrderUnit[aType].OrderList[sType].FindOrder( aOrder );
//  ord := FOrderUnit[aType].OrderList[sType].FindOrder( aOrder.OrderNo );
  if ord = nil then Exit;

  // 서브거래소 주문이 체결 되면..주거래소로 주문.
  with ord.Fills do
  begin
    DoLog( Format('%s 주문 체결-> %s,[ %s, %s ]', [ ifThenStr(aType=aoEntry,'진입','청산'),
      ord.Represent,
      aOrder.Symbol.PriceToStr( LastFill.Price ),   aOrder.Symbol.QtyToStr( LastFill.Volume )
     ] ), true);

    var dPrice, dAmt : double;
    dPrice :=  FBasePrice[aType];

//    // 테스트 : 체결 안되게
//    if ord.Side < 0 then
//      dPrice := FSymbols[spMajor].Bids[0].Price
//    else
//      dPrice := FSymbols[spMajor].Asks[0].Price;

    // 주거래소로 주문..
    if sType = spSub then begin

      bOrder := true;

      if (dPrice * LastFill.Volume) < MIN_ORD_AMT then
      begin
        bOrder := false;
        if aOrder.Side > 0  then begin
          // 섭 매수체결 -> 주 매도주문 수량
          MustOrdQty[ptShort]  := MustOrdQty[ptShort] + LastFill.Volume;
        end
        else begin
          // 섭 매도체결 -> 주 매수주문 수량
          MustOrdQty[ptLong] := MustOrdQty[ptLong] + LastFill.Volume;
        end;

        DoLog( Format('Dust 체결차 발생 -> (S:%s,L:%s)', [
          FSymbols[spMajor].QtyToStr(MustOrdQty[ptShort])
          , FSymbols[spMajor].QtyToStr(MustOrdQty[ptLong]) ])  , true);

      end else
      begin
        dQty   := LastFill.Volume;

        if (aOrder.Side > 0) and (MustOrdQty[ptShort] > 0)  then begin
          dQty := LastFill.Volume + MustOrdQty[ptShort];
          if CheckMajorAvailableBalance(dQty) then begin
            DoLog( Format('체결차 +  주거래소로 주문 %.4n -> %.4n', [LastFill.Volume, dQty]), true );
            MustOrdQty[ptShort] := 0;
          end
          else
            dQty := LastFill.Volume;
        end
        else if (aOrder.Side < 0) and (MustOrdQty[ptLong] >0) then begin
          dQty := LastFill.Volume + MustOrdQty[ptLong];
          if CheckMajorAvailableAmt(dPrice, dQty) then
          begin
            DoLog( Format('체결차 +  주거래소로 주문 %.4n -> %.4n', [LastFill.Volume, dQty]), true );
            MustOrdQty[ptLong] := 0;
          end
          else
            dQty := LastFill.Volume;
        end;
      end;

      if bOrder then
      begin
        newOrd  := DoOrder( FAccounts[spMajor], FSymbols[spMajor],  ifThen(aType=aoEntry,-1,1),
            dPrice, dQty, aType=aoEntry );
            //FSymbols[spMajor].Asks[3].Price, LastFill.Volume, true );
        if newOrd <> nil then begin
          FOrderUnit[aType].OrderList[spMajor].Add( newOrd );
          FModifyOrderList[aType].New( FParam, OnModifyOrderLog ).SetOrder( newOrd, true )  ;
        end;
      end;
    end;
    // 주거래소 누적 거래량.
    //if sType = spMajor then
    AccVolume[sType] := AccVolume[sType] + LastFill.Volume;
  end;

  FOrderUnit[aType].CheckOrderList(sType);
  FModifyOrderList[aType].CheckOrder;

  if FOrderUnit[aType].OrderList[sType].Count <= 0 then
  begin
    if sType = spSub then
    // 주거래소가 전량 체결 되야...섭거래소가 나가게끔 수정
//    if sType = spMajor then
//      SetReady(aType, false );
    DoLog( Format('%s 전량체결 %s' , [ IfThenStr(aType=aoEntry,'진입', '청산'),
      IfThenStr(sType=spMajor,'(주)','(섭)')    ]), true );
  end;

  if FPositions[sType] = nil then Exit;
  FPositions[sType].AddFill( ord.Fills.LastFill );
  // 코인전송시마다 거래량을 초기화해야 해서,  한도계산을 위해 잔고는 별도로 구한다.
  Volumes[sType]  := Volumes[sType] + (ord.Fills.LastFill.Volume * aOrder.Side);
  // 코인전송시마다 거래량을 초기화
  if sType = spSub then
  begin
    if aOrder.Side > 0 then
      SubAccVol[ptLong] := SubAccVol[ptLong] + ord.Fills.LastFill.Volume
    else
      SubAccVol[ptShort]:= SubAccVol[ptLong] + ord.Fills.LastFill.Volume;
  end;

  if (FOrderUnit[aType].OrderList[spSub].Count <= 0) and (FOrderUnit[aType].OrderList[spMajor].Count <= 0)then
  begin
    if (sType = spMajor) or ((sType = spSub) and (not bOrder)) then
      if CheckAccVolumeDiff(aType) then
      begin
        SetReady(aType, false );
        if sType = spMajor then
          DoLog( Format('%s 전량체결 (주)', [ IfThenStr(aType=aoEntry,'진입', '청산')]), true )
        else
          DoLog( Format('%s 최소금액 체결 (섭)', [ IfThenStr(aType=aoEntry,'진입', '청산')]), true );
      end;
  end;
end;

