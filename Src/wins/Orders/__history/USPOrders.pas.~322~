function TSPOrder.CheckAccVolumeDiff(aType: TAutoOrderType): boolean;
var
  dDiff, dAcc : double;
begin
  if (FPositions[spSub] = nil) or (FPositions[spMajor] = nil) then
    Result := true
  else begin
    if aType = aoEntry then begin
      dDiff := abs(FPositions[spSub].BuyVol - FPositions[spMajor].SellVol);
      dAcc  := FPositions[spSub].BuyVol;
    end else
    begin
      dDiff := abs(FPositions[spSub].SellVol - FPositions[spMajor].BuyVol);
      dAcc  := FPositions[spSub].SellVol;
    end;

    if (dDiff <= ZERO_EPSILON) or (dAcc <= ZERO_EPSILON) then
      Result := true
    else begin

      if dDiff <= MIN_ORD_AMT then
        Result := true
      else begin
        Result := false;
        DoLog( Format('%s 체결차 %.4n -> 주 체결대기', [
          ifThenStr( aType = aoEntry, '진입', '청산'), dDiff ]), true);
      end;
    end;
  end;
end;

