{ TSPOrder }

procedure TSPOrder.CalcSPValue;
begin

  if CheckZero( FSymbols[spMajor].Bids[0].Price ) then
    FSPValue[aoEntry] := 0
  else
    FSPValue[aoEntry] := ( FSymbols[spSub].Bids[0].Price - FSymbols[spMajor].Bids[0].Price )
      / FSymbols[spMajor].Bids[0].Price;

  if CheckZero( FSymbols[spMajor].Asks[0].Price ) then
    FSPValue[aoExit] := 0
  else
    FSPValue[aoExit] := ( FSymbols[spSub].Asks[0].Price - FSymbols[spMajor].Asks[0].Price )
      / FSymbols[spMajor].Asks[0].Price;
end;

constructor TSPOrder.Create(aColl: TCollection);
var
  I: TSPType;
  j: TAutoOrderType;
begin
  inherited Create( aColl );

  FRun := false;

  for I := spMajor to High(TSPType) do
  begin
    FSymbols[i]   := nil;
    FAccounts[i]  := nil;
    FAssets[i]    := nil;

    FMgQuotes[i]  := TMergedQuote.Create;
    FPositions[i] := nil;//TSPPosition.Create( nil );

  end;

  for j := aoEntry to High(TAutoOrderType) do
  begin
    FTimer[j] := TTimer.Create(nil);
    FTimer[j].OnTimer  := OnDelayTimer;
    FTimer[j].Enabled  := false;
    FTimer[j].Tag      := integer(j);

    FOrderUnit[j] := TSpOrderUnit.Create;

    FModifyOrderList[j] := TModifyOrderList.Create(self);

    FLastOrdQty[j]      := 0.0;
  end;

  FTimer2 := TTimer.Create(nil);
  FTimer2.OnTimer  := OnMustOrderTimer;
  FTimer2.Enabled  := false;
  FTimer2.Interval := 1000;

  MustOrdQty[ptLong]  := 0;
  MustOrdQty[ptShort] := 0;

end;

destructor TSPOrder.Destroy;
var
   I: TSPType;
   j: TAutoOrderType;
begin

  for j := aoEntry to High(TAutoOrderType) do
  begin
    FTimer[j].Free;
    FOrderUnit[j].Free;
    FModifyOrderList[j].Free;
  end;

  for I := spMajor to High(TSPType) do
  begin
//    FMgQuotes[i].Free;
    FPositions[i].Free;
  end;

  inherited;
end;

procedure TSPOrder.DoAllOrderCancel;
begin
  FOrderUnit[aoEntry].DoCancelOrder(QS,'');
  FOrderUnit[aoExit].DoCancelOrder(QS,'');
end;

procedure TSPOrder.DoLog(stLog: string; bShow : boolean );
begin
  stLog := FName + ' : ' + stLog;
  App.Log( llInfo, FParam.Code + '_SP', ' %s', [ stLog]  );
  if bShow and  Assigned( FOnSPNotify) then
    FOnSPNotify( Self, stLog );
end;

procedure TSPOrder.DoMustOrder(ptType: TPositionType);
var
  dAmt, dQty, dPrice : double;
  aOrder  : TOrder;
  aType   : TAutoOrderType;
begin

  if IsZero(MustOrdQty[ptType]) then Exit;

  if ptType = ptLong then begin
    if FParam.UseHogaMerge then
      dPrice := FMgQuotes[spMajor].Asks[0].Price
    else
      dPrice := FSymbols[spMajor].Asks[0].Price;
    aType := aoExit;
    // 주거래소 매수 주문 가능 금액 구하기...
    if not CheckMajorAvailableAmt( dPrice, MustOrdQty[ptType]) then Exit;

  end else
  begin
    if FParam.UseHogaMerge then
      dPrice := FMgQuotes[spMajor].Bids[0].Price
    else
      dPrice := FSymbols[spMajor].Bids[0].Price;
    aType := aoEntry;

    if not CheckMajorAvailableBalance(MustOrdQty[ptShort]) then Exit;
  end;

  if dPrice * MustOrdQty[ptType] < MIN_ORD_AMT then Exit;

  aOrder  := DoOrder( FAccounts[spMajor], FSymbols[spMajor],  ifThen(ptType=ptLong,1,-1),
      dPrice, MustOrdQty[ptType],  aType = aoEntry );

  if aOrder <> nil then begin
    MustOrdQty[ptType] := 0;
    DoLog( '체결차 발생으로 인한 주문',true);
    FOrderUnit[aType].OrderList[spMajor].Add( aOrder );
    FModifyOrderList[aType].New( FParam, OnModifyOrderLog ).SetOrder( aOrder, true )  ;
  end ;

end;

function TSPOrder.GetPriceInfo( aSymbol : TSymbol; bEntry : boolean ) : string;
var
  aType : TAutoOrderType;
begin

  if bEntry then
    aType := aoEntry
  else
    aType := aoExit;

  Result := Format('B:%s, C:%s, M:%s', [
        aSymbol.PriceToStr(FBasePrice[aType]),
        FmtString(4, FTargetPrice[aType]),
        aSymbol.PriceToStr(FCompPrice[aType])
         ] );
end;

function TSPOrder.DoOrder( aAcnt : TAccount; aSymbol : TSymbol; iSide: integer; dPrice: double;
  dOrderVol : double;  bEntry: boolean): TOrder;
  var
    sType : TSPType;
begin

  Result := nil;

  if (aAcnt=nil) or (aSymbol=nil)  then Exit;

  if IsZero(dPrice) or IsZero(dOrderVol) then
  begin
    DoLog( Format('%s wrong parameter %f, %f', [ ifThenStr( bEntry,'진입','청산')
      , dPrice, dOrderVol ]));
    Exit;
  end;

  if not App.Engine.TradeCore.CheckLimitOrder( aAcnt, aSymbol, iSide, dPrice, dOrderVol, ORD_AUTO) then
  begin
    DoLog( '주문 제한에 걸림', true );
    Exit;
  end;

  Result := App.Engine.TradeCore.Orders[ aSymbol.Spec.ExchangeType ].NewOrder(
    aAcnt, aSymbol, iSide, dOrderVol, pcLimit, dPrice, tmGTC
  );

  if Result <> nil then
  begin
    Result.StgType  := stSPOrder;
    Result.Entry    := bEntry;
    Result.GroupNo  := FName;
    App.Engine.TradeBroker.Send(Result);

    if aSymbol.Spec.ExchangeType = FParam.SubEx then
      sType := spSub
    else
      sType := spMajor;

    TSPOrders( Collection ).SetTime(sType);

    DoLog( Format('%s 주문 -> %s, (%s) ', [ ifThenStr( bEntry,'진입','청산'),
      Result.Represent  , GetPriceInfo( aSymbol, bEntry )
       ]  ), true );

  end else
  begin
    DoLog( Format('%s 주문 생성 실패 (%s %s)', [ ifThenStr( bEntry, '진입','청산'),
      ExKindToStr( aSymbol.Spec.ExchangeType ),
      ifThenStr( iSide = 1, '매수','매도') ]), true ) ;
    Exit;
  end;
end;

procedure TSPOrder.Init( aItem : TSPParam );
var
  I: TSPType;
begin

  FSymbols[spMajor] := App.Engine.SymbolCore.BaseSymbols.FindSymbol(aItem.Code, aItem.MajorEx);
  FSymbols[spSub]   := App.Engine.SymbolCore.BaseSymbols.FindSymbol(aItem.Code, aItem.SubEx  );

  FAccounts[spMajor]  := App.Engine.TradeCore.FindAccount( aItem.MajorEx );
  FAccounts[spSub]    := App.Engine.TradeCore.FindAccount( aItem.SubEx );

  FMgQuotes[spMajor].SetSymbol( FSymbols[spMajor], aItem.HogaMergeUnit );
  FMgQuotes[spSub].SetSymbol( FSymbols[spSub], aItem.HogaMergeUnit );

  FBasePosQty := 0;
  for I := spMajor to High(TSPType) do
  begin
    if FPositions[i] <> nil then
      FPositions[i].Free;
    FPositions[i] := TSPPosition.Create(nil);
    FPositions[i].Account := FAccounts[i];
    FPositions[i].Symbol  := FSymbols[i];

    FOrderUnit[TAutoOrderType(i)].Init( OnOrderUnitLog, TAutoOrderType(i) = aoEntry );
    FReady[TAutoOrderType(i)] := false;

    if FAccounts[i] <> nil then begin
      FAssets[i]  := FAccounts[i].Assets.Find(aItem.Code);
      if FAssets[i] = nil then
        FAssets[i]  := FAccounts[i].Assets.New(aItem.Code, FAccounts[i]);
    end;

    AccVolume[i] := 0;
    Volumes[i]  := 0;

    FBasePosQty := FBasePosQty + FAssets[i].Balance;
  end;

  InitLimit;
  FParam  := aItem;
end;

procedure TSPOrder.Init(aSymbols: TSPSymbolArray; aMsgQuotes: TMergedQuoteArray;
  aItem: TSPParam);
var
  I: TSPType;
begin
  for I := spMajor to High(TSPType) do
  begin
    FSymbols[I] := aSymbols[I];
    FMgQuotes[i]:= aMsgQuotes[I];
  end;

  FAccounts[spMajor]  := App.Engine.TradeCore.FindAccount( aItem.MajorEx );
  FAccounts[spSub]    := App.Engine.TradeCore.FindAccount( aItem.SubEx );

  FBasePosQty := 0;

  for I := spMajor to High(TSPType) do
  begin
    if FPositions[i] <> nil then
      FPositions[i].Free;
    FPositions[i] := TSPPosition.Create(nil);
    FPositions[i].Account := FAccounts[i];
    FPositions[i].Symbol  := FSymbols[i];

    FOrderUnit[TAutoOrderType(i)].Init( OnOrderUnitLog, TAutoOrderType(i) = aoEntry );
    FReady[TAutoOrderType(i)] := false;

    if FAccounts[i] <> nil then begin
      FAssets[i]  := FAccounts[i].Assets.Find(aItem.Code);
      if FAssets[i] = nil then
        FAssets[i]  := FAccounts[i].Assets.New(aItem.Code, FAccounts[i]);
    end;

    AccVolume[i] := 0;
    Volumes[i]  := 0;

    FBasePosQty := FBasePosQty + FAssets[i].Balance;
  end;

  FParam  := aItem;

  MustOrdQty[ptLong]  := 0;
  MustOrdQty[ptShort] := 0;

  InitLimit;
end;

procedure TSPOrder.InitLimit;
begin
  Volumes[spMajor]  := 0;
  Volumes[spSub]    := 0;

  SubAccVol[ptLong] := 0;
  SubAccVol[ptShort]:= 0;
end;

function TSPOrder.IsRun: boolean;
begin
  Result := false;

  if not FRun then Exit;
  if ( FSymbols[spMajor] = nil ) or ( FSymbols[spSub] = nil ) then Exit;
  if ( FAccounts[spMajor] = nil ) or ( FAccounts[spSub] = nil ) then Exit;

  Result := true;
end;

function TSPOrder.GetMajorBasePrice( bEntry : boolean; bCheckVol : boolean ) : TMarketDepth;
var
  aDepths : TMarketDepths;
begin

  if FParam.UseHogaMerge then begin
    if bEntry then
      aDepths := FMgQuotes[spMajor].Bids
    else
      aDepths := FMgQuotes[spMajor].Asks;
  end else
  begin
    if bEntry then
      aDepths := FSymbols[spMajor].Bids
    else
      aDepths := FSymbols[spMajor].Asks;
  end;

  if bCheckVol then
    Result := aDepths.GetBiggerDepth(FParam.MinVolume)
  else
    Result := aDepths.Depths[0];
end;

