var
  dTmp, dQty2, dQty : double;
begin
  //if FPositions[spSub] = nil then Exit (FParam.EntryQty);

// 한도비율로 변경되면서 수정
//  if aType = aoEntry then
//    dQty2 := {FParam.LimitEntryPos}FParam.LimitQty - ( FPositions[spSub].BuyVol - FPositions[spSub].SellVol )
//  else
//    dQty2 := {FParam.LimitLiquidPos}FParam.LimitQty - ( FPositions[spSub].SellVol - FPositions[spSub].BuyVol );

//  if FParam.UseVolumeRate then
//  begin
//    dQty := SimpleRoundTo( (FBaseVolume[aType] * ( FParam.VolumeRate / 100 )), -4);
//    if dQty2 > dQty then
//      Result := min( FParam.EntryQty, dQty )
//    else
//      Result := min( FParam.EntryQty, dQty2 );
//  end else
//  begin
//    Result := min(FParam.EntryQty, dQty2);
//  end;
//  if True then

  if aType = aoEntry then begin
    dTmp  := ifThen( Volumes[spSub] < 0, 0.0, Volumes[spSub]);
    dQty2 := (FAssets[spMajor].Balance + FAssets[spSub].Balance) * FParam.LimitRate / 100 - (FParam.HavingEntryQty + dTmp);
  end
  else begin
    dTmp  := ifThen( Volumes[spMajor] < 0, 0.0, Volumes[spMajor]);
    dQty2 := (FAssets[spMajor].Balance + FAssets[spSub].Balance) * FParam.LimitRate / 100 - (FParam.HavingLiquidQty + dTmp);
  end;

  // 수량이 마이너스면..한도임
  if (dQty2 < 0 ) and Assigned( FOnSPNotify2 ) then
    FOnSPNotify2( Self, ifThenStr(aType = aoEntry, '60', '-60') );

  if FParam.UseVolumeRate then
  begin
    dQty   := SimpleRoundTo( (FBaseVolume[aType] * ( FParam.VolumeRate / 100 )), -4);
    Result := min(min( FParam.EntryQty, dQty ), dQty2) ;
  end else
  begin
    Result := min(FParam.EntryQty, dQty2);
  end;

end;

function TSPOrder.GetSubCompPrice(bEntry: boolean): double;
var
  dTmp : double;
  res : TValueRelationship;
begin
  case FParam.BasePrice of
    0 : if bEntry then
          Result := TicksFromPrice( FSymbols[spSub], FSymbols[spSub].Asks[0].Price, -FParam.BaseTick )
        else
          Result := TicksFromPrice( FSymbols[spSub], FSymbols[spSub].Bids[0].Price, FParam.BaseTick );
    1 : if bEntry then
          Result := TicksFromPrice( FSymbols[spSub], FSymbols[spSub].Last, -FParam.BaseTick )
        else
          Result := TicksFromPrice( FSymbols[spSub], FSymbols[spSub].Last, FParam.BaseTick );
    2 : if bEntry then
        begin

          dTmp := TicksFromPrice( FSymbols[spSub], FSymbols[spSub].Bids[0].Price, FParam.BaseTick );
          // 매도호가가 더 커야 한다.
          res := CompareValue( dTmp, FSymbols[spSub].ASks[0].Price );

          if res >= 0 then
            Result := TicksFromPrice( FSymbols[spSub], FSymbols[spSub].ASks[0].Price, -1 )
          else
            Result := dTmp;

//          DoLog( Format('-- 진입 %s, %s->%s, %s (%d,%d) --', [ FSymbols[spSub].PriceToStr(FSymbols[spSub].ASks[0].Price), FSymbols[spSub].PriceToStr(dTmp),
//            FSymbols[spSub].PriceToStr(Result), FSymbols[spSub].PriceToStr(FSymbols[spSub].Bids[0].Price), res, FParam.BaseTick ] ));

        end else
        begin

          dTmp := TicksFromPrice( FSymbols[spSub], FSymbols[spSub].ASks[0].Price, -FParam.BaseTick );
          // 매수호가가 더 커야 한다.
          res := CompareValue( FSymbols[spSub].Bids[0].Price, dTmp );

          if res >= 0 then
            Result := TicksFromPrice( FSymbols[spSub], FSymbols[spSub].Bids[0].Price, 1 )
          else
            Result := dTmp;

//          DoLog( Format('-- 청산 %s, %s->%s, %s (%d,%d) --', [ FSymbols[spSub].PriceToStr(FSymbols[spSub].ASks[0].Price), FSymbols[spSub].PriceToStr(dTmp),
//            FSymbols[spSub].PriceToStr(Result), FSymbols[spSub].PriceToStr(FSymbols[spSub].Bids[0].Price), res, FParam.BaseTick ] ));
        end;
//    2 : if bEntry then
//          Result := FSymbols[spSub].Bids[0].Price //TicksFromPrice( FSymbols[spSub], FSymbols[spSub].Bids[0].Price, FParam.BaseTick )
//        else
//          Result := FSymbols[spSub].ASks[0].Price; //TicksFromPrice( FSymbols[spSub], FSymbols[spSub].ASks[0].Price, -FParam.BaseTick );
