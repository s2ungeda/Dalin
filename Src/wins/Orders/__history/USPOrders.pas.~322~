function TSPOrder.GetSubEntryPrice( dTargetPrice, dBasePrice : double; var dEntryPrice : double ) : boolean;
var
  i : integer;
  dPrice : double;
  res : TValueRelationship;
begin
  Result := false;

  res := CompareValue( dTargetPrice, dBasePrice );

  if res >= 0  then begin
    dEntryPrice := dBasePrice;
    Result      := true;
  end
  else
    // 호가 제한 적용 ( 2호가만 )
    for I := 0 to 2-1 do
    begin
      dPrice  := TicksFromPrice( FSymbols[spSub], dBasePrice, -i );
      res := CompareValue( dTargetPrice, dPrice );
      if res >= 0 then
      begin
        dEntryPrice := dPrice;
        Result      := true;
        break;
      end;
    end;
end;
