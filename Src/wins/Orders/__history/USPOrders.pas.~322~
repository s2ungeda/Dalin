procedure TSPOrders.OnTrade(aData: TObject; iEvent: integer);
var
  aOrder : TOrder;
  i : integer;
begin

  aOrder := aData as TOrder;
  if aOrder.StgType <> stSPOrder then Exit;

  for I := 0 to Count-1 do
    case iEvent of
      ORDER_ACCEPTED,
      ORDER_REJECTED,
      ORDER_CANCELED : GetSPOrders(i).OnOrder(aOrder, iEvent );
      ORDER_FILLED: GetSPOrders(i).OnFill(aOrder);
    end;
end;

