function TPutKipOrderItem.GetKip(var dKip : double): boolean;
var
  aSymbol : TSymbol;
  dPrice  : double;
begin

  if TFrmPutKipOrder(FParent).cbUseIDX.Checked then
  begin
    aSymbol := App.Engine.SymbolCore.Tethers[FSymbols[scDomes].Spec.ExchangeType];
    if aSymbol = nil then Exit (false);
    if App.Engine.ApiManager.ExRate.Value <= 1 then Exit;

    dPrice := ifThenFloat(FIsEntry, aSymbol.Bids[0].Price, aSymbol.Asks[0].Price);
    if dPrice < EPSILON then Exit (false);

    dKip := FKipData.Kip + ((dPrice / App.Engine.ApiManager.ExRate.Value * 100) - 100);
  end else
    dKip := FKipData.Kip;

  Result := true;
end;

