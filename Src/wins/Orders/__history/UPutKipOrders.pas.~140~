begin
  FSymbols[scDomes]  := nil;
  FSymbols[scInter]  := nil;

  FAccounts[scDomes]  := nil;
  FAccounts[scInter]  := nil;

  FTether             := nil;

  FOrdPrice[ptLong]   := 0;
  FOrdPrice[ptShort]  := 0;

  FCalcPrice[ptLong]  := 0;
  FCalcPrice[ptShort] := 0;

  FParent           := nil;

  FKipValue := 0;
  FEstPrice[ptLong]   := 0;
  FestPrice[ptShort]  := 0;

  FWorking  := false;
  //FFirstOrder := false;
  FCount    := 1;
end;

function TPutKipOrderItem.IsRun: boolean;
begin
  Result := false;
  if not FRun then Exit;
  if FParent = nil then Exit;
  if FTether = nil then Exit;

  if ( FSymbols[scDomes] = nil ) or ( FSymbols[scInter] = nil ) then Exit;
  if ( FAccounts[scDomes] = nil ) or ( FAccounts[scInter] = nil ) then Exit;

  if FDone then Exit;

  Result := true;
end;

procedure TPutKipOrderItem.NewOrders(aType : TPositionType);
begin
  KipItem[aType] := PKItems[aType].New(PKItems[aType].Count);
  KipItem[aType].IsEntry  := FIsEntry;
  KipItem[aType].KipValue := KipData.Kip;
end;

procedure TPutKipOrderItem.OnFillTimer(Sender: TObject);
var
  aType : TPositionType;
begin
  // 전량 체결 후 딜레이..타이머
  aType := TPositionType((Sender as TComponent).Tag);
  NewOrders(aType);

  DoLog(Format('%d - 매도:%d, 매수:%d', [ FCount, PKItems[ptShort].Count, PKItems[ptLong].Count ]));
  FillTimer[aType].Enabled := false;
end;

procedure TPutKipOrderItem.OnOrder(aOrder: TOrder; iEventID : integer);
var
  aType, aType2 : TPositionType;
  aoType: TAutoOrderType;
  iTick, iSide   : integer;
  aSCType : TSymbolCountryType;
  dQty, dTmp, dConQty, dDustQty : double;
begin

  if not IsRun then Exit;
  if aOrder.GroupNo <> FName then Exit;
  if aOrder.Symbol.Spec.BaseCode <> FSymbols[scDomes].Spec.BaseCode then Exit;

  if aOrder.Side > 0 then begin
    aType := ptLong; aType2 := ptShort;
  end  else begin
    aType := ptShort;aType2 := ptLong;
  end;
  // 취소
  case iEventID of
    ORDER_REJECTED :
      begin
        DoLog('거부됨 : ' + aOrder.Represent);
        if (aOrder.State = osRejected) and (aOrder.Tag = PUT_ORD) and (KipItem[aType].Order = aOrder) then
        begin
          if aOrder.Symbol = FSymbols[scInter] then
            // 바이낸스는 인터벌 없이 바로 주문 나가야 되서..
            KipItem[aType].SetOrder(nil)
          else
            if FKipData.Config.Cfg.UseOrdInterval then
              LegTimer[aType].Enabled := true
            else
              KipItem[aType].SetOrder(nil);
        end
        else if (aOrder.State = osRejected) and (aOrder.Tag = LIQ_ORD) and (KipItem[aType2].LiqOrds.FindOrder(aOrder) <> nil) then
        begin
          if aOrder.ModifyCnt < FKipData.Config.Cfg.ReTryCount then begin
            LegTimerLiq[aType2].Enabled := true;
            Exit;
          end
          else begin
            if Assigned(FOnKipNotify) then
              FOnKipNotify(Self, RJCT_STR);
          end;
        end;
      end;
    ORDER_CHANGED :
      begin
        //  정정후 무슨 처리를..해야하지..???
        DoLog('정정됨 : ' + aOrder.Represent);
      end;
    ORDER_CANCELED :
      begin
        DoLog('취소됨 : ' + aOrder.Represent);
        case aOrder.Tag of
          PUT_ORD : if (KipItem[aType].Order = aOrder) and (aOrder.State = osCanceled) then
                      if aOrder.Symbol = FSymbols[scInter] then
                        // 바이낸스는 인터벌 없이 바로 주문 나가야 되서..
                        KipItem[aType].SetOrder(nil)
                      else
                        if FKipData.Config.Cfg.UseOrdInterval then
                          LegTimer[aType].Enabled := true
                        else
                          KipItem[aType].SetOrder(nil);

          LIQ_ORD : if aOrder.State = osCanceled then
                      KipItem[aType2].DeleteLiqOrder(aOrder);
        end;
      end;
    ORDER_FILLED :
      begin
        var dPrice : double;   dPrice  := 0;
        var bOrder : boolean;  bOrder  := true;

        DoLog(Format('%s %s Fill : %s %s ', [ EntryToStr, ExKindToStr(aOrder.Symbol.Spec.ExchangeType),
          ifThenStr(aOrder.Tag = PUT_ORD,'PUT','HIT'), aOrder.Fills.LastFill.Represent ]));

        if FIsEntry then
          aoType := aoEntry
        else
          aoType := aoExit;

        with (Collection as TPutKipOrders) do
        begin
          KipReport[aoType].AccFilledQty[aType] := KipReport[aoType].AccFilledQty[aType] + abs(aOrder.Fills.LastFill.Volume);
          KipReport[aoType].TradeAmt[aType]     := KipReport[aoType].TradeAmt[aType] + aOrder.Fills.LastFill.Price * abs(aOrder.Fills.LastFill.Volume);
        end;

        if KipItem[aType].Order = aOrder then
        begin
          // 치는 주문..
          if aOrder.Symbol = FSymbols[scDomes] then begin
            aSCType := scInter;
            iTick   := StrToIntDef(TFrmPutKipOrder(FParent).edtFutOrdTick.Text, 10);
          end
          else begin
            aSCType := scDomes;
            iTick   := StrToIntDef(TFrmPutKipOrder(FParent).edtSpotOrdTick.Text, 10);
          end;

          if aOrder.Side > 0 then begin
            dPrice  := TicksFromPrice(FSymbols[aSCType], FSymbols[aSCType].Bids[0].Price , -iTick);
            iSide   := -1;
          end
          else begin
            dPrice  := TicksFromPrice(FSymbols[aSCType], FSymbols[aSCType].Asks[0].Price, iTick);
            iSide   := 1;
          end;

          //----------------------------------------------
          dDustQty  := (Collection as TPutKipOrders).Dusts.GetDust(FSymbols[aSCType], iSide);
          dTmp      := aOrder.Fills.LastFill.Volume + dDustQty;
          //dTmp  :=  aOrder.Fills.LastFill.Volume + PKItems[aType].DustQty;

          if aSCType = scInter then begin
            // 1. 국내 부분 체결시, 해외와 소수점이 다르기땜시  맞추기 위하 노오오오력...
            dQty := TruncDecimal(dTmp, FSymbols[scInter].Spec.QtyPrecision);
            if not CheckZero(dTmp - dQty) then
              DoLog( Format('+++++ 소수점으로 인한 수량 변경 :  %s -> %s +++++',[ doubleToStr(dTmp), DoubleToStr(dQty)]), true);
            // 2. 해외 Limit 가격 보정..
            dPrice := FSymbols[scInter].GetHitOrderPrice(iSide, dPrice);
          end
          else
            dQty := dTmp;

          if not FSymbols[aSCType].IsOrderAble(dPrice, dQty) then
          begin
            DoLog( Format('+++++ Dust 발생 (%s > %s(%s), TotD(%s)) +++++ ', [
              FSymbols[aSCType].Spec.MinNotional.ToString, doubleToStr(dPrice * dQty),
              doubleToStr(dQty),  doubleToStr(dTmp)] ));
            //PKItems[aType].SetDust(dTmp);
            (Collection as TPutKipOrders).Dusts.SetDust(FSymbols[aSCType], iSide, dTmp);
            KipItem[aType].SetDust(aOrder.Fills.LastFill.Volume);
            // 전량체결이 됐는지 체크 해야 하기에 Exit 를 하지 않는다.
            //Exit;
            bOrder := false;
          end;

          // 주문수량이 Dust 이면 패스..
          if bOrder then
          begin
//            if dDustQty > 0 then
//            begin
//              DoLog( Format('+++++ Dust 감소 (%s) +++++', [ doubleToStr(dTmp-dQty) ]));
//              (Collection as TPutKipOrders).Dusts.SetDust(FSymbols[aSCType], iSide, dTmp - dQty);
//              //PKItems[aType].SetDust(dTmp-dQty);
//            end;
            if ((dTmp - dQty) > EPSILON) or (dDustQty > EPSILON) then
            begin
              DoLog( Format('+++++ Dust Change (%s -> %s) +++++ ', [doubleToStr(dDustQty), doubleToStr(dTmp-dQty)] ));
              // 체결수량 + Dust - 주문수량
              (Collection as TPutKipOrders).Dusts.SetDust(FSymbols[aSCType], iSide, dTmp-dQty);
              // 체결 수량 - 주문수량
              KipItem[aType].SetDust(aOrder.Fills.LastFill.Volume-dQty);
            end;
            //----------------------------------------------
            var rOrder : TOrder; rOrder := nil;
            rOrder := DoOrder(aSCType, iSide, dPrice, dQty);
            if rOrder = nil then
            begin
              DoLog('--------------- 청산 주문 실패 !!!----------------');
            end else
            begin
              KipItem[aType].LiqOrds.Add(rOrder);
            end;
          end;

        end else
        begin
          // 청산주문?.

        end;
      end;
  end;

  // kip report
  // 체결 통지(취소통지 일때 부분체결이 있다면 상태는 osFilled) 이고 대놓은 주문 상태가 osFilled 일때
//  if (aOrder.Tag = LIQ_ORD) and (aOrder.Side > 0) then
//    aType := ptShort
//  else if (aOrder.Tag = LIQ_ORD) and (aOrder.Side < 0) then
//    aType := ptLong
//  else if (aOrder.Tag = PUT_ORD) and (aOrder.Side > 0) then
//    aType := ptLong
//  else if (aOrder.Tag = PUT_ORD) and (aOrder.Side < 0) then
//    aType := ptShort
//  else Exit;

  IsDone(ptLong);
  IsDone(ptShort);

end;

procedure TPutKipOrderItem.IsDone(aType2 : TPositionType);
var
  aOType : TAutoOrderType;
  dPrice, dFillQty : double;
  aSymbol  : Tsymbol;

begin
  if not KipItem[aType2].IsDone then Exit;

  DoLog(Format('------------ %d.th  %s %s %s 전량 체결-------------- %s', [
    FCount, EntryTostr, ifThenStr(aType2 = ptLong, '매수', '매도'),
    ifThenStr(KipItem[aType2].Order.Tag = PUT_ORD, 'PUT','HIT'),
    KipItem[aType2].RsltStr ]) );
  // 전량 체결 시 report
  aoType  := GetAOType;
  KipItem[aType2].CalcFillAvgKip;

  dPrice  := 0;
  if FSymbols[scDomes] <> nil then
  begin
    aSymbol := App.Engine.SymbolCore.Tethers[FSymbols[scDomes].Spec.ExchangeType];
    if aSymbol <> nil then
      dPrice := ifThenFloat(FIsEntry, aSymbol.Bids[0].Price, aSymbol.Asks[0].Price);
  end;

  KipItem[aType2].CalcIdxPk(dPrice);

  with (Collection as TPutKipOrders) do
  begin
//    KipReport[aoType].KipFillAvg.KipFill    := KipReport[aoType].KipFillAvg.KipFill + (KipItem[aType2].Kip * KipItem[aType2].Order.FilledQty);
//    KipReport[aoType].KipFillAvg.FilledQty  := KipReport[aoType].KipFillAvg.FilledQty + KipItem[aType2].Order.FilledQty;

    // 체결차가 발생할수 있으므로 항상 작은넘을 사용한다.
    dFillQty := min(KipItem[aType2].Order.FilledQty,  KipItem[aType2].FilledQty);
    KipReport[aoType].KipFillAvg.KipFill    := KipReport[aoType].KipFillAvg.KipFill + (KipItem[aType2].Kip * dFillQty);
    KipReport[aoType].KipFillAvg.FilledQty  := KipReport[aoType].KipFillAvg.FilledQty + dFillQty;

    DoLog( Format('[%.2f] %s 체결 -> %.2f(%.4n|%.4n), %.2f, (%.8f | %.8f) ', [ FKipData.Kip, EntryToStr,
      CalcDiv(KipReport[aoType].KipFillAvg.KipFill, KipReport[aoType].KipFillAvg.FilledQty),
      KipReport[aoType].KipFillAvg.KipFill, KipReport[aoType].KipFillAvg.FilledQty,
      KipItem[aType2].Kip, KipItem[aType2].Order.FilledQty, KipItem[aType2].FilledQty ]) );
  end;

  DebugLog(2);

  if Assigned(FOnKipDoneNotify) then
    FOnKipDoneNotify(KipItem[aType2]);

  inc(FCount);

  if Assigned(FOnKipNotify) then
    FOnKipNotify(Self, ORD_STR );

  if FCount < (FKipData.RepeatCnt + 1) then begin
    FillTimer[aType2].Enabled := true;
  end
  else begin
    ClearOrders;
    if Assigned(FOnKipNotify) then
      FOnKipNotify(Self, DONE_STR );
  end;
end;

