begin
  case aType of
    ptLong: Result := CheckBalance_OsBid;
    ptShort:Result := CheckBalance_OsAsk(bHit);
  end;
end;

function TPutKipOrderItem.BnFutOrderAmt(aOrder : TOrder): double;
var
  aPos : TPosition;
begin
  Result := 0;
  aPos := App.Engine.TradeCore.FindPosition(aOrder.Account, aOrder.Symbol);

  if aPos <> nil then
    Result := CalcBnFutOrderAmt(aPos, aOrder.Side, aOrder.ActiveQty, aOrder.Price);
end;

function TPutKipOrderItem.CalcBnFutOrderAmt(aPos: TPosition; iSide: integer; const dQty, dPrice: double): double;
var
  dFee, dim, dAmt : double;
begin
  dFee  := App.Engine.ApiConfig.ExchangeInfo[integer(aPos.Account.ExchangeKind) ].//ApiInfo[aPos.Symbol.Spec.ExApiType].TradeFee;
    GetTradeFee(aPos.Symbol.Spec.ExApiType, aPos.Symbol.Spec.SettleType, ftMaker);
  dim   := dQty * abs(min(0, iSide * ((aPos.Symbol as TFuture).MarkPrice - dPrice)));
  dAmt  := (dQty * dPrice * aPos.Symbol.Spec.PointValue / aPos.Leverage) + dim;
  if iSide < 0 then
    dAmt := dAmt + (dim / aPos.Leverage);
  Result :=  dAmt * (1 + (dFee / 100)) ;
end;

function TPutKipOrderItem.CheckBalance_OsAsk(bHit: boolean): boolean;
var
  dAvailable, dQty, dAmt, dOrderedAmt, dTotAmt, dPrice : double;
  i : Integer;
  aPos : TPosition;
  aOrder: TOrder;
begin

  Result := false;
  aPos := (Collection as TPutKipOrders).Positions[scInter];
  if aPos = nil then Exit;

  dAvailable:= FAccounts[scInter].Available;
  // 1. 나가 있는 주문 금액 구하기
  dOrderedAmt:= 0;
  with App.Engine.TradeCore.Orders[FAccounts[scInter].ExchangeKind] do
    for I := 0 to ActiveOrders.Count-1 do
    begin
      aOrder  := ActiveOrders.Orders[i];
      if (aOrder <> nil) and (aOrder.Account = FAccounts[scInter]) and (aOrder.Side < 0) then
        dOrderedAmt := dOrderedAmt + BnFutOrderAmt(aOrder);
    end;

  with App.Engine.TradeCore.Orders[FAccounts[scInter].ExchangeKind] do
    for I := 0 to NewOrders.Count-1 do
    begin
      aOrder  := NewOrders.Orders[i];
      if (aOrder <> nil) and (aOrder.Account = FAccounts[scInter]) and (aOrder.Side < 0) then
        dOrderedAmt := dOrderedAmt + BnFutOrderAmt(aOrder);
    end;

  // 2. 나가야만 하는 수량 (국내 매수 주문 체결시)
  dQty   := TPutKipOrders(Collection).GetDomesOrderQty(FIsEntry, ptLong);
  dPrice := GetHitOrderPrice(-1, scInter);
  dAmt   := CalcBnFutOrderAmt(aPos, -1, dQty, dPrice);

  // 3. 나가야 되는 수량
  if not bHit then
    dPrice := FOrdPrice[ptShort];

  dTotAmt := CalcBnFutOrderAmt(aPos, -1, FKipData.OrderQty, dPrice) + dOrderedAmt + dAmt;

  if CmpVal(dAvailable, dTotAmt) <= 0 then
  begin
    Exit ;
  end;
  Result := true;

end;

function TPutKipOrderItem.CheckBalance_OsBid: boolean;
var
  dQty, dQty2 : double;
  aPos : TPosition;
begin
  Result := false;
  aPos := (Collection as TPutKipOrders).Positions[scInter];
  if aPos = nil then Exit;
  // 청산..
  if FKipData.ReduceOnly then
  begin
    if aPos.Side >= 0 then Exit;

    // 이미 잔고 수량만큼 나가 있다면. reduce only 주문은 거부나기에
    // 1. Reduce Only 로 나가 있는 주문 수량을 구한다.
    dQty := TPutKipOrders(Collection).GetOSReduceOrderQty(FIsEntry, ptLong);
    // 2. Reduce Only 로 나가야 할 주문 수량을 구한다. (국내 청산 매도 주문 수량)
    dQty2:= TPutKipOrders(Collection).GetDomesOrderQty(FIsEntry, ptShort);
    // 3. 이미 포지션 수량만큼 주문이 나가 있으면 Exit;
    if (dQty + dQty2) >= abs(aPos.Volume) then
      Exit
    else
      Result := true;
  end else
  begin
    // 여기로 오는 경우는 거의 없음...
    Exit;
  end;
end;

function TPutKipOrderItem.CheckKipValue(aType: TPositionType): boolean;
var
  dTmp : double;
  dEstPrice : array [TPositionType] of double;
begin
  Result := false;
  try

    if aType = ptLong then begin
      dEstPrice[ptLong]   := KipItem[ptLong].Order.Price;
      dEstPrice[ptShort]  := FEstPrice[ptShort];
    end
    else begin
      dEstPrice[ptLong]   := FEstPrice[ptLong];
      dEstPrice[ptShort]  := KipItem[ptShort].Order.Price;
    end;

    if FIsEntry then begin
      dTmp  := dEstPrice[ptShort] * App.Engine.ApiManager.ExRate.Value;
      if CheckZero( dTmp ) then
        FKipValue := 0
      else begin
        FKipValue := (dEstPrice[ptLong] - dTmp) / dTmp * 100;
        if FKipData.Kip - DOUBLE_EPSILON > FKipValue then
          Result := true;
      end;
    end else
    begin
      dTmp  := dEstPrice[ptLong] * App.Engine.ApiManager.ExRate.Value;
      if CheckZero( dTmp ) then
        FKipValue := 0
      else begin
        FKipValue := (dEstPrice[ptShort] - dTmp) / dTmp * 100;
        if FKipValue - DOUBLE_EPSILON > FKipData.Kip then
          Result := true;
      end;
    end;

  except
  end;
end;

procedure TPutKipOrderItem.CheckEstPrice(aType : TPositionType);
begin
  if KipItem[aType].Order = nil then
    Exit
  else if (KipItem[aType].Order <> nil) and (KipItem[aType].Order.IsCancelAble) then
  begin
    DoLog(Format('%s %s %s EstPrice is Zero', [ EntryToStr
      , ifThenStr(KipItem[aType].Order.Symbol.Spec.ExchangeType = ekBinance,'국내', '해외')
      , ifThenStr(aType = ptLong, '매도', '매수')
      ] ) );
    DoCancelOrder(KipItem[aType].Order);
  end;
end;

procedure TPutKipOrderItem.CheckOrder(aType : TPositionType);
var
  s1, s2 : string;
begin

  if KipItem[aType].Order = nil then begin
    // new order
    DoOrder(aType);
  end
  else if (KipItem[aType].Order <> nil) and (KipItem[aType].Order.IsCancelAble) then
  begin
    // 기존 주문 가격이 아직 KIP 범위 안에 있다면 취소 안한다.
    // if CheckKipValue(aType) then Exit;
    s1 := KipItem[aType].Order.Symbol.PriceToStr(KipItem[aType].Order.Price);
    s2 := KipItem[aType].Order.Symbol.PriceToStr(FOrdPrice[aType]);

    //if CmpVal(KipItem[aType].Order.Price, FOrdPrice[aType]) <> 0 then begin
    if s1 <> s2 then begin
      DoLog(Format('%s %s %s 주문가 변화 : %s -> %s', [ EntryToStr
        , TExchangeKindDesc[KipItem[aType].Order.Symbol.Spec.ExchangeType]
        , ifThenStr(aType = ptLong, '매수', '매도')
        , KipItem[aType].Order.Symbol.PriceToStr(KipItem[aType].Order.Price )
        , KipItem[aType].Order.Symbol.PriceToStr(FOrdPrice[aType])] ) );

      if KipItem[aType].Order.Symbol.Spec.ExApiType = eaFutUsdt then
        DoChange(KipItem[aType].Order, FOrdPrice[aType])
      else
        DoCancelOrder(KipItem[aType].Order);
    end;
  end;
end;


constructor TPutKipOrderItem.Create(aColl: TCollection);
var
  i  : TPositionType;
begin
  inherited Create( aColl );

  FDone      := false;

  for I := ptLong to High(TPositionType) do
  begin
    PKItems[i]   := TPutKipItems.Create;
    LegTimer[i]  := TTimer.Create(nil);
    LegTimer[i].Tag := integer(i);
    LegTimer[i].Interval := 1000;
    LegTimer[i].Enabled  := false;
    LegTimer[i].OnTimer  := OnTimer;

    LegTimerLiq[i]  := TTimer.Create(nil);
    LegTimerLiq[i].Tag := integer(i);
    LegTimerLiq[i].Interval := 1000;
    LegTimerLiq[i].Enabled  := false;
    LegTimerLiq[i].OnTimer  := OnTimerLiq;

    FillTimer[i]  := TTimer.Create(nil);
    FillTimer[i].Tag := integer(i);
    FillTimer[i].Interval := 1000;
    FillTimer[i].Enabled  := false;
    FillTimer[i].OnTimer  := OnFillTimer;

    StopTimer := TTimer.Create(nil);
    StopTimer.Enabled := false;
    StopTimer.Interval := 1000;
    StopTimer.OnTimer  := OnStopTimer;
  end;
end;

