procedure TPutKipOrderItem.OnStopTimer(Sender: TObject);
//begin
//  //
//  ClearOrders;

var
  I: TPositionType;
  iRes, iCnt : integer;
begin

  try

    iRes := 0; iCnt := 0;
    for I := ptLong to High(TPositionType) do
      if (KipItem[i].Order <> nil) then
      begin
        inc(iCnt);
        if not (KipItem[i].Order.State in [osReady, osSent, osActive]) then
          inc(iRes);
      end;

    if (iRes = iCnt) {and (iCnt > 0)} then begin
      StopTimer.Enabled := false;
      DoLog('ALL CANCEL');
