destructor TPutKipOrderItem.Destroy;
var
  i  : TPositionType;
begin

  for I := ptLong to High(TPositionType) do
  begin
    LegTimer[i].Free;
    LegTimerLiq[i].Free;
    FillTimer[i].Free;
    PKItems[i].Free;
  end;

  inherited;
end;

function TPutKipOrderItem.DoOrder(aSCType: TSymbolCountryType;
  const iSide: integer; const dPrice, dQty: double): TOrder;
begin
  Result := nil;

  Result := App.Engine.TradeCore.Orders[ FSymbols[aSCType].Spec.ExchangeType ].NewOrder(
        FAccounts[aSCType], FSymbols[aSCType], iSide, dQty, pcLimit, dPrice, tmGTC
      );

  if Result = nil then Exit;

  Result.GroupNo  := FName;
  Result.StgType  := stPutKipOrder;
  Result.Tag      := LIQ_ORD;

  App.Engine.TradeBroker.Send(Result);

  TPutKipOrders( Collection ).SetTime;

  DoLog(Format('%s Hit 주문 %s | %s', [ EntryToStr, Result.RepresentWithEx,
    Result.Symbol.PriceToStr( ifThenFloat(iSide > 0, Result.Symbol.Bids[0].Price, Result.Symbol.Asks[0].Price)) ] ));

  DebugLog(1);
end;

procedure TPutKipOrderItem.DoOrder(aType: TPositionType);
var
  aOrder : TOrder;
  bAble  : boolean;
  stLog  : string;

  aAcnt : TAccount;
  aSymbol : TSymbol;
  dPrice, dEstPrice  : double;
  iSide  : integer;
  tmVal  : TTimeInForce;
begin

  if TPutKipOrders( Collection ).IsWaiting then Exit;

  stLog := '주문가능금액';

  bAble := false;
  if FIsEntry then begin
    if aType = ptLong then begin
      // 해외쪽 매도 가능한지 체크..
      bAble := CheckBalance_OsAsk(true);// CheckBalance_Os(ptShort, true);
      if bAble then
        bAble := CheckBalance_KrBid(false);
    end else
    begin
      // 국내 매수 가능한지 체크
      bAble :=  CheckBalance_KrBid(true);
      if bAble then
        bAble := CheckBalance_OsAsk(false);//CheckBalance_Os(aType, false);
    end;
  end else begin
    if aType = ptLong then begin
      // 국내 매도 가능한지 체크
      bAble := CheckBalance_KrAsk;
      if bAble then
        bAble := CheckBalance_OsBid;//CheckBalance_Os(aType, false);
    end else
    begin
      // 해외 매수 가능한지 체크
      bAble := CheckBalance_OsBid;//CheckBalance_Os(ptLong, true);
      if bAble then
        bAble := CheckBalance_KrAsk;
      stLog := '잔고';
    end;
  end;

  if not bAble then
  begin
    //DoLog( Format('%s %s %s 부족', [ EntryToStr, ifThenStr(aType = ptLong, '매수', '매도'), stLog ]));
    if Assigned(FOnKipNotify) then
      FOnKipNotify(Self, BAL_STR);
    Exit;
  end;


  if FIsEntry then
  begin

    if aType = ptLong then begin
      aAcnt   := FAccounts[scDomes];
      aSymbol := FSymbols[scDomes];
      dPrice  := FOrdPrice[ptLong];
      dEstPrice := FEstPrice[ptShort];
      iSide   := 1;
      tmVal   := tmGTC;
    end else begin
      aAcnt   := FAccounts[scInter];
      aSymbol := FSymbols[scInter];
      dPrice  := FOrdPrice[ptShort];
      dEstPrice := FEstPrice[ptLong];
      iSide   := -1;
      tmVal   := tmGTX;
    end;

  end else
  begin

    if aType = ptShort then begin
      aAcnt   := FAccounts[scDomes];
      aSymbol := FSymbols[scDomes];
      dPrice  := FOrdPrice[ptShort];
      dEstPrice := FEstPrice[ptLong];
      iSide   := -1;
      tmVal   := tmGTC;
    end else begin
      aAcnt   := FAccounts[scInter];
      aSymbol := FSymbols[scInter];
      dPrice  := FOrdPrice[ptLong];
      dEstPrice := FEstPrice[ptShort];
      iSide   := 1;
      tmVal   := tmGTX;
    end;
  end ;

  if (aAcnt = nil) or (aSymbol = nil) then Exit;

  if not App.Engine.TradeCore.CheckLimitOrder( aAcnt, aSymbol, iSide, dPrice, FKipData.OrderQty, ORD_AUTO) then
  begin
    DoLog( '=========== 공통 리스크 제한에 걸림 ===============', true );
    if Assigned(FOnKipNotify) then
      FOnKipNotify(Self, RSK_STR);
    Exit;
  end;

  aOrder := App.Engine.TradeCore.Orders[ aSymbol.Spec.ExchangeType ].NewOrder(
    aAcnt, aSymbol, iSide, FKipData.OrderQty, pcLimit, dPrice, tmVal
  );

  aOrder.ReduceOnly := FKipData.ReduceOnly;

  if (aOrder<> nil) then
  begin

    KipItem[aType].SetOrder(aOrder);
    aOrder.StgType   := stPutKipOrder;
    aOrder.GroupNo   := FName;
    aOrder.Tag       := PUT_ORD;

    App.Engine.TradeBroker.Send( aOrder );
//    FFirstOrder := true;
//    inc( FCount );
    // 주르르 주문 나가는것을 막기 위해..마지막 주문 시간을 셋팅.
    TPutKipOrders( Collection ).SetTime;

    if Assigned(FOnKipNotify) then
      FOnKipNotify(Self, ORD_STR);

    DoLog( Format('%s Put 주문 %s (%.2f) - %s, %s', [ ifThenStr( FIsEntry,'진입','청산'),
      aOrder.SideToStr, FKipData.Kip, aOrder.RepresentWithEx ,
      aSymbol.PriceToStr(ifThenFloat(atype=ptLong, aSymbol.Bids[0].Price, aSymbol.Asks[0].Price))] ) );

    DebugLog(0);
  end;

end;

function TPutKipOrderItem.EntryToStr: string;
begin
  Result := ifThenStr( FIsEntry, '진입','청산');
end;

procedure TPutKipOrderItem.DoLog(stLog: string; bNotify : boolean);
begin

  stLog := Format('%s_%d, %d.th - ', [ifThenStr(FIsEntry,'En','Ex'), FIdx, FCount ]) + stLog;
  App.Log(llInfo, GetLogName, stLog);
  if bNotify and Assigned( FOnNotify ) then
    FOnNotify( Self, stLog );
end;

function TPutKipOrderItem.GetLogName: string;
begin
  Result := 'PK_'+ifThenStr(FIsEntry,'EN','EX');
  if FSymbols[scDomes] <> nil then
    Result := FSymbols[scDomes].Spec.BaseCode + '_' +
      TExchangeKindShortDesc[FSymbols[scDomes].Spec.ExchangeType] + '_' + Result;
end;

procedure TPutKipOrderItem.DoCancelOrder( aOrder : TOrder );
var
  aCnlOrder : TOrder;
begin

  if aOrder.Symbol = FSymbols[scInter] then
    DoLog('-----');

  if (aOrder.OrderType = otNormal) and
     (aOrder.State = osActive) and (not aOrder.Modify) then
  begin
    aCnlOrder := App.Engine.TradeCore.Orders[ aOrder.Account.ExchangeKind].NewCancelOrder( aOrder, aOrder.ActiveQty);
    App.Engine.TradeBroker.Send( aCnlOrder);

    DoLog( Format('주문 취소- %s', [ aOrder.Represent ]  ) );
  end;
end;

procedure TPutKipOrderItem.DoChange(aOrder: TOrder; dPrice: double);
begin
  if (aOrder.OrderType = otNormal) and (aOrder.State = osActive) and (not aORder.Modify) then
  begin
    App.Engine.TradeBroker.Send(
      App.Engine.TradeCore.Orders[aOrder.Account.ExchangeKind].NewChangeOrder(aOrder, dPrice)
      );
    DoLog( Format('주문 정정- %s', [ aOrder.Represent ]  ) );

    DebugLog(0);
  end;
end;

