  // 거부 주문에 딜레이..타이머
  aType := TPositionType((Sender as TComponent).Tag);
  if (KipItem[aType].Order <> nil) and (KipItem[aType].Order.State in [osCanceled,osRejected]) then
    KipItem[aType].SetOrder(nil);

  LegTimer[aType].Enabled := false;
