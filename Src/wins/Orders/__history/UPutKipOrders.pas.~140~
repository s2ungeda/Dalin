var
  sType : string;
begin

  case iDiv of
   0 : sType := 'put';
   1 : sType := 'hit';
   2 : sType := 'end';
   else sType :='---';
  end;

  DoLog(
    format(' +++++ %s %s %s(%s|%s), (%s|%s), T(%s|%s) Ex(%.2n)  Est(%.4n|%.4n), Prc(%.4n|%.4n)  Calc(%.4n|%.4n)', [
      EntryToStr,  sType, TExShortDesc[FSymbols[scDomes].Spec.ExchangeType],
      FSymbols[scDomes].PriceToStr(FSymbols[scDomes].Asks[0].Price), FSymbols[scDomes].PriceToStr(FSymbols[scDomes].Bids[0].Price),
      FSymbols[scInter].PriceToStr(FSymbols[scInter].Asks[0].Price), FSymbols[scInter].PriceToStr(FSymbols[scInter].Bids[0].Price),
      FTether.PriceToStr(FTether.Asks[0].Price), FTether.PriceToStr(FTether.Bids[0].Price),
      App.Engine.ApiManager.ExRate.Value,
