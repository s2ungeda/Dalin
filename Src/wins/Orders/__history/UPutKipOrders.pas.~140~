function TPutKipOrderItem.Start: boolean;
var
  i : TPositionType;
begin
  FRun := true;
  FDone:= false;

  FDataCount  := 0;
  FCount      := 1;
  DoLog( 'Start');

  PKItems[ptLong].Clear;
  PKItems[ptShort].Clear;

  for I := ptLong to High(TPositionType) do
    NewOrders(i);
end;

procedure TPutKipOrderItem.Stop;
begin

  LegTimer[ptLong].Enabled  := false;
  LegTimer[ptShort].Enabled := false;

  LegTimerLiq[ptLong].Enabled  := false;
  LegTimerLiq[ptShort].Enabled := false;

  FillTimer[ptLong].Enabled := false;
  FillTimer[ptShort].Enabled  := false;

  ClearOrders;

  FRun := false;

  DoLog('Stop.........');

  StopTimer.Enabled := true;

  FSpotTimerCount := 0;
end;

{ TPutKipOrders }

procedure TPutKipOrders.CheckDust;
var
  i, ifTick, isTick : integer;
  aDust : TDust;
  bRes  : boolean;
begin

  if not tryStrToInt(TFrmPutKipOrder(FParent).edtFutOrdTick.Text, ifTick) then Exit;
  if not tryStrToInt(TFrmPutKipOrder(FParent).edtSpotOrdTick.Text,isTick) then Exit;

  for I := 0 to FDusts.Count-1 do
  begin
    aDust := FDusts.Dust[i];
    if aDust.Qty <= EPSILON then continue;

    bRes := false;
    if aDust.Symbol.Spec.Market = mtFutures then
      bRes := aDust.IsOrder(ifTick)
    else if aDust.Symbol.Spec.Market = mtSpot then
      bRes := aDust.IsOrder(isTick);

    if bRes then
    begin
      DoOrder(aDust);
    end;

  end;
end;

procedure TPutKipOrderItem.ClearOrders;
var
  I: TPositionType;
begin
  for I := ptLong to High(TPositionType) do
    if KipItem[i].Order <> nil then
      DoCancelOrder(KipItem[i].Order);
end;

