procedure TPutKipOrders.DoOrder(aDust: TDust);
var
  aAcnt : TAccount;
  aOrder: TOrder;
begin

  aAcnt := nil;
  if aDust.Symbol.Spec.ExchangeType <> ekBinance then
    aAcnt := App.Engine.TradeCore.FindAccount(aDust.Symbol.Spec.ExchangeType)
  else
    aAcnt := App.Engine.TradeCore.FindAccount(aDust.Symbol.Spec.ExchangeType,
      TAccountMarketType( ifThen(aDust.Symbol.Spec.FutureType = ftCoin, integer(amFutureCm), integer(amFuture)))) ;

  if aAcnt = nil then Exit;

  aOrder  := App.Engine.TradeCore.Orders[aDust.Symbol.Spec.ExchangeType].NewOrder(aAcnt,
    aDust.Symbol, aDust.Side, aDust.OrdQty, pcLimit, aDust.OrdPrice, tmGTC );

  if aOrder <> nil then
  begin
    aOrder.StgType  := stPutKipOrder;
    aOrder.Tag      := DST_ORD;
    App.Engine.TradeBroker.Send( aOrder );
    aDust.DecQty(aDust.OrdQty);
    TFrmPutKipOrder(FParent).DoLog(Format('Dust 주문 %s, Remain Qty : %s',[aOrder.Represent,
      DoubleToStr(aDust.Qty)]), true);
  end;

end;

function TPutKipOrders.Find(stName: string): TPutKipOrderItem;
var
  I: Integer;
begin
  Result := nil;

  for I := 0 to Count-1 do
    if GetKipOrders(i).Name = stName then
    begin
      Result := GetKipOrders(i);
      break;
    end;

end;

function TPutKipOrders.GetDomesOrderQty(bEntry: boolean;
  ptType: TPositionType): double;
var
  i : integer;
  aItem : TPutKipOrderItem;
begin
  Result := 0;
  for i := 0 to Count -1 do
  begin
    aItem := GetKipOrders(i);
    if (aItem.FIsEntry = bEntry) and (aItem.KipItem[ptType].Order <> nil) and
      (aItem.KipItem[ptType].Order.State in [osSent, osActive]) then
      Result := Result + aItem.KipItem[ptType].Order.ActiveQty;
  end;
end;

function TPutKipOrders.GetKipOrders(i: integer): TPutKipOrderItem;
begin
  if (i < 0 ) or ( i >= Count )  then
    Result := nil
  else
    Result := Items[i] as  TPutKipOrderItem;
end;

function TPutKipOrders.GetOSEntryAskOrderQty: double;
var
  i : integer;
  aItem : TPutKipOrderItem;
begin
  Result := 0;
  for i := 0 to Count -1 do
  begin
    aItem := GetKipOrders(i);
    if aItem.FIsEntry and (aItem.KipItem[ptShort].Order <> nil) and
      (aItem.KipItem[ptShort].Order.State in [osSent, osActive]) then
      //Result := Result + aItem.KipItem[ptShort].Order.ActiveQty;
      Result := Result + ifThenFloat(aItem.KipItem[ptShort].Order.State = osSent,
        aItem.KipItem[ptShort].Order.OrderQty, aItem.KipItem[ptShort].Order.ActiveQty);
  end;
end;

function TPutKipOrders.GetOSExitBidOrderQty: double;
var
  i : integer;
  aItem : TPutKipOrderItem;
begin
  Result := 0;
  for i := 0 to Count -1 do
  begin
    aItem := GetKipOrders(i);
    if (not aItem.FIsEntry) and (aItem.KipItem[ptLong].Order <> nil) and
      (aItem.KipItem[ptLong].Order.State in [osSent,osActive]) then
      Result := Result + ifThenFloat(aItem.KipItem[ptLong].Order.State = osSent,
        aItem.KipItem[ptLong].Order.OrderQty, aItem.KipItem[ptLong].Order.ActiveQty);
  end;

end;

function TPutKipOrders.GetOSReduceOrderQty(bEntry: boolean; ptType: TPositionType): double;
var
  i : integer;
  aItem : TPutKipOrderItem;
begin
  Result := 0;
  for i := 0 to Count -1 do
  begin
    aItem := GetKipOrders(i);
    if (aItem.FIsEntry = bEntry) and (aItem.KipItem[ptType].Order <> nil) and
      (aItem.KipItem[ptType].Order.ReduceOnly) and
      (aItem.KipItem[ptType].Order.State in [osSent, osActive]) then
      Result := Result + ifThenFloat(aItem.KipItem[ptType].Order.State = osSent,
        aItem.KipItem[ptType].Order.OrderQty, aItem.KipItem[ptType].Order.ActiveQty);
  end;
end;

function TPutKipOrders.GetRunItemCount: integer;
var
  I: Integer;
begin
  Result := 0;
  for I := 0 to Count-1 do
    if GetKipOrders(i).IsRun then
      inc(Result );
end;

procedure TPutKipOrders.InitReport;
begin
  KipReport[aoEntry].Init;
  KipReport[aoExit].Init;
end;

function TPutKipOrders.IsWaiting: boolean;
var
  iTime : integer;
begin
  Result := false;
  EnterCriticalSection(CriticalSection);
  try
    iTime := MilliSecondsBetween( now, LastGetTime );
    if iTime < 100 then
      Result := true;
//    FLastGetTime := now;
  finally
    LeaveCriticalSection(CriticalSection);
  end;
end;

function TPutKipOrders.New(sDiv: string; iTag: integer): TPutKipOrderItem;
begin
  Result := Find(Format('PK_%s_%d', [sDiv, iTag]));
  if Result = nil then
  begin
    Result := Add as TPutKipOrderItem;
    Result.Name := Format('PK_%s_%d', [sDiv, iTag]);
    Result.Idx  := iTag;
  end;
end;

