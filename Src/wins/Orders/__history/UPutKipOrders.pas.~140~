procedure TPutKipOrderItem.GetLongOrderPrice;
var
  aSCType :TSymbolCountryType;
  dKip, dStartPrice, dPrice, dPrice2, dLimitPrice : double;
  bFind : boolean;

  stLog : string;
  aSymbol : TSymbol;
  dTmp : double;
begin
  // 진입 - 국내 매수, 해외 매도
  // 청산 - 국내 매도, 해외 매수
  aSCType := TSymbolCountryType(ifThen(FIsEntry, 0, 1));

  dStartPrice := FSymbols[aSCType].Asks[0].Price;
  if not GetKip(dKip) then Exit;

  if FIsEntry then
    dPrice  := (FEstPrice[ptShort] * App.Engine.ApiManager.ExRate.Value) * (dKip / 100 + 1)
  else
    dPrice  := FEstPrice[ptShort] / (dKip / 100 + 1) / App.Engine.ApiManager.ExRate.Value;

  if CmpVal(dPrice, dStartPrice) >= 0  then
  begin
    // 매도 1호가 보다 크다면...매도1호가 - 1Tick
    FOrdPrice[ptLong] := TicksFromPrice(FSymbols[aSCType], dStartPrice, -1);
    Exit;
  end;

  dLimitPrice := dStartPrice * ( 1 - 15 / 100 );

  bFind := false;

  // dStartPrice ~ dLimitPrice 사이에 주문 가격을 구한다.
  // dStartPrice >= dPrice > dLimitPrice

  if (CmpVal(dPrice, dLimitPrice) > 0 ) and (CmpVal(dStartPrice, dPrice) >= 0) then
    while CmpVal(dStartPrice, dLimitPrice) > 0 do
    begin
      if CmpVal(dPrice, dStartPrice) >= 0 then
      begin
        bFind := true;
        break;
      end;
      dStartPrice  := TicksFromPrice(FSymbols[aSCType], dStartPrice, -1 );
    end;

  FOrdPrice[ptLong]  := ifThenFloat( bFind, dStartPrice, 0 );
  FCalcPrice[ptLong] := dPrice;
end;

