function TFrmPKIDXOrders.CheckProcTime: boolean;
var
  sMsg: string;
begin

  Result := false;
  sMsg := '';
  try
    if not gAOConfig.CheckAutoConfig(sMsg) then
      Exit;

    if not gAOConfig.CheckQuoteDelay([FExKind[ptLong], FExKind[ptShort]], sMsg) then
      Exit;

    if not gAOConfig.CheckExRateFilter(FEntry, sMsg) then
      Exit;

    Result := true;
  finally
    stNotice.Panels[3].Text := sMsg;
  end;

end;

