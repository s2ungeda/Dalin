procedure TFrmSPOrderEx.DpTimerTimer(Sender: TObject);
var dVal : array [TSPType] of double;
begin
  if FWDConfirimFalg[spMajor] and FWDConfirimFalg[spSub] then
  begin
    dVal[spMajor] := GetBalance(spMajor);
    dVal[spSub]   := GetBalance(spSub);
    DoLog( format('입출금확인 %.4n , %.4n  |  %.4n , %.4n', [ dVal[spMajor],
       FInitBalance[spMajor], dVal[spSub],  FInitBalance[spSub] ]) );

    if (dVal[spMajor] - EPSILON > FInitBalance[spMajor]) and ( dVal[spSub] < FInitBalance[spSub] - EPSILON ) then
    begin
      DoLog('==== 입출금 잔고 반영 ====', true );

      FReqCount := 0;
      DpTimer.Enabled := false;
      FSPOrders.InitLimit;
      // 한도 재계산
      CalcLimtiRate;

      FSPOrders.OnParam2(FParams);
      // 거래 재개
      CheckBox1.Checked := false;
    end;

  end else
    if FReq[spMajor] <> nil then
    begin
      inc(FReqCount);
      if not FWDConfirimFalg[spMajor] then
        FReq[spMajor].RequestDepositList(edtCode.Text, FReqCount = 1);
      if not FWDConfirimFalg[spSub] then
        FReq[spSub].RequestWithdrawList(edtCode.Text, FReqCount = 1);
    end;
end;

