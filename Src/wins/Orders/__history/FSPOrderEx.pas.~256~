procedure TFrmSPOrderEx.QuoteProc(Sender, Receiver: TObject; DataID: Integer;
  DataObj: TObject; EventID: TDistributorID);
var
  I: Integer;
  dval : double;
begin

  if (Receiver <> Self) or (DataObj = nil) then Exit;

  if (DataObj as TQuote).Symbol = FSymbols[spMajor] then
  begin
    if cbHogaMerge.Checked then
      if not FMgQuotes[spMajor].OnMakeMergeQuote(FSymbols[spMajor]) then
      begin
        DoLog( ' ++++ Failed Hoga Merge !!! +++');
        Exit;
      end;

    CalcSPValue;

    if (cbRun.Checked) then
    begin
      if ((DataObj as TQuote).LastEvent = qtMarketDepth ) and (not CheckBox1.Checked)
        and (FQuoteStop)  then
          for I := 0 to SP_CNT-1 do
            FSPOrders.SPOrders[i].OnMajorQuote( FSymbols[spMajor]);
    end;

    OnQuoteNotifiy( Self, spMajor );
  end else
  if (DataObj as TQuote).Symbol = FSymbols[spSub] then
    OnQuoteNotifiy( Self, spSub );

end;

