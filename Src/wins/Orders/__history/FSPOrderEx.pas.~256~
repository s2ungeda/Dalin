function TFrmSPOrderEx.CheckInput(var iErr : integer): boolean;
var
  aParam : TSPParam;
  i : integer;

  d1, d2, dTmp : double;
begin

  Result := false;    iErr := 0;

  if edtCode.Text = '' then Exit;
  if cbMajor.ItemIndex = cbSub.ItemIndex then Exit;

  for I := 0 to SP_CNT-1 do
  begin
    d1 := 0; d2 := 0;
    TryStrToFloat(FSPControls[i].edtEntryRate.Text, d1);

    if FSPControls[i].cbEntry.Checked then begin
      if FSPControls[i].edtEntryRate.Text = '' then Exit;
      if FSPControls[i].edtOrderQty.Text = '' then Exit;
      if FSPControls[i].edtLimitRate.Text = '' then Exit;

      if FSPControls[i].edtOrderQty.Text = '0' then Exit;
      if FSPControls[i].edtLimitRate.Text = '0' then Exit;
    end;

    TryStrToFloat(FSPControls[i].edtLiquidRate.Text, d2);

    if FSPControls[i].cbLiquid.Checked then begin
      if FSPControls[i].edtLiquidRate.Text = '' then Exit;
      if FSPControls[i].edtOrderQty.Text = '' then Exit;
      if FSPControls[i].edtLimitRate.Text = '' then Exit;

      if FSPControls[i].edtOrderQty.Text = '0' then Exit;
      if FSPControls[i].edtLimitRate.Text = '0' then Exit;
    end;

    if FSPControls[i].cbEntry.Checked or FSPControls[i].cbLiquid.Checked then
    begin
      var  r : TValueRelationship;
      r := CompareValue( d1, d2 );
      if d1 >= d2 then begin
        iErr := i+1;
        Exit;
      end;
    end;
  end;

  if edtLimitTradeAmt.Text = '' then Exit;
  if edtLimitPL.Text = '' then Exit;

  //if edtAutoModifyInterval.Text = '' then Exit;
  if edtAutoModifyCount.Text = '' then Exit;
  //if edtAutoModifyTick.Text = '' then Exit;
  if edtAutoModifyLastTick.Text = '' then Exit;

  if edtMinVolume.Text = '' then Exit;

  if cbHogaMerge.Checked then
    if edtMergeUnit.Text = '' then Exit;

  if cbModifyDelay.Checked then
    if edtModifyDelaySec.Text = '' then Exit;

  if TryStrToFloat( edtModifyDelaySec.Text, d1 ) then
    if d1 < 0.1 then
    begin
      iErr := 6;
      Exit;
    end;

  if cbVolumeRate.Checked then
    if edtVolumeRate.Text = '' then Exit;

  if edtAccVolGap.Text = ''then Exit;

  dTmp := 0.0;

  for I := 0 to SP_CNT-1 do
  begin

    FParams[i].Code := edtCode.Text;

    FParams[i].MajorEx  := TExchangeKind( cbMajor.ItemIndex + 1 );
    FParams[i].SubEx    := TExchangeKind( cbSub.ItemIndex + 1 );

    FParams[i].UseEntry := FSPControls[i].cbEntry.Checked;

    if not TryStrToFloat( FSPControls[i].edtEntryRate.Text, FParams[i].EntryRate ) then Exit;
    if not TryStrToFloat( FSPControls[i].edtOrderQty.Text,  FParams[i].EntryQty ) then Exit;
    if not TryStrToFloat( FSPControls[i].edtLimitRate.Text, FParams[i].LimitRate ) then Exit;

    FParams[i].UseLiquid  := FSPControls[i].cbLiquid.Checked;

    if not TryStrToFloat( FSPControls[i].edtLiquidRate.Text, FParams[i].LiquidRate ) then Exit;
//    if not TryStrToFloat( FSPControls[i].edtOrderQty.Text, FParams[i].LiquidQty ) then Exit;
//    if not TryStrToFloat( FSPControls[i].edtLiquidLimitQty.Text,  FParams[i].LimitLiquidPos ) then Exit;

    FParams[i].BasePrice  := 2;//cbBasePrice.ItemIndex;

    if not TryStrToInt( edtBaseTick.Text, FParams[i].BaseTick) then Exit;
    if not TryStrToFloat( edtMinVolume.Text, FParams[i].MinVolume ) then Exit;

    if not TryStrToFloat( edtLimitTradeAmt.Text, FParams[i].LimitTradeAmt ) then Exit;
    if not TryStrToFloat( edtLimitPL.Text, FParams[i].LimitPL ) then Exit;

    FParams[i].UseHogaMerge     := cbHogaMerge.Checked;
    FParams[i].UseMdodifyDelay  := cbModifyDelay.Checked;

    if not TryStrToInt( edtMergeUnit.Text, FParams[i].HogaMergeUnit ) then Exit;

    //if not TryStrToInt( edtAutoModifyInterval.Text, FParams[i].AutoModifyInterval ) then Exit;
    if not TryStrToInt( edtAutoModifyCount.Text, FParams[i].AutoModifyCount ) then Exit;
    //if not TryStrToInt( edtAutoModifyTick.Text, FParams[i].AutoModifyTick ) then Exit;
    if not TryStrToInt( edtAutoModifyLastTick.Text, FParams[i].AutoModifyLastTick ) then Exit;

    if not TryStrToFloat( edtModifyDelaySec.Text, FParams[i].ModifyDelaySec ) then Exit;

    FParams[i].UseVolumeRate  := cbVolumeRate.Checked;

    if not TryStrToFloat( edtVolumeRate.Text, FParams[i].VolumeRate) then Exit;
    if not TryStrToFloat( edtAccVolGap.Text, FParams[i].AccVolGap) then Exit;

    dTmp := dTmp + FParams[i].LimitRate;
    if dTmp > 100 then
    begin
      iErr := 7;
      Exit;
    end;
  end;

  FWDParam.use  := cbWithdraw.Checked;

  Result := true;

end;

function TFrmSPOrderEx.CheckQuoteStop: boolean;
var
  iDelay1, iDelay2 : integer;
begin
  // 시세 딜레이 3초 이상이면...Exit;
  try
    Result := false;

    iDelay1 := App.Engine.ApiManager.ExManagers[TExchangeKind( cbMajor.ItemIndex + 1 )].QuoteSock[0].DelaySec;
    iDelay2 := App.Engine.ApiManager.ExManagers[TExchangeKind( cbSub.ItemIndex + 1 )].QuoteSock[0].DelaySec;
    if (iDelay1 >= 3) or (iDelay2 >= 3) then Exit;

    Result := true;
  finally
    if not Result then
      DoLog( Format('시세 멈춤 .. %s, %s',[
        ifThenStr( iDelay1 >= 3, ExKindToStr(TExchangeKind( cbMajor.ItemIndex + 1 ))+ ' > ' + iDelay1.ToString, '' ),
        ifThenStr( iDelay2 >= 3, ExKindToStr(TExchangeKind( cbSub.ItemIndex + 1 ))+ ' > ' + iDelay2.ToString, '' )
        ]) );
  end;
end;

