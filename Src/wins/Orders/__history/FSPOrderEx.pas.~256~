procedure TFrmSPOrderEx.LimitTimerTimer(Sender: TObject);
var
  iGap, iCnt : integer;
  dVal : double;
begin
  try

    if edtLimitInterval.Text = '' then
      iCnt := 2
    else
      if not TryStrToInt( edtLimitInterval.Text, iCnt) then Exit;

    if FLimitCount > iCnt then
    begin
      FLimitCount := 0;

      if cbRun.Checked then
      begin
          //dval := Round(FSPOrders.GetTotTradePL / 10000) ;

          dval := Round(FSPOrders.GetTotTradePLForComp / 10000) ;
          if dval < FParams[0].LimitPL then
          begin
            cbRun.Checked := false;
            OnTextNotifyEvent(Self, Format('--- Stop 손익 한도 %.0n ---' , [dval]) );
            Exit;
          end;

          dval := FSPOrders.GetTotTradeRate;
          if dval > FParams[0].LimitTradeAmt then
          begin
            cbRun.Checked := false;
            OnTextNotifyEvent(Self, Format('--- Stop 회전율 한도 %.0f%% ---' , [dval]) );
            Exit;
          end;

          dVal := FSPOrders.GetAccVolumeGap;
          if dVal > FParams[0].AccVolGap then
          begin
            cbRun.Checked := false;
            OnTextNotifyEvent(Self, Format('--- Stop 누적체결량 차이  %.4n ---' , [dval]) );
            Exit;
          end;
      end;
    end;

//    iGap  := MinutesBetween( FWDParam.startTime, now );
    // 출금....
    if (FWDParam.use) and (cbRun.Checked)
      and (FWDParam.BasicCheck)
      and (FAvgSPVal[aoEntry].Count >= FWDParam.minTerm) then
//      and (iGap >= 5) then
    begin
      var dAvg : double;
      dAvg  := FAvgSPVal[aoEntry].Average;

      if dAvg < FWDParam.spValue then
        if FReq[spSub] <> nil then begin
          cbWithdraw.Checked := false;
          FWDParam.use       := false;

          DoLog( Format('====  출금 시작 ===== (%.3f < %.3f)', [ dAvg, FWDParam.spValue] ));

          var aParam  : TWithDrawParam;

          aParam.qty      := FWDParam.qty;
          aparam.addr1    := FWDParam.addr1;
          aParam.addr2    := FWDParam.addr2;
          aParam.currency := edtCode.Text;
          aParam.nettype  := FWDParam.netType;
          aParam.exname   := TExchangeKindDesc[ FParams[0].MajorEx];
          aParam.custtype := '01';
//          aParam.korname  := App.Engine.ApiConfig.ExchangeInfo[integer(FParams[0].SubEx)].MarketInfo[mtSpot].KorName;
//          aParam.Engname  := App.Engine.ApiConfig.ExchangeInfo[integer(FParams[0].SubEx)].MarketInfo[mtSpot].EngName;

          FReq[spSub].DoJob(aParam);
        end;
    end;

  finally
    inc(FLimitCount);
  end;
end;

