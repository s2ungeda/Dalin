procedure TFrmSPOrderEx.OnQuoteNotifiy(Sender: TObject; sType: TSPType);
var
  aGrid : TStringGrid;
  aAsks, aBids : TMarketDepths;
  I, iCol, iCol2: integer;
  sCurPrice, sTmp : string;
  aSymbol : TSymbol;
  dRate, dTmp : double;

  procedure SetCurPrice( iRow : integer );
  begin
    with aGrid do
      if Cells[iCol,iRow] = sCurPrice then
        Objects[iCol,iRow] := Pointer(100)
      else
        Objects[iCol,iRow] := nil;
  end;

  function GetVol( dPrice : double; dVolume : double) : string;
  var
    iPre : integer;
    dVol : double;
  begin
    iPre := GetQtyPrecision( aSymbol, dPrice );
    if iPre < 0 then
    begin
      dVol := Floor(dVolume / 1000);
      result := Format('%sk', [ FmtString( 0,  dVol ) ] );
    end
    else
      result := FmtString( iPre, dVolume );
  end;
begin

  if not spBooks.Down then Exit;

  if sType = spMajor then begin
    aSymbol :=  FSymbols[spMajor];
    if aSymbol = nil then Exit;
    aGrid := sgHoga;
    iCol  := 2;      iCol2 := 0;
    //if (cbRun.Checked) and (FParams[0].UseHogaMerge) then
    if cbHogaMerge.Checked then
    begin
      aAsks := FMgQuotes[spMajor].Asks;
      aBids := FMgQuotes[spMajor].Bids;
    end else
    begin
      aAsks := FSymbols[spMajor].Asks;
      aBids := FSymbols[spMajor].Bids;
    end;
  end
  else begin
    iCol := 0;      iCol2 := 2;
    aSymbol :=  FSymbols[spSub];
    if aSymbol = nil then Exit;
    aGrid := sgHoga2;
    aAsks := FSymbols[spSub].Asks;
    aBids := FSymbols[spSub].Bids;
  end ;

  sCurPrice := aSymbol.PriceToStr(aSymbol.Last);

  dRate := StrToFloatDef(edtVolumeRate.Text, 1);

  with aGrid do
  begin
    for I := 0 to 4 do//aAsks.Count-1 do
    begin
      if i >= aAsks.Count then
      begin
        Cells[iCol, 4-i] := '';
        Cells[1, 4-i]    := '';
      end else
      begin
        Cells[iCol, 4-i]  := aSymbol.PriceToStr(aAsks[i].Price);
        sTmp := GetVol( aAsks[i].Price,  aAsks[i].Volume );
        Cells[1, 4-i] := sTmp;
        SetCurPrice(4-i);

        if i = 0 then begin
          //dTmp  := RoundTo( aAsks[i].Volume * 0.1 , -4 ) ;
          sTmp := GetVol( aAsks[i].Price,  RoundTo( aAsks[i].Volume * (dRate/100) , -4 ) );
          Cells[iCol2, 4-i] := sTmp
        end;
      end;
    end;

    for I := 0 to 4 do //aBids.Count-1 do
    begin
      if i >= aBids.Count then
      begin
        Cells[iCol, 5+i] := '';
        Cells[1, 5+i]    := '';
      end else
      begin
        Cells[iCol,5+i]  := aSymbol.PriceToStr(aBids[i].Price);
        sTmp := GetVol( aBids[i].Price,  aBids[i].Volume );
        Cells[1, 5+i] := sTmp;
        SetCurPrice(5+i);

        if i = 0 then begin
          sTmp := GetVol( aBids[i].Price,  RoundTo( aBids[i].Volume * (dRate/100) , -4 ) );
          Cells[iCol2, 5+i] := sTmp;//dTmp.ToString;
        end;
      end;
    end;

  end;

end;

