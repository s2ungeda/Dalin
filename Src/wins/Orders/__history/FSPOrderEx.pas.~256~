function TFrmSPOrderEx.UpdateParam(var iErr: integer) : boolean;
var
  i : integer;
  aParams : array [0..SP_CNT-1] of TSPParam;
  bUse : boolean;
begin

  if cbRun.Checked then
  begin
    for I := 0 to SP_CNT-1 do
      aParams[i]  := FParams[i];
    bUse  := FWDParam.use;
  end;

  Result := CheckInput(iErr) ;

  if (not Result) and (cbRun.Checked) then begin
    for I := 0 to SP_CNT-1 do begin
      FParams[i]  := aParams[i];
      RollBackParam( i );
    end;
    FWDparam.use  := bUse;
    cbWithdraw.Checked  := bUse;
  end;

  if Result then
    for I := 0 to SP_CNT-1 do
      if FParams[i].LimitRate <> aParams[i].LimitRate then
      begin
        CalcLimtiRate;
        break;
      end;

  // 출금 체;크...
//  if (cbRun.Checked) and (not bUse) and (cbWithdraw.Checked) and (Result) then
//    FWDparam.startTime  := now;

end;

procedure TFrmSPOrderEx.WithDrawNotify(Sender: TObject; Result: TResultMesage);
begin
//  DoLog( Format('==== 출금%s %s ====', [ IfThenStr(Result.Code = 0, '성공','실패'), Result.Reason ] ), true);

  case Result.ResType of
    RES_WT :
      begin
        if Result.Code = 0 then
        begin
          DoLog('==== 출금으로 인한 일시정지 ====', true);
          WithDrawProc;
        end else
          DoLog( Format('==== 출금실패 : %s ====', [ Result.Reason ] ), true);
      end;
    RES_WT_LIST :
      if Result.Code = 0 then begin
        DoLog( Format('==== 출금완료 : %s ====', [ Result.Reason ] ), true);
        FWDConfirimFalg[spSub]  := true;

      	if FSymbols[spSub] <> nil then
        	App.Engine.ApiManager.ExManagers[FSymbols[spSub].Spec.ExchangeType].RequestBalance(FSymbols[spSub]);
      end;
  end;

end;

