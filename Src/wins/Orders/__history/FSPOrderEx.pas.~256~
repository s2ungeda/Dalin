procedure TFrmSPOrderEx.CopyAvgSpVal( aType : TAutoOrderType );
var
  dArr : Array of double;
  i : integer;
  d : double;
begin
  if FAvgSPVal[aType].Capacity = FWDParam.minTerm then Exit;

  SetLength(dArr, FAvgSPVal[aType].Count);
  try

    for I := 0 to FAvgSPVal[aType].Count-1 do
      dArr[i] := FAvgSPVal[aType].Pop;

    FAvgSPVal[aType].Init(FWDParam.minTerm);

    for I := 0 to High(dArr) do
      FAvgSPVal[aType].Push(dArr[i]);
  finally
    SetLength(dArr, 0);
  end;

end;

