procedure TFrmSPOrderEx.CalcSPValue;
var
  dBidPrice, dAskPrice : double;
begin

  if (FSymbols[spMajor] = nil) or (FSymbols[spSub] = nil) then Exit;
  if (FMgQuotes[spMajor] = nil) or (FMgQuotes[spSub] = nil) then Exit;

  if cbHogaMerge.Checked then
  begin
    dBidPrice := FMgQuotes[spMajor].Bids[0].Price;
    dAskPrice := FMgQuotes[spMajor].Asks[0].Price
  end else
  begin
    dBidPrice := FSymbols[spMajor].Bids[0].Price;
    dAskPrice := FSymbols[spMajor].Asks[0].Price;
  end;

  if CheckZero( dBidPrice) then
    FSPValue[aoEntry] := 0
  else
    FSPValue[aoEntry] := ( FSymbols[spSub].Bids[0].Price - dBidPrice ) / dBidPrice * 100;

  if CheckZero( dAskPrice ) then
    FSPValue[aoExit] := 0
  else
    FSPValue[aoExit] := ( FSymbols[spSub].Asks[0].Price - dAskPrice ) / dAskPrice * 100;
end;

