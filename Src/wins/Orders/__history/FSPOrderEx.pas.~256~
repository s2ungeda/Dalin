function TFrmSPOrderEx.SubscribSymbol : boolean;
var
  aSymbol : TSPSymbolArray;
  aExKind : TExchangeKind;
  I: TSPType;
begin

  Result := false;

  try

    aExKind := TExchangeKind( cbMajor.ItemIndex + 1 );
    aSymbol[spMajor] := App.Engine.SymbolCore.BaseSymbols.FindSymbol(edtCode.Text, aExKind);
    aSymbol[spSub] := App.Engine.SymbolCore.BaseSymbols.FindSymbol(edtCode.Text, TExchangeKind( cbSub.ItemIndex + 1 ));

    if (aSymbol[spMajor] = nil) or (aSymbol[spSub] = nil) then
    begin
//      ShowMessage('종목코드를 확인하세요');
      Exit;
    end;

    //if aSymbol[spMajor] = FSymbols[spMajor] then Exit;

    for I := spMajor to High(TSPType) do
    begin
      aExKind := aSymbol[i].Spec.ExchangeType;
      if FSymbols[i] <> nil then
        App.Engine.QuoteBroker.Brokers[aExKind].Cancel(Self, FSymbols[i]);
      App.Engine.QuoteBroker.Brokers[aExKind].Subscribe(Self, aSymbol[i], QuoteProc );
      FSymbols[i] := aSymbol[i];
      //FMgQuotes[i].SetSymbol( FSymbols[i], StrToInt(edtMergeUnit.Text) );
    end;

    Result := true;

  finally
//    if Sender <> nil then
      for I := spMajor to High(TSPType) do
        if FSymbols[i] <> nil then
          FMgQuotes[i].SetSymbol( FSymbols[i], StrToInt(edtMergeUnit.Text) );
  end;
end;

