procedure TFrmSPOrderEx.Start;
var
  aSp : TSPOrder;
  iErr, I: Integer;
  bStart : boolean;
begin
  if not CheckInput(iErr) then
  begin
    ShowMessage('입력값을확인하세요' + GetFailMessage(iErr));
    cbRun.Checked := false;
    Exit;
  end;

  CalcLimtiRate;

  bStart := false;

  for I := 0 to FSPOrders.Count-1 do
  begin
    aSP := FSPOrders.SPOrders[i];
    if aSP <> nil then
    begin
      //aSP.Init( FParams[i]);
      aSP.Init(FSymbols, FMgQuotes, FParams[i]);
      aSP.OnSPNotify    := OnTextNotifyEvent;
      aSP.OnSPNotifyEx  := OnIntNotifyEVent;
      aSP.OnQuoteNofity := nil;

      bStart := aSP.Start;

      if not bStart then
        break;
    end;
  end;


  if not bStart then
  begin
    cbRun.Checked := false;
    ShowMessage('시작을 할 수 없음');
    Exit;
  end;

  case FParams[0].SubEx of
    ekUpbit : FReq[spSub] := TUpbitWithdraw.Create;
    ekBithumb : FReq[spSub] := TBitWithdraw.Create;
  end;

  case FParams[0].MajorEx of
    ekUpbit : FReq[spMajor] := TUpbitWithdraw.Create;
    ekBithumb : FReq[spMajor] := TBitWithdraw.Create;
  end;

  // 출금
  if FReq[spSub] <> nil then
    FReq[spSub].OnNotify := WithDrawNotify;

  // 입금리스트
  if FReq[spMajor] <> nil then
    FReq[spMajor].OnNotify := DepositList;

  if CheckBox1.Checked then
    Panel3.Color  := clFuchsia
  else
    Panel3.Color  := clSkyBlue;

  FCount  := 0;
  FLimitCount := 0;
  FReqCount   := 0;

  FInitBalance[spMajor] := GetBalance(spMajor);
  FInitBalance[spSub] := GetBalance(spSub);

  // 전략매니저에 등록
  App.Engine.StgManager.SPObject.SetObject(FParams[0].MajorEx, FParams[0].SubEx, FParams[0].Code );

end;

procedure TFrmSPOrderEx.Stop;
var
  aSP : TSPOrder;
  i : integer;
begin
  for I := 0 to FSPOrders.Count-1 do
  begin
    aSP := FSPOrders.SPOrders[i];
    if aSP <> nil then
      aSP.Stop;
  end;

  App.Engine.StgManager.SPObject.DeleteObject(FParams[0].MajorEx, FParams[0].SubEx, FParams[0].Code );

  DpTimer.Enabled := false;

  FreeAndNil(FReq[spMajor]);
  FreeAndNil(FReq[spSub]);

  Panel3.Color  := clBtnFace;
end;

