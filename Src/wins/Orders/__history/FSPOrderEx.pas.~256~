  case iErr of
    1,2,3,4,5 : Result := IntToStr(iErr) + ' 번째 SP 수치 설정이 잘못되었음';
    6 : Result := ' 딜레이 초 설정은 0.1 보다 작으면 안됨';
    7 : Result := ' 한도비율의 합이 100 초과';
  end;
end;

