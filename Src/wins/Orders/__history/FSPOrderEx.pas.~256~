procedure TFrmSPOrderEx.Timer1Timer(Sender: TObject);
var
  aSp : TSPOrder;
  I, iTick : Integer;
  dStd, dPrice, dTmp, d1, d2, dSumBal : double;
  dValue  : array [0..9] of double;
  dBalance : array [TSPType] of double;
begin

  try
  // 1분안 한번 빗썸만 잔고 조회.
  if (cbRun.Checked) and (FCount > 60) then
  begin
    FCount := 0;

    FAvgSPVal[aoEntry].Push(FSPValue[aoEntry]);
    FAvgSPVal[aoExit].Push(FSPValue[aoExit]);
  end;

  DoQuoteStopProc;
//
  if FSymbols[spMajor] <> nil then
  begin
    plEntrySP.Caption := Format('%.3f', [ FSPValue[aoEntry] ] );
    plLiquidSP.Caption:= Format('%.3f', [ FSPValue[aoExit] ] );

    dStd  := FAvgSPVal[aoEntry].StDev;

    stValue.Panels[0].Text  :=  Format('%.3f', [ FAvgSPVal[aoEntry].Average + dStd ] );
    stValue.Panels[1].Text  :=  Format('%.3f', [ FAvgSPVal[aoEntry].Average ] );
    stValue.Panels[2].Text  :=  Format('%.3f', [ FAvgSPVal[aoEntry].Average - dStd ] );

    stValue.Panels[3].Text  := FWDParam.minTerm.ToString;
    dStd  := FAvgSPVal[aoExit].StDev;

    stValue.Panels[4].Text  :=  Format('%.3f', [ FAvgSPVal[aoExit].Average + dStd ] );
    stValue.Panels[5].Text  :=  Format('%.3f', [ FAvgSPVal[aoExit].Average ] );
    stValue.Panels[6].Text  :=  Format('%.3f', [ FAvgSPVal[aoExit].Average - dStd ] );
  end;

{
  ('Base호가','계산가격','주문가격','비교호가');
}
  if FSymbols[spSub] <> nil then
  begin

    dBalance[spMajor] :=  GetBalance(spMajor);  dBalance[spSub] :=  GetBalance(spSub);
    dSumBal := dBalance[spMajor] + dBalance[spSub];

    for I := 0 to FSPOrders.Count-1 do
    begin
      aSp := FSPOrders.SPOrders[i];
      if aSp <> nil then begin
        dTmp  := aSp.GetVolume(true);// aSp.SubAccVol[ptLong]  + FParams[i].HavingEntryQty;

        FSPControls[i].edtAccEntryQty.Text   := Format('%.0n', [ CalcDiv( dTmp, dSumBal )*100 ]);
        dTmp  := aSp.GetVolume(false); //aSp.SubAccVol[ptShort] + FParams[i].HavingLiquidQty;
        FSPControls[i].edtAccLiquidQty.Text  := Format('%.0n', [ CalcDiv( dTmp, dSumBal)*100 {ifThenFloat( dTmp >= 0, dTmp, 0 )} ]);
      end;
    end;

    edtEntryMyPrice.Text  := FSymbols[spsub].PriceToStr(FSymbols[spSub].Bids[0].Price);
    edtLiquidMyPrice.Text  := FSymbols[spsub].PriceToStr(FSymbols[spSub].Asks[0].Price);

  end;

  if FSymbols[spMajor] <> nil then
    if TryStrToInt( edtBaseTick.Text, iTick ) then
    begin

      if cbHogaMerge.Checked then
      //if (cbRun.Checked) and (FParams[0].UseHogaMerge) then
      begin
        if FMgQuotes[spMajor].Bids.Count <= 0 then
          dPrice := 0
        else
          dPrice := FMgQuotes[spMajor].Bids[0].Price;
      end else
        dPrice  :=  FSymbols[spMajor].Bids[0].Price;

      edtEntryBasePrice.Text  := FSymbols[spMajor].PriceToStr( dPrice );

      if cbHogaMerge.Checked then
      begin
        if FMgQuotes[spMajor].Asks.Count <= 0 then
          dPrice := 0
        else
          dPrice := FMgQuotes[spMajor].Asks[0].Price;
      end else
        dPrice  :=  FSymbols[spMajor].Asks[0].Price;

      edtLiquidBasePrice.Text  := FSymbols[spMajor].PriceToStr( dPrice );
    end;

  dBalance[spMajor] :=  GetBalance(spMajor);  dBalance[spSub] :=  GetBalance(spSub);
  edtMajorBalance.Text  := Format('%.4f', [ dBalance[spMajor] ] );
  edtSubBalance.Text    := Format('%.4f', [ dBalance[spSub] ]);

  dTmp  := FSPOrders.GetTotTradePL;
  if CheckZero( dTmp ) then
    edtPL.Font.Color := clBlack
  else if dTmp > 0 then
    edtPL.Font.Color  := clRed
  else
    edtPL.Font.Color  := clBlue;
  edtPL.Text  := FmtString( 0, Round(FSPOrders.GetTotTradePL));
  edtFee.Text := FmtString( 0, FSPOrders.GetTotFee);
  edtTradeRate.Text := FmtString(0, FSPOrders.GetTotTradeRate) + '%';

  FSPOrders.GetTotalValue( dValue );

  if FSymbols[spMajor] <> nil then
    dPrice  := FSymbols[spMajor].Last
  else
    dPrice  := 0;

  d1:=0; d2:=0;
  // 섭 누적매수거래대금(2) / 섭 누적매수게약수(0)
  d1 := CalcDiv( dValue[2], dValue[0]);
  // 주 누적매도거래대금(7) / 주 누적매도계약수(5)
  d2 := CalcDiv( dValue[7], dValue[5]);
  dTmp  := CalcDiv( (d1-d2), dPrice ) * 100;

  stBar2.Panels[1].Text  := FmtString(8, dValue[0]);
  stBar2.Panels[2].Text  := FmtString(2, dTmp )+'%';
  stBar2.Panels[3].Text  := FmtString(0, dValue[2] / 1000 );
  stBar2.Panels[4].Text  := FmtString(0, dValue[7] / 1000);
  //stBar2.Panels[5].Text  := FmtString(0, dValue[2] - dValue[7]);  섭매수대금 - 주매도대금
  stBar2.Panels[5].Text  := FmtString(0, dValue[7] - dValue[2]);  // 주매도대금 - 섭매수대금
  stBar2.Panels[6].Text  := FmtString(8, dValue[0] - dValue[5]);

  d1:=0; d2:=0;
  // 섭 누적매도거래대금(3) / 섭 누적매도계약수(1)
  d1 := CalcDiv( dValue[3], dValue[1]);
  // 주 누적매수거래대금(6) / 주 누적매수계약수(4)
  d2 := CalcDiv( dValue[6], dValue[4]);
  dTmp  := CalcDiv( (d1-d2), dPrice ) * 100;

  stBar.Panels[1].Text  := FmtString(8, dValue[1]);
  stBar.Panels[2].Text  := FmtString(2, dTmp)+'%';
  stBar.Panels[3].Text  := FmtString(0, dValue[3] / 1000);
  stBar.Panels[4].Text  := FmtString(0, dValue[6] / 1000);
  stBar.Panels[5].Text  := FmtString(0, dValue[3] - dValue[6]); // 섭매도대금 - 주매수대금
  stBar.Panels[6].Text  := FmtString(8, dValue[1] - dValue[4]);

  if cbRun.Checked then
  begin
    Label1.Caption  :=  'M: '+FmtString(0, dValue[8]);
    Label2.Caption  :=  'S: '+FmtString(0, dValue[9]);
    Label3.Caption  :=  'T: '+FmtString(0, dValue[8]+ dValue[9]);
  end;

  finally
    inc(FCount);
  end;
end;

procedure TFrmSPOrderEx.CalcLimtiRate;
var
  i : integer;
  dBalance, dQty, dTmp : double;
begin
  dBalance  := GetBalance(spMajor) + GetBalance(spSub);

  DoLog2(Format(' == tot balance : %.8n = %.8n + %.8n ==', [dBalance, GetBalance(spMajor), GetBalance(spSub)] ));

  for I := 0 to SP_CNT-1 do
  begin
    if (dBalance <= EPSILON) or (FParams[i].LimitRate <= 0) then
    begin
      FSPControls[i].edtLimitQty.Text := '0';
      FParams[i].LimitQty       := 0.0;
//      FParams[i].LimitEntryQty  := 0.0;
//      FParams[i].LimitLiquidQty := 0.0;
      FParams[i].HavingEntryQty := 0.0;
      FParams[i].HavingLiquidQty:= 0.0;
    end else begin
      dQty  := FloorEx((dBalance * FParams[i].LimitRate / 100) * QTY_BAESU) / QTY_BAESU;
      FSPControls[i].edtLimitQty.Text := dQty.ToString;
      FParams[i].LimitQty        := dQty;
      FParams[i].HavingEntryQty  := FloorEx((GetBalance(spSub) * FParams[i].LimitRate / 100) * QTY_BAESU)/QTY_BAESU;
      FParams[i].HavingLiquidQty := dQty - FParams[i].HavingEntryQty;

//      FParams[i].LimitEntryQty := dQty - FParams[i].HavingEntryQty;
//      FParams[i].LimitLiquidQty:= dQty - FParams[i].LimitEntryQty;

      DoLog2(Format(' %d :%.8n = %.8n + %.8n ==', [i, dQty, FParams[i].HavingEntryQty, FParams[i].HavingLiquidQty] ));
    end;
  end;
end;

procedure TFrmSPOrderEx.TradeProc(Sender, Receiver: TObject; DataID: Integer;
  DataObj: TObject; EventID: TDistributorID);
begin
  if not cbRun.Checked then Exit;
  if (Self <> Receiver) or (DataObj = nil) then Exit;

  case integer(EventID) of
    ORDER_ACCEPTED,
    ORDER_REJECTED,
    ORDER_CANCELED,
    ORDER_FILLED: FSPOrders.OnTrade(DataObj, Integer(EventID));
  end

end;

end.
