procedure TStgOrders.IsDone;
begin
  if Last = nil then Exit;
  if not Last.IsDone(GetCode) then Exit;
  {
  후주문 체결시 로그 보내는걸로 변경...
  TTVSignal(FOwner).Results[FAoType].Add(Last);
  // 결과 로그..
  if FAOType = aoEntry then begin
    TTVSignal(FOwner).SendMessageToOwner(mtResult, integer(srtEFILL))
  end
  else begin
    TTVSignal(FOwner).SendMessageToOwner(mtResult, integer(srtXFILL))  ;
  end;
    }

  TTVSignal(FOwner).CheckNextOrder(FAOType, FExKind);
end;

