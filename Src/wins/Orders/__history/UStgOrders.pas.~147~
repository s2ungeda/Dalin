  aFill : TFill;
  dSum: double;
begin

  Result := false;

  if TOrder(f.Order).Symbol.Spec.ExchangeType = ekBinance then
    fs := mtF
  else
    fs := mtS;
end;

function TStgOrderItem.IsDone(const sCode: string): boolean;
var

  b1: boolean;
  I: Integer;
  dPutOrdFillQty : double;

begin
  Result := false;
  if FDone then Exit;
  if FOrderList[MK].Count <= 0 then Exit;

  b1 := false;    dPutOrdFillQty := 0;
  for I := 0 to FOrderList[MK].Count-1 do
    if FOrderList[MK][i].State = osFilled then
    begin
      dPutOrdFillQty := dPutOrdFillQty+ FOrderList[MK][i].FilledQty;
      b1 := true;
    end;

  if b1 then begin
    if (GetAfterOrderQty(FMethod) - FFailedLiqQty) < gAOConfig.GetMajorTradeSymbolLotSize(sCode) then
      Result := true;
  end;

  FDone := result;

  if FDone then
  begin
    DoLog(Format('------------ %d.th  %s %s Next Order -------------- %s', [
      Collection.Count, ifThenStr(FAOType  = aoEntry, '진입','청산'),
      FOrderList[MK][0].SideToStr,
      //
      Format('선주문 체결:%s, 선-후 : %s(failedqty %s)', [ doubleToStr(dPutOrdFillQty),
        doubleToStr(GetAfterOrderQty(FMethod)),  DoubleToStr(FFailedLiqQty) ])
    ]) );
  end;
end;

//   TK 체결량,   MK 체결평균가,  TK 체결평균가
procedure TStgOrderItem.CalcFillAvgKip(const dPutFilledQty,dFilledQty, dPutOrdAvgPrice, dAvgPrice: double);
var
  I: Integer;
  dAsk, dBid : double;
begin

  FMethod    := TStgOrders(Collection).Method;

  FPutFilledQty := dPutFilledQty;

  if dFilledQty <= EPSILON then
  begin
    FFilledQty  := 0.0;
    FAvgPrice   := 0.0;
    FKip        := WRONG_VALUE;

    Exit;
  end;

  FFilledQty := dFilledQty;
  FAvgPrice  := dAvgPrice;

  if FAOType = aoEntry {GetState = ssEntry} then begin
    if TStgOrders(Collection).Method = S then begin
      dAsk := dAvgPrice * App.Engine.ApiManager.ExRate.Value;
      dBid := dPutOrdAvgPrice;
    end else
    begin
      dAsk := dPutOrdAvgPrice * App.Engine.ApiManager.ExRate.Value;
      dBid := dAvgPrice;
    end;
    if dAsk <= 0 then
      dAsk := 1;
    FKip := (dBid / dAsk - 1) * 100;
//    FIdxPk  := FKip - ( App.Engine.SymbolCore.Tethers[aS

  end else
  if FAOType = aoExit {GetState = ssExit} then begin
    if TStgOrders(Collection).Method = S then begin
      dAsk := dPutOrdAvgPrice;
      dBid := dAvgPrice * App.Engine.ApiManager.ExRate.Value;
    end else
    begin
      // F - 해외 매수, 국내 매도.
      dAsk := dAvgPrice;
      dBid := dPutOrdAvgPrice * App.Engine.ApiManager.ExRate.Value;
    end;
    if dBid <= 0 then
      dBid := 1;
    FKip := (dAsk / dBid -1) * 100;
  end;

  TStgOrders(Collection).DoSumRealKipParam(Self);

end;


function TStgOrderItem.CheckOrder(const dPrice: double): boolean;
var
  i : integer;
begin

  Result := false;

  for I := 0 to FOrderList[MK].Count-1 do
    if (FOrderList[MK][i] <> nil) and (FOrderList[MK][i].IsCancelAble) then
    begin
      var aOrder :=FOrderList[MK][i];
      if CmpVal(dPrice, aOrder.Price) <> 0 then
      begin
        if aOrder.Symbol.Spec.ExApiType = eaFutUsdt then begin
          if aOrder.ModifyCnt > 50 then
            DoCancelOrder(aOrder)
          else
            DoChange(aOrder, dPrice);
        end  else
          DoCancelOrder(aOrder);

        Result := true;

        DoLog(Format('주문가격 변동으로 정정/취소 : %s -> %s', [
          aORder.PriceToStr, aOrder.Symbol.PriceToStr(dPrice) ] )  );
      end;
    end;
end;

constructor TStgOrderItem.Create(aColl: TCollection);
begin
  inherited;

  FOrderList[MK]  := TList<TOrder>.Create;
  FOrderList[TK]  := TList<TOrder>.Create;

  FMakerCount := 1;
  FDone       := false;
  FKip        := WRONG_VALUE;

  FFailedLiqQty    := 0;
end;

destructor TStgOrderItem.Destroy;
begin

  FOrderList[MK].Free;
  FOrderList[TK].Free;

  inherited;
end;

// Only Maker Order
function TStgOrderItem.DoOrder(aAccount: TAccount; aSymbol: TSymbol; iSide: integer;
  dPrice, dQty: double; aoType: TAutoOrderType; trgCEX: TExchangeKind) : TOrder;
begin
  Result := nil;
  if not App.Engine.TradeCore.CheckLimitOrder(aAccount, aSymbol, iSide, dPrice, dQty, ORD_AUTO) then
  begin
    DoLog( '=========== 공통 리스크 제한에 걸림 ===============');
    if aoType = aoEntry then
      TTVSignal(TStgOrders(Collection).FOwner).SendMessageToOwner(mtResult, integer(srtERSK))
    else
      TTVSignal(TStgOrders(Collection).FOwner).SendMessageToOwner(mtResult, integer(srtXRSK));
    Exit;
  end;

  Result := App.Engine.TradeCore.Orders[aSymbol.Spec.ExchangeType].NewOrder(
    aAccount, aSymbol, iSide, dQty, pcLimit, dPrice, tmGTX
  );

  if (Result<> nil) then
  begin
    FOrderList[MK].Add(Result);

    Result.StgType   := stTVSignal;
    Result.GroupNo   := Name;
    Result.Tag       := PUT_ORD;
    Result.Entry     := aoType = aoEntry ;
    Result.TargetCEX := integer(trgCEX);

    App.Engine.TradeBroker.Send( Result );
    FAOType := aoType;
    // 환율 저장..
    FExRate := Result.ExRate;

    DoLog(Format('Put 주문(%d) %s - %s, (%s|%s) ', [
      Index, Result.SideToStr, Result.RepresentWithEx ,
      aSymbol.PriceToStr(aSymbol.Asks[0].Price), aSymbol.PriceToStr(aSymbol.Bids[0].Price)
      ] ) );

    if Result.Entry then
      TTVSignal(TStgOrders(Collection).FOwner).SendMessageToOwner(mtResult, integer(srtEORD))
    else
      TTVSignal(TStgOrders(Collection).FOwner).SendMessageToOwner(mtResult, integer(srtXORD));

  end;
end;

function TStgOrderItem.DoTakerOrder(aAccount: TAccount; aSymbol: TSymbol;
  iSide: integer; dPrice, dQty: double; aoType: TAutoOrderType): TOrder;
begin
  Result := nil;

  Result := App.Engine.TradeCore.Orders[aSymbol.Spec.ExchangeType ].NewOrder(
        aAccount, aSymbol, iSide, dQty, pcLimit, dPrice, tmGTC
      );

  if Result = nil then Exit;

  Result.GroupNo  := Name;
  Result.StgType  := stTVSignal;
  Result.Tag      := LIQ_ORD;
  Result.Entry    := aoType = aoEntry ;
  Result.TargetCEX:= integer(TStgOrders(Collection).ExKind);

  // 거부를 내기 위해
//  Result.OrderQtyBI.convert('0');
//  Result.OrderQty := 0;

  if (aSymbol.Spec.ExchangeType = ekBinance) and (aoType = aoExit) then
    Result.ReduceOnly := gAOConfig.Result.UseReduce;

  App.Engine.TradeBroker.Send(Result);

  // 다음 거부 방지를 위해
//  Result.OrderQty := dQty;
//  Result.OrderQtyBI.convert(FmtString(REsult.Symbol.Spec.QtyPrecision, dQty, 1) );

  DoLog(Format('%s Hit 주문 %s - (%s|%s)', [ GetStateToStr, Result.RepresentWithEx,
    Result.Symbol.PriceToStr(Result.Symbol.Asks[0].Price),
    Result.Symbol.PriceToStr(Result.Symbol.Bids[0].Price)
    ] ));
end;

// 체결된 주문,  나가야 할 주문의 계좌, 종목
function TStgOrderItem.LiquidOrder(const f:TFill; aAccount: TAccount; aSymbol: TSymbol): boolean;
var
  iSide, iTick: integer;
  dPrice: double;
  rOrder, aTarget: TOrder;

  dTmp, dQty : double;
  o: TOrder;
begin
  Result := false;

  o := f.Order as TOrder;

  dQty := GetAfterOrderQty(f, aSymbol);
  if dQty <= EPSILON then Exit;
  // 해외체결 -> 국내 주문(STick)
  iTick := ifThen(aSymbol.Spec.ExchangeType = ekBinance,
    gAOConfig.Result.FTick, gAOConfig.Result.STick);

  if f.Side > 0 then begin
    dPrice  := TicksFromPrice(aSymbol, aSymbol.Bids[0].Price , -iTick);
    iSide   := -1;
  end
  else begin
    dPrice  := TicksFromPrice(aSymbol, aSymbol.Asks[0].Price, iTick);
    iSide   := 1;
  end;
  // 위 아래 범위 제한 체크(only  binance)
  dPrice := aSymbol.GetHitOrderPrice(iSide, dPrice);

  rOrder := nil;
  try
    if not aSymbol.IsOrderAble(dPrice, dQty) then
    begin
      DoLog( Format('+++++ Dust 발생 (%s > %s(%s), TotD(%s)) +++++ ', [
        aSymbol.Spec.MinNotional.ToString, doubleToStr(dPrice * dQty),
        doubleToStr(dQty),  doubleToStr(GetAfterOrderQty(FMethod) + dQty) ] ));
    end else
    begin
      rOrder := DoTakerOrder(aAccount, aSymbol, iSide, dPrice, dQty, FAOType);
      if rOrder = nil then
      begin
        DoLog('--------------- 청산 주문 실패 !!!----------------');
      end else
      begin
        GetAfterOrders.Add(rOrder);
        //FOrderList[TK].Add(rOrder);
      end;
    end;
  finally
    if rOrder = nil then begin
      SetAfterOrderQty(dQty);
      FFailedLiqQty := FFailedLiqQty + dQty;
      DoLog( Format('후주문 실패 수량 Add : %s -> %s', [DoubleToStr(dQty),
        DoubleToStr(FFailedLiqQty)]) );
    end else
      Result := true;
  end;

end;


function TStgOrderItem.ReLiquidOrder(aTarget: TOrder): boolean;
var
  iTick: integer;
  dPrice: double;
  aOrder: TOrder;
  bDust : boolean;
begin
  Result := false;
  bDust  := false;

  if aTarget.ModifyCnt + 1 > gAOConfig.Result.ReTryCount then
  begin
    DoLog( Format('+++++ Try count over Dust 발생 (Add Dust %s) +++++ ', [DoubleToStr(aTarget.OrderQty)] ));
    bDust := true;
  end else
  begin
    if aTarget.Symbol.Spec.ExchangeType = ekBinance then begin
      iTick   := gAOConfig.Result.FTick;
    end
    else begin
      iTick   := gAOConfig.Result.STick;
    end;

    if aTarget.Side > 0 then
      dPrice  := TicksFromPrice(aTarget.Symbol, aTarget.Symbol.Asks[0].Price, iTick)
    else
      dPrice  := TicksFromPrice(aTarget.Symbol, aTarget.Symbol.Bids[0].Price, -iTick);

    dPrice := aTarget.Symbol.GetHitOrderPrice(aTarget.Side, dPrice);

    if not aTarget.Symbol.IsOrderAble(dPrice, aTarget.OrderQty) then
    begin
      DoLog( Format('+++++ Liq timer Dust 발생 (%s > %s(%s)) +++++ ', [
        aTarget.Symbol.Spec.MinNotional.ToString, doubleToStr(dPrice * aTarget.OrderQty), doubleToStr(aTarget.OrderQty)] ));
      bDust := true;
    end else
    begin
      aOrder := MakeNewLiqOrder(aTarget, dPrice);
      if aOrder <> nil then
      begin
        aOrder.ModifyCnt  := aTarget.ModifyCnt + 1;
        GetAfterOrders.Add(aOrder);
        //FOrderList[TK].Add(aOrder);
        DoLog(Format('%d.th Hit 주문 %s', [aOrder.ModifyCnt, aOrder.Represent]) );
        //FOrderList[TK].Remove(aTarget);
        GetAfterOrders.Remove(aTarget);
        Result := true;
      end;
    end;
  end;

  if bDust then
  begin
//    FDusts.AddDust(aTarget.Symbol, aTarget.Side, aTarget.OrderQty).GroupNo  := aTarget.GroupNo;
    //FOrderList[TK].Remove(aTarget);
    SetAfterOrderQty(aTarget.OrderQty);
    GetAfterOrders.Remove(aTarget);
    Result:= true;
  end;

end;

function TStgOrderItem.MakeNewLiqOrder(aTarget: TOrder; dPrice: double): TOrder;
begin
  Result := App.Engine.TradeCore.Orders[aTarget.Symbol.Spec.ExchangeType].NewOrder(
    aTarget.Account, aTarget.Symbol, aTarget.Side, aTarget.OrderQty, pcLimit, dPrice, tmGTC
  );

  if Result = nil then Exit;

  Result.GroupNo  := aTarget.GroupNo;
  Result.StgType  := aTarget.StgType;
  Result.Tag      := LIQ_ORD;
  Result.Entry    := aTarget.Entry;
  Result.TargetCEX:= aTarget.TargetCEX;

//  if aTarget.ModifyCnt < gAOConfig.Result.ReTryCount then
//  Result.OrderQtyBI.convert('0');
//  Result.OrderQty := 0;

  if aTarget.Symbol.Spec.ExchangeType = ekBinance then
    Result.ReduceOnly := gAOConfig.Result.UseReduce;

  App.Engine.TradeBroker.Send(Result);

  // 다음 거부 방지를 위해
//  Result.OrderQty := Result.OrgOrderQty;
//  Result.OrderQtyBI.convert(FmtString(REsult.Symbol.Spec.QtyPrecision, Result.OrgOrderQty, 1) );

  DoLog(Format('Hit 주문 %s - (%s|%s)', [Result.RepresentWithEx,
    Result.Symbol.PriceToStr(Result.Symbol.Asks[0].Price),
    Result.Symbol.PriceToStr(Result.Symbol.Bids[0].Price)
    ] ));

end;

