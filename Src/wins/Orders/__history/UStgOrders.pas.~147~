function TStgOrderItem.GetLiqExKindToStr: string;
var
  i: integer;
  cnt: array [TExchangeKind] of integer;
  e, es : TExchangeKind;
begin
  Result := '';
  for e := ekBinance to High(TExchangeKind) do cnt[e] := 0;

  for I := 0 to FOrderList[TK].Count-1 do
    if FOrderList[TK][i].State = osFilled then
    begin
      e := FOrderList[TK][i].Symbol.Spec.ExchangeType;
      inc(cnt[e]);
    end;

  i := -1;
  for e := ekBinance to High(TExchangeKind) do
    if (cnt[e] > EPSILON) and (cnt[e] > i) then
    begin
      i := cnt[e];
      es:= e;
    end;

  if i < 0  then
    Result := ''
  else
    Result := TExShortDesc[es];
end;

function TStgOrderItem.GetActiveOrderQty: double;
var
  I: Integer;
begin
  Result := 0;

  for I := 0 to FOrderList[MK].Count-1 do
    if FOrderList[MK][i].State = osSent then
      Result := Result +  FOrderList[MK][i].OrderQty
    else if FOrderList[MK][i].State = osActive then
      Result := Result +  FOrderList[MK][i].ActiveQty;
end;

