procedure TStgOrderItem.AllCancel;
var
  I: Integer;
begin
  for I := 0 to FOrderList[MK].Count-1 do
    if (FOrderList[MK][i] <> nil) and (FOrderList[MK][i].IsCancelAble) then
      DoCancelOrder(FOrderList[MK][i]);
end;

procedure TStgOrderItem.DoCancelOrder( aOrder : TOrder );
var
  aCnlOrder : TOrder;
begin
  with App.Engine do
  begin
    aCnlOrder := TradeCore.Orders[aOrder.Account.ExchangeKind].NewCancelOrder(aOrder, aOrder.ActiveQty);
    if aCnlOrder <> nil then begin
      TradeBroker.Send( aCnlOrder);
      DoLog( Format('주문 취소- %s', [ aOrder.Represent ]  ) );
    end;
  end;

end;

procedure TStgOrderItem.DoChange(aOrder: TOrder; dPrice: double);
begin
  if (aOrder.OrderType = otNormal) and (aOrder.State = osActive) and (not aORder.Modify) then
  begin
    App.Engine.TradeBroker.Send(
      App.Engine.TradeCore.Orders[aOrder.Account.ExchangeKind].NewChangeOrder(aOrder, dPrice)
      );
//    DoLog( Format('주문 정정- %s', [ aOrder.Represent ]  ) );

  end;
end;

procedure TStgOrderItem.DoLog(sLog: string);
begin
  TStgOrders(Collection).DoLog(sLog);
end;

