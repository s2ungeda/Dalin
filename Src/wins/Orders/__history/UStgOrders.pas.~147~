  Result := false;
  if Last = nil then Exit;

  for I := 0 to Last.FOrderList[iMT].Count-1 do
  begin
    if aOrder = Last.FOrderList[iMT][i] then
    begin
      Result := true;
      break;
    end;
  end;

end;

