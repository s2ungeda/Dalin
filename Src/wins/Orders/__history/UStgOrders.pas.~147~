procedure TStgOrders.CalcAvgData(f:TFill; dExRate: double; iOrdDiv: integer );
var s : TSideType;
  dPrice : double;
begin
  // 누적체결은 적은걸 선택(후주문이 항상 작다);
  FSumFilledQty := FMTFilledQty[TK];
  if iORdDiv = LIQ_ORD then
    FSumExRate  := FSumExRate + (dExRate * f.Volume);

  s := TSideType(ifThen(f.Side > 0, 0, 1));

  if f.Symbol.Spec.ExchangeType = ekBinance then
    dPrice := f.Price * dExRate
  else
    dPrice := f.Price;

  FKipData[s].AvgPrice  :=(FKipData[s].AvgPrice * FKipData[s].FilledQty + dPrice * f.Volume)
    / (FKipData[s].FilledQty + f.Volume);

  FKipData[s].FilledQty := FKipData[s].FilledQty + f.Volume;
end;

procedure TStgOrders.CheckTimer;
var
  ElapsedMs: UInt64;
begin
  if FWaitStartTick = 0 then
    Exit;

  ElapsedMs := GetTickCount64 - FWaitStartTick;

  if FSuspend then
      begin
        if (gAOConfig.Result.ResumeType = 0) and
           (ElapsedMs >= gAOConfig.Result.ResumeDelay * 1000) then
        begin
          RjtInit;
          DoLog(Format('--- %s %s %s 자동 거래 재개 (%d)  ---', [
            TAutoOrderTypeDesc[FAoType], ifThenStr(FExKind = ekBinance, 'F', 'S'),
            TExchangeKindDesc[FExKind],  ElapsedMs
            ]) );

          SendMessageAboutSuspend;
        end;
      end;
end;

procedure TStgOrders.DoCancelForSMP(const f:TFill; aAccount: TAccount; aSymbol: TSymbol);
  var
    iRes:integer;
begin

  iRes := App.Engine.TradeCore.Orders[aSymbol.Spec.ExchangeType].CancelActiveOrders(
    f.Side * -1, aAccount, aSymbol) ;

  if iRes > 0 then
  begin
    DoLog( Format(' -- SMP 회피 %d 개 주문 취소-- ', [ iRes ]  ) );
  end;

end;

