function TStgOrderItem.GetAfterOrderQty(const f: TFill; aOrdSymbol: TSymbol): double;
var
  dUnit, dSum: double;
  fs: TMethodType;
begin

  Result := 0;

  fs := FMethod;

  dUnit := gAOConfig.GetMajorTradeSymbolLotSize(TOrder(f.Order).Symbol.Spec.BaseCode);
  dSum  := CalcAfterOrderQty(f.Volume, dUnit);

  if dUnit < 0 then begin
    if aOrdSymbol.Spec.ExchangeType = ekBinance then begin
      // 1. 국내 부분 체결시, 해외와 소수점이 다르기땜시  맞추기 위하 노오오오력...
      Result := TruncDecimal(dSum, aOrdSymbol.Spec.QtyPrecision);
      if not CheckZero(dSum - Result) then begin
        SetAfterOrderQty(dSum - Result);
        DoLog( Format('+++++ 소수점으로 인한 수량 변경 :  %s -> %s +++++',
          [doubleToStr(dSum), DoubleToStr(Result)]));
      end;
    end else
      Result := dSum;
  end else
  begin
    Result := dSum;
  end;

end;

