begin
  Clear;

  FMTFilledQty[MK]  := 0;
  FMTFilledQty[TK]  := 0;

  FSumFilledQty:= 0;
  FSumRealKip  := 0;
  FSumExRate   := 0;

  FKipData[stLong].Init;
  FKipData[stShort].Init;

  RjtInit;
end;

procedure TStgOrders.SendMessageAboutSuspend;
var srType: TSigResultType;
begin
  case FAoType of
    aoEntry: if FSuspend then srType := srtERJT else srType := srtERSM;
    aoExit:  if FSuspend then srType := srtXRJT else srType := srtXRSM;
  end;

  TTVSignal(FOwner).SendMessageToOwner(mtResult, integer(srType));
end;

procedure TStgOrders.ManualResume(bManual: boolean);
var ival: integer;
begin
  if FSuspend  then
  begin
    RjtInit;

    DoLog(Format('--- %s %s %s %s 거래 재개 ---', [
      TAutoOrderTypeDesc[FAoType], ifThenStr(FExKind = ekBinance, 'F', 'S'),
      TExchangeKindDesc[FExKind] ,
      ifThenStr(bManual,'수동', '바로')
      ]) );

    SendMessageAboutSuspend;
  end;
end;

