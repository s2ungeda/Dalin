procedure TStgOrders.OnOrder(aOrder: TOrder);
begin
  if FSuspend then
    ManualResume(false)
  else
    FRejectCount := 0;
end;

function TStgOrders.OnOrderFill(const f:TFill; tarCEX: TExchangeKind): boolean;
begin
  // SMP 거부를 위해 주문 취소 필요
  if tarCEX <> ekBinance then
    DoCancelForSMP(f, TTVSignal(FOwner).GetAccount(tarCEX),
                      TTVSignal(FOwner).GetSymbol(tarCEX));
  //
  Result := Last.LiquidOrder(f, TTVSignal(FOwner).GetAccount(tarCEX),
                                TTVSignal(FOwner).GetSymbol(tarCEX));
end;

procedure TStgOrders.RejectOrderProc(aOrder: TOrder);
begin
  Inc(FRejectCount);

  if FRejectCount >= gAOConfig.Result.RjtMaxCnt then
  begin
    FWaitStartTick := GetTickCount64;
    FSuspend       := true;
    DoLog(Format('--- %s %s %s 연속 거부 %d.th -> 잠시중단 ---', [
      TAutoOrderTypeDesc[FAoType], ifThenStr(FExKind = ekBinance, 'F', 'S'),
      TExchangeKindDesc[FExKind],  FRejectCount
      ]) );

    SendMessageAboutSuspend;
  end;
end;

procedure TStgOrders.RjtInit;
begin
  FRejectCount := 0;
  FWaitStartTick := 0;
  FSuspend  := false;
end;

