procedure TStgOrders.DoSumRealKipParam(const aItem: TStgOrderItem);
var
  d: double;
begin
  d := Min(aItem.PutFilledQty, aItem.FilledQty);
  if (d <= EPSILON) or (aItem.Kip = WRONG_VALUE) then Exit;

  FSumFilledQty := FSumFilledQty + d;
  FSumRealKip   := FSumRealKip + (aItem.Kip * d);
  FSumExRate    := FSumExRate + (aItem.ExRate * d);
end;

