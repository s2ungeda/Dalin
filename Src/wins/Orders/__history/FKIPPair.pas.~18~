  var
    stTxt : string;
    aBack : TColor;
    dFormat : word;
    aRect : TRect;
    iVal  : integer;
begin

  aBack := clWhite;
  aRect := Rect;
  dFormat := DT_RIGHT or DT_VCENTER;

  with sgHoga do
  begin
    stTxt := Cells[ACol, ARow];

    Canvas.Brush.Color  := aBack;
    Canvas.Font.Size := FFontSize;
    Canvas.Font.Name := FFontName;

    // 매도/매수 하이라이트
    if ACol in [1 .. 2] then
      if Objects[ ACol, ARow] <> nil then
      begin
        iVal := integer( Objects[ACol, ARow] );
        if iVal > 0 then begin
          if ACol = 1 then
            aBack := Short_COLOR
          else
            aBack := LONG_COLOR;
        end;
      end;

    aRect.Top := Rect.Top + 2;
    aRect.Right := aRect.Right - 1;
    dFormat := dFormat or DT_VCENTER;

    Canvas.Brush.Color  := aBack;
    Canvas.FillRect( Rect);
    DrawText( Canvas.Handle, PChar( stTxt ), Length( stTxt ), aRect, dFormat );

    if ACol in [1,2] then
    begin
      Canvas.Pen.Color := clBlack;
      Canvas.PolyLine([Point(Rect.Left,  Rect.Bottom),
                       Point(Rect.Right, Rect.Bottom),
                       Point(Rect.Right, Rect.Top)]);
    end else
    if ACol = 0 then
    begin
      Canvas.Pen.Color := clBlack;
      Canvas.PolyLine([Point(Rect.Right, Rect.Bottom),
                       Point(Rect.Right, Rect.Top)]);

    end;

  end;
end;


