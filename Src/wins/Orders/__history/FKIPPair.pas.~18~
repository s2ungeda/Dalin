procedure TFrmKIPPair.calcEstPrice( aType : TPositionType; iRow : integer);
var
  dTmp, dQty, dSum , dPrice: double;
  i : integer;
  aList : TList;
  aItem : TCalcPriceItem;
  aDepths : TMarketDepths;
begin

  if FSymbol[aType] = nil then Exit;
  if (iRow = 0) and ( not TryStrToFloat( edtEntryQty.Text, dQty )) then Exit;
  if (iRow = 1) and ( not TryStrToFloat( edtExitQty.Text, dQty )) then Exit;
  if dQty <= 0 then Exit;

  aList := TList.Create;
  try

    if iRow = 0 then begin
      // entry
      // 매수거래소에서 매수를, 매도거래소에서 매도를
      if aType = ptLong then
        aDepths := FSymbol[aType].Asks
