  if aStorage = nil then Exit;

  aStorage.FieldByName('SellExIndex').AsInteger := cbSellEx.ItemIndex;
  aStorage.FieldByName('BuyExIndex').AsInteger := cbBuyEx.ItemIndex;

  aStorage.FieldByName('StartTime').AsFloat := double( dtStart.Time );
