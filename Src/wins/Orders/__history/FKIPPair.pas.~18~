procedure TFrmKIPPair.subscribeSymbol(aSymbol: TSymbol; aType :TPositionType );
begin
  if aSymbol = nil then Exit;
  if FSymbol[aType] = aSymbol then Exit;

  if FSymbol[aType] <> nil then
    App.Engine.QuoteBroker.Brokers[aSymbol.Spec.ExchangeType].Cancel( Self, FSymbol[aType] );
  App.Engine.QuoteBroker.Brokers[aSymbol.Spec.ExchangeType].Subscribe( Self, aSymbol, SymbolProc );

  FSymbol[aType] := aSymbol;

  // 바이낸스 입출금은 현물을 참고 하기땜시.
  if aSymbol.Spec.ExchangeType = ekBinance  then
    FBinSymbol := App.Engine.SymbolCore.BaseSymbols.FindSymbol(  aSymbol.Spec.BaseCode, ekBinance, mtSpot );

  UpdateHoga( aType );

end;

procedure TFrmKIPPair.UpdateHoga( aType : TPositionType );
var
  stLast : string;
  procedure setcolor( stPrice1, stPrice2 : string; iCol, iRow : Integer );
  begin
    if stPrice1 = stPrice2 then
      sgHoga.Objects[iCol, iRow]  := Pointer(100)
    else
      sgHoga.Objects[iCol, iRow]  := Pointer(-100);
  end;
begin
  with sgHoga do

  case aType of
    ptLong: begin
        stLast := FSymbol[aType].PriceToStr( FSymbol[aType].Last);

        Cells[2, 0] := FSymbol[aType].PriceToStr( FSymbol[aType].Asks[0].Price );
        Cells[3, 0] := FSymbol[aType].QtyToStr( FSymbol[aType].Asks[0].Volume );

        setcolor(Cells[2,0], stLast, 2,0);

        Cells[2, 1] := FSymbol[aType].PriceToStr( FSymbol[aType].Bids[0].Price );
        Cells[3, 1] := FSymbol[aType].QtyToStr( FSymbol[aType].Bids[0].Volume );

        setcolor(Cells[2,1], stLast, 2,1);

      end;
    ptShort: begin
        stLast := FSymbol[aType].PriceToStr( FSymbol[aType].Last);

        Cells[1, 0] := FSymbol[aType].PriceToStr( FSymbol[aType].Asks[0].Price );
        Cells[0, 0] := FSymbol[aType].QtyToStr( FSymbol[aType].Asks[0].Volume );

        setcolor(Cells[1,0], stLast, 1,0);

        Cells[1, 1] := FSymbol[aType].PriceToStr( FSymbol[aType].Bids[0].Price );
        Cells[0, 1] := FSymbol[aType].QtyToStr( FSymbol[aType].Bids[0].Volume );

        setcolor(Cells[1,1], stLast, 1,1);
      end;
  end;
end;

procedure TFrmKIPPair.SymbolProc(Sender, Receiver: TObject; DataID: Integer;
  DataObj: TObject; EventID: TDistributorID);
  var
    aSymbol : TSymbol;
begin
  if ( Receiver <> Self ) or ( DataObj = nil ) then Exit;

  aSymbol := (DataObj as TQuote).Symbol;

  if aSymbol = FSymbol[ptLong] then begin
    UpdateHoga( ptLong );
    calcEstPrice(ptLong);
    calcEstPrice(ptLong,1);
  end
  else if aSymbol = FSymbol[ptShort] then begin
    UpdateHoga( ptShort);
    calcEstPrice(ptShort);
    calcEstPrice(ptShort,1);
  end;

end;

procedure TFrmKIPPair.tmExRateTimer(Sender: TObject);
begin
  edtExRate.Text  := Format('%.2n', [ App.Engine.ApiManager.ExRate.Value ] );

  if FBinSymbol <> nil then
  begin
    if FBinSymbol.DepositState then
      sgDnw.Cells[1, 0] := ifThenStr( FBinSymbol.NetworkList.IsDeposit(true), 'O', '△')
    else
      sgDnw.Cells[1, 0] := ifThenStr( FBinSymbol.NetworkList.IsDeposit(false), 'X', '△');

    if FSymbol[ptShort].WithDrawlState then
      sgDnw.Cells[1, 1] := ifThenStr( FBinSymbol.NetworkList.IsWithdraw(true), 'O', '△')
    else
      sgDnw.Cells[1, 1] := ifThenStr( FBinSymbol.NetworkList.IsWithdraw(false), 'X', '△');
  end;

  if FSymbol[ptLong] <> nil then
  begin
    sgDnw.Cells[2, 0] :=ifThenStr( FSymbol[ptLong].DepositState, 'O', 'X');
    sgDnw.Cells[2, 1] :=ifThenStr( FSymbol[ptLong].WithDrawlState, 'O', 'X') ;
  end;
end;

procedure TFrmKIPPair.sgDnWDrawCell(Sender: TObject; ACol, ARow: Integer;
  Rect: TRect; State: TGridDrawState);
  var
    stTxt : string;
    aBack : TColor;
    dFormat : word;
    aRect : TRect;
begin

  aBack := clWhite;
  aRect := Rect;
  dFormat := DT_CENTER or DT_VCENTER;

  with sgDnw do
  begin
    stTxt := Cells[ACol, ARow];

    if (ACol = 0) then
    begin
      aBack   := clBtnFace;
    end else
    begin

    end;

    Canvas.Brush.Color  := aBack;
    Canvas.Font.Size := FFontSize;
    Canvas.Font.Name := FFontName;
    aRect.Top := Rect.Top + 2;
    aRect.Right := aRect.Right - 1;


    Canvas.FillRect( Rect);
    DrawText( Canvas.Handle, PChar( stTxt ), Length( stTxt ), aRect, dFormat );

    if ACol = 0 then
    begin
      Canvas.Pen.Color := clBlack;
      Canvas.PolyLine([Point(Rect.Left,  Rect.Bottom),
                       Point(Rect.Right, Rect.Bottom),
                       Point(Rect.Right, Rect.Top)]);
      Canvas.Pen.Color := clWhite;
      Canvas.PolyLine([Point(Rect.Left,  Rect.Bottom),
                       Point(Rect.Left,  Rect.Top),
                       Point(Rect.Right, Rect.Top)]);
    end;

  end;
end;

