       if aType = ptLong then
        aDepths := FSymbol[aType].Bids
      else
        aDepths := FSymbol[aType].Asks;
    end;

    for I := 0 to aDepths.Count-1 do
    begin
      dTmp := aDepths[i].Volume - dQty;
      if dTmp > 0 then begin
        aItem := TCalcPriceItem.Create;
        aItem.price := aDepths[i].Price;
        aItem.Volume:= dQty;
        aList.Add( aItem );
        break;
      end else
      if dTmp < 0 then begin
        aItem := TCalcPriceItem.Create;
        aItem.price := aDepths[i].Price;
        aItem.Volume:= aDepths[i].Volume;
        aList.Add( aItem );
        dQty := abs(dTmp);
      end else
      if CheckZero(dTmp) then
      begin
        aItem := TCalcPriceItem.Create;
        aItem.price := aDepths[i].Price;
        aItem.Volume:= aDepths[i].Volume;
