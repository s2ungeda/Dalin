procedure TFrmKIPPair.LoadEnv(aStorage: TStorage);
begin
  if aStorage = nil then Exit;

  cbSellEx.ItemIndex  := aStorage.FieldByName('SellExIndex').AsIntegerDef(0);
  cbBuyEx.ItemIndex   := aStorage.FieldByName('BuyExIndex').AsIntegerDef(0);

  dtStart.Time  := TDateTime( aStorage.FieldByName('StartTime').AsFloat );
  dtEnd.Time    := TDateTime( aStorage.FieldByName('EndTime').AsFloat );

  cbDnW.ItemIndex := aStorage.FieldByName('DnwIndex').AsIntegerDef(0);
end;

procedure TFrmKIPPair.SaveEnv(aStorage: TStorage);
