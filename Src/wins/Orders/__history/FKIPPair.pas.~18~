      TExchangeKindDesc[ FAccount[ptLong].ExchangeKind], edtCode.Text]) );
    Exit;
  end;

  subscribeSymbol( aSymbol[ptLong], ptLong );
  subscribeSymbol( aSymbol[ptShort], ptShort );


