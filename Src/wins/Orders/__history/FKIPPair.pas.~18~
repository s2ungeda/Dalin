procedure TFrmKIPPair.btnApplyClick(Sender: TObject);
var
  aSymbol : array [TPositionType] of TSymbol;
begin
  if (FAccount[ptShort] = nil) or ( FAccount[ptLong] = nil) then
  begin
    showmessage('계좌가 없음 ' );
    Exit;
  end;

  aSymbol[ptShort]:=  App.Engine.SymbolCore.BaseSymbols.FindSymbol( edtCode.Text,
      FAccount[ptShort].ExchangeKind, TMarketType(integer(FAccount[ptShort].AccountType)-1) );

  aSymbol[ptLong] := App.Engine.SymbolCore.BaseSymbols.FindSymbol( edtCode.Text,
      FAccount[ptLong].ExchangeKind, TMarketType(integer(FAccount[ptLong].AccountType)-1) );

