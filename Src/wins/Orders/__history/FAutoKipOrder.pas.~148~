procedure TFrmKipAutoOrder.SetEnableUnitContorls( bEntry : boolean; iTag : integer;
  bEnable : boolean );
var
  stTmp : string;
  I: Integer;
begin
   stTmp  := ifThenStr( bEntry , 'En', 'Ex' );

  TEdit( FindComponent( 'edt'+stTmp+'Kip_'+IntToStr(iTag+1) ) ).Enabled := bEnable;
  TEdit( FindComponent( 'edt'+stTmp+'OrderQty_'+IntToStr(iTag+1) )).Enabled := bEnable;
  TEdit( FindComponent( 'edt'+stTmp+'Count_'+IntToStr(iTag+1) )).Enabled  := bEnable;
//  TEdit( FindComponent( 'edt'+stTmp+'Interval_'+IntToStr(iTag+1) )).Enabled := bEnable;
  if bEnable then
  begin
    for I := 0 to FKipOrders.Count-1 do
      if FKipOrders.KipOrders[i].Run then
        Exit;
  end;

  edtCode.Enabled := bEnable;
  cbBuyEx.Enabled := bEnable;
  cbSellEx.Enabled:= bEnable;
  Button1.Enabled := bEnable;
  cbFutType.Enabled := bEnable;

end;

