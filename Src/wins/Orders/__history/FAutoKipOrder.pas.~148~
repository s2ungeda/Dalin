    if not CreateNStart( true, iTag ) then
    begin
      TCheckBox(Sender).Checked := false;
      Exit;
    end;
    Tpanel(TCheckBox(Sender).Parent).Color := clYellow;
  end
  else begin
    Stop( true, iTag);
    SetEnableUnitContorls( true, iTag, true );
    Tpanel(TCheckBox(Sender).Parent).Color := clBtnFace;
  end;

end;

