    FieldByName('LimitEndTime_1').AsFloat         := double( dtLimitEnd1.Time );

    FieldByName('UseLimitStartTime_2').AsBoolean  := ckLimitTime2.Checked;
    FieldByName('LimitStartTime_2').AsFloat       := double( dtLimitStart2.Time );
    FieldByName('LimitEndTime_2').AsFloat         := double( dtLimitEnd2.Time );

    FieldByName('UseLimitStartTime_3').AsBoolean  := ckLimitTime3.Checked;
    FieldByName('LimitStartTime_3').AsFloat       := double( dtLimitStart3.Time );
    FieldByName('LimitEndTime_3').AsFloat         := double( dtLimitEnd3.Time );

    FieldByName('MoveAvgPeriod').AsString   := edtMoveAvgPeriod.Text;
    FieldByName('ExDisparity').AsString     := edtExDisparity.Text;
    FieldByName('FutOrdTick').AsString      := edtFutOrdTick.Text;
