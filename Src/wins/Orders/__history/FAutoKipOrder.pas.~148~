    FieldByName('SellEx').AsInteger := cbSellEx.ItemIndex;

    FieldByName('EnInputQty').AsString    := edtEnInputQty.Text;
    FieldByName('ExInputQty').AsString    := edtEXInputQty.Text;
    FieldByName('ReduceOnly').AsBoolean   := cbReduceOnly.Checked;

    FieldByName('ReTryCount').AsInteger   := FConfig.ReTryCount;
    FieldByName('ReTryInterval').AsInteger:= FConfig.ReTryInterval;
    FieldByName('OrderInterval').AsInteger:= FConfig.OrderInterval;


    for j := 0 to 1 do
      for I := 1 to ConCount do
      begin
        if j = 0 then
          stName  := 'En'
        else
          stName  := 'Ex';

        FieldByName(stName+'Kip_'+IntTostr(i)).AsString      :=TEdit( FindComponent( 'edt'+stName+'Kip_'+IntToStr(i) ) ).Text;
        FieldByName(stName+'OrderQty_'+IntTostr(i)).AsString :=TEdit( FindComponent( 'edt'+stName+'OrderQty_'+IntToStr(i) ) ).Text;
