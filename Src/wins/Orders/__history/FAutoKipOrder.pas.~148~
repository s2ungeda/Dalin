function TFrmKipAutoOrder.CheckProcTime : boolean;
var
  tNow : TDateTime;
  bResult : boolean;
  dmavg, dPer, dDisp   : double;
  iPeriod, iDelay1, iDelay2, iDelay3, iDly, iExDly : integer;

  function IsLimitTime( dtStart, dtEnd, dtNow : TDateTime ) : boolean;
  var
    s, e, n : TDateTime;
  begin

    Result := true;

    s := Frac( dtStart ); e := Frac( dtEnd );  n := Frac( dtNow );

    if e < s then
    begin
      if ( n >= s) or ( n <= e ) then
        Result := false;
    end else
    begin
      if (n >= s ) and ( n <= e ) then
        Result := false;
    end;

  end;

begin

  Result := false;
  tNow := now;

  if ckLimitTime1.Checked then
    if not IsLimitTime( dtLimitStart1.Time, dtLimitEnd1.Time, tNow ) then
      Exit;

  if ckLimitTime2.Checked then
    if not IsLimitTime( dtLimitStart2.Time, dtLimitEnd3.Time, tNow ) then
      Exit;

  if ckLimittime3.Checked then
    if not IsLimitTime( dtLimitStart3.Time, dtLimitEnd3.Time, tNow ) then
      Exit;

  // ČŻŔĚ°Ýµµ.
  if not TryStrToInt( edtMoveAvgPeriod.Text, iPeriod ) then Exit;
  if not TryStrToFloat(edtExDisparity.Text, dPer) then Exit;
  if not TryStrToInt(edtSiseDelay.Text, iDly) then Exit;
  if not TryStrToInt(edtExDelay.Text, iExDly) then Exit;

  dmavg := App.Engine.ApiManager.ExRate.GetAvgExRate( iPeriod);
  if CheckZero(dmavg) then
    Exit
  else begin
    dDisp := abs(App.Engine.ApiManager.ExRate.GetExRate - dmavg) / dmavg * 100;
    if dDisp >= dPer then
    begin
      DoLog( Format('ČŻŔĚ°Ýµµ »ó˝Â  %.2f ( %.2f|%.2f ) ', [  dDisp ,dmavg
        , App.Engine.ApiManager.ExRate.GetExRate ] ), true );
      gbExRate.Color  := clYellow;
      Exit;
    end;
  end;

  gbExRate.Color  := clBtnFace;

  iDelay1 := App.Engine.ApiManager.ExManagers[ekBinance].QuoteSock[1].DelaySec;
  iDelay2 := App.Engine.ApiManager.ExManagers[FExKind[ptLong]].QuoteSock[0].DelaySec;
  iDelay3 := SecondsBetween(now, App.Engine.ApiManager.ExRate.LastTime );

  if (iDelay1 > iDly) or (iDelay2 > iDly) then begin
    DoLog( Format('%s ˝ĂĽĽ µô·ąŔĚ (%d,%d) > %d', [ExKindToStr( FExKind[ptShort] ), iDelay1, iDelay2, iDly ] ), true);
    gbDelay.Color := clYellow;
    Exit;
  end;

  if iDelay3 > iExDly then
  begin
    DoLog(Format('ČŻŔ˛ µô·ąŔĚ %d > %d', [iDelay3, iExDly ]), true);
    gbDelay.Color := clYellow;
    Exit;
  end;
  gbDelay.Color  := clBtnFace;

  Result := true;

end;

function TFrmKipAutoOrder.CreateNStart( bEntry : boolean; iTag : integer ) : boolean;
var
  stName, stTmp : string;
  aItem  : TAutoKipOrderItem;

  dQty, dKip : double;
  iRep, iInter: integer;

  bReduce, bRes : boolean;
  dInt  : TDecimalHelper;
begin
  stTmp  := ifThenStr( bEntry , 'En', 'Ex' );

  bREs := TryStrToFloat( TEdit( FindComponent( 'edt'+stTmp+'Kip_'+IntToStr(iTag+1) ) ).Text, dKip )
      and TryStrToFloat( TEdit( FindComponent( 'edt'+stTmp+'OrderQty_'+IntToStr(iTag+1) ) ).Text, dQty )
      and TryStrToInt( TEdit( FindComponent( 'edt'+stTmp+'Count_'+IntToStr(iTag+1) ) ).Text, iRep )
      //and TryStrToInt( TEdit( FindComponent( 'edt'+stTmp+'Interval_'+IntToStr(iTag+1) ) ).Text, iInter )
      ;

  if not bRes then
  begin
    ShowMessage( 'ŔÔ·Â°ŞŔĚ Ŕß¸ř µĆŔ˝');
    Exit (false );
  end;

  if iRep <= 0 then
  begin
    ShowMessage( 'ŔÔ·Â°ŞŔĚ Ŕß¸ř µĆŔ˝');
    Exit (false );
  end;

  if dQty < FMinQty then
  begin
    ShowMessage('ĂÖĽŇ ÁÖą®Ľö·®ş¸´Ů ŔŰŔ˝');
    Exit (false);
  end;

  if (FSymbols[scDomes] = nil) or (FSymbols[scInter] = nil) then
  begin
    ShowMessage( 'Áľ¸ńĽ±ĹĂŔ» ¸ŐŔú');
    Exit (false );
  end;

  // ąŮŔĚł˝˝ş ĽŇĽöÁˇ ´ÜŔ§ ĂĽĹ©..
  dInt.convert(dQty);
  if dInt.Precision > FSymbols[scInter].Spec.QtyPrecision  then
  begin
    ShowMessage( 'ÁÖą®Ľö·® ĽŇĽöÁˇ °łĽö´Â ' +  FSymbols[scInter].Spec.QtyPrecision.ToString );
    Exit (false );
  end;

  stName := Format('%s_%d', [ stTmp, iTag ] );

  if bEntry then
    bReduce := false
  else
    bReduce := cbReduceOnly.Checked;

  aItem  := FKipOrders.New( stName );
  if aItem <> nil then
  begin
    aItem.KipData.SetKipData(dQty, dKip, iRep, bReduce );
    aItem.KipData.SetConfig( FConfig );
    aItem.OnNotify  := OnLogNotify;
    aItem.OnKipNotify := OnKipNotify;
    aItem.SetSymbol( Self, bEntry, FSymbols );
    aItem.Start;
  end else
  begin
    ShowMessage( 'ÇŘ´ç unit Ŕ» ˝ÇÇŕ ÇŇ Ľö ľřŔ˝');
    Exit (false );
  end;

  Result := true;

  TEdit( FindComponent( 'edt'+stTmp+'DoneCount_'+IntToStr(iTag+1) ) ).Text := '0';

  if Result then
    SetEnableUnitContorls( bEntry, iTag, false );
end;

