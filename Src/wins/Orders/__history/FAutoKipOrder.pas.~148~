procedure TFrmKipAutoOrder.OnKipNotify(Sender: TObject; Value: string);
var
  aItem : TAutoKipOrderItem;
  sts   : TArray<string>;
  iRow  : integer;
  aCheck: TCheckBox;
begin
  aItem := TAutoKipOrderItem( Sender );
  sts   := aItem.Name.Split(['_']);
  if Length(sts) > 1 then
    if TryStrToInt( sts[1], iRow ) then
    begin

      if Value = ORD_STR then
      begin
        var aEdit : TEdit;
        if aItem.IsEntry then
          aEdit := TEdit(FindComponent('edtEnDoneCount_'+IntToStr(iRow+1)))
        else
          aEdit := TEdit(FindComponent('edtExDoneCount_'+IntToStr(iRow+1)));

        if aEdit <> nil then
        begin
          aEdit.Text  := aItem.Count.ToString;
        end;

      end else
      begin

        aCheck := nil;
        if aItem.IsEntry then
          aCheck := TCheckBox(FindComponent('cbEnOn_'+IntToStr(iRow+1)))
        else
          aCheck := TCheckBox(FindComponent('cbExOn_'+IntToStr(iRow+1)));

        if aCheck <> nil then
        begin
          if Value = RJCT_STR then
            Tpanel(aCheck.Parent).Color := clGray
          else begin
            aCheck.Checked := false;
            if Value = DONE_STR then
              Tpanel(aCheck.Parent).Color := clSkyblue
            else if Value = RANG_STR then
              Tpanel(aCheck.Parent).Color := clLime
            else if Value = BAL_STR then
              Tpanel(aCheck.Parent).Color := clRed;
          end;
        end;

      end;
    end;

end;

