procedure TFrmKipAutoOrder.UpdateCalcedPrice;
var
  dQty, dQty2 : double;
begin

  plKrEstShort.Caption := FSymbols[scDomes].PriceToStr( FSymbols[scDomes].Last );
  plOsEstLong.Caption  := FSymbols[scInter].PriceToStr( FSymbols[scInter].Last );

  if FSymbols[scDomes].Last > EPSILON then
    dQty := TMinOrdAmount[FExKind[ptLong]] / FSymbols[scDomes].Last
  else
    dQty := 0.0001;

  if FSymbols[scInter].Spec.FutureType = ftCoin then
  begin
    dQty2 := CalcDiv( FSymbols[scInter].Spec.ContractSize, Fsymbols[scInter].Last );
    plMinQty.Caption  := Format('1 = %.4f ',[dQty2 ] );

  end else
  begin
    dQty2 := StrToFloat( FSymbols[scInter].QtyToStr(  FSymbols[scInter].Spec.MinNotional / FSymbols[scInter].Last ) );

    // binance minQty = stepsize
    if dQty2 < FSymbols[scInter].Spec.QtySize then
      dQty2 := FSymbols[scInter].Spec.QtySize;

    FMinQty := Max( dQty, dQty2);
    plMinQty.Caption  := Format('%d | %s ', [ FSymbols[scInter].Spec.QtyPrecision,
//       FSymbols[scInter].QtyToStr( FSymbols[scInter].Spec.QtySize) ,
       FSymbols[scInter].QtyToStr(FMinQty) ] );
  end;

  plEn.Caption  := Format('%.3f', [ FKipPrice[aoEntry] ]);
  plEx.Caption  := Format('%.3f', [ FkipPrice[aoExit] ]);
end;

