//        FieldByName(stName+'Interval_'+IntTostr(i)).AsString :=TEdit( FindComponent( 'edt'+stName+'Interval_'+IntToStr(i) ) ).Text;
//        FieldByName(stName+'On_'+IntTostr(i)).AsBoolean     :=TCheckBox( FindComponent( 'cb'+stName+'On_'+IntToStr(i) ) ).Checked;
      end;
  end;

end;


