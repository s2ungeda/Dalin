procedure TFrmSPOrder.OnQuoteNotifiy(Sender: TObject; sType: TSPType);
var
  aGrid : TStringGrid;
  aAsks, aBids : TMarketDepths;
  I, iCol, iCol2: integer;
  sCurPrice, sTmp : string;
  aSymbol : TSymbol;

  procedure SetCurPrice( iRow : integer );
  begin
    with aGrid do
      if Cells[iCol,iRow] = sCurPrice then
        Objects[iCol,iRow] := Pointer(100)
      else
        Objects[iCol,iRow] := nil;
  end;

  function GetVol( dPrice : double; dVolume : double) : string;
  var
    iPre : integer;
    dVol : double;
  begin
    iPre := GetQtyPrecision( aSymbol, dPrice );
    if iPre < 0 then
    begin
      dVol := Floor(dVolume / 1000);
      result := Format('%sk', [ FmtString( 0,  dVol ) ] );
    end
    else
      result := FmtString( iPre, dVolume );
  end;

begin
  if Sender <> FSPOrder then Exit;
  if not spBooks.Down then Exit;

  if sType = spMajor then begin
    aSymbol :=  FSPOrder.Symbols[spMajor];
    aGrid := sgHoga;
    iCol  := 2;
    if FSPOrder.Param.UseHogaMerge then begin
      aAsks := FSPOrder.MgQuotes[spMajor].Asks;
      aBids := FSPOrder.MgQuotes[spMajor].Bids;
    end else
    begin
      aAsks := FSPOrder.Symbols[spMajor].Asks;
      aBids := FSPOrder.Symbols[spMajor].Bids;
    end;
  end
  else begin
    iCol := 0;
    aSymbol :=  FSPOrder.Symbols[spSub];
    aGrid := sgHoga2;
    aAsks := FSPOrder.Symbols[spSub].Asks;
    aBids := FSPOrder.Symbols[spSub].Bids;
  end ;

  sCurPrice := aSymbol.PriceToStr(aSymbol.Last);

  with aGrid do
  begin
    for I := 0 to 4 do//aAsks.Count-1 do
    begin
      if i >= aAsks.Count then
      begin
        Cells[iCol, 4-i] := '';
        Cells[1, 4-i]    := '';
      end else
      begin
        Cells[iCol, 4-i]  := aSymbol.PriceToStr(aAsks[i].Price);
        sTmp := GetVol( aAsks[i].Price,  aAsks[i].Volume );
        Cells[1, 4-i] := sTmp;
        SetCurPrice(4-i);
      end;
    end;

    for I := 0 to 4 do //aBids.Count-1 do
    begin
      if i >= aBids.Count then
      begin
        Cells[iCol, 5+i] := '';
        Cells[1, 5+i]    := '';
      end else
      begin
        Cells[iCol,5+i]  := aSymbol.PriceToStr(aBids[i].Price);
        sTmp := GetVol( aBids[i].Price,  aBids[i].Volume );
        Cells[1, 5+i] := sTmp;
        SetCurPrice(5+i);
      end;
    end;

  end;

end;

