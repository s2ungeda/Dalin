    Cells[1, 0]  := FSPOrder.Symbols[spMajor].PriceToStr( FSPOrder.BasePrice[aoEntry] );
    Cells[1, 1]  := FmtString(3,  FSPOrder.TargetPrice[aoEntry]  );
    Cells[1, 2]  := FSPOrder.Symbols[spSub].PriceToStr( FSPOrder.OrderPrice[aoEntry] );
    Cells[1, 3]  := FSPOrder.Symbols[spSub].PriceToStr( FSPOrder.CompPrice[aoEntry] );
  end;

  with sgLiquid do
  begin
    Cells[1, 0]  := FSPOrder.Symbols[spMajor].PriceToStr( FSPOrder.BasePrice[aoExit] );
    Cells[1, 1]  := FmtString(3, FSPOrder.TargetPrice[aoExit] );
    Cells[1, 2]  := FSPOrder.Symbols[spSub].PriceToStr( FSPOrder.OrderPrice[aoExit] );
    Cells[1, 3]  := FSPOrder.Symbols[spSub].PriceToStr( FSPOrder.CompPrice[aoExit] );
  end;

  stBar.Panels[0].Text  := Format('%.4f', [ FSPOrder.Assets[spMajor].Balance ]);//.ToString;
  stBar.Panels[1].Text  := Format('%.4f', [ FSPOrder.Assets[spSub].Balance ] );
  stBar.Panels[2].Text  := FmtString( 0, FSPOrder.TradeRate) + '%';
  stBar.Panels[3].Text  := FSPOrder.TradePL.ToString;

end;

end.
