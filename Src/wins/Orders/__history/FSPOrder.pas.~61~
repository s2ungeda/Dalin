function TFrmSPOrder.CheckInput: boolean;
begin

  Result := false;

  if edtCode.Text = '' then Exit;
  if cbMajor.ItemIndex = cbSub.ItemIndex then Exit;

  if edtEntryCount.Text = '' then Exit;
  if edtEntryQty.Text = '' then Exit;
  if edtEntryRate.Text = '' then Exit;
  if edtEntryTick.Text = '' then Exit;

  if edtLiquidCount.Text = '' then Exit;
  if edtLiquidQty.Text = '' then Exit;
  if edtLiquidRate.Text = '' then Exit;
  if edtLiquidTick.Text = '' then Exit;

  if edtLimitMajorPosition.Text = '' then Exit;
  if edtLimitSubPosition.Text = '' then Exit;
  if edtLimitTradeAmt.Text = '' then Exit;
  if edtLimitPL.Text = '' then Exit;

  if edtAutoModifyInterval.Text = '' then Exit;
  if edtAutoModifyCount.Text = '' then Exit;
  if edtAutoModifyTick.Text = '' then Exit;
  if edtAutoModifyLastTick.Text = '' then Exit;

  if edtMinVolume.Text = '' then Exit;

  if cbHogaMerge.Checked then
    if edtMergeUnit.Text = '' then Exit;

  if cbModifyDelay.Checked then
    if edtModifyDelaySec.Text = '' then Exit;

  FParam.Code := edtCode.Text;

  FParam.MajorEx  := TExchangeKind( cbMajor.ItemIndex + 1 );
  FParam.SubEx    := TExchangeKind( cbSub.ItemIndex + 1 );

  FParam.UseEntry := cbEntry.Checked;
//  if not TryStrToInt( edtEntryCount.Text, FParam.EntryCount) then Exit;
//  if not TryStrToInt( edtEntryTick.Text, FParam.EntryTick) then Exit;
  if not TryStrToFloat( edtEntryRate.Text, FParam.EntryRate ) then Exit;
  if not TryStrToFloat( edtEntryQty.Text, FParam.EntryQty ) then Exit;

  FParam.UseLiquid  := cbLiquid.Checked;
//  if not TryStrToInt( edtLiquidCount.Text, FParam.LiquidCount) then Exit;
//  if not TryStrToInt( edtLiquidTick.Text, FParam.LiquidTick) then Exit;
  if not TryStrToFloat( edtLiquidRate.Text, FParam.LiquidRate ) then Exit;
  if not TryStrToFloat( edtLiquidQty.Text, FParam.LiquidQty ) then Exit;

  FParam.BasePrice  := cbBasePrice.ItemIndex;
  if not TryStrToInt( edtBaseTick.Text, FParam.BaseTick) then Exit;
  if not TryStrToFloat( edtMinVolume.Text, FParam.MinVolume ) then Exit;

  if not TryStrToFloat( edtLimitMajorPosition.Text, FParam.LimitMajorPos ) then Exit;
  if not TryStrToFloat( edtLimitSubPosition.Text, FParam.LimitSubPos ) then Exit;
  if not TryStrToFloat( edtLimitTradeAmt.Text, FParam.LimitTradeAmt ) then Exit;
  if not TryStrToFloat( edtLimitPL.Text, FParam.LimitPL ) then Exit;

  FParam.UseHogaMerge     := cbHogaMerge.Checked;
  FParam.UseMdodifyDelay  := cbModifyDelay.Checked;

  if not TryStrToInt( edtMergeUnit.Text, FParam.HogaMergeUnit ) then Exit;

  if not TryStrToInt( edtAutoModifyInterval.Text, FParam.AutoModifyInterval ) then Exit;
  if not TryStrToInt( edtAutoModifyCount.Text, FParam.AutoModifyCount ) then Exit;
  if not TryStrToInt( edtAutoModifyTick.Text, FParam.AutoModifyTick ) then Exit;
  if not TryStrToInt( edtAutoModifyLastTick.Text, FParam.AutoModifyLastTick ) then Exit;

  if not TryStrToInt( edtModifyDelaySec.Text, FParam.ModifyDelaySec ) then Exit;

  Result := true;

end;

