    ShowMessage('입력값을확인하세요');
    cbRun.Checked := false;
    Exit;
  end;

  if FSPOrder = nil then
    FSPOrder  := TSPOrder.Create( nil );

  FSPOrder.Init( FParam );
  FSPOrder.OnSPNotify     :=  OnTextNotifyEvent;
  FSPOrder.OnQuoteNofity  := OnQuoteNotifiy;

  if not FSPOrder.Start then
  begin
    ShowMessage('시작을 할 수 없음');
    cbRun.Checked := false;
    Exit;
  end;

  Panel3.Color  := clSkyBlue
end;

