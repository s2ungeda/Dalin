function TFrmCoinWithdrawl.SetSymbol(bFrom: boolean): boolean;
var
  aExKind : TExchangeKind;
  aSymbol : TSymbol;  aNet : TDnwNetWork;
  aCombo  : TComboBox;
  aLabel  : TLabel;
  i: integer;
begin
  Result := false;

  if bFrom then
  begin
    aCombo  := cbFromNetType;
    aLabel  := lbFromNet;
    aExKind := TExchangeKind(cbFrom.ItemIndex);
  end ;

  try
    aSymbol := App.Engine.SymbolCore.BaseSymbols.FindSymbol(edtcurrency.Text, aExKind, eaSpot );
    if aSymbol = nil then
    begin
      DoLog('해당종목을 찾을수 없음');
      Exit;
    end;

    for I := 0 to aSymbol.NetworkList.Count-1 do begin
      aNet  := aSymbol.NetworkList.Network[i];
      aCombo.AddItem(aNet.NetType, aNet);
    end;

    if aCombo.Items.Count > 0 then begin
      aCombo.ItemIndex := 0;
      cbFromNetTypeChange(nil)
    end
    else Exit;

    Result := true;
  except
  end;
end;

procedure TFrmCoinWithdrawl.btnSymbolClick(Sender: TObject);
var
  bRes : boolean;
begin

  cbFromNetType.Items.Clear;

  try
    if edtcurrency.Text = '' then
    begin
      DoLog('가상자산 코드를 입력하시오');
      Exit;
    end;

    bRes := SetSymbol(true)

  finally
  end;

end;

procedure TFrmCoinWithdrawl.btnWithDrawlClick(Sender: TObject);
var
  aExKind : TExchangeKind;
  aParam  : TWithDrawParam;
begin

  if not ckCheck.Checked then
  begin
    DoLog('체크박스 체크');
    Exit;
  end;

  aExKind := TExchangeKind(cbFrom.ItemIndex);

  if not CheckInput(aExKind) then begin
    DoLog('입력값이 잘못됐음');
    Exit;
  end;

  btnWithDrawl.Enabled  := false;

  aParam.qty      := edtQty.Text;
  aparam.addr1    := edtAddr1.Text;
  aParam.addr2    := edtAddr2.Text;
  aParam.currency := Uppercase(edtCurrency.Text);
  aParam.nettype  := cbFromNetType.Items[cbFromNetType.ItemIndex];
  aParam.exname   := cbTo.Items[cbTo.ItemIndex];

  aParam.engname  := edtEngName.Text;
  aParam.korname  := edtKorName.Text;

  if Req[aExKind] <> nil then
    Req[aExKind].DoJob( aParam );

end;

