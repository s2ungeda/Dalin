procedure TFrmCoinWithdrawl.DoLog(stLog: string);
begin
  with statusBar1 do
  begin
    Panels[0].Text  := FormatDateTime('hh:nn:ss', now);
    Panels[1].Text  := stLog;
  end;
end;


