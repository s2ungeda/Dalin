procedure TFrmCoinWithdrawl.FormCreate(Sender: TObject);
var
  I: TExchangeKind;
begin
  FSymbol := nil;

  for var e := ekBinance to High(TExchangeKind) do
  begin
    cbFrom.Items.Add(TExchangeKindDesc[e]);
    cbTo.Items.Add(TExchangeKindDesc[e]);
  end;

  cbFrom.ItemIndex  := 1;
  cbTo.ItemIndex    := 0;

  for I := ekBinance to High(TExchangeKind) do
  begin
    case i of
      ekBinance: Req[i] := TBinanceWithdraw.Create(i);
      ekUpbit:   Req[i] := TUpbitWithdraw.Create(i);
      ekBithumb: Req[i] := TBitWithdraw.Create(i);
    end;

    if Req[i] <> nil then
      Req[i].OnNotify := OnResNotify;
  end;
end;

procedure TFrmCoinWithdrawl.FormDestroy(Sender: TObject);
var
  I: TExchangeKind;
begin
  for I := ekBinance to High(TExchangeKind) do
    FreeAndNil(Req[i]);
end;


procedure TFrmCoinWithdrawl.OnResNotify(Sender: TObject; Result : TResultMesage);
begin
  if not btnWithDrawl.Enabled then
    btnWithDrawl.Enabled  := true;

  if (Result.Code = 0) and (Result.Reason = 'address') then
  begin
    if TUpbitWithdraw(Req[ekUpbit]).Address.Count <= 0 then begin
      with statusBar1 do
      begin
        Panels[0].Text  := FormatDateTime('hh:nn:ss', now);
        Panels[1].Text  := '등록된 주소가 없음';
      end;
    end else
      UpdateAddress( TUpbitWithdraw(Req[ekUpbit]).Address );

  end else
    with statusBar1 do
    begin
      Panels[0].Text  := FormatDateTime('hh:nn:ss', now);
      Panels[1].Text  := Result.Reason;
    end;
end;

procedure TFrmCoinWithdrawl.LoadEnv(aStorage: TStorage);
begin
  if aStorage = nil then Exit;

  with aStorage do
  begin
    cbFrom.ItemIndex  := FieldByName('from').AsInteger;
    cbTo.ItemIndex    := FieldByName('to').AsInteger;

    edtCurrency.Text  := FieldByName('Currency').AsString;
    if edtcurrency.Text <> '' then
      btnSymbolClick(nil);

    cbFromNetType.ItemIndex := FieldByName('FromNetType').AsInteger;
    if cbFromNetType.ItemIndex >= 0 then
      cbFromNetTypeChange(nil);

    edtAddr1.Text  := FieldByName('address').AsString;
    edtAddr2.Text  := FieldByName('address2').AsString;

    edtKorName.Text:= FieldByName('korName').AsString;
    edtEngName.Text:= FieldByName('EngName').AsString;
  end;
end;

procedure TFrmCoinWithdrawl.SaveEnv(aStorage: TStorage);
begin
  if aStorage = nil then Exit;

  with aStorage do
  begin
    FieldByName('from').AsInteger := cbFrom.ItemIndex;
    FieldByName('to').AsInteger   := cbTo.ItemIndex;

    FieldByName('Currency').AsString  := edtCurrency.Text;

    FieldByName('FromNetType').AsInteger  := cbFromNetType.ItemIndex;

    FieldByName('address').AsString   := edtAddr1.Text;
    FieldByName('address2').AsString  := edtAddr2.Text;

    FieldByName('korName').AsString   := edtKorName.Text;
    FieldByName('EngName').AsString   := edtEngName.Text;
  end;
end;

