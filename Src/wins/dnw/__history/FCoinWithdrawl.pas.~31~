function TFrmCoinWithdrawl.CheckInput( aExKind : TExchangeKind ) : boolean;
begin
  Result := false;

  if TExchangeKind(cbTo.ItemIndex) = aExkind then
    Exit;

  if edtCurrency.Text = '' then Exit;
  if edtQty.Text = '' then Exit;
  if edtAddr1.Text = '' then Exit;

  if aExKind = ekBithumb then
    if (edtKorName.Text = '') or (edtEngName.Text = '') then
      Exit;

  Result := true;
end;

