unit UDepositAddressEditDlg;
interface
uses
  System.SysUtils, System.Classes,
  Vcl.Graphics, Vcl.Controls, Vcl.Forms, Vcl.Dialogs, Vcl.StdCtrls,
  USymbols,
  UDepositAddressForm
  ;
type
  TDepositAddressEditDlg = class(TForm)
    LblExchange: TLabel;
    LblCoin: TLabel;
    LblAddress: TLabel;
    LblMemo: TLabel;
    CboExchange: TComboBox;
    CboNetwork: TComboBox;
    EdtAddress: TEdit;
    EdtMemo: TEdit;
    BtnCancel: TButton;
    BtnSave: TButton;
    edtCoin: TEdit;
    Label1: TLabel;
    procedure BtnSaveClick(Sender: TObject);
    procedure BtnCancelClick(Sender: TObject);
    procedure edtCoinKeyDown(Sender: TObject; var Key: Word;
      Shift: TShiftState);
  private
    FIsEdit: Boolean;
    FRecordID: Integer;
    procedure LoadCombos;
  public
    class function Add(aOwner: TComponent): TDepositAddress;
    class function Edit(aOwner: TComponent; const aRec: TDepositAddress): TDepositAddress;
  end;
implementation
uses
  GApp
  , UApiTypes, UApiConsts
  , Winapi.Windows
  ;
{$R *.dfm}
procedure TDepositAddressEditDlg.LoadCombos;
var
  e: TExchangeKind;
begin
  //TExchangeKindDesc       : array [ TExchangeKind ] of string = ('Binance', 'Upbit', 'Bithumb');
  for e := ekBinance to High(TExchangeKind) do
    CboExchange.Items.Add(TExchangeKindDesc[e]);
  CboExchange.ItemIndex := 0;
end;
procedure TDepositAddressEditDlg.BtnSaveClick(Sender: TObject);
begin
  if Trim(EdtAddress.Text) = '' then
  begin
    MessageDlg('주소를 입력하세요.', mtWarning, [mbOK], 0);
    EdtAddress.SetFocus;
    Exit;
  end;
  ModalResult := mrOK;
end;
procedure TDepositAddressEditDlg.BtnCancelClick(Sender: TObject);
begin
  ModalResult := mrCancel;
end;
class function TDepositAddressEditDlg.Add(aOwner: TComponent): TDepositAddress;
var
  Dlg: TDepositAddressEditDlg;
begin
  Result := Default(TDepositAddress);
  Dlg := TDepositAddressEditDlg.Create(aOwner);
  try
    Dlg.Caption := '주소 추가';
    Dlg.FIsEdit := False;
    Dlg.LoadCombos;
    if Dlg.ShowModal = mrOK then
    begin
      Result.Exchange := Dlg.CboExchange.Text;
      Result.Coin     := Dlg.edtCoin.Text;
      Result.Network  := Dlg.CboNetwork.Text;
      Result.Address  := Trim(Dlg.EdtAddress.Text);
      Result.Memo     := Trim(Dlg.EdtMemo.Text);
    end;
  finally
    Dlg.Free;
  end;
end;
class function TDepositAddressEditDlg.Edit(aOwner: TComponent;
  const aRec: TDepositAddress): TDepositAddress;
var
  Dlg: TDepositAddressEditDlg;
  i: Integer;
begin
  Result := Default(TDepositAddress);
  Dlg := TDepositAddressEditDlg.Create(aOwner);
  try
    Dlg.Caption := '주소 수정';
    Dlg.FIsEdit := True;
    Dlg.FRecordID := aRec.ID;
    Dlg.LoadCombos;
    // 기존 값 세팅
    Dlg.CboExchange.ItemIndex := Dlg.CboExchange.Items.IndexOf(aRec.Exchange);
    Dlg.edtCoin.Text          := aRec.Coin;
    i := Dlg.CboNetwork.Items.IndexOf(aRec.Network);
    if i >= 0 then
      Dlg.CboNetwork.ItemIndex := i;
    Dlg.EdtAddress.Text := aRec.Address;
    Dlg.EdtMemo.Text := aRec.Memo;
    if Dlg.ShowModal = mrOK then
    begin
      Result.ID       := aRec.ID;
      Result.Exchange := Dlg.CboExchange.Text;
      Result.Coin     := Dlg.edtCoin.Text;
      Result.Network  := Dlg.CboNetwork.Text;
      Result.Address  := Trim(Dlg.EdtAddress.Text);
      Result.Memo     := Trim(Dlg.EdtMemo.Text);
    end;
  finally
    Dlg.Free;
  end;
end;
procedure TDepositAddressEditDlg.edtCoinKeyDown(Sender: TObject; var Key: Word;
  Shift: TShiftState);
  var
    sText : string;
    aSymbol : TSymbol;
    I: Integer;
begin
  if Key = VK_RETURN then
  begin
    sText := UpperCase(edtCoin.Text);

    if sText <> '' then
    begin
      aSymbol := App.Engine.SymbolCore.BaseSymbols.FindSymbol( sText,
        TExchangeKind(CboExchange.ItemIndex) , eaSpot );

      if aSymbol = nil then
      begin
        if aSymbol = nil then ShowMessage('잘못된 코드');
        Exit;
      end;

      CboNetwork.Clear;

      for I := 0 to aSymbol.NetworkList.Count-1 do
        CboNetwork.AddItem( aSymbol.NetworkList.Network[i].Name, aSymbol.NetworkList.Network[i] );

      if CboNetwork.Items.Count > 0 then begin
        CboNetwork.ItemIndex := 0;
//        cbNetTypeChange(nil);
      end;
    end;
  end;

end;

end.
