class function TFrmDepositList.Add(aOwner: TComponent): TDepositAddress;
var
  Dlg: TFrmDepositList;
begin
  Result := Default(TDepositAddress);
  Dlg := TFrmDepositList.Create(aOwner);
  try
    Dlg.Caption := '¡÷º“ √þ∞°';
    Dlg.FIsEdit := False;

    if Dlg.ShowModal = mrOK then
    begin
      Result.Exchange := TExchangeKindDesc[Dlg.FExKind];
      Result.Coin     := UpperCase(Dlg.edtCode.Text);
      Result.NetType  := Dlg.cbNetType.Items[Dlg.cbNetType.ItemIndex];
      Result.Address  := Trim(Dlg.sgAddr.Cells[1, 0]);
      Result.Memo     := Trim(Dlg.sgAddr.Cells[1, 1]);
    end;
  finally
    Dlg.Free;
  end;

end;

