procedure TFrmDepositList.btnCreateClick(Sender: TObject);
begin
  if FExKind <> ekBinance then
  begin
    if FSymbol = nil then
    begin
      ShowMessage('¡æ∏Òº±≈√¿ª ∏’¿˙');
      Exit;
    end;

    if FReq[FExKind] = nil then Exit;

