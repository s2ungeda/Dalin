procedure TFrmDepositList.cbExKindChange(Sender: TObject);
begin
  if FExKind <> TExchangeKind(cbExKind.ItemIndex) then
  begin
    FExKind := TExchangeKind(cbExKind.ItemIndex);
    Clear;
    btnCreate.Visible := not (FExKind = ekBinance);
  end;
end;

