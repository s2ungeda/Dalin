}
end;

procedure TFrmDepositList.Clear;
begin
  FSymbol := nil;

  sgAddr.Cells[1,1]  := '';
  sgAddr.Cells[1,0]  := '';

  btnAddr1.Visible  := false;
  btnAddr2.Visible  := false;

  cbNetType.Items.Clear;
end;

procedure TFrmDepositList.DrawActionButtons(aCanvas: TCanvas;
  aRect: TRect; aRow: Integer);
var
  BtnRect: TRect;
  i: Integer;
  Caption: string;
  BtnLeft: Integer;
begin
  Caption := #$2398;   // ∫πªÁ

  BtnLeft := aRect.Left + 10;

  BtnRect.Left := BtnLeft;
  BtnRect.Top := aRect.Top + 8;
  BtnRect.Right := BtnRect.Left + 28;
  BtnRect.Bottom := BtnRect.Top + 28;

  aCanvas.Pen.Color := clGray;
  aCanvas.RoundRect(aRect.Left, aRect.Top,
    aRect.Right, aRect.Bottom, 6, 6);
  aCanvas.Font.Name := 'Segoe UI Symbol';
  aCanvas.Font.Size := 10;
  aCanvas.Font.Style := [];
  aCanvas.TextOut(aRect.Left + 6, aRect.Top + 2, Caption);

  aCanvas.Font.Name := 'Segoe UI';
end;

procedure TFrmDepositList.edtCodeKeyDown(Sender: TObject; var Key: Word;
  Shift: TShiftState);
  var
    sText : string;
    aSymbol : TSymbol;
    I: Integer;
begin
  if Key = VK_RETURN then
  begin
    sText := UpperCase(edtCode.Text);

    if sText <> '' then
    begin
      aSymbol := App.Engine.SymbolCore.BaseSymbols.FindSymbol( sText, FExKind, eaSpot );
      if aSymbol = FSymbol then
      begin
        if aSymbol = nil then ShowMessageAtCursor('¿þ∏¯µ» ƒ⁄µÂ', TMsgDlgType.mtConfirmation, [mbOK]);
        Exit;
      end;

      cbNetType.Clear;

      FSymbol   := aSymbol;
      for I := 0 to aSymbol.NetworkList.Count-1 do
        cbNetType.AddItem( aSymbol.NetworkList.Network[i].NetType, aSymbol.NetworkList.Network[i] );

      if cbNetType.Items.Count > 0 then begin
        cbNetType.ItemIndex := 0;
        cbNetTypeChange(nil);
      end;
    end;
  end;

end;

procedure TFrmDepositList.FormClose(Sender: TObject; var Action: TCloseAction);
begin
  Action := caFree;
end;

procedure TFrmDepositList.FormCreate(Sender: TObject);
var
  aRect : TRect;
begin
  FSymbol := nil;

  for var e := ekBinance to High(TExchangeKind) do
    cbExKind.Items.Add(TExchangeKindDesc[e]);

  cbExKind.ItemIndex  := 0;
  cbExKindChange(nil);

  sgAddr.Cells[0,0] := '¿‘±ð¡÷º“';
  sgAddr.Cells[0,1] := '2¬˜¡÷º“';

  FReq[ekBinance] := TBinanceWithdraw.Create(ekBinance);  FReq[ekBinance].OnNotify:= ResultNotifyEvent;
  FReq[ekUpbit]   := TUpbitWithdraw.Create(ekUpbit);      FReq[ekUpbit].OnNotify := ResultNotifyEvent;
  FReq[ekBithumb] := TBitWithdraw.Create(ekBithumb);      FReq[ekBithumb].OnNotify := ResultNotifyEvent;

  btnAddr2.Caption  := #$2398;
  btnAddr1.Caption  := #$2398;

  btnAddr1.Visible  := false;
  btnAddr2.Visible  := false;

end;

procedure TFrmDepositList.FormDestroy(Sender: TObject);
var
  I: TExchangeKind;
begin
  for I := ekBinance to High(TExchangeKind) do
    FreeAndNil(FReq[i]);
end;

procedure TFrmDepositList.ResultNotifyEvent(Sender: TObject;
  Result: TResultMesage);
  var
    stArr, stArr2 : TArray<string>;
    iLen  : integer;
begin

  sgAddr.BeginUpdate;

  try
    sgAddr.Cells[1,1]  := '';
    sgAddr.Cells[1,0]  := '';

    if Result.Code <> 0 then begin
      lbResult.Caption  := Result.Reason;
      sgAddr.Cells[1,0]  := '';
      sgAddr.Cells[1,1]  := '';

      btnAddr1.Visible  := false;
      btnAddr2.Visible  := false;
    end
    else begin
      lbResult.Caption  := '¡∂»∏º∫∞¯';

      stArr := Result.Reason.Split(['=']);
      iLen  := Length(stArr );

      with sgAddr do
        case iLen of
          1 :
            begin
              Cells[1,0]  := stArr[0];
              Cells[1,1]  := '';
              btnAddr1.Visible  := true;
              btnAddr2.Visible  := false;
            end;
          2 :
            begin

              Cells[1,0]  := stArr[0];
              Cells[1,1]  := stArr[1];

              btnAddr1.Visible  := true;
              btnAddr2.Visible  := true;
            end;
        end;
    end;
  finally
    sgAddr.EndUpdate;
  end;
end;

procedure TFrmDepositList.sgAddrDrawCell(Sender: TObject; ACol, ARow: Integer;
  Rect: TRect; State: TGridDrawState);
  var
    sTxt: string;
    clBack: TColor;
    dFmt : DWORD;
    aRect: TRect;
begin
  //
  clBack := clWhite;
  dFmt   := DT_SINGLELINE or DT_VCENTER ;
  aRect  := Rect;

  with sgAddr do
  begin
    sTxt := Cells[ACol, ARow];

    case ACol of
      0 : clBack := clBtnFace;
//      2 : DrawActionButtons(Canvas, Rect, ARow);
    end;

    case ACol of
      0 : dFmt := dFmt or DT_CENTER;
      1 : aRect.Left := aRect.Left + 2;
    end;

    canvas.Brush.Color := clBack;
    Canvas.FillRect(aRect);

    DrawText(Canvas.Handle, PChar(sTxt), Length(sTxt), aRect, dFmt);
  end;

end;

end.
