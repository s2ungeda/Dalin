procedure TOrderBoard.UpdatePL( bClear : boolean );
var
  stLog : string;
  dPL   : double;
begin

  if bClear then
  begin
    //stLog := Format('%20.0n' ,  [0.0 ]);
    FSymbolPanel.Font.Color := clBlack;
    FSymbolPanel.Caption  := '';
    exit;
  end;

  dPL :=  Round(((FPosition.EntryOTE + FPosition.EntryPL ) / 1000) - (FPosition.Fee / 1000));
  stLog := Format('%20.0n' ,  [dPL ]);

  FSymbolPanel.Font.Color := clBlack;

  if dPL > 0 then
    FSymbolPanel.Font.Color := clRed
  else if dPL < 0 then
    FSymbolPanel.Font.Color := clBlue
  else if dPL = 0 then
    FSymbolPanel.Font.Color := clBlack;

  FSymbolPanel.Caption  := '                   '+stLog;
end;

procedure TOrderBoard.UpdatePositionInfo;
begin
  if FPosition = nil then
  begin
    UpdatePL( true );
    Exit;
  end;

    // set open position
  FTablet.OpenPosition := FPosition.Volume;
    //
  FTablet.AvgPrice := FPosition.AvgPrice;
  FTablet.EvalPL := FPosition.EntryOTE/1000;
    //
  UpdatePL;
end;

procedure TOrderBoard.UpdateEvalPL;
begin
  if FPosition = nil then Exit;
  FTablet.EvalPL := FPosition.EntryOTE/1000;
  UpdatePL;
end;

procedure TOrderBoard.UpdateOrderLimit;
begin
  if FPosition = nil then
  begin
    FClearOrderQty  := 0;
    SetClearVolume( false );
    Exit;
  end;

    // set clear order volume
  FClearOrderQty := 0;//FPosition. .LiquidatableQty;

    // set order type
  if FClearOrderQty > 0 then
    FOrderType := ptShort
  else
    FOrderType := ptLong;

    // set control
  if FClearOrder then
