  dOrderQty := StrToDouble(FEditOrderVolume.Text);

  if bRefresh or (dOrderQty <> dQty) then
  begin
      // highlited state
    FQtyState := qsSelected;

      // default order volume
    FDefQty := Abs(dQty);

      // set the volume to the edit box
    //FEditOrderVolume.Text := IntToStr(FDefQty);
    FEditOrderVolume.Text := DoubleToStr(FDefQty);// FormatFloat('#,##0', FDefQty);
