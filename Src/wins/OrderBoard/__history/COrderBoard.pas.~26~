  begin
    if FSymbolCombo.Items.Count > 10 then
      FSymbolCombo.Items.Delete( FSymbolCombo.Items.Count-1);
    FSymbolCombo.Items.InsertObject( 0, aSymbol.Code, aSymbol);
    FSymbolCombo.ItemIndex := 0;
  end
  else
    FSymbolCombo.ItemIndex := i;

  FSymbolCombo.Repaint;
  FLabelExchange.Caption  := TExchangeKindDesc[aSymbol.Spec.ExchangeType];
end;


