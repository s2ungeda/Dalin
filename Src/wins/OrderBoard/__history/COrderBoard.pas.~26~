procedure TOrderBoard.StringGridVolumesSelectCell(Sender: TObject; ACol,
  ARow: Integer; var CanSelect: Boolean);
var
  iNum : Integer;
  dQty, dTmp, dFee : double;
  aGrid : TStringGrid;
begin
  aGrid := TStringGrid( Sender );
    // reset clear order flat
  SetClearVolume(False);

  if (FAccount = nil) or (FSymbol = nil) then
    dQty  := 0
  else begin
    iNum := StrToIntDef(aGrid.Cells[aCol, aRow], 0);
    dFee:= App.Engine.ApiConfig.ExchangeInfo[ integer(FAccount.ExchangeKind) ].ApiInfo[FSymbol.Spec.ExApiType].TradeFee;
    if FSymbol.Last > EPSILON then
      dQty := ((FAccount.Asset.Balance * (1-dFee/100)) / FSymbol.Last) * iNum / 100
    else
      dQty := 0;
  end;
    // set order volume
  SetOrderVolume(dQty,  True);

    // selection notified
  Select;
end;


