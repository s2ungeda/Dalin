procedure TOrderBoardForm.SearchInList;
var
//  Regex: TRegEx;
  i: Integer;
  sCode : string;
  sg : TStringGrid;
  bFut: boolean;
  ftType : TFuturesType;
begin

  sCode := edtCode.Text;

  if sCode = '' then
  begin
//    ComboBoxUnderlyingsChange(nil);
    initSymbolGrid;
  end else
  begin
    FSrchList.Clear;
    FRegex := TRegEx.Create(UpperCase(sCode));

//    bFut := false;
//    if (ExKind = ekBinance) and (PageControl1.ActivePageIndex > 0) then
//      bFut := true;

    case PageControl1.ActivePageIndex of
      0 : begin sg := sgSpotSymbols; bFut := false; end;
      1 : begin sg := sgFutures; ftType := ftUsdt; bFut := true; end;
      2 : begin sg := sgCoinm; ftType := ftCoin; bFut := true; end;
    end;

    if bFut then begin
      for i := 0 to App.Engine.SymbolCore.FutureType[ExKind][ftType].Count-1 do
      begin
        if FRegex.IsMatch( App.Engine.SymbolCore.FutureType[ExKind][ftType].Symbols[i].Code ) then
          FSrchList.AddObject(App.Engine.SymbolCore.FutureType[ExKind][ftType].Symbols[i].Code,
            App.Engine.SymbolCore.FutureType[ExKind][ftType].Symbols[i] );
      end;
    end else
    begin
      for i := 0 to App.Engine.SymbolCore.Spots[ExKind].Count-1 do
      begin
        if FRegex.IsMatch( App.Engine.SymbolCore.Spots[ExKind].Spots[i].Code ) then
          FSrchList.AddObject(App.Engine.SymbolCore.Spots[ExKind].Spots[i].Code,
            App.Engine.SymbolCore.Spots[ExKind].Spots[i] );
      end;
    end;

    InitGrid(sg, true, 1 );
    sg.RowCount := FSrchList.Count+1;
    for I := 0 to FSrchList.Count-1 do begin
      sg.Cells[0,i+1]  := FSrchList[i];
      sg.Objects[0,i+1]:= FSrchList.Objects[i];
    end;

    if sg.RowCount > 1 then
      sg.FixedRows := 1;
  end;
end;

