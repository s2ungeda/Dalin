                otChange, FMenuPoint.Qty, FMenuPoint.Price) then
            ChangeOrder(FMenuBoard, FMenuPoint, aDlg.Qty, aDlg.Price);
        finally
          aDlg.Free;
        end;
      end;
    400 : // cancel an order partly
      begin
        try
          aDlg := TBoardOrderDialog.Create(Self);
          if aDlg.Open(FAccount, FMenuBoard.Tablet.Symbol, FMenuPoint.PositionType,
                otCancel, FMenuPoint.Qty, FMenuPoint.Price ) then
            CancelOrders(FMenuBoard, FMenuPoint, aDlg.Qty);
        finally
          aDlg.Free;
        end;
      end;
    500 : // cancel all an order
       CancelOrders(FMenuBoard, FMenuPoint);
    900 : // one side cancel all
       CancelOrders(FMenuBoard, [FMenuPoint.PositionType]);
    1000 : // cancel all orders
       CancelOrders(FMenuBoard, [ptLong, ptShort]);
  end;
   }
end;

