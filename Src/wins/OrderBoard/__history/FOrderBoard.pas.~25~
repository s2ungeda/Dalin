    // unsubscribe
  if FSelectedBoard.Symbol <> nil then
    App.Engine.QuoteBroker.Brokers[ExKind].Cancel(FSelectedBoard);

    //
  FSelectedBoard.Tablet.Ready := False;
  FSelectedBoard.DeliveryTime := '';

    // 계좌 처리 먼저 한다...
  var aAMType : TAccountMarketType;
  if aSymbol.Spec.Market = mtSpot then
    aAMType := amSpot
  else
    if aSymbol.Spec.FutureType = ftUsdt then
      aAMType := amFuture
    else
      aAMType := amFutureCm;
    // 계좌 처리 먼저 한다...
  FSelectedBoard.Account  := App.Engine.TradeCore.FindAccount( aSymbol.Spec.ExchangeType, aAMType );

    // set symbol and subscribe
  FSelectedBoard.Symbol := aSymbol;
  FSelectedBoard.Quote := App.Engine.QuoteBroker.Brokers[ExKind].Subscribe(FSelectedBoard, aSymbol,
                            QuoteBrokerEventHandler);
  FSelectedBoard.AddSymbol( aSymbol );

  if FSelectedBoard.Account = nil then Exit;

    // assign position
  FSelectedBoard.Position := App.Engine.TradeCore.Positions[ExKind].Find(FSelectedBoard.Account , aSymbol);

    // apply orders
  for i := 0 to App.Engine.TradeCore.Orders[ExKind].ActiveOrders.Count - 1 do
  begin
    aOrder := App.Engine.TradeCore.Orders[ExKind].ActiveOrders[i];

    if (aOrder.State = osActive)
       and (aOrder.Account = FSelectedBoard.Account)
       and (aOrder.Symbol = FSelectedBoard.Symbol) then
      FSelectedBoard.Tablet.DoOrder(aOrder);
  end;

    // update order limite
  FSelectedBoard.UpdatePositionInfo;
  FSelectedBoard.UpdateOrderLimit;

    // fill count
  FSelectedBoard.TNSCount := 0;

    // clear info window
  for i := 0 to GridInfo.RowCount - 1 do
  begin
    GridInfo.Cells[1,i] := '' ;
  end;

    //
  FLastSynFutures := 0;

    //
  FSelectedBoard.Resize;

    // if quote has been subscribed somewhere else
  if (FSelectedBoard.Quote <> nil) then
     //and (FSelectedBoard.Quote.EventCount > 0) then
    QuoteBrokerEventHandler(FSelectedBoard.Quote, Self, 0, FSelectedBoard.Quote, 0);

  CheckOrientation( FSelectedBoard );

end;

