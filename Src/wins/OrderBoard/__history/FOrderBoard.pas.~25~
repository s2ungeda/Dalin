procedure TOrderBoardForm.SpeedButtonPrefsClick(Sender: TObject);
var
  aDlg: TBoardPrefDialog;
  i: Integer;
begin
  aDlg := TBoardPrefDialog.Create(Self);
  FLeftPos := Left;
  try
    aDlg.Prefs := FPrefs;

    if aDlg.ShowModal = mrOK then
    begin
      FPrefs:= aDlg.Prefs;

