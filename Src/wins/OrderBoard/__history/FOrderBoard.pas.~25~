procedure TOrderBoardForm.PopupMenuOrdersPopup(Sender: TObject);
var
  aBoard: TOrderBoard;
  aPopupMenu: TPopupMenu;
  aPoint: TPoint;
  aOrderPoint: TTabletPoint;
  stLS: String;
begin
    // check 1
  if (Sender = nil) or not (Sender is TPopupMenu) then Abort;

    // get TPopupMenu reference
  aPopupMenu := Sender as TPopupMenu;

    // check 2
  if (aPopupMenu.PopupComponent = nil) or
      not (aPopupMenu.PopupComponent is TPaintBox) then Exit;

    // find board
  aBoard := FBoards.FindPaintBox(aPopupMenu.PopupComponent as TPaintBox);
  if aBoard = nil then Exit;

    // get tablet point
  GetCursorPos(aPoint);
  aPoint := aBoard.PaintBoxTablet.ScreenToClient(aPoint);
  aOrderPoint := aBoard.Tablet.GetPoint(aPoint.X, aPoint.Y);
  if aOrderPoint.AreaType <> taOrder then Abort;

    // save the point
  FMenuBoard := aBoard;
  FMenuPoint := aOrderPoint;

    // change menu caption
  stLS := ifThenStr( aOrderPoint.PositionType = ptLong, 'Long', 'Short');

    //
  PopupMenuOrders.Items[0].Caption := stLS
               + Format('%.2f X %d(&1)',[aOrderPoint.Price, aBoard.DefQty]);
  PopupMenuOrders.Items[0].Enabled := True;    // 잠시 멈춤 없어짐
    //
  PopupMenuOrders.Items[1].Caption := stLS + '주문(&2)...';
  PopupMenuOrders.Items[1].Enabled := True ;    // 잠시 멈춤 없어짐
  PopupMenuOrders.Items[2].Caption := '정정(&3)...';
  PopupMenuOrders.Items[2].Enabled := FMenuPoint.Qty > 0;
  PopupMenuOrders.Items[3].Caption := '일부취소(&4)...';
  PopupMenuOrders.Items[3].Enabled := FMenuPoint.Qty > 0;
  PopupMenuOrders.Items[4].Caption := '전부취소(&5)...';
  PopupMenuOrders.Items[4].Enabled := FMenuPoint.Qty > 0;
  PopupMenuOrders.Items[6].Caption := stLS + '주문 전부취소(&S)...';
  PopupMenuOrders.Items[7].Caption := '주문 전부취소(&A)...';
end;

