procedure TOrderBoardForm.FormResize(Sender: TObject);
var
  iCnt, iSumW, i: Integer;
begin

  iSumW := 0;
  iCnt  := 0;

  if FBoards.Count >1 then
  begin
    for i := 0 to FBoards.Count - 1 do
    begin
      if not FBoards[i].Tablet.ShowForceDist then
        iSumW := iSumW + FBoards[i].Width
      else
        inc( iCnt );
    end;
  end;

  if iCnt = 0 then iCnt := 1;

  for i := 0 to FBoards.Count - 1 do
  begin
    if not FLoadEnd then
      FBoards[i].Resize
    else begin
      if (FBoards[i].Tablet.ShowForceDist) and (FResize) then
        FBoards[i].Resize2( (PanelMain.Width - iSumW) div iCnt )
      else
        FBoards[i].Resize;
    end;
  end;
end;

