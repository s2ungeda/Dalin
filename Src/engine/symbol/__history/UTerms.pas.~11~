unit UTerms;

interface

uses
  System.Classes, System.SysUtils,

  Generics.Collections
  ;

type
  TTermItem = class(TCollectionItem )
  public
    O, H, L, C : double;
    LastTime   : TDateTime;
    MMIndex    : integer;
    Added      : boolean;
    procedure SetValue( const val : double );
    procedure UpdateValue(const val : double);
  end;

  TMATermItem = class(TCollectionItem)
  private
    FCount: integer;
    FList: TQueue<TTermItem>;
    FSum: double;
    FLastItem: TTermItem;
    FMATerm: integer;
    FLastVal: double;

    procedure New(aItem: TTermItem);
    function GetAverage: double;
  public

    Constructor Create(aColl: TCollection); override;
    Destructor  Destroy; override;
    procedure Init(iMATerm: integer);
    procedure Update(aItem: TTermItem; bLoad: boolean = false);
    procedure Reset(iMATerm: integer);

    property List : TQueue<TTermItem> read FList;
    // 賃碟ゎ敕..(20, 60, 120 碟 ゎ敕)
    property MATerm : integer read FMATerm;
    // FMATerm 檜 120 -> FCount = 24;
    property Count: integer read FCount;
    property Sum  : double read FSum;
    property LastItem : TTermItem read FLastItem;
    property LastVal  : double read FLastVal;
    //
    property Average: double read GetAverage;
  end;

  TMATerms = class(TCollection)
  private
    FOwner: TCollection;
    function GetMATerm(i: integer): TMATermItem;
  public
    Constructor Create(aOwner: TCollection); overload;
    Destructor  Destroy; override;

    procedure Update(aItem: TTermItem);

    function New(iMATerm: integer) : TMATermItem;
    property MATerm[i: integer] : TMATermItem read GetMATerm;
    property Owner: TCollection read FOwner;
  end;

  TTerms = class(TCollection)
  private
    FOnAdd: TNotifyEvent;
    FMATerms: TMATerms;

    function GetLastTerm: TTermItem;
    function GetTerm(i: integer): TTermItem;

  public
    Constructor Create;
    Destructor  Destroy; override;

    procedure Update(const value : double);
    function  New : TTermItem;

    property LastTerm : TTermItem read GetLastTerm;
    property Term[i:integer] : TTermItem read GetTerm;
    property OnAdd : TNotifyEvent read FOnAdd write FOnAdd;

    property MATerms: TMATerms read FMATerms;
  end;



implementation

uses
  System.DateUtils, System.Math
  ;

{ TTermItem }

procedure TTermItem.SetValue(const val: double);
begin
  O := val;
  H := val;
  L := val;
  C := val;
end;

procedure TTermItem.UpdateValue(const val: double);
begin
  H := Max(H, val);
  L := Min(L, val);
  C := val;
end;

{ TTerms }

constructor TTerms.Create;
begin
  inherited Create(TTermItem);
  FMATerms:= TMATerms.Create(Self);
end;

destructor TTerms.Destroy;
begin
  FMATerms.Free;
  inherited;
end;

function TTerms.GetLastTerm: TTermItem;
begin
  Result := GetTerm(Count-1);
end;

function TTerms.GetTerm(i: integer): TTermItem;
begin
  if (i < 0) or (i >= Count) then
    Result := nil
  else
    Result := Items[i] as TTermItem
end;

function TTerms.New: TTermItem;
begin
  Result := Add as TTermItem;
  Result.Added  := true;
end;

procedure TTerms.Update(const value : double);
var
  aItem : TTermItem;

  bNew  : boolean;
  iT, iT2 : integer;
  aTime : TDateTime;
  wHH, wMM, wSS, wCC : Word;
  iMMIndex, iNextMMIndex : Integer;
  iGap : integer;
begin

  if Value <= 0.00000001 then Exit;

  aTime := now;
//  DecodeTime(aTime, wHH, wMM, wSS, wCC);
//  iMMIndex := (wHH )*60 + wMM;
//  if iMMIndex < 0 then exit;

  try
    if Count = 0 then
    begin
      aItem := nil;
      bNew  := true;
    end else
    begin
      aItem := GetLastTerm;//ExchangeRateItems.Items[ ExchangeRateItems.Count-1 ] as TExchangeRateItem;
  //    bNew  := ( Floor( aTime ) <> Floor( aItem.LastTime ) ) or
  //             ( iMMIndex > aItem.MMIndex );

      if aItem = nil then Exit;

      iGap := SecondsBetween( aTime, aItem.LastTime );
      if iGap >= (60 * 5) then
        bNew := true;
    end;

    if bNew then
    begin

      aItem := Add as TTermItem;

  //    24 衛除檜賊 縑楝 嫦儅
  //    aItem.MMIndex := iMMIndex;
  //    iNextMMIndex  := aItem.MMIndex + 1;
  //    aItem.LastTime:= Floor( aTime ) +  EncodeTime(iNextMMIndex div 60,
  //                                                  iNextMMIndex mod 60, 0, 0);

  //    DecodeTime(aTime, wHH, wMM, wSS, wCC);
      aItem.LastTime:= aTime;//Floor( aTime ) +  EncodeTime(wHH, wMM, 0, 0);
      aItem.SetValue(value);

      if Count > 300 then
        Delete(0);

    end else
    begin
      aItem.UpdateValue(value);
    end;

    aItem.Added := bNew;
  finally
    if aItem <> nil then
      FMATerms.Update(aItem);
  end;
end;

{ TMATermItem }

constructor TMATermItem.Create(aColl: TCollection);
begin
  inherited Create(aColl);
  FList   := TQueue<TTermItem>.Create;
  FLastItem := nil;
end;

destructor TMATermItem.Destroy;
begin
  FList.Free;
  inherited;
end;

function TMATermItem.GetAverage: double;
begin
  if FList.Count > 0 then
    Result := FSum / FList.Count
  else
    Result := 1;
end;

procedure TMATermItem.Init(iMATerm: integer);
begin
  FMATerm := iMATerm;
  FCount  := FMATerm div 5;
  FSum    := 0;
end;

procedure TMATermItem.New(aItem: TTermItem);
begin
  FList.Enqueue(aItem);
  FSum := FSum + aItem.C;

  if FList.Count > FCount then
    FSum := FSum - FList.Dequeue.C;
end;

procedure TMATermItem.Reset(iMATerm: integer);
var
  i, j: integer;
begin
  Init(iMATerm);
  FList.Clear;

  j := max(0, TMATerms(Collection).Owner.Count - FCount);

  for I := j to TMATerms(Collection).Owner.Count-1 do
    Update( TMATerms(Collection).Owner.Items[i] as TTermItem, true);
end;

procedure TMATermItem.Update(aItem: TTermItem; bLoad: boolean);
//var
//  sItem : TTermItem;
begin
  if aItem.Added or bLoad then
    New(aItem)
  else begin
    if FList.Count > 0 then begin
      //sItem := FList.ToArray[FList.Count - 1];
      FSum  := FSum + aItem.C - FLastVal;//sItem.C;
      //FList.ToArray[FList.Count-1]  := aItem;
      FLastVal := aItem.C;
    end else
    begin
      FList.Enqueue(aItem);
      FSum := FSum + aItem.C;
    end;
  end;
end;

{ TMATerms }

constructor TMATerms.Create(aOwner: TCollection);
begin
  inherited Create(TMATermItem);
  FOwner  := aOwner;
end;

destructor TMATerms.Destroy;
begin

  inherited;
end;

function TMATerms.GetMATerm(i: integer): TMATermItem;
begin
  if (i < 0) or (i >= Count) then
    Result := nil
  else
    Result := Items[i] as TMATermItem;
end;

function TMATerms.New(iMATerm: integer): TMATermItem;
begin
  Result  := Add as TMATermItem;
  Result.Reset(iMATerm);
end;

procedure TMATerms.Update(aItem: TTermItem);
var
  I: Integer;
begin
  for I := 0 to Count-1 do
    GetMATerm(i).Update(aItem);
end;

end.
