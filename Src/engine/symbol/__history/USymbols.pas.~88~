function TSymbol.GetCustomIndex: double;
var
 dEstPrice : double;
begin
  //: 1매수호가잔량/(1매도호가잔량+1매수호가잔량)*매도호가가격 +
  //  1매도호가잔량/(1매도호가잔량+1매수호가잔량)*매수호가가격
  dEstPrice := (CalcDiv(Bids[0].Volume, (Asks[0].Volume + Bids[0].Volume)) * Asks[0].Price) +
               (CalcDiv(Asks[0].Volume, (Asks[0].Volume + Bids[0].Volume)) * Bids[0].Price);

  if (dEstPrice <= EPSILON) or (Last <= EPSILON) then
    Result := 0
  else
    Result  := (dEstPrice * 2 + Last) / 3;
end;

//  only binance futures
function TSymbol.GetHitOrderPrice(iSide: integer; dComPrice: double): double;
var
  dPrice : double;
begin
  Result := dComPrice;

  if FSpec.ExchangeType <> ekBinance then Exit;

  dPrice := GetLimitOrderPrice(iSide = 1);
  if dPrice > EPSILON then
    if (iSide = 1 ) and (CmpVal(dPrice, dComPrice) < 0) then
      Result := dPrice
    else if (iSide = -1) and (CmpVal(dPrice, dComPrice) > 0) then
      Result := dPrice;
end;

//  only binance futures
function TSymbol.GetLimitOrderPrice(bBid: boolean): double;
var
  dMultiple : double;
begin
  if bBid then
    dMultiple := 1 + ((FSpec.MultiplierUp-1) / 2)
  else
    dMultiple := 1 - ((1-FSPec.MultiplierDown) / 2);

  Result := TruncDecimal(TFuture(Self).MarkPrice * dMultiple, FSpec.Precision);
end;

function TSymbol.GetOrderPrice(iSide: integer; dEstPrice: double;
  iTick: integer): double;
var
  I: Integer;
begin
  Result := 0;

  if iSide > 0 then
  begin
    for I := 0 to FAsks.Count-1 do
    begin
      if FAsks[i].Price > dEstPrice - DOUBLE_EPSILON then
      begin
        REsult := TicksFromPrice( Self, FAsks[i].Price, iTick );
        break;
      end;
    end;
  end else
  begin
    for I := 0 to FBids.Count-1 do
    begin
      if FBids[i].Price - DOUBLE_EPSILON < dEstPrice  then
      begin
        Result := TicksFromPrice( Self, FBids[i].Price, -iTick );
        break;
      end;
    end;
  end;
end;


