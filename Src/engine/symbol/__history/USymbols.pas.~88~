function TSymbol.CalcEstPrice(iSide: integer; dQty : double): double;
var
  i : Integer;
  dTmp, dSum, dVolSum : double;
  aDepths : TMarketDepths;
  bDone : boolean;
begin

  if dQty <= EPSILON then Exit (0.0);

  if iSide > 0 then
    aDepths := Asks
  else
    aDepths := Bids;

  dQty := dQty + gAOConfig.Result.SafeMarginQty[FSpec.ExchangeType];

  dSum := 0;    dVolSum := 0;   bDone := false;
  for I := 0 to aDepths.Count-1 do
  begin
    //dSum := dSum + aDepths[i].Volume;
    dVolSum := dVolSum + aDepths[i].Volume;

    dTmp := dVolSum - dQty;

    if (dTmp > 0) or ( CheckZero(dTmp)) then begin
      dSum  := dSum + ( aDepths[i].Price * (aDepths[i].Volume - dTmp ) );
      dVolSum := dVolSum - dTmp;
      bDone := true;
      break;
    end
    else begin
      dSum  := dSum + ( aDepths[i].Price * aDepths[i].Volume );
    end;
  end;

  if CheckZero( dVolSum ) then begin
    if not bDone then Exit (0);
    Result := aDepths[i].Price
  end
  else
    Result := dSum / dVolSum;

  if (( iSide > 0 ) and ( Result  + PRICE_EPSILON < aDepths[0].Price ) )
    or
    (( iSide < 0 ) and ( Result > aDepths[0].Price + PRICE_EPSILON )) then
    Result := aDepths[0].Price;

  if Result <= 0 then
    Result := 0;
end;

function TSymbol.CalcMakerPrice(iSide, iRate: integer): double;
var
  dTick, dPrice, dTmp : double;
  iRes: integer;
  i : Integer;
  iSteps : int64;
begin
  Result := 0;

  if (Asks[0].Price <= EPSILON) or (Bids[0].Price <= EPSILON) then Exit;

  if iSide > 0 then begin
    dPrice  := Bids[0].Price + (Asks[0].Price - Bids[0].Price) * (iRate / 100);

    if FSpec.ExchangeType = ekBinance then
      dTick := FSpec.TickSize
    else
      dTick := UnitFromPrice(Self, dPrice);
    // 올림. (일반적으로 매수는 내림인데, 체결이 잘 안될 거 같아서 올림)
    iSteps  := Trunc(dPrice / dTick + 1.0 - ZERO_EPSILON);
    dPrice  := iSteps * dTick;

    if CmpVal(dPrice, Asks[0].Price) >= 0 then
      dPrice  := TicksFromPrice(Self, Asks[0].Price, -1);

    Result := dPrice;
  end else
  begin
    dPrice  := Asks[0].Price - (Asks[0].Price - Bids[0].Price) * (iRate / 100);

    if FSpec.ExchangeType = ekBinance then
      dTick := FSpec.TickSize
    else
      dTick := UnitFromPrice(Self, dPrice);

    // 내림.
    iSteps := Trunc(dPrice / dTick + ZERO_EPSILON);
    dPrice  := iSteps * dTick;

    if CmpVal(Bids[0].Price, dPrice) >= 0 then
      dPrice := TicksFromPrice(Self, Bids[0].Price, 1);;

    Result := dPrice;
  end;
end;

