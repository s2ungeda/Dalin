function TSymbol.AdjustAsks : integer;
var
  i, iRes : integer;
  dSum, dVol : double;
begin

  dVol  := Sales.Last.Volume;
  dSum  := 0;
  
  for I := 0 to Asks.Count-1 do
  begin
    iRes := CmpVal(Asks[i].Price, Sales.Last.Price);
    dSum := dSum + Asks[i].Volume;
    if iRes > 0 then
      break
    else if iRes < 0 then
    begin
      Asks[i].Volume  := 0;
    end
    else begin
      Asks[i].Volume := Max(0, dSum - dVol);
      if Asks[i].Volume <= EPSILON then
        // i+1 을 매수호가로 재정렬
        reArrageAsks(i+1)
      else if (Asks[i].Volume > EPSILON) and (i > 0) then
        reArrageAsks(i);
    end;
  end;

  Result := i;
end;

procedure TSymbol.AdjustAsks(dPrice, dVolume: double);
var
  i, j, iRes, iCmp : integer;
  bOK: boolean;

  s1, s2: string;
  procedure SetFirstAsk;
  begin
    Asks[0].Price := dPrice;
    Asks[0].Volume:= dVolume;
  end;

begin

  if dPrice <= EPSILON then Exit;

  iCmp := CmpVal(Asks[0].Price, dPrice);
  // 현재매도가가 더 크다면..한호가씩 뒤로 밀림
  if iCmp > 0 then begin
    s1 := AsksLogNow;
    for j := Asks.Count-1 downto 0 do
      if j = 0 then
        SetFirstAsk
      else  begin
        Asks[j].Price :=  Asks[j-1].Price;
        Asks[j].Volume := Asks[j-1].Volume;
      end;
    s2 := AsksLogNow ;
  end else
  if iCmp < 0 then begin
    s1 := AsksLogNow;
    bOK := false;
    for j := 1 to Asks.Count-1 do
    begin
      bOK := false;
      iRes := CmpVal(Asks[j].Price, dPrice);
      if iRes > 0 then begin
        reArrageAsks(j-1);
        bOK := true;
        break;
      end else
      if iRes = 0 then begin
        reArrageAsks(j);
        bOK := true;
        break;
      end;
    end;

    if bOK then SetFirstAsk
    else begin
      // 최우선 매도가가 현재 구성된 호가보다 클때( Count-1 매도호가 보다 클때)
      // 2호가부터 호가만 새로 만들어준다.
      SetFirstAsk;
      for j := 1 to Asks.Count-1 do
      begin
        Asks[j].Price   := TicksFromPrice(Self, Asks[j-1].Price, 1);
        Asks[j].Volume  := 0;
      end;
    end;
    s2 := AsksLogNow;
  end else
    SetFirstAsk;

//  if iCmp <> 0 then begin
//    App.Log(llDebug, 'TestAsks', 'Asks %d:%s,%S', [iCmp, PriceToStr(dPrice), QtyToStr(dVolume)] );
//    App.Log(llDebug, 'TestAsks', s1);
//    App.Log(llDebug, 'TestAsks', s2);
//  end;

end;

