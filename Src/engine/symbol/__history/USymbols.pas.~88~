    begin
      Bids[i].Volume  := 0;
    end
    else begin
      Bids[i].Volume := Max(0, dSum - dVol);
      if Bids[i].Volume <= EPSILON then
        // i+1 을 매수호가로 재정렬
        reArrageBids(i+1)
      else if (Bids[i].Volume > EPSILON) and (i > 0) then
