procedure TSymbol.reArrageAsks(i: integer);
var
  j : integer;
begin
  if i >= Asks.Count then Exit;

  for j := i to Asks.Count-1 do
    if Asks[j].Volume > EPSILON then
    begin
      i := j;
      break;
    end;

  for j := 0 to Asks.Count-1 do
    if (j + i) < Asks.Count then
    begin
      Asks[j].Price := Asks[i+j].Price;
      Asks[j].Volume:= Asks[i+j].Volume;
    end else
    begin
      Asks[j].Price   := TicksFromPrice(Self, Asks[j-1].Price, 1);
      Asks[j].Volume  := 0;
    end;
end;

procedure TSymbol.reArrageBids(i: Integer);
var
  j : integer;
begin

  if i >= Bids.Count then Exit;

  for j := i to Bids.Count-1 do
    if Bids[j].Volume > EPSILON then
    begin
      i := j;
      break;
    end;

  for j := 0 to Bids.Count-1 do
    if (j + i) < Bids.Count then
    begin
      Bids[j].Price := Bids[i+j].Price;
      Bids[j].Volume:= Bids[i+j].Volume;
    end else
    begin
      Bids[j].Price   := TicksFromPrice(Self, Bids[j-1].Price, -1);
      Bids[j].Volume  := 0;
    end;

end;

