function TSymbol.AdjustByLast : boolean;
var
  iRes, i : integer;
  bMove : boolean;
begin
  Result := false;
  if CmpVal(FLast, FAsks[0].Price) > 0 then
  begin
    bMove := false;
    for I := 0 to Asks.Count-1 do
    begin
      iRes := CmpVal(Asks[i].Price, FLast);
      if iRes >= 0 then
        break
      else if iRes < 0 then
      begin
        Asks[i].Volume  := 0;
        bMove := true;
      end;
    end;

    if bMove and (i > 0) then begin
      reArrageAsks(i);
      Result := true;

      if CmpVal(FLast, FAsks[0].Price) > 0 then
        Result := true;
    end;

  end else
  if CmpVal(FBids[0].Price, FLast) > 0 then
  begin
    bMove := false;
    for I := 0 to Bids.Count-1 do
    begin
      iRes := CmpVal(FLast, Bids[i].Price);
      if iRes >= 0 then
        break
      else if iRes < 0 then
      begin
        Bids[i].Volume  := 0;
        bMove := true;
      end;
    end;

    if bMove and (i > 0) then begin
      reArrageBids(i);
      Result := true;

      if CmpVal(FBids[0].Price, FLast) > 0 then
        Result := true;
    end;

  end;

end;

