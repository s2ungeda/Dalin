unit UTerms;

interface

uses
  System.Classes, System.SysUtils,

  Generics.Collections
  ;

type
  TTermItem = class(TCollectionItem )
  public
    O, H, L, C : double;
    LastTime   : TDateTime;
    MMIndex    : integer;
    Added      : boolean;
    procedure SetValue( const val : double );
  end;

  TTerms = class(TCollection)
  private
    FOnAdd: TNotifyEvent;
    function GetLastTerm: TTermItem;
    function GetTerm(i: integer): TTermItem;

  public
    Constructor Create;
    Destructor  Destroy; override;

    procedure Update(const value : double);
    function  New : TTermItem;

    property LastTerm : TTermItem read GetLastTerm;
    property Term[i:integer] : TTermItem read GetTerm;

    property OnAdd : TNotifyEvent read FOnAdd write FOnAdd;
  end;

  TTermList = class(TCollectionItem)
  private
    FCount: integer;
    FList: TQueue<double>;
    FSum: double;
    FLastItem: TTermItem;
    function GetValue: double;
    procedure New(aItem: TTermItem);
  public

    Constructor Create(aColl: TCollection; iCnt: integer); overload;
    Destructor  Destroy; override;
    procedure Update(aItem: TTermItem; bLoad: boolean = false);

    property List : TQueue<double> read FList;
    property Count: integer read FCount;
    property Sum  : double read FSum;
    property LastItem : TTermItem read FLastItem;
    property Value  : double read GetValue;
  end;

  TCustomTerms = class(TCollection)
  private
    function GetCustomTerm(i: integer): TTermList;
  public
    Constructor Create;
    Destructor  Destroy; override;

    function New(iCnt: integer) : TTermList;

    property CustomTerm[i: integer] : TTermList read GetCustomTerm;

  end;



implementation

uses
  System.DateUtils, System.Math
  ;

{ TTermItem }

procedure TTermItem.SetValue(const val: double);
begin
  O := val;
  H := val;
  L := val;
  C := val;
end;

{ TTerms }

constructor TTerms.Create;
begin
  inherited Create(TTermItem);
end;

destructor TTerms.Destroy;
begin

  inherited;
end;

function TTerms.GetLastTerm: TTermItem;
begin
  Result := GetTerm(Count-1);
end;

function TTerms.GetTerm(i: integer): TTermItem;
begin
  if (i < 0) or (i >= Count) then
    Result := nil
  else
    Result := Items[i] as TTermItem
end;

function TTerms.New: TTermItem;
begin
  Result := Add as TTermItem;
  Result.Added  := true;
end;

procedure TTerms.Update(const value : double);
var
  aItem : TTermItem;

  bNew  : boolean;
  iT, iT2 : integer;
  aTime : TDateTime;
  wHH, wMM, wSS, wCC : Word;
  iMMIndex, iNextMMIndex : Integer;
  iGap : integer;
begin

  aTime := now;
//  DecodeTime(aTime, wHH, wMM, wSS, wCC);
//  iMMIndex := (wHH )*60 + wMM;
//  if iMMIndex < 0 then exit;

  if Count = 0 then
  begin
    aItem := nil;
    bNew  := true;
  end else
  begin
    aItem := GetLastTerm;//ExchangeRateItems.Items[ ExchangeRateItems.Count-1 ] as TExchangeRateItem;
//    bNew  := ( Floor( aTime ) <> Floor( aItem.LastTime ) ) or
//             ( iMMIndex > aItem.MMIndex );

    if aItem = nil then Exit;

    iGap := SecondsBetween( aTime, aItem.LastTime );
    if iGap >= 60 then
      bNew := true;
  end;

  if bNew then
  begin

    aItem := Add as TTermItem;

//    24 시간이면 에러 발생
//    aItem.MMIndex := iMMIndex;
//    iNextMMIndex  := aItem.MMIndex + 1;
//    aItem.LastTime:= Floor( aTime ) +  EncodeTime(iNextMMIndex div 60,
//                                                  iNextMMIndex mod 60, 0, 0);

//    DecodeTime(aTime, wHH, wMM, wSS, wCC);
    aItem.LastTime:= aTime;//Floor( aTime ) +  EncodeTime(wHH, wMM, 0, 0);
    aItem.SetValue(value);

    if Count > 300 then
      Delete(0);

  end else
  begin
    aItem.H := Max(aItem.H, value);
    aItem.L := Min(aItem.L, value);
    aItem.C := value;
  end;

  aItem.Added := bNew;
end;

{ TTermList }

constructor TTermList.Create(aColl: TCollection; iCnt: integer);
begin
  inherited Create(aColl);
  FList   := TQueue<double>.Create;
  FCount  := iCnt;
  FSum    := 0;
  FLastItem := nil;
end;

destructor TTermList.Destroy;
begin
  FList.Free;
  inherited;
end;

function TTermList.GetValue: double;
begin
  Result := FSum / FCount;
end;

procedure TTermList.New(aItem: TTermItem);
begin
  FList.Enqueue(aItem.C);
  FSum := FSum + aItem.C;

  if FList.Count > FCount then
    FSum := FSum - FList.Dequeue
end;

procedure TTermList.Update(aItem: TTermItem; bLoad: boolean);
var
  dTmp: double;
begin

  if aItem.Added or bLoad then
  begin
    New(aItem);
  end else
  begin
    if FList.Count > 0 then begin
      dTmp := FList.ToArray[FList.Count - 1];
      FSum := FSum + aItem.C - dTmp;
      FList.ToArray[FList.Count-1]  := aItem.C;
    end else
    begin
      FList.Enqueue(aItem.C);
      FSum := FSum + aItem.C;
    end;
  end;

end;

{ TCustomTerms }

constructor TCustomTerms.Create;
begin
  inherited Create(TTermList);
end;

destructor TCustomTerms.Destroy;
begin

  inherited;
end;

function TCustomTerms.GetCustomTerm(i: integer): TTermList;
begin

end;

function TCustomTerms.New(iCnt: integer): TTermList;
begin

end;

end.
