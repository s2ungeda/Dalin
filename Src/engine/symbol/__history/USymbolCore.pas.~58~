          else if Result < 500000 + EPSILON then
            Result := Result - 100
          else if Result < 1000000 + EPSILON then
            Result := Result - 500
          else if Result < 2000000 + EPSILON then
            Result := Result - 1000
          else
            Result := Result - 1000;
        end;
      end;
    ekBithumb:
      begin
        for i:=1 to Abs(iTicks) do
        if iSign > 0 then
        begin
          if Result > 1000000.0 - EPSILON then
            Result := Result + 1000
          else if Result > 500000.0 - EPSILON then
