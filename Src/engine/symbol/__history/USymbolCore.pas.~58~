            Result := Result + 0.0001  //
          else if Result > 0.001 - EPSILON  then
            Result := Result + 0.00001  //
          else if Result > 0.0001 - EPSILON then
            Result := Result + 0.000001
          else if Result > 0.00001 - EPSILON then
            Result := Result + 0.0000001
          else
            Result := Result + 0.00000001;
        end else
        begin
          if Result < 0.00001 + EPSILON then
            Result := Result - 0.00000001
          else if Result < 0.0001 + EPSILON then      //  0.00001 ~ 0.0001
