procedure TSymbolCore.TopAmtSubscribe(aExKind: TExchangeKind; aSymbol1,
  aSymbol2: TSymbol);
  var
    aSymbol : TSymbol;
    I: Integer;
begin
  if (aSymbol1 = nil) or ( aSymbol2 = nil) then Exit;

  for I := 0 to 1 do
  begin
    aSymbol := App.Engine.ApiManager.ExManagers[aExKind].TopAmtSymbols[i] ;
    if aSymbol <> nil then
    begin
      if (aSymbol <> aSymbol1) and (aSymbol <> aSymbol2) then
        App.Engine.QuoteBroker.Brokers[aExKind].Cancel(Self,aSymbol);
    end;
  end;

  if (aSymbol1 <> App.Engine.ApiManager.ExManagers[aExKind].TopAmtSymbols[0])
    and (aSymbol1 <> App.Engine.ApiManager.ExManagers[aExKind].TopAmtSymbols[1])  then
      App.Engine.QuoteBroker.Brokers[aExKind].Subscribe(Self, aSymbol1,
        App.Engine.QuoteBroker.Brokers[aExKind].DummyEventHandler );

  if (aSymbol2 <> App.Engine.ApiManager.ExManagers[aExKind].TopAmtSymbols[0])
    and (aSymbol2 <> App.Engine.ApiManager.ExManagers[aExKind].TopAmtSymbols[1])  then
      App.Engine.QuoteBroker.Brokers[aExKind].Subscribe(Self, aSymbol2,
        App.Engine.QuoteBroker.Brokers[aExKind].DummyEventHandler );

  App.Engine.ApiManager.ExManagers[aExKind].TopAmtSymbols[0] := aSymbol1;
  App.Engine.ApiManager.ExManagers[aExKind].TopAmtSymbols[1] := aSymbol2;

end;

procedure TSymbolCore.RegisterSymbol(aExKind : TExchangeKind; aSymbol: TSymbol);
var
  aMarket : TMarket;
begin
  if aSymbol = nil then Exit;

  if FSymbols[aExKind].IndexOfObject(aSymbol) < 0 then
    FSymbols[aExKind].AddObject(aSymbol.Code, aSymbol );

  if aSymbol.Spec <> nil then
  begin
    aMarket := FMarkets[aExKind].FindMarket( aSymbol.Spec.FQN );

    if aMarket = nil then
    begin

      case aSymbol.Spec.Market of
        mtSpot:     aMarket := FSpotMarkets[aExKind].New(aSymbol.Spec.FQN);
        mtFutures:  aMarket := FFutureMarkets[aExKind].New(aSymbol.Spec.FQN);
        else
          Exit;
      end;
    end;

    aMarket.Spec  := aSymbol.Spec;
    FMarkets[aExKind].AddMarket(aMarket);

    if (aSymbol.Spec.Market = mtFutures ) and (( aSymbol as TFuture ).Underlying <> nil ) then
    begin
      FUnderlyings[aExKind].AddMarket(aMarket,
                             aSymbol.Spec.SubMarket
                             + aSymbol.Spec.Underlying
                             + '.' + aSymbol.Spec.Exchange
                             + '.' + aSymbol.Spec.Country,
                             (aSymbol as TFuture).Underlying.Code,
                             (aSymbol as TFuture).Underlying);

      if aSymbol.Spec.ExchangeType = ekBinance then begin
        aSymbol.ReSizeMarketDepth(20);
      end;

      FFutureType[aExKind][aSymbol.Spec.FutureType].AddSymbol(aSymbol);
    end;

    FExchanges[aExKind].AddMarket(aMarket,
                         aSymbol.Spec.Exchange + '.' + aSymbol.Spec.Country,
                         aSymbol.Spec.Exchange);


    if aSymbol.Spec.Country = 'kr' then
      FCommSymbols.Add( aSymbol );

    FBaseSymbols.AddSymbol( aSymbol );

  end;

  if aSymbol.Spec.BaseCode = 'USDT' then
    FTethers[aSymbol.Spec.ExchangeType] := aSymbol;

  aMarket.AddSymbol( aSymbol );

end;



function TicksFromPrice(aSymbol: TSymbol; dPrice: Double; iTicks: Integer): Double;
