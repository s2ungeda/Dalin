  if App.Config.TradeMod then Exit;
  CalcKimp( aSymbol );
  CalcMainKimp( aSymbol );
  CalcMainWDC(aSymbol);
  // 5분데이터 담기..
end;

procedure TSymbolCore.CalcKimp( aSymbol : TSymbol );
var
  dEx : double;
  pSymbol : TSymbol;
  aList   : TList<TSymbol>;
  I: Integer;
  bOS : boolean;
begin

  bOS := false;
  if (aSymbol.Spec.ExchangeType = FMainExKind ) then
    bOS := true;

  if bOS then
  begin

    if aSymbol.Spec.ExApiType <> FMainExApiType then Exit;

    aList := FBaseSymbols.FindSymbolList( aSymbol.Spec.BaseCode );
    if aList = nil then Exit;

    for I := 0 to aList.Count-1 do
    begin
      pSymbol := aList[i];
      if (pSymbol.Spec.ExchangeType = FSubExKind1) or
         (pSymbol.Spec.ExchangeType = FSubExKind2) then
      begin
         //CalcKimp( aSymbol.Last, pSymbol );
         // 선물 현재가 대신 인덱스 가격(현물가격) 사용
         CalcKimp( aSymbol.IndexPrice, pSymbol );
         // 계산된 kip 에 basis 를 더해준다.
         // basis 더하지 말랜다.
         //pSymbol.KimpPrice := pSymbol.KimpPrice + aSymbol.Basis;
      end;
    end;

  end else
  begin
    pSymbol := FBaseSymbols.FindSymbol( aSymbol.Spec.BaseCode, FMainExKind, FMainExApiType  );
    if pSymbol <> nil then begin
      //CalcKimp( pSymbol.Last, aSymbol );
      CalcKimp( pSymbol.IndexPrice, aSymbol );
      // 계산된 kip 에 basis 를 더해준다.
      // basis 더하지 말랜다.
      //aSymbol.KimpPrice := aSymbol.KimpPrice + pSymbol.Basis;
    end;
    //  빗썸 USDT 김프는 다른방식으로 구함.
    if (aSymbol.Code = 'USDT') {and (aSymbol.Spec.ExchangeType = ekBithumb)} then
      CalcUSDTKimp(aSymbol);

    if aSymbol.Spec.ExchangeType = FSubExKind1 then begin
      // aymbol = upbit , psymbol = bithumb
      pSymbol := FBaseSymbols.FindSymbol( aSymbol.Spec.BaseCode, FSubExKind2  );
      if pSymbol <> nil then begin
        // 빗썸의 현재가, 업비트 종목
        CalcSP( pSymbol.Last, aSymbol );
        CalcSP( aSymbol, pSymbol );
      end;
    end  else
    if aSymbol.Spec.ExchangeType = FSubExKind2 then begin
      // aymbol = bithumb, psymbol = upbit
      pSymbol := FBaseSymbols.FindSymbol( aSymbol.Spec.BaseCode, FSubExKind1  );
      if pSymbol <> nil then begin
        // 빗썸의 현재가, 업비트의 종목
        CalcSP( aSymbol.Last, pSymbol );
        CalcSP( pSymbol, aSymbol );
      end;
    end;


