          Result := 4
        else if dPrice > 100000 - EPSILON then  // 100만원 미만 10만원 이상
          Result := 3
        else if dPrice > 10000 - EPSILON then   // 10만원 미만 만원 이상
          Result := 2
        else if dPrice > 1000 - EPSILON then    // 만원 미만 천원 이상
          Result := 1
        else if dPrice > 1 - EPSILON then       // 천원 미만 1원 이상
          Result := 0
        else                                    // 1원 미만
          Result := -1;
      end;

   end;
end;



