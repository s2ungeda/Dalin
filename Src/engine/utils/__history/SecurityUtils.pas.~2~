
unit SecurityUtils;

interface

uses
  Windows, SysUtils, Classes, IdHashSHA, IdGlobal, IdSSLOpenSSL;

procedure CheckFileIntegrity;
procedure ProtectCodeRegion(Address: Pointer; Size: DWORD);
procedure StartIntegrityMonitorThread;

implementation


{$I Hash.inc}
{$I CodeBytes.inc}

function GetFileHash(const FileName: string): string;
var
  Stream: TFileStream;
  Hash: TIdHashSHA256;
begin
  Result := '';
  LoadOpenSSLLibrary;
  if not TIdHashSHA256.IsAvailable then
    raise Exception.Create('SHA256 hashing is not available!');

  Stream := TFileStream.Create(FileName, fmOpenRead or fmShareDenyNone);
  try
    Hash := TIdHashSHA256.Create;
    try
      Result := Hash.HashStreamAsHex(Stream);
    finally
      Hash.Free;
    end;
  finally
    Stream.Free;
  end;
end;

procedure CheckFileIntegrity;
var
  HashNow: string;
begin
  HashNow := GetFileHash(ParamStr(0));
  if not SameText(HashNow, ORIGINAL_HASH) then
  begin
    MessageBox(0, '무결성 오류: 실행 파일이 변조되었습니다.', '보안 경고', MB_ICONERROR);
    Halt(1);
  end;
end;

procedure ProtectCodeRegion(Address: Pointer; Size: DWORD);
var
  OldProtect: DWORD;
begin
  VirtualProtect(Address, Size, PAGE_EXECUTE_READ, OldProtect);
end;

procedure IntegrityMonitor;
begin
  while True do
  begin
    if not CompareMem(@CheckFileIntegrity, @ExpectedCodeBytes, Length(ExpectedCodeBytes)) then
    begin
      MessageBox(0, '메모리 변조 감지됨.', '보안 경고', MB_ICONERROR);
      ExitProcess(1);
    end;
    Sleep(3000);
  end;
end;

procedure StartIntegrityMonitorThread;
begin
  CreateThread(nil, 0, @IntegrityMonitor, nil, 0, PDWORD(nil)^);
end;

end.
