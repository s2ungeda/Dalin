unit UDllFormLoader;

interface

uses
  System.Classes, System.SysUtils, Windows,

  UStorage

  ;

type

  TDllFormItem = class(TCollectionItem)
  public
    FFormID: Integer;
    FDllHandle : THandle;
  end;

  TDllFormOpenEvent = procedure(iFormID: integer; var aHandle: THandle) of object;

  TDllFormLoader = class(TCollection)
  private
    FStorage: TStorage;
    FOnDllFormOpen: TDllFormOpenEvent;
  public
    constructor Create;
    destructor Destroy; override;

    function Open(iFormID, iVar: Integer): THandle;
    function Load(stFile: String): Boolean;
    function Save(stFile: String): Boolean;

    property Storage: TStorage read FStorage write FStorage;

    property OnDllFromOpen : TDllFormOpenEvent read FOnDllFormOpen write FOnDllFormOpen;
  end;

implementation

{ TDllFormLoader }

constructor TDllFormLoader.Create;
begin
 inherited Create(TDllFormItem);

  FStorage := TStorage.Create;
end;

destructor TDllFormLoader.Destroy;
begin
  FStorage.Free;
  inherited;
end;

function TDllFormLoader.Load(stFile: String): Boolean;
begin

end;

function TDllFormLoader.Open(iFormID, iVar: Integer): THandle;
var
  aItem : TDllFormItem;
  ShowFormProc: procedure (Sender: TComponent);
begin

  if Assigned(FOnDllFormOpen) then
  try
    FOnDllFormOpen(iFormID, Result);
  except
  end;

  if Result <> 0 then
  begin
    aItem := Add as  TDllFormItem;
    aItem.FFormID := iFormID;
    aItem.FDllHandle  := Result;
  end;
end;

function TDllFormLoader.Save(stFile: String): Boolean;
begin

end;

end.
