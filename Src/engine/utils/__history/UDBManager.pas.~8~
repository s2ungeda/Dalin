      'E_F_FilledQty REAL , '+
      'E_S_FilledQty REAL , '+
      'X_F_FilledQty REAL , '+
      'X_S_FilledQty REAL , '+

      'LastDate TEXT, '+
      'PRIMARY KEY(Code,StgCode)'+
      ')'
      );
end;

