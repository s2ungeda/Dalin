procedure TDBManager.RecreateTestTable;
var
  iRes : integer;
begin
  // Kip Table 생성
  FQuery.ExecSQL(
    'CREATE TABLE IF NOT EXISTS KipOrder (' +
   //   'id INTEGER PRIMARY KEY,' +
      'Code TEXT , '+
      'MajorEx INTEGER , '+
      'SubEx INTEGER , '+

      'AccFilledQty_1 TEXT, '+
      'TradeAmt_1 TEXT, '+
      'KipFill_1 TEXT, '+
      'FilledQty_1 TEXT, '+

      'AccFilledQty_2 TEXT, '+
      'TradeAmt_2 TEXT, '+
      'KipFill_2 TEXT, '+
      'FilledQty_2 TEXT, '+
      'PRIMARY KEY(Code,MajorEx,SubEx)'+
      ')'
      );

  FQuery.ExecSQL(
    'CREATE TABLE IF NOT EXISTS SignalOrder (' +
   //   'id INTEGER PRIMARY KEY,' +
      'Code TEXT , '+
