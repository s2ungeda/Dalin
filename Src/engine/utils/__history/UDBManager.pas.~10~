procedure TDBManager.RecreateTestTable;
var
  iRes : integer;
begin
  // Kip Table 생성
  FQuery.ExecSQL(
    'CREATE TABLE IF NOT EXISTS KipOrder (' +
   //   'id INTEGER PRIMARY KEY,' +
      'Code TEXT , '+
      'MajorEx INTEGER , '+
      'SubEx INTEGER , '+

      'AccFilledQty_1 TEXT, '+
      'TradeAmt_1 TEXT, '+
      'KipFill_1 TEXT, '+
      'FilledQty_1 TEXT, '+

      'AccFilledQty_2 TEXT, '+
      'TradeAmt_2 TEXT, '+
      'KipFill_2 TEXT, '+
      'FilledQty_2 TEXT, '+
      'PRIMARY KEY(Code,MajorEx,SubEx)'+
      ')'
      );

  FQuery.ExecSQL(
    'CREATE TABLE IF NOT EXISTS SignalOrder (' +
   //   'id INTEGER PRIMARY KEY,' +
      'Code TEXT , '+
      'StgCode TEXT , '+

      'E_F_Qty REAL , '+
      'E_S_Qty REAL , '+
      'X_F_Qty REAL , '+
      'X_S_Qty REAL , '+

      'E_B_S_Qty REAL , '+
      'E_B_L_Qty REAL , '+
      'E_U_S_Qty REAL , '+
      'E_U_L_Qty REAL , '+
      'E_T_S_Qty REAL , '+
      'E_T_L_Qty REAL , '+

      'X_B_S_Qty REAL , '+
      'X_B_L_Qty REAL , '+
      'X_U_S_Qty REAL , '+
      'X_U_L_Qty REAL , '+
      'X_T_S_Qty REAL , '+
      'X_T_L_Qty REAL , '+

      'PRIMARY KEY(Code,StgCode)'+
      ')'
      );
end;

