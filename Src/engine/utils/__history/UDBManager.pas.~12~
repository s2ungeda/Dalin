unit UDBManager;
{
  TSQLiteManager - Thread-Safe SQLite Wrapper for Delphi 11.3 (64-bit)
  =====================================================================
  - FireDAC 기반, DLL 불필요 (Static Linkage)
  - 스레드별 독립 Connection (TThreadList 관리)
  - WAL 모드 + 성능 PRAGMA 자동 설정
  - 비동기 쓰기 큐 (TDBWriterThread) 내장
  - 트랜잭션 헬퍼, 배치 INSERT 지원
  - 사용 예:
      FSQLite := TSQLiteManager.Create('C:\Data\trade.db');
      FSQLite.Execute('CREATE TABLE IF NOT EXISTS ...');
      FSQLite.AsyncExecute('INSERT INTO orders ...', [sSymbol, fPrice, nQty]);
      FSQLite.Free;
}

interface

uses
  System.SysUtils, System.Classes, System.SyncObjs, System.Generics.Collections,
  FireDAC.Comp.Client, FireDAC.Phys.SQLite, FireDAC.Phys.SQLiteDef,
  FireDAC.Stan.Def, FireDAC.Stan.Async, FireDAC.DApt,
  FireDAC.Stan.Param, FireDAC.Stan.Option;

type
  // 비동기 큐에 넣을 SQL 작업 레코드
  TSQLTask = record
    SQL: string;
    Params: TArray<Variant>;
    constructor Create(const aSQL: string; const aParams: TArray<Variant>);
  end;

  // 콜백 타입
  TSQLiteErrorEvent = reference to procedure(Sender: TObject; const aSQL: string;
    E: Exception);

  // 내부 비동기 쓰기 스레드
  TDBWriterThread = class(TThread)
  private
    FConn: TFDConnection;
    FQueue: TThreadedQueue<TSQLTask>;
    FDBPath: string;
    FOnError: TSQLiteErrorEvent;
    FBatchSize: Integer;
    FBatchTimeoutMs: Integer;
    FIdleEvent: TEvent;
    procedure InitConnection;
  protected
    procedure Execute; override;
  public
    constructor Create(const aDBPath: string;
      aQueue: TThreadedQueue<TSQLTask>;
      aBatchSize: Integer = 100;
      aBatchTimeoutMs: Integer = 50);
    destructor Destroy; override;
    property OnError: TSQLiteErrorEvent read FOnError write FOnError;
    property IdleEvent: TEvent read FIdleEvent;
  end;

  // 메인 클래스
  TSQLiteManager = class
  private
    FDBPath: string;
    FConnPool: TThreadList<TFDConnection>;
    FThreadConnMap: TDictionary<TThreadID, TFDConnection>;
    FMapLock: TCriticalSection;
    FWriterThread: TDBWriterThread;
    FAsyncQueue: TThreadedQueue<TSQLTask>;
    FOnError: TSQLiteErrorEvent;
    FDriverLink: TFDPhysSQLiteDriverLink;
    // 스레드별 Connection 획득
    function AcquireConnection: TFDConnection;
    function CreateNewConnection: TFDConnection;
    procedure ApplyPragma(aConn: TFDConnection);
    procedure SetOnError(const aValue: TSQLiteErrorEvent);
  public
    constructor Create(const aDBPath: string; aStartWriter: Boolean = True);
    destructor Destroy; override;

    // 동기 실행 (현재 스레드의 Connection 사용)
    procedure Execute(const aSQL: string); overload;
    procedure Execute(const aSQL: string; const aParams: array of Variant); overload;

    // SELECT - 콜백 방식 (Connection 자동 관리)
    procedure Query(const aSQL: string;
      const aParams: array of Variant;
      aProc: TProc<TFDQuery>);

    // SELECT - DataSet 반환 (호출자가 Free 해야 함)
    function OpenQuery(const aSQL: string;
      const aParams: array of Variant): TFDQuery;

    // 트랜잭션 블록
    procedure Transaction(aProc: TProc<TFDConnection>);

    // 비동기 실행 (큐에 넣고 즉시 리턴)
    procedure AsyncExecute(const aSQL: string); overload;
    procedure AsyncExecute(const aSQL: string;
      const aParams: array of Variant); overload;

    // 비동기 조회 (별도 스레드에서 실행, 콜백은 메인 스레드)
    procedure AsyncQuery(const aSQL: string;
      const aParams: array of Variant;
      aProc: TProc<TFDQuery>);

    // 배치 INSERT 헬퍼
    procedure BatchInsert(const aSQL: string;
      aParamLoader: TProc<TFDQuery, Integer>;
      aCount: Integer);

    // 유틸리티
    function TableExists(const aTableName: string): Boolean;
    function LastInsertRowID: Int64;
    function GetDBPath: string;

    // 현재 스레드의 Connection 해제 (익명 스레드 종료 시 호출)
    procedure ReleaseConnection;

    // WriterThread 수동 시작 (InitDB 등 스키마 작업 후 호출)
    procedure StartWriter;

    // 비동기 큐 남은 개수
    function AsyncQueueCount: Integer;
    // 비동기 큐가 빌 때까지 대기
    procedure FlushAsync(aTimeoutMs: Integer = 5000);

    property OnError: TSQLiteErrorEvent read FOnError write SetOnError;
  end;

implementation

{ TSQLTask }

constructor TSQLTask.Create(const aSQL: string; const aParams: TArray<Variant>);
begin
  SQL := aSQL;
  Params := aParams;
end;

{ TDBWriterThread }

constructor TDBWriterThread.Create(const aDBPath: string;
  aQueue: TThreadedQueue<TSQLTask>;
  aBatchSize: Integer; aBatchTimeoutMs: Integer);
begin
  inherited Create(False);
  FreeOnTerminate := False;
  FDBPath := aDBPath;
  FQueue := aQueue;
  FBatchSize := aBatchSize;
  FBatchTimeoutMs := aBatchTimeoutMs;
  FConn := nil;
  FIdleEvent := TEvent.Create(nil, True, True, '');
end;

destructor TDBWriterThread.Destroy;
begin
  FConn.Free;
  FIdleEvent.Free;
  inherited;
end;

procedure TDBWriterThread.InitConnection;
begin
  FConn := TFDConnection.Create(nil);
  FConn.DriverName := 'SQLite';
  FConn.Params.Database := FDBPath;
  FConn.Params.Add('OpenMode=CreateUTF8');
  FConn.Params.Add('LockingMode=Normal');
  FConn.LoginPrompt := False;
  FConn.Connected := True;
  FConn.ExecSQL('PRAGMA journal_mode=WAL');
  FConn.ExecSQL('PRAGMA synchronous=NORMAL');
  FConn.ExecSQL('PRAGMA cache_size=-32000');
  FConn.ExecSQL('PRAGMA temp_store=MEMORY');
  FConn.ExecSQL('PRAGMA mmap_size=134217728');
  FConn.ExecSQL('PRAGMA busy_timeout=5000');
end;

procedure TDBWriterThread.Execute;
var
  Task: TSQLTask;
  Qry: TFDQuery;
  WaitResult: TWaitResult;
  BatchCount: Integer;

  procedure BindAndExec;
  var
    j: Integer;
  begin
    if Qry.SQL.Text <> Task.SQL then
      Qry.SQL.Text := Task.SQL;
    for j := 0 to High(Task.Params) do
      Qry.Params[j].Value := Task.Params[j];
    Qry.ExecSQL;
  end;

begin
  InitConnection;
  Qry := TFDQuery.Create(nil);
  try
    Qry.Connection := FConn;

    while not Terminated do
    begin
      FIdleEvent.SetEvent;
      WaitResult := FQueue.PopItem(Task);
      if WaitResult <> TWaitResult.wrSignaled then
        Continue;
      FIdleEvent.ResetEvent;

      // 첫 번째 아이템을 받았으면 배치 시작
      FConn.StartTransaction;
      try
        BatchCount := 0;
        repeat
          BindAndExec;
          Inc(BatchCount);

          if BatchCount >= FBatchSize then
            Break;

          // 큐에 더 있으면 계속 꺼냄 (짧은 타임아웃)
          WaitResult := FQueue.PopItem(Task);
        until (WaitResult <> TWaitResult.wrSignaled) or Terminated;

        FConn.Commit;
      except
        on E: Exception do
        begin
          FConn.Rollback;
          if Assigned(FOnError) then
            FOnError(Self, Task.SQL, E);
        end;
      end;
    end;

    // 종료 전 남은 큐 처리
    while FQueue.PopItem(Task) = TWaitResult.wrSignaled do
    begin
      try
        BindAndExec;
      except
        on E: Exception do
          if Assigned(FOnError) then
            FOnError(Self, Task.SQL, E);
      end;
    end;

  finally
    Qry.Free;
  end;
end;

{ TSQLiteManager }

constructor TSQLiteManager.Create(const aDBPath: string; aStartWriter: Boolean);
begin
  inherited Create;
  FDBPath := aDBPath;

  // FireDAC SQLite 드라이버 링크
  FDriverLink := TFDPhysSQLiteDriverLink.Create(nil);

  FConnPool := TThreadList<TFDConnection>.Create;
  FThreadConnMap := TDictionary<TThreadID, TFDConnection>.Create;
  FMapLock := TCriticalSection.Create;

  // 비동기 큐 (최대 10000개, Push 타임아웃 1초)
  FAsyncQueue := TThreadedQueue<TSQLTask>.Create(10000, 1000, 100);

  if aStartWriter then
  begin
    FWriterThread := TDBWriterThread.Create(FDBPath, FAsyncQueue);
    FWriterThread.OnError := FOnError;
  end
  else
    FWriterThread := nil;
end;

destructor TSQLiteManager.Destroy;
var
  List: TList<TFDConnection>;
  Conn: TFDConnection;
begin
  // Writer 스레드 종료
  if Assigned(FWriterThread) then
  begin
    FWriterThread.Terminate;
    FWriterThread.WaitFor;
    FWriterThread.Free;
  end;

  FAsyncQueue.Free;

  // 모든 Connection 해제
  List := FConnPool.LockList;
  try
    for Conn in List do
    begin
      try
        Conn.Connected := False;
        Conn.Free;
      except
        // 종료 시 예외 무시
      end;
    end;
  finally
    FConnPool.UnlockList;
  end;
  FConnPool.Free;

  FMapLock.Free;
  FThreadConnMap.Free;
  FDriverLink.Free;
  inherited;
end;

function TSQLiteManager.CreateNewConnection: TFDConnection;
begin
  Result := TFDConnection.Create(nil);
  Result.DriverName := 'SQLite';
  Result.Params.Database := FDBPath;
  Result.Params.Add('OpenMode=CreateUTF8');
  Result.Params.Add('LockingMode=Normal');
  Result.LoginPrompt := False;
  Result.Connected := True;
  ApplyPragma(Result);
end;

procedure TSQLiteManager.ApplyPragma(aConn: TFDConnection);
begin
  aConn.ExecSQL('PRAGMA journal_mode=WAL');
  aConn.ExecSQL('PRAGMA synchronous=NORMAL');
  aConn.ExecSQL('PRAGMA cache_size=-32000');  // 32MB
  aConn.ExecSQL('PRAGMA temp_store=MEMORY');
  aConn.ExecSQL('PRAGMA mmap_size=134217728'); // 128MB
  aConn.ExecSQL('PRAGMA busy_timeout=5000');   // 5초 대기 후 BUSY 에러
end;

function TSQLiteManager.AcquireConnection: TFDConnection;
var
  TID: TThreadID;
begin
  TID := TThread.Current.ThreadID;
  FMapLock.Enter;
  try
    if not FThreadConnMap.TryGetValue(TID, Result) then
    begin
      Result := CreateNewConnection;
      FThreadConnMap.Add(TID, Result);
      FConnPool.Add(Result);
    end;
  finally
    FMapLock.Leave;
  end;

  // 연결이 끊어진 경우 재연결
  if not Result.Connected then
  begin
    Result.Connected := True;
    ApplyPragma(Result);
  end;
end;

procedure TSQLiteManager.SetOnError(const aValue: TSQLiteErrorEvent);
begin
  FOnError := aValue;
  if Assigned(FWriterThread) then
    FWriterThread.OnError := aValue;
end;

procedure TSQLiteManager.ReleaseConnection;
var
  TID: TThreadID;
  Conn: TFDConnection;
begin
  TID := TThread.Current.ThreadID;
  FMapLock.Enter;
  try
    if FThreadConnMap.TryGetValue(TID, Conn) then
    begin
      FThreadConnMap.Remove(TID);
      FConnPool.Remove(Conn);
      try
        Conn.Connected := False;
        Conn.Free;
      except
        // 해제 시 예외 무시
      end;
    end;
  finally
    FMapLock.Leave;
  end;
end;

{ 동기 실행 }

procedure TSQLiteManager.Execute(const aSQL: string);
var
  Conn: TFDConnection;
begin
  Conn := AcquireConnection;
  Conn.ExecSQL(aSQL);
end;

procedure TSQLiteManager.Execute(const aSQL: string;
  const aParams: array of Variant);
var
  Conn: TFDConnection;
begin
  Conn := AcquireConnection;
  Conn.ExecSQL(aSQL, aParams);
end;

{ SELECT - 콜백 방식 }

procedure TSQLiteManager.Query(const aSQL: string;
  const aParams: array of Variant;
  aProc: TProc<TFDQuery>);
var
  Qry: TFDQuery;
  i: Integer;
begin
  Qry := TFDQuery.Create(nil);
  try
    Qry.Connection := AcquireConnection;
    Qry.SQL.Text := aSQL;
    for i := 0 to High(aParams) do
      Qry.Params[i].Value := aParams[i];
    Qry.Open;
    aProc(Qry);
  finally
    Qry.Free;
  end;
end;

{ SELECT - DataSet 반환 }

function TSQLiteManager.OpenQuery(const aSQL: string;
  const aParams: array of Variant): TFDQuery;
var
  i: Integer;
begin
  Result := TFDQuery.Create(nil);
  try
    Result.Connection := AcquireConnection;
    Result.SQL.Text := aSQL;
    for i := 0 to High(aParams) do
      Result.Params[i].Value := aParams[i];
    Result.Open;
    // FetchAll 하여 Connection과 독립적으로 사용 가능
    Result.FetchAll;
  except
    Result.Free;
    raise;
  end;
end;

{ 트랜잭션 블록 }

procedure TSQLiteManager.Transaction(aProc: TProc<TFDConnection>);
var
  Conn: TFDConnection;
begin
  Conn := AcquireConnection;
  Conn.StartTransaction;
  try
    aProc(Conn);
    Conn.Commit;
  except
    Conn.Rollback;
    raise;
  end;
end;

{ 비동기 실행 }

procedure TSQLiteManager.AsyncExecute(const aSQL: string);
begin
  AsyncExecute(aSQL, []);
end;

procedure TSQLiteManager.AsyncExecute(const aSQL: string;
  const aParams: array of Variant);
var
  Task: TSQLTask;
  ParamArr: TArray<Variant>;
  i: Integer;
begin
  SetLength(ParamArr, Length(aParams));
  for i := 0 to High(aParams) do
    ParamArr[i] := aParams[i];
  Task := TSQLTask.Create(aSQL, ParamArr);
  FAsyncQueue.PushItem(Task);
end;

{ 비동기 조회 }

procedure TSQLiteManager.AsyncQuery(const aSQL: string;
  const aParams: array of Variant;
  aProc: TProc<TFDQuery>);
var
  ParamArr: TArray<Variant>;
  i: Integer;
  Mgr: TSQLiteManager;
begin
  SetLength(ParamArr, Length(aParams));
  for i := 0 to High(aParams) do
    ParamArr[i] := aParams[i];
  Mgr := Self;

  TThread.CreateAnonymousThread(
    procedure
    var
      Qry: TFDQuery;
      j: Integer;
    begin
      try
        Qry := TFDQuery.Create(nil);
        try
          Qry.Connection := Mgr.AcquireConnection;
          Qry.SQL.Text := aSQL;
          for j := 0 to High(ParamArr) do
            Qry.Params[j].Value := ParamArr[j];
          Qry.Open;
          Qry.FetchAll;
          TThread.Queue(nil,
            procedure
            begin
              try
                aProc(Qry);
              finally
                Qry.Free;
              end;
            end
          );
        except
          on E: Exception do
          begin
            Qry.Free;
            if Assigned(Mgr.FOnError) then
              Mgr.FOnError(nil, aSQL, E);
          end;
        end;
      finally
        Mgr.ReleaseConnection;
      end;
    end
  ).Start;
end;

{ 배치 INSERT }

procedure TSQLiteManager.BatchInsert(const aSQL: string;
  aParamLoader: TProc<TFDQuery, Integer>;
  aCount: Integer);
var
  Conn: TFDConnection;
  Qry: TFDQuery;
  i: Integer;
begin
  Conn := AcquireConnection;
  Qry := TFDQuery.Create(nil);
  try
    Qry.Connection := Conn;
    Qry.SQL.Text := aSQL;

    Conn.StartTransaction;
    try
      for i := 0 to aCount - 1 do
      begin
        aParamLoader(Qry, i);
        Qry.ExecSQL;
      end;
      Conn.Commit;
    except
      Conn.Rollback;
      raise;
    end;
  finally
    Qry.Free;
  end;
end;

{ 유틸리티 }

function TSQLiteManager.TableExists(const aTableName: string): Boolean;
var
  Qry: TFDQuery;
begin
  Qry := TFDQuery.Create(nil);
  try
    Qry.Connection := AcquireConnection;
    Qry.SQL.Text :=
      'SELECT COUNT(*) FROM sqlite_master WHERE type=''table'' AND name=:tbl';
    Qry.ParamByName('tbl').AsString := aTableName;
    Qry.Open;
    Result := Qry.Fields[0].AsInteger > 0;
  finally
    Qry.Free;
  end;
end;

function TSQLiteManager.LastInsertRowID: Int64;
var
  Qry: TFDQuery;
begin
  Qry := TFDQuery.Create(nil);
  try
    Qry.Connection := AcquireConnection;
    Qry.SQL.Text := 'SELECT last_insert_rowid()';
    Qry.Open;
    Result := Qry.Fields[0].AsLargeInt;
  finally
    Qry.Free;
  end;
end;

procedure TSQLiteManager.StartWriter;
begin
  if not Assigned(FWriterThread) then
  begin
    FWriterThread := TDBWriterThread.Create(FDBPath, FAsyncQueue);
    FWriterThread.OnError := FOnError;
  end;
end;

function TSQLiteManager.GetDBPath: string;
begin
  Result := FDBPath;
end;

function TSQLiteManager.AsyncQueueCount: Integer;
begin
  Result := FAsyncQueue.QueueSize;
end;

procedure TSQLiteManager.FlushAsync(aTimeoutMs: Integer);
var
  Elapsed: Integer;
begin
  Elapsed := 0;
  while Elapsed < aTimeoutMs do
  begin
    if (AsyncQueueCount = 0) and
       (not Assigned(FWriterThread) or
        (FWriterThread.IdleEvent.WaitFor(0) = wrSignaled)) then
      Break;
    Sleep(10);
    Inc(Elapsed, 10);
  end;
end;

end.
