procedure TTradeBroker.Fill(aOrder: TOrder; aFill: TFill; bDone : boolean);
var
  aPos : TPosition;
  aAsset : TAsset;
//  dFeeRate : double;
begin
  if not aOrder.IsAccept then
  begin
    Accept( aOrder, aFill.FillTime, true );
    App.Log( llInfo, 'Forward Accept Process : %s', [ aOrder.Represent ] );
  end;

  aOrder.Fill( aFill, bDone );

  if aOrder.Symbol.Spec.Market = mtSpot then
  begin

//    dFeeRate := App.Engine.ApiConfig.ExchangeInfo[ integer(aOrder.Account.ExchangeKind) ].TradeFee[ aOrder.Symbol.Spec.Market];

    if aOrder.Side > 0  then
    begin
      // ¸ĹĽö ±Ýľ× + ĽöĽö·á ¸¸Ĺ­ ŔÜ°íżˇĽ­ Â÷°¨.
      aOrder.Account.Asset.Balance := aOrder.Account.Asset.Balance - (aFill.Price * aFill.Volume) - aFill.Fee;// ( aFill.Price * aFill.Volume * ( 1+dFeeRate/100 ));
      aOrder.Account.Asset.Locked  := aOrder.Account.Asset.Locked - (aFill.Price * aFill.Volume) - aFill.Fee;// ( aFill.Price * aFill.Volume * ( 1+dFeeRate/100 ));

      aAsset  := aOrder.Account.Assets.Find( aOrder.Symbol.Spec.BaseCode );
      if aAsset = nil then begin
        aAsset := aOrder.Account.Assets.New( aOrder.Symbol.Spec.BaseCode, aOrder.Account );
        App.Engine.TradeBroker.AssetEvent( aAsset, ASSET_NEW);
      end;

      //aAsset.Balance  := aAsset.Balance + aFill.Volume;

      aAsset.AddFill( aFill);

      if aAsset <> nil then
        App.DebugLog( '%s: %s, %s, ĂĽ°á, %s, %s, %s (A:%.8n, F:%.8n, %s) -> %s, %.4f, %.4f : %s, %.4f, %.4f',[ aOrder.Symbol.Code,
          ExKindToStr( aOrder.Symbol.Spec.ExchangeType), aOrder.SideToStr,
          aOrder.Symbol.PriceToStr( aFill.Price), aOrder.Symbol.QtyToStr( aFill.Volume), aOrder.OrderNo,
          aOrder.ActiveQty, aOrder.FilledQty, aOrder.StateToStr,
          aOrder.Account.Asset.Currency, aOrder.Account.Asset.Balance, aOrder.Account.Asset.Locked,
          aAsset.Currency, aAsset.Balance, aAsset.Locked ] );

    end else
    begin
      aAsset  := aOrder.Account.Assets.Find( aOrder.Symbol.Spec.BaseCode );
      if aAsset = nil then begin
        aAsset := aOrder.Account.Assets.New( aOrder.Symbol.Spec.BaseCode, aOrder.Account );
        App.Engine.TradeBroker.AssetEvent( aAsset, ASSET_NEW);
      end;

      //aAsset.Balance  := aAsset.Balance - aFill.Volume;
      //aAsset.Locked   := aAsset.Locked  - aFill.Volume;

      aAsset.AddFill( aFill );

      aOrder.Account.Asset.Balance  := aOrder.Account.Asset.Balance + ( aFill.Price * aFill.Volume ) - aFill.Fee;// 	 * ( 1-dFeeRate/100 ));

      if aAsset <> nil then
        App.DebugLog( '%s: %s, %s, ĂĽ°á, %s, %s, %s (A:%.8n, F:%.8n, %s) -> %s, %.4f, %.4f : %s, %.4f, %.4f',[ aOrder.Symbol.Code,
          ExKindToStr( aOrder.Symbol.Spec.ExchangeType),
          aOrder.SideToStr, aOrder.Symbol.PriceToStr( aFill.Price),
          aOrder.Symbol.QtyToStr( aFill.Volume), aOrder.OrderNo,
          aOrder.ActiveQty, aOrder.FilledQty, aOrder.StateToStr,
          aAsset.Currency, aAsset.Balance, aAsset.Locked,
          aOrder.Account.Asset.Currency, aOrder.Account.Asset.Balance, aOrder.Account.Asset.Locked
           ] );
    end;

    FDistributor.Distribute(Self, TRD_DATA, aOrder, ORDER_FILLED);
  end else
  begin

    aPos := App.Engine.TradeCore.FindPosition( aOrder.Account, aOrder.Symbol);
    if aPos = nil then
    begin
      aPos  := App.Engine.TradeCore.NewPosition( aOrder.Account, aOrder.Symbol);
      FDistributor.Distribute(Self, TRD_DATA, aPos, POSITION_NEW);
    end;

    aPos.DoOrder( aOrder.Side, -abs(aFill.Volume) );
    aPos.DoOrder( aOrder.Side, aOrder.Price, -abs(aFill.Volume)  );

    aPos.AddFill( aFill );
    aPos.Account.ApplyFill( aFill );

    FDistributor.Distribute(Self, TRD_DATA, aOrder, ORDER_FILLED);
    FDistributor.Distribute(Self, TRD_DATA, aPos,   POSITION_UPDATE);
  end;

  // ÁÖą®°ˇ´É±Ýľ× żřşą
//  aOrder.Account.DoOrder( scKRW, 1,
//    GetOrderAmt(aOrder, aFill.Volume,
//      ifThenFloat( aOrder.State = osFilled, aOrder.Fee, 0 )
//      ) );


end;

