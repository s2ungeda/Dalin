begin
  case aOrder.Symbol.Spec.ExchangeType of
    ekBinance: ;
    ekUpbit: Result := dQty * aOrder.Price + dFee;
    ekBithumb: ;
  end;
end;


procedure TTradeBroker.Accept(aOrder: TOrder; dtTime : TDateTime;
  bAccepted: boolean; sRjtCode : string);
var
  aPos : TPosition;
  dAmt : double;
  aAsset, aAsset2 : TAsset;
begin
  if bAccepted then
  begin
    if aOrder.IsAccept then Exit;

    aOrder.Accept( dtTime );

    if aOrder.Symbol.Spec.Market = mtSpot then
    begin
      if aOrder.Side > 0  then
      begin
        aAsset  := aOrder.Account.Asset;
        aAsset.Locked  := aAsset.Locked + aOrder.OrderAmt;
        aAsset2  := aOrder.Account.Assets.Find( aOrder.Symbol.Spec.BaseCode );
        if aAsset2 = nil then
        begin
          aAsset2  := aOrder.Account.Assets.New( aOrder.Symbol.Spec.BaseCode, aOrder.Account);
          App.Engine.TradeBroker.AssetEvent(aAsset2, ASSET_NEW);
        end;

      end else
      begin
        aAsset  := aOrder.Account.Assets.Find( aOrder.Symbol.Spec.BaseCode );
        if aAsset = nil then
        begin
          aAsset  := aOrder.Account.Assets.New( aOrder.Symbol.Spec.BaseCode, aOrder.Account);
          App.Engine.TradeBroker.AssetEvent(aAsset, ASSET_NEW);
        end;
//        aAsset.Balance  := aAsset.Balance - aOrder.OrderQty ;
        aAsset.Locked   := aAsset.Locked  + aOrder.OrderQty;
      end;

      App.DebugLog( '%s Á˘Ľö %s: %s,%s,%s,%s,%.2f - %s,%.4f, %.4f',[
        ExKindToStr(aOrder.Account.ExchangeKind), aOrder.Symbol.Code, aOrder.SideToStr
        , aOrder.OrderTypeToStr, aOrder.Symbol.PriceToStr( aOrder.Price),
        aOrder.Symbol.QtyToStr( aOrder.OrderQty), aOrder.OrderAmt,
        aAsset.Currency, aAsset.Balance, aAsset.Locked ] );

      FDistributor.Distribute(Self, TRD_DATA, aOrder, ORDER_ACCEPTED);

    end else
    if aOrder.Symbol.Spec.Market = mtFutures then
    begin

      aPos  := App.Engine.TradeCore.FindPosition( aOrder.Account, aOrder.Symbol );
      if aPos = nil then begin
        aPos := App.Engine.TradeCore.NewPosition( aOrder.Account, aOrder.Symbol );
        FDistributor.Distribute(Self, TRD_DATA, aPos, POSITION_NEW);
      end;

      if aOrder.OrderType = otNormal then begin
        aPos.DoOrder( aOrder.Side, aOrder.OrderQty);
        aPos.DoOrder( aOrder.Side, aOrder.Price, aOrder.OrderQty  );
      end;
      // Á˘Ľö˝Ă ąĚĂĽ°áĂł¸®..ÇŘľßÇÔ.
      // upbit
      if ((aOrder.Symbol.Spec.Market = mtSpot ) and ( aOrder.Side = 1))
        or (aOrder.Symbol.Spec.Market = mtFutures)  then
        aOrder.Account.DoOrder( scKRW, 0, GetOrderAmt(aOrder, aOrder.OrderQty , aOrder.RsvFee) );

      FDistributor.Distribute(Self, TRD_DATA, aOrder, ORDER_ACCEPTED);
      FDistributor.Distribute(Self, TRD_DATA, aPos, POSITION_UPDATE);
    end;
  end else
  begin
    aOrder.Reject(sRjtCode, dtTime);
    FDistributor.Distribute(Self, TRD_DATA, aOrder, ORDER_REJECTED);
  end;
end;


procedure TTradeBroker.OnCancel(aOrder : TOrder; dQty : double );
var
  aAsset : TAsset;
  aPos   : TPosition;
begin
  if aOrder.Symbol.Spec.Market = mtSpot then
  begin

    if aOrder.Side > 0  then
    begin
      aAsset  := aOrder.Account.Asset;
      aAsset.Locked := aAsset.Locked - aOrder.OrderAmt;
    end else
    begin
      aAsset  := aOrder.Account.Assets.Find( aOrder.Symbol.Spec.BaseCode);
      if aAsset = nil then
        aAsset  := aOrder.Account.Assets.New( aOrder.Symbol.Spec.BaseCode, aOrder.Account );
      aAsset.Locked := aAsset.Locked - dQty;
    end;

    App.DebugLog( 'ĂëĽŇ %s - %s,%.4f, %.4f',[ aOrder.Represent,
      aAsset.Currency, aAsset.Balance, aAsset.Locked ] )

  end else
  begin

    aPos  := App.Engine.TradeCore.FindPosition(aOrder.Account, aOrder.Symbol );
    if aPos = nil then begin
      aPos := App.Engine.TradeCore.NewPosition( aOrder.Account, aOrder.Symbol );
      FDistributor.Distribute(Self, TRD_DATA, aPos, POSITION_NEW);
    end else
    begin
      aPos.DoOrder( aoRder.Side, -dQty);
      aPos.DoOrder( aOrder.Side, aOrder.Price, -dQty );
    end;
  end;
end;

procedure TTradeBroker.Cancel(aOrder: TOrder; dQty : double);
begin

  if aOrder.State = osCanceled then
  begin
    App.Log(llInfo, 'ĂëĽŇ Č®ŔÎ Áßşą Ľö˝Ĺ : %s', [ aOrder.Represent ]);
    Exit;
  end;

  if dQty > 0 then
  begin
    OnCancel(aOrder, dQty);
    aOrder.Cancel( dQty );
    FDistributor.Distribute(Self, TRD_DATA, aOrder, ORDER_CANCELED);
  end;
end;

