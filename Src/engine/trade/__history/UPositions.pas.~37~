procedure TPosition.AddFill(aFill: TFill);
begin
  FFills.AddFill( aFill );
  FLastFill := aFill;

	DoCalcPosition;
end;

procedure TPosition.DoCalcPosition;
var
  dEntryPL, dFilledQty , dNewQty, dFeeRate, dAmt : double;

begin

  dFilledQty  := FLastFill.Volume * FLastFill.Side;
  dNewQty     := FVolume + dFilledQty;
  dEntryPL    := 0;

  if CheckZero( FVolume ) then
    FAvgPrice := FLastFill.Price
  else if ( FVolume * dNewQty ) < 0 then // 반대포지션
  begin
    dEntryPL  := (FLastFill.Price - FAvgPrice) * FVolume * FSymbol.Spec.PointValue;
    FEntryPL  := FEntryPL + dEntryPL;
    FAvgPrice := FLastFill.Price;
  end else
  if CheckZero( dNewQty ) then  // 청산
  begin
    dEntryPL  := (FLastFill.Price - FAvgPrice) * FVolume * FSymbol.Spec.PointValue;
    FEntryPL  := FEntryPL + dEntryPL;
    FAvgPrice := 0;
  end else
  if abs(dNewQty) > abs(FVolume) then
  begin
    FAvgPrice := ( FAvgPrice * FVolume + FLastFill.Price * dFilledQty ) / dNewQty;
  end else
  begin
    dEntryPL := (FLastFill.Price - FAvgPrice) * -dFilledQty * FSymbol.Spec.PointValue;
    FEntryPL := FEntryPL + dEntryPL;
  end;

  FTradeAmt   := FTradeAmt + abs(FLastFill.Volume) * FLastFill.Price * FSymbol.Spec.PointValue;

  // sp 를 위해 계산
  dAmt  := abs(FLastFill.Volume) * FLastFill.Price * FSymbol.Spec.PointValue;
  if FlastFill.Side > 0 then begin
    FBuyAmt := FBuyAmt + dAmt;
    FBuyVol := FBuyVol + FLastFill.Volume;
  end
  else begin
    FSellAmt:= FSellAmt+ dAmt;
    FSellVol := FSellVol + FLastFill.Volume;
  end;

  FFee  := Fee + LastFill.Fee;

  if (Symbol.Spec.Market = mtFutures) then
  begin
    Account.Asset.Balance := Account.Asset.Balance + dEntryPL - LastFill.Fee;
  end;

  FVolume     := dNewQty;
  CalcOpenPL;
end;

procedure TPosition.CalcOpenPL;
begin
  FEntryOTE := FVolume * (FSymbol.Last - FAvgPrice) * FSymbol.Spec.PointValue;
	case FSymbol.Spec.Market of
    mtSpot		: FEntryOTE := FVolume  * FSymbol.Last;
//    mtFutures	: FEntryOTE := FVolume * (FSymbol.Last - FAvgPrice) * FSymbol.Spec.PointValue;
    mtFutures	:
      case FSymbol.Spec.FutureType of
        ftUsdt :
          begin
            FEntryOTE := FVolume * ((FSymbol as TFuture).MarkPrice - FAvgPrice) * FSymbol.Spec.PointValue;
            FPositionMargin := ( abs(FVolume) * (FSymbol as TFuture).MarkPrice * FSymbol.Spec.PointValue) ;
          end;
        ftCoin :
          if CheckZero((FSymbol as TFuture).MarkPrice) or CheckZero(FAvgPrice) then
          begin
            FEntryOTE := 0;
            FPositionMargin := 0;
          end else
          begin
            FEntryOTE := FVolume * (1/(FSymbol as TFuture).MarkPrice - 1/FAvgPrice) * FSymbol.Spec.PointValue;
            FPositionMargin := ( abs(FVolume) * 1/(FSymbol as TFuture).MarkPrice * FSymbol.Spec.PointValue) ;
          end;
      end;
  end;
end;

