constructor TPosition.Create(aColl: TCollection);
begin
  inherited Create( aColl );
  FAccount := nil;
  FSymbol := nil;
  FVolume := 0;
  FAvgPrice := 0.0;
  FEntryDate := 0.0;
  FEntryPL := 0.0;
  FEntryOTE := 0.0;
  FAccTradeAmt := 0.0;

  FPositionMargin := 0.0;

  FBuyAmt:= 0;
  FSellAmt:= 0;

  FSellVol:= 0;
  FBuyVol:= 0;

  FOpenOrderMargin[ptLong]  := 0.0;
  FOpenOrderMargin[ptShort] := 0.0;

  FFills:= TFillList.Create;
  FLastFill := nil;

  FLeverage := 1;
end;

destructor TPosition.Destroy;
begin
  FFills.Free;
  inherited;
end;

procedure TPosition.DoOrder(iSide: integer; dQty: double);
begin
  if iSide = 1 then
    FActiveBuyOrderVolume := Max(0, FActiveBuyOrderVolume + dQty)
  else
  if iSide = -1 then
    FActiveSellOrderVolume := Max(0, FActiveSellOrderVolume + dQty);
end;


procedure TPosition.DoOrder(iSide: integer; dPrice, dVolume: double);
  function CalcMargin : double;
  begin
    Result := dPrice * dVolume * FSymbol.Spec.PointValue
  end;
begin
  if iSide = 1 then
    FOpenOrderMargin[ptLong]  := FOpenOrderMargin[ptLong] + CalcMargin
  else if iSide = -1 then
    FOpenOrderMargin[ptShort] := FOpenOrderMargin[ptShort] + CalcMargin;
end;

function TPosition.GetInitMargin: double;
var
  dGap : double;
begin
  Result := 0;

  if FVolume > 0 then
  begin
    dGap  := FOpenOrderMargin[ptShort] - FPositionMargin;
    if dGap <= ( FOpenOrderMargin[ptLong] + FPositionMargin ) then
      Result := FOpenOrderMargin[ptLong] + FPositionMargin
    else
      Result := dGap;
  end else
  if FVolume < 0 then
  begin
    dGap :=  FOpenOrderMargin[ptLong] - FPositionMargin;
    if  dGap <= ( FOpenOrderMargin[ptShort] + FPositionMargin) then
      Result := FOpenOrderMargin[ptShort] + FPositionMargin
    else
      Result := dGap;
  end
  else begin
    Result := Max( FOpenOrderMargin[ptLong], FOpenOrderMargin[ptShort] );
  end;

  if FLeverage > 0 then
    Result := Result / FLeverage;
end;

function TPosition.GetFee: double;
begin
  Result := FFee;
end;

function TPosition.GetLastPL: Double;
var
  dOpenPL : double;
begin
  // 평가손익을 계산후 반영..
  if FSymbol = nil  then Result := 0;

  if ( FSymbol.Spec.Market = mtFutures ) then
    dOpenPL := FVolume * ((FSymbol as TFuture).MarkPrice - FAvgPrice)
  else
    dOpenPL := FVolume * (FSymbol.Last - FAvgPrice);

  Result := FEntryPL + dOpenPL - FFee;
end;

function TPosition.GetOpenAmt: double;
begin
  Result := 0;
  if FSymbol = nil then Exit;

  if FSymbol.Spec.Market = mtFutures then
    case FSymbol.Spec.FutureType of
      ftUsdt: Result := abs(FVolume) * (FSymbol as TFuture).MarkPrice ;
      ftCoin:
        begin
          if (FSymbol as TFuture).MarkPrice > DOUBLE_EPSILON then
            Result := abs(FVolume) * (1/ (FSymbol as TFuture).MarkPrice);
        end ;
    end;
end;

function TPosition.GetSide: integer;
begin
  if Volume > 0 then
    Result := 1
  else if Volume < 0 then
    Result := -1
  else
    Result := 0;
end;

