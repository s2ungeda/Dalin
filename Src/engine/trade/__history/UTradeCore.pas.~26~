unit UTradeCore;
interface
uses
	System.Classes, System.SysUtils, Windows,
  UAccounts, UFills, UOrders, UPositions , USymbols,
  UApiTypes, UApiConsts, UBalance,
  UBithActiveOrderThread
  ;
type
	TAccountArray = array [TExchangeKind] of TAccounts;
  TOrderArray		= array [TExchangeKind] of TOrders;
  TFillArray		= array [TExchangeKind] of TFills;
  TPositionArray= array [TExchangeKind] of TPositions;
  TBalanceArray = array [TExchangeKind] of TBalances;
  TOrderResultArry = array [TExchangeKind] of TOrderResults;
  TMutexArray   = array [TExchangeKind] of HWND;

	TTradeCore	= class
  private
    FOrders: TOrderArray;
    FFills: TFillArray;
    FAccounts: TAccountArray;
    FPositions: TPositionArray;
    FTotalOrders: TOrderList;
    FBalances: TBalanceArray;
    FAOMutex: TMutexArray;
    FBithActOrdThread: TGetActOrdThread;
    FOrderResult: TOrderResultArry;

  public
    constructor Create;
    destructor Destroy; override;
    procedure AccountLoad;

    function FindAccount( ekType : TExchangeKind ) : TAccount;  overload;
    function FindAccount( ekType : TExchangeKind; aMarket : TAccountMarketType) : TAccount; overload;

    function FindPosition( aAcnt : TAccount;  aSymbol : TSymbol ) : TPosition; overload;
    function FindPosition( aAcnt : TAccount;  stCode : string ) : TPosition; overload;
    function NewPosition( aAcnt : TAccount;  aSymbol : TSymbol ) : TPosition;

    function FindOrder( ekType : TExchangeKind; aAcnt : TAccount;
      aSymbol : TSymbol; sID : string ) : TOrder; overload;
    // only bithumb   // 0 : localNo  , 1 : OrderNo;
    function FindOrder( ekType : TExchangeKind;  sNo : string; iDiv : integer = 0 ) : TOrder;  overload;

    function FindBalance( aAcnt : TAccount;  aSymbol : TSymbol ) : TBalance;

    // iLv - 0 : 기본 , 1 : 반자동
    function CheckLimitOrder( aAcnt : TAccount; aSymbol : TSymbol; iSide : integer;
            dPrice : double; dOrderQty : double; iLv : integer ) : boolean;

    property Accounts: TAccountArray read FAccounts;
    property Orders: TOrderArray read FOrders;
    property Fills: TFillArray read FFills;
    property Positions: TPositionArray read FPositions;
    property Balances : TBalanceArray  read FBalances;

    property OrderResult : TOrderResultArry read FOrderResult;

    property TotalOrders : TOrderList read FTotalOrders;

    property AOMutex : TMutexArray read FAOMutex write FAOMutex;
    property BithActOrdThread : TGetActOrdThread read FBithActOrdThread;
  end;
implementation
uses
	GApp, Math
  , UConsts
  , UTypes
  , GLibs
  , System.Threading
  ;

{ TTradeCore }
procedure TTradeCore.AccountLoad;

var
  I: TExchangeKind;
  aAcnt : TAccount;
  j: TExchangeApiType;

begin
  // account 라 표현했지만.. 거래소랑 비교하면 wallets 라 할수 잇다!!??.
  // spot 과 future 마켓은 다르지만 api 는 같을수도 있고 다를수도 잇음..
  for I := ekBinance to High( TExchangeKind ) do
  begin
    if i = ekBinance then
    begin
      for j := eaSpot to High(TExchangeApiType) do
        aAcnt := FAccounts[i].New( App.Engine.ApiConfig.GetApiKey( I, j )
            ,'', I, TAccountMarketType(integer(j)+1) );

    end else
    	aAcnt := FAccounts[i].New( App.Engine.ApiConfig.GetApiKey( I, eaSpot )
      	,App.Engine.ApiConfig.GetSceretKey( I, eaSpot ) , I , amSpot);
  end;

end;


function TTradeCore.CheckLimitOrder(aAcnt : TAccount; aSymbol: TSymbol; iSide: integer; dPrice,
  dOrderQty: double; iLv: integer): boolean;
  var
    dTradeAmt, dCompPrice, dTmp : double;
    aExKind : TExchangeKind;
    bRes : boolean;
begin

  Result := true;
  if (aSymbol = nil) or (aAcnt = nil ) then Exit (false) ;

  if aSymbol.Spec.FutureType = ftCoin then
    dTradeAmt := 1/dPrice * dOrderQty * aSymbol.Spec.PointValue
  else
    dTradeAmt := dPrice * dOrderQty;

  aExKind := aSymbol.Spec.ExchangeType;

  if dTradeAmt > App.Engine.ApiConfig.OrderLimit.DefOrderLimit[aExKind].OneTimeLimit - DOUBLE_EPSILON then
  begin
    App.Log( llWarning, '[%s,%s] 1회대 기분주문액 제한 --> %.0f > %d ', [   ExKindToStr(aExKind), aSymbol.Code,
      dTradeAmt, App.Engine.ApiConfig.OrderLimit.DefOrderLimit[aExKind].OneTimeLimit ] );
    Exit (false);
  end;

  if iSide > 0 then
  begin
    dCompPrice := aSymbol.Last * ( 1 + App.Engine.ApiConfig.OrderLimit.DefOrderLimit[aExKind].LestrictArea / 100 );
    if dCompPrice < dPrice - PRICE_EPSILON then
      Result := false;
  end
  else begin
    dCompPrice := aSymbol.Last * ( 1 - App.Engine.ApiConfig.OrderLimit.DefOrderLimit[aExKind].LestrictArea / 100 );
    if dCompPrice - PRICE_EPSILON > dPrice then
      Result := false;
  end;

  if not Result then
  begin
    App.Log( llWarning, '[%s,%s] 주문불가영역 --> %s, %s, [%s <- %s] ', [
      ExKindToStr(aExKind), aSymbol.Code, ifThenStr( iSide > 0 , '매수', '매도'),
      aSymbol.PriceToStr( dPrice), aSymbol.PriceToStr(dCompPrice), aSymbol.PriceToStr(aSymbol.Last) ] );
    Exit;
  end;

  // 일단 여기까지 체크
  Exit;

  if iLv = ORD_NORMAL then Exit;

  if dTradeAmt > App.Engine.ApiConfig.OrderLimit.OrderLimit[aExKind].OneTimeLimit - DOUBLE_EPSILON then
  begin
    App.Log( llWarning, '[%s,%s] 반자동 주문 1회대 기분주문액 제한 --> %.0f > %.0f ', [ ExKindToStr(aExKind), aSymbol.Code,
      dTradeAmt, App.Engine.ApiConfig.OrderLimit.OrderLimit[aExKind].OneTimeLimit ] );
    Exit (false);
  end;

//  if aSymbol.FiveTerm = nil then
//  begin
//    App.Log( llWarning, '[%s,%s] %s', [ExKindToStr(aExKind), aSymbol.Code,'아직 5분이 안됐음'] );
//    Exit (false);
//  end;
////
//  if iSide > 0 then
//  begin
//    dTmp  := aSymbol.FiveTerm.L;
//    dCompPrice := dTmp * ( 1 + App.Engine.ApiConfig.OrderLimit.OrderLimit[aExKind].BusyHogaRate / 100 );
//    if dCompPrice < dPrice - PRICE_EPSILON then
//      Result := false;
//  end
//  else begin
//    dTmp  := aSymbol.FiveTerm.H;
//    dCompPrice := dTmp * ( 1 - App.Engine.ApiConfig.OrderLimit.OrderLimit[aExKind].BusyHogaRate / 100 );
//    if dCompPrice - PRICE_EPSILON > dPrice then
//      Result := false;
//  end;
//
//  if not Result then
//  begin
//    App.Log( llWarning, '[%s,%s] 급등락매매불가 --> %s, %s, [%s <- %s] ', [
//      ExKindToStr(aExKind), aSymbol.Code, ifThenStr( iSide > 0 , '매수', '매도'),
//      aSymbol.PriceToStr( dPrice),  aSymbol.PriceToStr(dCompPrice), aSymbol.PriceToStr(dTmp)   ] );
//    Exit;
//  end;

  if aSymbol.SpreadRate > App.Engine.ApiConfig.OrderLimit.OrderLimit[aExKind].SpreadRate then
  begin
    App.Log(llWarning, '[%s,%s] 호가차 제한 %.1f', [ ExKindToStr(aExKind), aSymbol.Code, aSymbol.SpreadRate ] );
    Exit (false);
  end;

  bRes := false;
  TTask.Run(Procedure
    begin
      bRes := App.Engine.ApiManager.ExManagers[ aExKind ].ASyncRequestTradeAmt( aSymbol );
    end).Wait();

  if not bRes then
  begin
    App.Log( llWarning, '[%s,%s] %s', [ExKindToStr(aExKind), aSymbol.Code,'1일 최대 주문금액 조회 실패'] );
    Exit (false);
  end;

  if aAcnt.TradeAmt[aSymbol.Spec.ExApiType] + dTradeAmt > App.Engine.ApiConfig.OrderLimit.OrderLimit[aExKind].OneDayLimit then
  begin
    App.Log(llWarning, '[%s,%s] 1일 최대주문 제한 %.0f + %.0f > %.0f', [ ExKindToStr(aExKind), aSymbol.Code,
      aAcnt.TradeAmt[aSymbol.Spec.ExApiType], dTradeAmt, App.Engine.ApiConfig.OrderLimit.OrderLimit[aExKind].OneDayLimit ] );
    Exit (false);
  end;

end;

constructor TTradeCore.Create;
var
  I: TExchangeKind;
begin  
  for I := ekBinance to High( TExchangeKind ) do
  begin
    FOrders[i]	:= TOrders.Create(i);
    FFills[i]		:= TFills.Create;
    FAccounts[i]:= TAccounts.Create;
    FPositions[i]:= TPositions.Create;
    FBalances[i] := TBalances.Create;
    FOrderResult[i]  := TOrderResults.Create;

    FAOMutex[i]  := CreateMuTex( nil, false, PChar( ExKindToStr(i)+'_Mutex'));
  end;
  FTotalOrders  := TOrderList.Create;

  //FBithActOrdThread:= TGetActOrdThread.Create;
end;

destructor TTradeCore.Destroy;
var
  I: TExchangeKind;
begin

//  FBithActOrdThread.Terminate;
//  FBithActOrdThread.WaitFor;
//  FreeAndNil(FBithActOrdThread);

  for I := ekBinance to High( TExchangeKind ) do
  begin
    FOrderResult[i].Free;
    FPositions[i].Free;
    FOrders[i].Free;
    FFills[i].Free;
    FAccounts[i].Free;
    FBalances[i].Free;

    CloseHandle( FAOMutex[i] );
  end;
  FTotalOrders.Free;
  inherited;

  App.Log(llInfo, 'TTradeCore Destroy' );
end;

function TTradeCore.FindAccount(ekType: TExchangeKind;
  aMarket: TAccountMarketType): TAccount;
begin
	Result := nil;
	if FAccounts[ekType] <> nil then
  	Result := FAccounts[ekType].Find(ektype, aMarket);
end;

function TTradeCore.FindBalance(aAcnt: TAccount; aSymbol: TSymbol): TBalance;
begin
  if aAcnt = nil then
    Result := nil
  else
    Result  := Balances[aAcnt.ExchangeKind].Find(aAcnt, aSymbol);
end;

function TTradeCore.FindOrder(ekType: TExchangeKind; sNo: string;
  iDiv: integer): TOrder;
begin
	if iDiv = DIV_LOC_NO then
  	Result := Orders[ekType].FindLocalNo( sNo)
  else
  	Result := Orders[ekType].Find( sNo);
end;


function TTradeCore.FindOrder(ekType: TExchangeKind; aAcnt: TAccount;
  aSymbol: TSymbol; sID: string): TOrder;
begin
  Result := Orders[ekType].Find( aAcnt, aSymbol, sID );
end;

function TTradeCore.FindPosition( aAcnt: TAccount;
  aSymbol: TSymbol): TPosition;
begin
  Result := Positions[aAcnt.ExchangeKind].Find( aAcnt, aSymbol);
end;

function TTradeCore.FindPosition(aAcnt: TAccount; stCode: string): TPosition;
begin
  Result := Positions[aAcnt.ExchangeKind].Find(
    aAcnt, App.Engine.SymbolCore.FindSymbol(aAcnt.ExchangeKind, stCode) );
end;

function TTradeCore.NewPosition(aAcnt: TAccount; aSymbol: TSymbol): TPosition;
begin
  Result := Positions[aAcnt.ExchangeKind].New( aAcnt, aSymbol);
end;

function TTradeCore.FindAccount(ekType: TExchangeKind): TAccount;
begin
	Result := nil;
	if FAccounts[ekType] <> nil then
  	Result := FAccounts[ekType].Find(ektype);
end;



end.

