function TOrderList.FindOrder(sOrderNo: string): TOrder;
var
  i: Integer;
  aOrder: TOrder;
begin
  Result := nil;
  for i := 0 to Count - 1 do
  begin
    aOrder := TOrder(Items[i]);
    if aOrder.OrderNo = sOrderNo then
    begin
      Result := aOrder;
      Break;
    end;
  end;
end;

function TOrderList.FindLocalOrder(sLocalNo: string): TOrder;
var
  i: Integer;
  aOrder: TOrder;
begin
  Result := nil;
  for i := 0 to Count - 1 do
  begin
    aOrder := TOrder(Items[i]);
    if aOrder.LocalNo = sLocalNo then
    begin
      Result := aOrder;
      Break;
    end;
  end;
end;

function TOrderList.FindOrder(aOrder: TOrder): TOrder;
var
  iRes : integer;
begin
  iRes := IndexOf( aOrder );
  if iRes >= 0 then
    Result := TOrder(Items[iRes])
  else
    Result := nil;
end;

function TOrderList.GetOrder(i: Integer): TOrder;
begin
  if (i >= 0) and (i <= Count-1) then
    Result := TOrder(Items[i])
  else
    Result := nil;
end;

function CompareAcptTime(Data1, Data2: Pointer): Integer;
var
  Order1: TOrder absolute Data1;
  Order2: TOrder absolute Data2;
begin
  if Order1.AcptTime > Order2.AcptTime then
    Result := 1
  else if Order1.AcptTime < Order2.AcptTime then
    Result := -1
  else
    Result := 0;
end;

procedure TOrderList.SortByAcptTime;
begin
  Sort(CompareAcptTime);
end;

procedure TOrder.Accept(dtTime: TDateTime);
var sTime : string;
begin
  if FState in [ osReady, osSent, osSrvAcpt ] then
  begin
    FState      := osActive;
    FActiveQty  := FOrderQty;
    FAcptTime   := dtTime;
    FEventTime  := now;
    FIsAccept   := true;
    FNewRecvTime:= GetTickCount64;

    // 임시 주문 로그
    sTime :=  (IntToStr(DateTimeToUnix(FAcptTime, False))+ FormatDateTime('zzz', FAcptTime));
    App.QuoteLog(FAccount.ExchangeKind, Symbol.Spec.ExApiType, Symbol.Spec.BaseCode,
      ',%s, ,%s, ,%s,%s,%s,%s,%s', [ 'W',
        sTime, SideToStr,
        FmtString(GetPrecision(Symbol, FPrice), FPrice, 1),
        FmtString(Symbol.Spec.QtyPrecision, FOrderQty, 1),
        Symbol.DepthLog(false), FOrderNo ]
      );

//    App.Log(llInfo, 'ordspeed', '%s Acpt Speed : %d (%s) ', [ ExKindToStr(FAccount.ExchangeKind),
//      FNewRecvTime -NewTime, Represent ]);

    if Assigned(FOnStateChanged) then
      FOnStateChanged(Self);
  end;
end;

procedure TOrder.Cancel(dQty: double);
begin
  if FState in [ osReady, osSent, osSrvAcpt, osActive ] then
  begin

    FActiveQty  := FActiveQty - dQty ;
    if FActiveQty <= EPSILON then FActiveQty := 0.0;
    FCanceledQty:= FCanceledQty + dQty;
    FModify     := false;
    FCancelTime := now;
    FCnlRecvTime:= GetTickCount64;

    App.QuoteLog(FAccount.ExchangeKind, Symbol.Spec.ExApiType, Symbol.Spec.BaseCode,
        ',%s, , , ,%s,%s,%s,%s,%s', [ 'D', SideToStr,
          FmtString(GetPrecision(Symbol, FPrice), FPrice, 1),
          FmtString(Symbol.Spec.QtyPrecision, dQty, 1),
          Symbol.DepthLog(false), FOrderNo ]
        );

    if CheckZero(FActiveQty) then
    begin
      //FState      := osCanceled;
      if FFilledQty > 0 then
        FState := osFilled
      else
        FState := osCanceled;

      if Assigned(FOnStateChanged) then
        FOnStateChanged(Self);
    end;

  end;
end;

procedure TOrder.Change(dtTime: TDateTime);
var
  sTime: string;
begin
  if FState in [osSent, osActive  ] then
  begin
    FOrderType  := otNormal;

    FAcptTime   := dtTime;
    FEventTime  := now;
    FChgRecvTime:= GetTickCount64;

    FModify     := false;
    FPriceBI    := ChgPriceBI;
    FPrice      := ChgPrice;

    // 임시 주문 로그
    sTime :=  (IntToStr(DateTimeToUnix(FAcptTime, False))+ FormatDateTime('zzz', FAcptTime));
    App.QuoteLog(FAccount.ExchangeKind, Symbol.Spec.ExApiType, Symbol.Spec.BaseCode,
      ',%s, ,%s, ,%s,%s,%s,%s,%s', [ 'M',
        sTime, SideToStr,
        FmtString(GetPrecision(Symbol, FPrice), FPrice, 1),
        FmtString(Symbol.Spec.QtyPrecision, FOrderQty, 1),
        Symbol.DepthLog(false), FOrderNo ]
      );

//    App.Log(llInfo, 'ordspeed', '%s change Speed : %d (%s) ', [ ExKindToStr(FAccount.ExchangeKind),
//      FChgRecvTime -ChgTime, Represent ]);

//    if Assigned(FOnStateChanged) then
//      FOnStateChanged(Self);
  end;
end;

procedure TOrder.Fill(aFill: TFill; bDone : boolean);
//  var sTime : string;
begin
  if FState in [ osActive ] then
  begin
    Fills.AddFill( aFill );
    FActiveQty  := FActiveQty - aFill.Volume;
    if FActiveQty <= EPSILON then FActiveQty := 0.0;
    FFilledQTy  := FFilledQty + aFill.Volume;
    FAvgPrice   := (FAvgPrice * ( FFilledQty - aFill.Volume ) + aFill.Price * aFill.Volume ) / FFilledQty;
  end;

//  sTime :=  (IntToStr(DateTimeToUnix(aFill.FillTime, False))+ FormatDateTime('zzz', aFill.FillTime));
//
//  App.QuoteLog(FAccount.ExchangeKind, Symbol.Spec.ExApiType, Symbol.Spec.BaseCode,
//    ',%s, ,%s, ,%s,%s,%s,%s,%s,%s', [
//      'T', sTime, SideToStr,
//      FmtString(GetPrecision(Symbol, aFill.Price), aFill.Price, 1),
//      FmtString(Symbol.Spec.QtyPrecision, aFill.Volume, 1),
//      Symbol.DepthLog(false), FOrderNo, aFill.FillNo ]
//    );


  if CheckZero( FActiveQty ) or (bDone) then
  begin
    FState := osFilled;
    FActiveQty  := 0;
    if Assigned(FOnStateChanged) then
      FOnStateChanged(Self);
  end;
end;

// 부동소수 계산착오로 체결 상태 변화 안됐을경우만 이쪽으로 온다.




procedure TOrder.Fill;
begin
  FState := osFilled;
  App.Log(llInfo, ' 체결 상태로 강제 전환 -> %s', [Represent] );
  FActiveQty  := 0;
  if Assigned(FOnStateChanged) then
    FOnStateChanged(Self);
end;


function TOrder.FilledAmt: double;
var
  I: Integer;
  aFill : TFill;
begin
  Result := 0.0;
  for I := 0 to FFills.Count-1 do
  begin
    aFill := FFills.Fills[i];
    Result:= Result + aFill.Price * abs(aFill.Volume)
  end;
end;

function TOrder.GetPositionType: TPositionType;
begin
  if Side > 0 then
    Result := ptLong
  else
    Result := ptShort;
end;

function TOrder.IsCancelAble: boolean;
begin
  if (FState = osActive) and (FOrderType = otNormal) and (not FModify) and (FActiveQty > 0) then
    Result := true
  else
    Result := false;
end;

function TOrder.OrderAmt: double;
var
  iMa, iEx : integer;
  dFee, dOrdQty : double;
begin
  iEx := integer( FAccount.ExchangeKind );
  dFee:= App.Engine.ApiConfig.ExchangeInfo[iEx].GetTradeFee(FSymbol.Spec.ExApiType, FSymbol.Spec.SettleType, ftMaker);
  dOrdQty := FOrderQty;//IfThen( FState = osActive, FActiveQty, FOrderQty);
  case Symbol.Spec.Market of
    mtSpot:   Result :=(dOrdQty * Price) * ( 1 + dFee / 100 );
    mtFutures:
      begin
        var aPos : TPosition;
        aPos :=  App.Engine.TradeCore.Positions[FAccount.ExchangeKind].Find(FAccount, FSymbol);
        if aPos <> nil then
          if aPos.Leverage <= 0 then
            Result := (dOrdQty * Price * Symbol.Spec.PointValue)
          else
            Result := (dOrdQty * Price * Symbol.Spec.PointValue) / aPos.Leverage ;
      end;
  end;
end;

function TOrder.OrderTypeToStr: string;
begin
  case FOrdertype of
    otNormal: Result := '신규';
    otChange: Result := '정정';
    otCancel: Result := '취소';
  end;
end;

function TOrder.PriceToStr: string;
begin
  Result := FSymbol.PriceToStr(FPrice);
end;

procedure TOrder.Reject(sRjtCode: string; dtTime: TDateTime);
begin
  if FState in [osReady, osSent, osSrvAcpt, osActive] then
  begin
    // 취소 주문 거부면...액티브 상태로 유지..
    if FOrderType = otNormal then
    begin
      FState      := osRejected;
      FRejectCode := sRjtCode;
      FModify     := false;
      FRjtRecvTime:= GetTickCount64;
      FRejectTime := now;

      if Assigned(FOnStateChanged) then
        FOnStateChanged(Self);
    end else
      if FOrderType in [otCancel, otChange] then begin
        FOrderType := otNormal;
        FModify    := false;
      end;
  end;
end;

procedure TOrder.Failed(sCode:string);
begin
  if FState in [osReady, osSent, osSrvAcpt, osActive] then
  begin
    if FOrderType = otNormal then
    begin
      FState      := osFailed;
      FRejectCode := sCode;
      FModify     := false;
      FRjtRecvTime:= GetTickCount64;
      FRejectTime := now;

      if Assigned(FOnStateChanged) then
        FOnStateChanged(Self);
    end else
      if FOrderType in [otCancel, otChange] then begin
        FOrderType := otNormal;
        FModify    := false;
      end;
  end;
end;

function TOrder.Represent: string;
begin
  if ( FAccount = nil ) or ( FSymbol = nil ) then
    Result := ''
  else begin
    Result := ExKindToStr( FAccount.ExchangeKind )
      + ', ' + StateToStr
      + ', ' + OrderTypeToStr
      + ', ' + MarketToStr( FSymbol.Spec.Market )
      + ', ' + FSymbol.Code
      + ', ' + SideToStr
      + ', ' + FSymbol.PriceToStr(FPrice)
      + ', ' + FSymbol.QtyToStr( FOrderQty)
      + ', ' + ifThenStr( FReduceOnly , 'Reduce', '' )
      + ', ' + FOrderNo
      + ', ' + FLocalNo
      + ', ' + FTag.ToString
      ;
  end;
end;

function TOrder.RepresentWithEx: string;
begin
  if ( FAccount = nil ) or ( FSymbol = nil ) then
    Result := ''
  else begin
    Result := ExKindToStr( FAccount.ExchangeKind )
      + ', ' + TExApiTypeDesc[ FSymbol.Spec.ExApiType ]
      + ', ' + FSymbol.Code
      + ', ' + SideToStr
      + ', ' + FSymbol.PriceToStr( FPrice)
      + ', ' + FSymbol.QtyToStr( FOrderQty)
      + ', ' + ifThenStr( FReduceOnly , 'Reduce', '' )
      + ', ' + FOrderNo
      + ', ' + FLocalNo
      + ', ' + FTag.ToString
      + ', ' + FExRate.ToString
      ;
  end;
end;

function TOrder.SideToStr: string;
begin
  Result := ifThenStr( FSide > 0, '매수','매도');
end;

function TOrder.SimpleRepresent: string;
begin
  if ( FAccount = nil ) or ( FSymbol = nil ) then
    Result := ''
  else begin
    Result := ExKindToStr(FAccount.ExchangeKind)
      + ', ' + StateToStr
      + ', ' + OrderTypeToStr
      + ', ' + FSymbol.Code
      + ', ' + SideToStr
      + ', ' + FSymbol.PriceToStr(FPrice)
      + ', ' + FSymbol.QtyToStr(FOrderQty)
      + ', ' + FOrderNo
      + ', ' + FLocalNo
      ;
  end;
end;

function TOrder.StateToStr: string;
begin
  case FState of
    osReady,
    osSent,
    osSrvAcpt: Result := '준비';
    osActive:  Result := '접수';
    osSrvRjt,
    osRejected:Result := '거부' ;
    osFilled:  Result := '체결';
    osCanceled:Result := '취소' ;
    osFailed:  Result := '실패';
  end;
end;

function TOrder.StgToStr: string;
begin
  case FStgType of
    stNormal: Result := 'Normal';
    stKipOrder: Result := 'KIP';
    stPutKipOrder : Result := 'PK';
    stSPOrder: Result := 'SP';
    stNS1 : Result := 'NS1';
    stTVSignal : Result := 'SGNL';
