function TOrders.GetAcceptOrderAmt(aAccount: TAccount; iSide: integer): double;
var
  aOrder : TOrder;
begin

  Result := 0;

  for aOrder in FActiveOrders do
  begin
    if (aOrder.Account = aAccount) {and (aOrder.OrderType = otNormal )} and
       (aOrder.Side = iSide) and (aOrder.State = osActive)  then
      Result := Result + aOrder.OrderAmt;
  end;

