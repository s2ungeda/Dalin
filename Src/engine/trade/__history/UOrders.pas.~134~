{ TOrderResults }

constructor TOrderResults.Create;
begin
  inherited Create(TOrderResult);
end;

function TOrderResults.Find(aOrder: TORder;
  rtType: TresultType): TOrderResult;
  var
    i : integer;
    aRslt : TOrderResult;
begin
  Result := nil;
  for I := 0 to Count-1 do begin
    aRslt := GetOrderResults(i);
    if (aRslt <> nil) then
      if (aRslt.Order = aOrder) and (aRslt.ResultType = rtType) then
      begin
        Result := aRslt;
        break;
      end;
  end;
end;

function TOrderResults.GetOrderResults(i: integer): TOrderResult;
begin
  if (i < 0) or (i >= Count) then
    Result := nil
  else
    Result := Items[i] as TOrderResult;
end;

function TOrderResults.New(aOrder: TOrder;
  rtType: TResultType): TOrderResult;
begin
  Result := Add as TOrderResult;
  Result.FOrder  := aOrder;
  Result.FResultType := rtType;
end;

