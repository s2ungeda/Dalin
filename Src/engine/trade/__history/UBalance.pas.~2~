unit UBalance;

interface

uses
  System.Classes, System.SysUtils,

  UAccounts, USymbols,

  UApiTypes

  ;

type

  TBalance = class( TCollectionItem )
  private
    FSymbol: TSymbol;
    FLocked: double;
    FBalance: double;
    FAccount: TAccount;
    FAvgPrice: Double;
    FAvailable: double;
  public
    constructor Create(aColl: TCollection); override;
    destructor Destroy; override;

    property Account: TAccount read FAccount write FAccount;
    property Symbol: TSymbol read FSymbol write FSymbol;

    property Balance : double read FBalance write FBalance;
    property Locked  : double read FLocked  write FLocked;
    property AvgPrice: Double read FAvgPrice write FAvgPrice;
    property Available  : double read FAvailable write FAvailable;
  end;


  TBalances = class( TCollection )
  private
    function GetBalance(i: integer): TBalance;
  public
    constructor Create;
    destructor  Destroy; override;

    function New( aAcnt : TAccount; aSymbol : TSymbol ) : TBalance;
    function Find( aAcnt : TAccount; aSymbol : TSymbol ) : TBalance;

    property Balances[i: integer] : TBalance read GetBalance; default;
  end;


implementation

{ TBalance }

constructor TBalance.Create(aColl: TCollection);
begin
  inherited;

  FAccount := nil;
  FSymbol  := nil;

  FBalance  := 0;
  FLocked   := 0;
  FAvgPrice := 0;
  FAvailable:= 0;

end;

destructor TBalance.Destroy;
begin

  inherited;
end;

{ TBalances }

constructor TBalances.Create;
begin
  inherited Create(TBalance);
end;

destructor TBalances.Destroy;
begin

  inherited;
end;

function TBalances.Find(aAcnt: TAccount; aSymbol: TSymbol): TBalance;
var
  I: Integer;
  aBal : TBalance;
begin
  Result := nil;

  for I := 0 to Count-1 do
  begin
    aBal  := GetBalance(i);
    if aBal <> nil then
      if (aBal.Account= aAcnt) and ( aBal.Symbol = aSymbol ) then
      begin
        Result := aBal;
        break;
      end;
  end;
end;

function TBalances.GetBalance(i: integer): TBalance;
begin
  if (i<0 ) or ( i>=Count) then
    Result := nil
  else
    Result := Items[i] as TBalance;
end;

function TBalances.New(aAcnt: TAccount; aSymbol: TSymbol): TBalance;
begin
  Result := Add as TBalance;
  Result.Account  := aAcnt;
  Result.Symbol   := aSymbol;

end;

end.
