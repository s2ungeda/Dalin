{ TAsset }

procedure TAsset.AddFill(aFillObj: TObject);
var
  aFill : TFill;
  dFillQty, dNewQty : double;
begin

  aFill := TFill( aFillObj );
  dNewQty := Balance + aFill.Volume * aFill.Side     ;

  if CheckZero( Balance ) then
    AvgPrice  := aFill.Price
  else if (Balance * dNewQty ) < 0 then
    AvgPrice  := aFill.Price
  else if CheckZero( dNewQty ) then
    AvgPrice  := 0
  else if abs( dNewQty ) > abs( Balance ) then
    AvgPrice  := ( AvgPrice * Balance + aFill.Price * (aFill.Price * aFill.Side )) / dNewQty;

  Balance := Max(0, dNewQty );

  if aFill.Side < 0 then
    Locked := Max( 0, Locked - aFill.Volume );
end;

constructor TAsset.Create(aColl: TCollection);
