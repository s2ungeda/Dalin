{ TAccount }
procedure TAccount.ApplyFill(aFillObj: TObject);
var
  aFill : TFill;
  aExApitype : TExchangeApiType;
begin
  if aFillObj = nil then Exit;
  aFill := aFillObj as TFill;

  case aFill.Symbol.Spec.Market of
    mtSpot:
      begin
        FTradeAmt[eaSpot] := FTradeAmt[eaSpot]  + ( aFill.Price * aFill.Volume );
        FFees[eaSpot] := FFees[eaSpot]  + aFill.Fee;
      end ;
    mtFutures:
      begin
        aExApitype  := aFill.Symbol.Spec.ExApiType;
        FTradeAmt[aExApitype] := FTradeAmt[aExApitype] + (ifThenFloat( aFill.Symbol.Spec.FutureType = ftCoin, 1/aFill.Price, aFill.Price)
          * abs(aFill.Volume) * aFill.Symbol.Spec.PointValue);
        FFees[aExApitype] := FFees[aExApitype]  + aFill.Fee;
      end;
  end;
end;

constructor TAccount.Create(aColl: TCollection);
var
  i : TSettleCurType;
  j: TExchangeApiType;
begin
  inherited create( aColl );

  for j := eaSpot to High(TExchangeApiType) do
