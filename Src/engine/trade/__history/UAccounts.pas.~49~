function TAccount.GetAvailable: double;
var
  uafo, im, dTotCoin, dSum : double;   // uniAvailableForOrder
  i : integer;
  aAss : TAsset;
begin
  Result := 0;
  if FAsset = nil then Exit;

  im :=App.Engine.TradeCore.Positions[FExchangeKind].GetTotInitMargin(Self);
  dTotCoin		:= App.Engine.TradeCore.Positions[FExchangeKind].GetOpenPL( Self );
  dSum        := 0;

  for I := 0 to FAssets.Count-1 do
  begin
    aAss  := FAssets.Assets[i];
    if aAss.FMarginAvailable then begin
      var dRate : double;
      dRate := min( aAss.AskRate, aAss.BidRate );
      if aAss.Currency = 'USDT' then
        dSum:= dSum + ((aAss.Balance + dTotCoin) * dRate )
      else
        dSum:= dSum + (aAss.Balance * dRate );
    end;
  end;

  if (ExchangeKind = ekBinance) and (FAccountType = amFuture) and (FMultiAssetsMode) then begin
    uafo   := dSum - (im * FAsset.AskRate);
    Result := CalcDiv(uafo, FAsset.AskRate);
  end else
    if FAsset <> nil then
      Result := FAsset.Balance + dTotCoin - im;
end;

function TAccount.GetBalance: double;
begin
  Result := 0;
  if FAsset = nil then Exit;

  if (ExchangeKind = ekBinance) and (FAccountType = amFuture) and (FMultiAssetsMode) then
    Result := GetEquity
  else
    if FAsset <> nil then
      Result := FAsset.Balance;
end;

function TAccount.GetEquity: double;
var
  I: Integer;
  aAss : TAsset;
begin
  Result := 0;

  for I := 0 to FAssets.Count-1 do
  begin
    aAss  := FAssets.Assets[i];
    if aAss.FMarginAvailable then begin
      var dRate : double;
      dRate := min( aAss.AskRate, aAss.BidRate );
      Result:= Result + (aAss.Balance * dRate );
    end;
  end;

  FEquity := Result;
end;

