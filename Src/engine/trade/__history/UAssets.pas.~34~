{ TAssetManager }

procedure TAssetManager.AcceptOrder(const ALocalNo, AOrderNo: string);
var
  Order: POrderReservation;
begin
  if not IsProcess then Exit;

  FLock.Enter;
  try
    if not FPendingOrders.TryGetValue(ALocalNo, Order) then begin
      App.Log(llError, 'AcceptOrder 실패: ALocalNo "%s"에 해당하는 주문 없음', [ALocalNo]);
      Exit;
    end;

    Order^.UUID := AOrderNo;
    // Dictionary의 Key를 Identifier에서 UUID로 바꿉니다.
    // ExtractPair는 딕셔너리에서 데이터를 제거하되, 객체(레코드 포인터)를 파괴하지 않고 반환합니다.
    FPendingOrders.ExtractPair(ALocalNo);
    FPendingOrders.Add(AOrderNo, Order);
  finally
    FLock.Leave;
  end;
end;

function TAssetManager.ReserveOrder(ASide: integer; const ACurrency, ALocalNo: string; APrice, AVolume: Double): boolean;
var
  NewOrder: POrderReservation;
  ReservedQty: Double;
  aAsset : TAsset;
  dStdFee: double;
begin
  Result := false;
  if not IsProcess then Exit;

  dStdFee :=  App.Engine.ApiConfig.GetStandardFee(TAccount(FAccount).ExchangeKind, eaSpot);

  FLock.Enter;
  try
    if ASide > 0 then
    begin
      aAsset  := TAccount(FAccount).Asset;
      if aAsset = nil then
      begin
        App.Log(llError, 'KRW 잔고 없음');
        Exit;
      end;

      ReservedQty := (APrice * AVolume) * (1 + dStdFee/100);
      if aAsset.Available < ReservedQty then
      begin
        App.Log(llError, 'KRW 잔고 부족: 필요 %m, 가용 %m', [ReservedQty, aAsset.Available]);
        Exit;
      end;
    end
    else
    begin
      ReservedQty := AVolume;
      aAsset  := Find(ACurrency);
      if aAsset = nil then
      begin
        App.Log(llError, '%s 잔고 없음');
        Exit;
      end;

      if aAsset.Available < ReservedQty then
      begin
        App.Log(llError, '%s 잔고 부족: 필요 %m, 가용 %m', [ACurrency, ReservedQty, aAsset.Available]);
        Exit;
      end;
    end;

    aAsset.UpdateAsset(-ReservedQty, ReservedQty);

    System.New(NewOrder);

    NewOrder^.Side := ASide;
    NewOrder^.Currency := ACurrency;
    NewOrder^.Price := APrice;
    NewOrder^.OriginalVolume := AVolume;
    NewOrder^.RemainingVolume := AVolume;
    NewOrder^.StandardFeeRate := dStdFee/100;
    NewOrder^.ReservedAmount := ReservedQty;
    NewOrder^.ReservedAt := now;

    FPendingOrders.Add(ALocalNo, NewOrder);

    Result := true;
  finally
    FLock.Leave;
  end;
end;


procedure TAssetManager.SyncAsset(aAsset: TAsset; AActualBalance, AActualLocked,
  AAvgPrice: double);
begin
  if aAsset = nil then Exit;
  aAsset.SyncAsset(AActualBalance, AActualLocked, AAvgPrice);
end;

procedure TAssetManager.ProcessCancel(const AOrderNo: string);
var
  Order: POrderReservation;
  Refund: double;
begin
  if not IsProcess then Exit;

  FLock.Enter;
  try
    if FPendingOrders.TryGetValue(AOrderNo, Order) then
    begin
      Refund := Order^.ReservedAmount;
      if Order^.Side > 0 then
      begin
        { 매수 취소: 잔여 예약금만큼 KRW 복원 }
        //Refund := (Order^.Price * Order^.RemainingVolume) * (1 + Order^.StandardFeeRate);
        UpdateAsset('KRW',Refund, -Refund);
      end  else
      begin
        { 매도 취소: 잔여 코인 수량만큼 코인 복원 }
        UpdateAsset(Order^.Currency, Refund, -Refund);
      end;
      FPendingOrders.Remove(AOrderNo);
      Dispose(Order);
    end;
  finally
    FLock.Leave;
  end;
end;

procedure TAssetManager.ProcessTrade(const AOrderNo: string; ATradePrice, ATradeVolume, APaidFee: Double;
  bDone:boolean);
var
  Order: POrderReservation;
  ReservedPart, ActualKRW, RefundKRW, ReFund: Double;
begin
  if not IsProcess then Exit;
  FLock.Enter;
  try
    if FPendingOrders.TryGetValue(AOrderNo, Order) then
    begin
      if Order^.Side > 0 then
      begin
        { [매수 체결 처리] }
        ReservedPart := (Order^.Price * ATradeVolume) * (1 + Order^.StandardFeeRate);
        Order^.ReservedAmount := Max(0, Order^.ReservedAmount - ReservedPart);

        ActualKRW := (ATradePrice * ATradeVolume) + APaidFee;
        RefundKRW := ReservedPart - ActualKRW;
        // 1. KRW 잠금: 예약 분 풀고, 차액(환불분)은 Balance로
        UpdateAsset('KRW',RefundKRW, -ReservedPart);
        // 2. 코인 획득: 체결된 수량만큼 코인 Balance 증가
        UpdateAsset(Order^.Currency, ATradeVolume, 0);
      end
      else
      begin
        { [매도 체결 처리] }
        // 1. 매도 예약금(ReservedAmount)은 '코인 수량' 자체임
        ReservedPart := ATradeVolume;
        // 2. 예약된 코인 수량 잔액에서 차감
        Order^.ReservedAmount := Max(0, Order^.ReservedAmount - ReservedPart);

        // 1. 코인 차감: 잠겨있는 코인 수량 차감
        UpdateAsset(Order^.Currency, 0, -ATradeVolume);
        // 2. KRW 획득: 매도 대금에서 수수료를 뺀 금액 Balance 증가
        ActualKRW := (ATradePrice * ATradeVolume) - APaidFee;
        UpdateAsset('KRW',ActualKRW, 0);
      end;

      Order^.RemainingVolume := Order^.RemainingVolume - ATradeVolume;
      if (Order^.RemainingVolume < EPSILON) or bDone then
      begin

        ReFund := Order^.ReservedAmount;
        if ReFund > EPSILON then
          if Order^.Side > 0 then
            UpdateAsset('KRW',Refund, -Refund)
          else
            UpdateAsset(Order^.Currency, Refund, -Refund);

        FPendingOrders.Remove(AOrderNo);
        Dispose(Order);
      end;
    end;
  finally
    FLock.Leave;
  end;
end;

procedure TAssetManager.UpdateAsset(const ACurrency: string; ADeltaBalance, ADeltaLocked: double);
var
  aAsset: TAsset;
begin
  if ACurrency = 'KRW' then
    aAsset := TAccount(FAccount).Asset
  else begin
    aAsset  := Find(ACurrency);
    if aAsset = nil then
      aAsset  := New(ACurrency, FAccount);
  end;

  if aAsset <> nil then
    aAsset.UpdateAsset(ADeltaBalance, ADeltaLocked);
end;

procedure TAssetManager.UpdateDone;
var
  i : integer;
begin
  for I := 0 to Count-1 do
    if (not GetAsset(i).Updated) and (not GetAsset(i).IsMain) then
      GetAsset(i).SyncAsset(0, 0, 0);
end;

procedure TAssetManager.UpdateReady;
var
  i : integer;
begin
  for I := 0 to Count-1 do
    GetAsset(i).Updated := false;
end;



constructor TAssetManager.Create;
begin
  inherited Create;

  FLock := TCriticalSection.Create;
  FAssets := TCollection.Create( TAsset );
  FPendingOrders := TDictionary<string, POrderReservation>.Create;

  Sorted := True;
end;

procedure TAssetManager.CleanupStuckOrders(AMaxSeconds: Integer);
var
  Order: POrderReservation;
  Key: string;
  StuckIds: TList<string>;
begin
  StuckIds := TList<string>.Create;
  try
    // [Step 1] 짧은 Lock: UUID가 없는 주문만 선별
    FLock.Enter;
    try
      for Key in FPendingOrders.Keys do
      begin
        Order := FPendingOrders[Key];
        // 1. UUID가 없고, 2. 설정한 시간을 초과한 주문만 스냅샷에 추가
        if (Order^.UUID = '') and
           (SecondsBetween(Now, Order^.ReservedAt) > AMaxSeconds) then
        begin
          StuckIds.Add(Key);
        end;
      end;
    finally
      FLock.Leave;
    end;
    //App.Engine.ApiManager.ExManagers[(FAccount as TAccount).ExchangeKind].re
    // [Step 2] Lock 밖에서 서버 API 호출 (비동기 처리)
    for Key in StuckIds do
    begin
      // 2026년 3월 빗썸/업비트 Identifier 통합 조회 로직 실행
      CheckServerStatusAndRecover(Key);
    end;
  finally
    StuckIds.Free;
  end;
end;

procedure TAssetManager.CheckServerStatusAndRecover(const AIdentifier: string);
var
  ServerUUID: string;
begin
  {
    1. 해당 거래소 어댑터를 통해 Identifier로 주문 상세 정보를 조회합니다.
       (3월 업데이트 후 빗썸 어댑터에 이 기능이 구현될 예정입니다.)
  }
  //ServerUUID := ExchangeAdapter.FetchUUIDByIdentifier(AIdentifier);

  if ServerUUID <> '' then
  begin
    // 케이스 A: 서버에 주문이 살아있음 -> UUID 매핑 및 정상 궤도 진입
//    ConfirmOrder(AIdentifier, ServerUUID);
    // 필요 시 추가로 주문 상세 상태(체결 여부)를 확인하여 ProcessTrade 호출
  end
  else
  begin
    {
      케이스 B: 서버에 주문이 없음
      네트워크 오류로 주문이 안 나갔거나, 이미 취소된 경우입니다.
      로컬에서 묶인 자산을 안전하게 롤백합니다.
    }
    ProcessCancel(AIdentifier);
  end;
end;

procedure TAssetManager.DeleteAsset(i: integer);
begin
  Delete(i);
end;

destructor TAssetManager.Destroy;
var
  Order: POrderReservation;
begin
  for Order in FPendingOrders.Values do
    Dispose(Order);
  FPendingOrders.Free;
  FAssets.Free;
  FLock.Free;
  inherited;
end;

procedure TAssetManager.DoLog;
var
  i : integer;
  aAsset : TAsset;
begin
  Exit;
  for I := 0 to Count-1 do
  begin
    aAsset  := GetAsset(i);
    if aAsset <> nil then
      App.DebugLog('%s : %s, %.4f, %.4f, %.4f', [ TAccount(aAsset.Account).Name,
        aAsset.Currency, aAsset.Balance, aAsset.Locked, aAsset.Available] );
  end;
end;

function TAssetManager.Find(sCurrency: string): TAsset;
begin
  Result := GetAsset(IndexOf(sCurrency));
end;

function TAssetManager.GetAsset(i: integer): TAsset;
begin
  if (i >= 0) and (i <= Count-1) then
    Result := TAsset(Objects[i])
  else
    Result := nil;
end;


function TAssetManager.GetTotalCoin: double;
var
  i : integer;
begin
  Result := 0;
  for I := 0 to Count-1 do
    if not GetAsset(i).IsMain then
      if GetAsset(i).Symbol <> nil then
        Result := Result + ( GetAsset(i).Balance * GetAsset(i).Symbol.Last );
end;

procedure TAssetManager.init;
var
  i : integer;
begin
  for I := 0 to Count-1 do
    GetAsset(i).init;
end;

function TAssetManager.IsProcess: boolean;
begin
  if FAccount = nil then Exit (false);

  if TAccount(FAccount).ExchangeKind = ekBinance then
    Result := false
  else
    Result := true;
end;

procedure TAssetManager.LoadOrder(ASide: integer; const ACurrency,
  AOrderNo: string; APrice, AVolume, ALocked: Double);
var
  NewOrder: POrderReservation;
  ReservedQty: Double;
begin
  if not IsProcess then Exit;

  FLock.Enter;
  try
    System.New(NewOrder);

    NewOrder^.Side := ASide;
    NewOrder^.Currency := ACurrency;
    NewOrder^.Price := APrice;
    NewOrder^.OriginalVolume := AVolume;
    NewOrder^.RemainingVolume := AVolume;
    NewOrder^.StandardFeeRate :=
      App.Engine.ApiConfig.GetStandardFee(TAccount(FAccount).ExchangeKind, eaSpot) / 100;
    NewOrder^.ReservedAmount := ALocked;
    FPendingOrders.Add(AOrderNo, NewOrder);

  finally
    FLock.Leave;
  end;

end;

function TAssetManager.New(sCurrency: string; aAcnt : TObject): TAsset;
//var
//  sCode : string;
begin

  if sCurrency = 'USDC' then
    sCurrency := 'USDC';

  Result := FAssets.Add as TAsset;
  Result.Currency := sCurrency;
  Result.Account  := aAcnt;

  if (TAccount(aAcnt).ExchangeKind = ekBinance) then
    Result.Symbol := App.Engine.SymbolCore.BaseSymbols.FindSymbol(sCurrency, ekBinance,
      TExchangeApiType(integer(TAccount(aAcnt).AccountType)-1) )
  else
    Result.Symbol := App.Engine.SymbolCore.FindSymbol(TAccount(aAcnt).ExchangeKind,
      sCurrency );

  AddObject(sCurrency, Result);
end;

