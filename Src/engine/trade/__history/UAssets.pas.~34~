    procedure   SyncAsset(ADeltaBalance, ADeltaLocked, AAvgPrice: Double);
    function    Represet : string ;

    property OpenAmt  : double read GetOpenAmt;
    property MarginAvailable : boolean read FMarginAvailable write FMarginAvailable;
  end;

  TAssetManager  = class(TStringList)
  private
    FLock: TCriticalSection;
    FAssets : TCollection;
    FPendingOrders: TDictionary<string, POrderReservation>;

    FAccount: TObject;
    function GetAsset(i: integer): TAsset;
    function IsProcess : boolean;
    procedure UpdateAsset(const ACurrency: string; ADeltaBalance,
      ADeltaLocked: double);
    procedure CheckServerStatusAndRecover(const AIdentifier: string);


  public
    constructor Create;
    destructor  Destroy; override;

    function Find(sCurrency : string ) : TAsset;
    function New( sCurrency : string; aAcnt : TObject ) : TAsset;

    procedure DeleteAsset( i : integer );
    function  GetTotalCoin : double;
    procedure init;
    procedure DoLog;
    procedure UpdateReady;
    procedure UpdateDone;

    procedure AcceptOrder(const ALocalNo, AOrderNo: string);
    procedure CleanupStuckOrders(AMaxSeconds: Integer);
    // only recovery active order
    procedure LoadOrder(ASide: integer; const ACurrency, AOrderNo: string;
      APrice, AVolume, ALocked: Double);

    function ReserveOrder(ASide: integer; const ACurrency, ALocalNo: string;
      APrice, AVolume: Double): boolean;

    procedure SyncAsset(aAsset: TAsset; AActualBalance, AActualLocked, AAvgPrice: double);

    procedure ProcessCancel(const AOrderNo: string);
    procedure ProcessTrade(const AOrderNo: string; ATradePrice, ATradeVolume,
