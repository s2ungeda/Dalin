constructor TAsset.Create(aColl: TCollection);
begin
  inherited Create( aColl );

  FLock   := TCriticalSection.Create;

  IsMain  := false;
  Symbol  := nil;
  Account := nil;

  init;

  Fess  := 0;
  MainMargin  := 0;
  QueryedAvailable  := 0;

  FMarginAvailable  := false;
end;

destructor TAsset.Destroy;
begin
  FLock.Free;
  inherited;
end;

function TAsset.GetOpenAmt: double;
begin
  if Symbol = nil then
    Result := 0 //Balance
  else
    if Symbol.Spec.FutureType = ftCoin then
      Result := Balance * CalcDiv(1,Symbol.Last) * Symbol.Spec.PointValue
    else
      Result := Balance * Symbol.Last;
end;

