end;

function TAsset.Represet: string;
begin
  Result := Format('%s : %.8n = %.8n + %.8n', [Currency, Balance, LocKed, Available ]);
end;


procedure TAsset.SyncAsset(ADeltaBalance, ADeltaLocked, AAvgPrice: Double);
begin
  //if App.AppStatus > asLoad then Exit;
  FLock.Enter;
  try
    Available  := ADeltaBalance;
    Locked     := ADeltaLocked;
    Balance    := ADeltaBalance + Locked;
    AvgPrice   := AAvgPrice;
    Updated    := true;
  finally

    var s : string;

    case TAccount(Account).ExchangeKind of
      ekBinance: ;
      ekUpbit :  s := 'upbit_assets';
      ekBithumb: s := 'bithumb_myAsset';
    end;

    App.Log(llDebug, s, '%s     B:%s, L:%s', [Currency,
      DoubleToStr(Balance), DoubleToStr(LocKed)]);
    FLock.Release;
  end;
end;


procedure TAsset.UpdateAsset(ADeltaBalance, ADeltaLocked: Double);
begin
  FLock.Enter;
  try
    Available  := Max(0, Available + ADeltaBalance);
    Locked     := Max(0, Locked + ADeltaLocked);
    Balance    := Available + Locked;
  finally
    var s : string;

    case TAccount(Account).ExchangeKind of
      ekBinance: ;
      ekUpbit :  s := 'upbit_assets';
      ekBithumb: s := 'bithumb_myAsset';
    end;

    App.Log(llDebug, s, '%s +++ B:%s, L:%s', [Currency,
      DoubleToStr(Balance), DoubleToStr(LocKed)]);
    FLock.Release;
  end;
end;

