function CheckZero( dVal : double ) : boolean;
begin
	Result := IsZero(dVal, 1E-9);
end;


function FloorEx(const X: Double): int64;
begin
  Result := int64(Trunc(X));
  if Frac(X) < 0 then
    Dec(Result);
end;

function CalcDiv( const Numerator, Denominator : double; Default : double ) : double;
begin
  if IsZero(Denominator) then
    Result := Default
  else
    REsult := Numerator / Denominator;
end;

function StrToDouble( const s : string ) : double;
var
  b : TBigInt;
begin
  if s = '' then Result := 0
  else begin
    b.convert(s);
    result := b.ToDouble;
  end;
end;

function DoubleToStr( const d : double; bComma:boolean ) : string;
var
  b : TBigInt;
begin
  if IsZero(d) then Result := '0'
  else begin
    b.convert(d);
    if bComma then
      result := format('%.*n', [ b.Precision, d])
    else
      result := format('%.*f', [ b.Precision, d]);
  end;
end;


function DoubleToStr( const d : double; iPrecision: integer ) : string;
begin
  result := format('%.*n', [ iPrecision, d]);
end;

function DblToStrEx( const d : double; iPrecision: integer): string;
var
  b : TBigInt;
begin
  if IsZero(d) then Result := '0'
  else begin
    b.convert(d);
    if b.Precision > iPrecision then
      result := format('%.*n', [ iPrecision, d])
    else
      result := format('%.*n', [ b.Precision, d])
  end;

end;

function CmpVal( const A, B : double ) : integer;
begin
  case CompareValue(A,B, 1E-9) of
    LessThanValue    : Result := -1;
    EqualsValue      : Result := 0;
    GreaterThanValue : Result := 1;
  end;
end;

function TruncDecimal(dValue : double; const n : integer) : double;
var
  f : double;
begin
  f := power(10, n);
  Result := Trunc(dValue * f) / f;
end;

function TruncDecimalToStr(dValue : double; const n : integer) : string;
begin
  Result := Format('%.*f',[n, TruncDecimal(dValue, n)]);
end;

function _Ceil(const X: double): int64;
begin
  Result := Trunc(X);
  if Frac(X) > 0 then
    Inc(Result);
end;

function CeilDecimal(dValue : double; const n : integer) : double;
var
  f : Extended;
begin
  f := power(10, n);
  Result := _Ceil(dValue * f) / f;
end;

function CeilDecimalToStr(dValue : double; const n : integer) : string;
begin
  Result := Format('%.*f',[n, CeilDecimal(dValue, n)]);
end;

function ScaleFactor(iPre: integer): integer;
begin
  Result := Round(power(10, iPre));
end;

function EncodePath(sRrsc, sPoint, sTime : string): string;
var
	sValue : string;
begin

  sValue := TURLEncoding.URL.Encode( UTF8Encode(sPoint) );

//	sValue := HTTPEncode(UTF8Encode(sPoint));
  sValue := StringReplace(sValue, '+', '%20', [rfReplaceAll]);
  sValue := StringReplace(sValue, '%21', '!', [rfReplaceAll]);
  sValue := StringReplace(sValue, '%27', '''', [rfReplaceAll]);
  sValue := StringReplace(sValue, '%28', '(', [rfReplaceAll]);
  sValue := StringReplace(sValue, '%29', ')', [rfReplaceAll]);
  sValue := StringReplace(sValue, '%26', '&', [rfReplaceAll]);
  sValue := StringReplace(sValue, '%3D', '=', [rfReplaceAll]);
  sValue := StringReplace(sValue, '%7E', '~', [rfReplaceAll]);

  Result := sRrsc + chr(0) + sValue +  chr(0 ) + sTime;
end;


