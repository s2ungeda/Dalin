procedure PlaySound(const s: string);
var ms: TMemoryStream;
begin
  if s.IsEmpty then Exit;

  ms := TMemoryStream.Create;
  try
    ms.LoadFromFile(s);
    ms.Position := 0;
    sndPlaySound(ms.Memory, (SND_ASYNC or SND_MEMORY))
  finally
    ms.Free
  end
end;

