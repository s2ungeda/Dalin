function UnixTimeToDateTime( UnixTime : int64; len : integer ) : TDateTime;
var
  dtTime : TDateTime;
  sTmp   : string;
  iDiv : Integer;
begin
// 1645961186247
  iDiv := 1;
	if len = 16 then
		iDiv := 1000000
  else if len = 13 then
  	iDiv := 1000
  else if len = 10 then
		iDiv := 1;

  dtTime:= UnixToDateTime(UnixTime div iDiv , false);
  sTmp 	:= Format( '%s.%03d', [ FormatDateTime('yyyy-mm-dd hh:nn:ss', dtTime ),  UnixTime mod iDiv ]);
  Result:= EncodeDate(  StrToInt(copy(sTmp, 1, 4 ) ) , StrToInt( copy(sTmp, 6, 2 )) , StrToInt( copy(sTmp, 9,2)) )
          + EnCodeTime(StrToInt(copy(sTmp, 12,2))
                    ,StrToInt(copy(sTmp, 15,2))
                    ,StrToInt(copy(sTmp, 18,2))
                    ,StrToInt(copy(sTmp, 21,3)) )  ;
end;

function UnixTimeToDateTime(sTime:string) : TDateTime;
var
  iTime: int64;
  iDiv  : integer;
begin
  if not TryStrToInt64(sTime, iTime) then
    Exit (0);

  case sTime.Length of
    13 : iDiv := 1000;
    16 : iDiv := 1000000;
    else iDiv := 1;
  end;

  var dtTime:= UnixToDateTime(iTime div iDiv , false);
  var sTmp 	:= Format( '%s.%03d', [ FormatDateTime('yyyy-mm-dd hh:nn:ss', dtTime ),  iTime mod iDiv ]);
  Result:= EncodeDate(  StrToInt(copy(sTmp, 1, 4 ) ) , StrToInt( copy(sTmp, 6, 2 )) , StrToInt( copy(sTmp, 9,2)) )
          + EnCodeTime(StrToInt(copy(sTmp, 12,2))
                    ,StrToInt(copy(sTmp, 15,2))
                    ,StrToInt(copy(sTmp, 18,2))
                    ,StrToInt(copy(sTmp, 21,3)) )  ;

end;


