{------------------------------------------------------------------------------
  [OPTIMIZED] StrToDouble - TBigInt 대신 TryStrToFloat 사용

  *** BEFORE ***
  var b: TBigInt;
  begin
    b.convert(s);
    result := b.ToDouble;
  end;

  *** AFTER ***
  - TBigInt 제거
  - 콤마 있을 때만 제거
  - TryStrToFloat 사용 (예외 없음)
------------------------------------------------------------------------------}
function StrToDouble( const s : string ) : double;
var
  sTemp: string;
  i: Integer;
  HasComma: Boolean;
begin
  if s = '' then
    Exit(0);

  // 콤마 체크 (있을 때만 제거)
  HasComma := False;
  for i := 1 to Length(s) do
    if s[i] = ',' then
    begin
      HasComma := True;
      Break;
    end;

  if HasComma then
    sTemp := StringReplace(s, ',', '', [rfReplaceAll])
  else
    sTemp := s;

  if not TryStrToFloat(sTemp, Result) then
    Result := 0;
end;

// [OPTIMIZED] TBigInt 대신 인라인 계산 사용
// - TBigInt.convert()는 문자열 필드(OrgVal, Jungsu, Sosu)를 할당하므로
// - Precision만 필요한 이 함수에서는 인라인이 더 효율적
function DoubleToStr( const d : double; bComma:boolean ) : string;
var
  Precision: Integer;
  FracPart: Double;
  FracInt: Int64;
begin
  if IsZero(d) then
    Exit('0');

  // 소수부 추출
  FracPart := Frac(Abs(d));

  if IsZero(FracPart) then
    Precision := 0
  else
  begin
    // 소수점 정밀도 계산 (최대 8자리)
    FracInt := Round(FracPart * 100000000);  // 8자리로 확장

    // trailing zero 제거
    Precision := 8;
    while (Precision > 0) and (FracInt mod 10 = 0) do
    begin
      Dec(Precision);
      FracInt := FracInt div 10;
    end;
  end;

  // 단일 Format 호출
  if bComma then
    Result := Format('%.*n', [Precision, d])
  else
    Result := Format('%.*f', [Precision, d]);
end;


function DoubleToStr( const d : double; iPrecision: integer ) : string;
begin
  result := format('%.*n', [ iPrecision, d]);
end;

{------------------------------------------------------------------------------
  [OPTIMIZED] DblToStrEx - 실제 정밀도와 요청 정밀도 중 작은 값 사용

  *** BEFORE ***
  var b: TBigInt;
  begin
    b.convert(d);  // 문자열 할당 오버헤드
    if b.Precision > iPrecision then
      result := format('%.*n', [iPrecision, d])
    else
      result := format('%.*n', [b.Precision, d])
  end;

  *** AFTER ***
  - TBigInt 제거, 인라인 계산
  - 문자열 할당 없음
------------------------------------------------------------------------------}
function DblToStrEx( const d : double; iPrecision: integer): string;
var
  ActualPrecision: Integer;
  FracPart: Double;
  FracInt: Int64;
begin
  if IsZero(d) then
    Exit('0');

  // 실제 정밀도 계산
  FracPart := Frac(Abs(d));

  if IsZero(FracPart) then
    ActualPrecision := 0
  else
  begin
    FracInt := Round(FracPart * 100000000);
    ActualPrecision := 8;
    while (ActualPrecision > 0) and (FracInt mod 10 = 0) do
    begin
      Dec(ActualPrecision);
      FracInt := FracInt div 10;
    end;
  end;

  // 실제 정밀도와 요청 정밀도 중 작은 값 사용
  if ActualPrecision > iPrecision then
    Result := Format('%.*n', [iPrecision, d])
  else
    Result := Format('%.*n', [ActualPrecision, d]);
end;

function CmpVal( const A, B : double ) : integer;
begin
  case CompareValue(A,B, 1E-9) of
    LessThanValue    : Result := -1;
    EqualsValue      : Result := 0;
    GreaterThanValue : Result := 1;
  end;
end;

{------------------------------------------------------------------------------
  [OPTIMIZED] TruncDecimal, CeilDecimal, ScaleFactor - Power 제거

  *** BEFORE ***
  f := power(10, n);
  Result := Trunc(dValue * f) / f;

  *** AFTER ***
  - Power 함수 대신 룩업 테이블 사용
  - 0~8 범위에서 즉시 반환
------------------------------------------------------------------------------}
const
  SCALE_FACTORS: array[0..8] of Int64 = (
    1, 10, 100, 1000, 10000, 100000, 1000000, 10000000, 100000000
  );

function ScaleFactor(iPre: integer): integer;
begin
  if (iPre >= 0) and (iPre <= 8) then
    Result := SCALE_FACTORS[iPre]
  else
    Result := Round(IntPower(10, iPre));
end;

function TruncDecimal(dValue: double; const n: integer): double;
var
  f: Int64;
begin
  if (n >= 0) and (n <= 8) then
    f := SCALE_FACTORS[n]
  else
    f := Round(IntPower(10, n));
  Result := Trunc(dValue * f) / f;
end;

function TruncDecimalToStr(dValue: double; const n: integer): string;
begin
  Result := Format('%.*f', [n, TruncDecimal(dValue, n)]);
end;

function _Ceil(const X: double): Int64; inline;
begin
  Result := Trunc(X);
  if Frac(X) > 0 then
    Inc(Result);
end;

function CeilDecimal(dValue: double; const n: integer): double;
var
  f: Int64;
begin
  if (n >= 0) and (n <= 8) then
    f := SCALE_FACTORS[n]
  else
    f := Round(IntPower(10, n));
  Result := _Ceil(dValue * f) / f;
end;

function CeilDecimalToStr(dValue: double; const n: integer): string;
begin
  Result := Format('%.*f', [n, CeilDecimal(dValue, n)]);
end;

function CalcOrderQty(dQty, dUnit: Double; var dRemainder: Double): Double;
var
  nQty, nUnit: Int64;
  nOrderQty: Int64;
begin
  nQty  := Round(dQty * SCALE);
  nUnit := Round(dUnit * SCALE);
  nOrderQty  := (nQty div nUnit) * nUnit;

  // dUnit 보다 작으면 전량 누적
  if nOrderQty < nUnit then
  begin
    dRemainder := dQty;
    Result := 0;
    Exit;
  end;

  dRemainder := (nQty - nOrderQty) / SCALE;
  Result := nOrderQty / SCALE;
end;

{------------------------------------------------------------------------------
  [OPTIMIZED] EncodePath - StringReplace 횟수 감소

  *** BEFORE ***
  sValue := StringReplace(sValue, '+', '%20', [rfReplaceAll]);
  sValue := StringReplace(sValue, '%21', '!', [rfReplaceAll]);
  ... (8회 StringReplace)

  *** AFTER ***
  - TStringBuilder 사용하여 단일 패스로 처리
  - 메모리 재할당 최소화
------------------------------------------------------------------------------}
function EncodePath(sRrsc, sPoint, sTime: string): string;
var
  sValue: string;
  sb: TStringBuilder;
  i, Len: Integer;
  c: Char;
  s3: string;
begin
  sValue := TURLEncoding.URL.Encode(UTF8Encode(sPoint));
  Len := Length(sValue);

  if Len = 0 then
    Exit(sRrsc + #0 + #0 + sTime);

  sb := TStringBuilder.Create(Len);
  try
    i := 1;
    while i <= Len do
    begin
      c := sValue[i];
      if c = '+' then
        sb.Append('%20')
      else if (c = '%') and (i + 2 <= Len) then
      begin
        s3 := Copy(sValue, i, 3);
        if s3 = '%21' then begin sb.Append('!'); Inc(i, 2); end
        else if s3 = '%27' then begin sb.Append(''''); Inc(i, 2); end
        else if s3 = '%28' then begin sb.Append('('); Inc(i, 2); end
        else if s3 = '%29' then begin sb.Append(')'); Inc(i, 2); end
        else if s3 = '%26' then begin sb.Append('&'); Inc(i, 2); end
        else if s3 = '%3D' then begin sb.Append('='); Inc(i, 2); end
        else if s3 = '%7E' then begin sb.Append('~'); Inc(i, 2); end
        else sb.Append(c);
      end
      else
        sb.Append(c);
      Inc(i);
    end;
    Result := sRrsc + #0 + sb.ToString + #0 + sTime;
  finally
    sb.Free;
  end;
end;


function ShowMessageEx(const Msg : String): Integer;
begin
  with CreateMessageDialog( Msg, mtCustom, [mbOK]) do
  try
    Position := poOwnerFormCenter;
    Result := ShowModal;
  finally
    Free;
  end;
end;

function ShowMessageEx(aForm: TForm; const Msg: string): boolean;
var aDlg: TForm;
begin

  aDlg := CreateMessageDialog(Msg, mtConfirmation, [mbYes , mbCancel]);
  try
    if aForm <> nil then
      aDlg.Position := aForm.Position;// poOwnerFormCenter;
    Result := aDlg.ShowModal = mrYes;
  finally
    aDlg.Free;
  end;
end;

procedure PlaySound(const s: string);
var ms: TMemoryStream;
begin
  if s.IsEmpty then Exit;

  ms := TMemoryStream.Create;
  try
    ms.LoadFromFile(s);
    ms.Position := 0;
    sndPlaySound(ms.Memory, (SND_ASYNC or SND_MEMORY))
  finally
    ms.Free
  end
end;

