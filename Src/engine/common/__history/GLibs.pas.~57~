{------------------------------------------------------------------------------
  [OPTIMIZED] UnixTimeToDateTime - 문자열 변환 제거

  *** BEFORE ***
  dtTime := UnixToDateTime(UnixTime div iDiv, false);
  sTmp := Format('%s.%03d', [FormatDateTime(...), UnixTime mod iDiv]);
  Result := EncodeDate(StrToInt(copy(...))) + EncodeTime(StrToInt(copy(...)));

  *** AFTER ***
  - Format, FormatDateTime, Copy, StrToInt 모두 제거
  - 직접 밀리초 계산
------------------------------------------------------------------------------}
function UnixTimeToDateTime( UnixTime : int64; len : integer ) : TDateTime;
var
  iDiv, iMs: Integer;
begin
  // 길이에 따른 나누기 값
  case len of
    16: iDiv := 1000000;
    13: iDiv := 1000;
  else
    iDiv := 1;
  end;

  // 기본 DateTime 변환
  Result := UnixToDateTime(UnixTime div iDiv, false);

  // 밀리초 추가 (13자리, 16자리인 경우)
  if iDiv > 1 then
  begin
    iMs := (UnixTime mod iDiv) mod 1000;  // 밀리초만 추출
    Result := Result + (iMs / MSecsPerDay);
  end;
end;

function UnixTimeToDateTime(sTime: string): TDateTime;
var
  iTime: Int64;
  iDiv, iMs: Integer;
begin
  if not TryStrToInt64(sTime, iTime) then
    Exit(0);

  case Length(sTime) of
    13: iDiv := 1000;
    16: iDiv := 1000000;
  else
    iDiv := 1;
  end;

  Result := UnixToDateTime(iTime div iDiv, false);

  if iDiv > 1 then
  begin
    iMs := (iTime mod iDiv) mod 1000;
    Result := Result + (iMs / MSecsPerDay);
  end;
end;


{
// itype = 0 : "2022-03-25T20:00:00"  no millisecond
// itype = 1 : "11:22:33"
}
function GetStrToTime(sTime : string; iType: integer) : TDateTime;
begin

  if sTime.IsEmpty then begin
    Result := 0; Exit; end;

  if iType = 0 then begin
  //  "2022-03-25T20:00:00"
  REsult := EncodeDate(  StrToInt(copy(sTime, 1, 4 ) ) , StrToInt( copy(sTime, 6, 2 )) , StrToInt( copy(sTime, 9,2)) )
          + EnCodeTime(StrToInt(copy(sTime, 12,2))
                    ,StrToInt(copy(sTime, 15,2))
                    ,StrToInt(copy(sTime, 18,2))
                    ,0 )  ;
  end else
  if iType = 1 then
  begin
  //  "20:00:00"
  REsult := Date + EnCodeTime(StrToInt(copy(sTime, 1,2))
                    ,StrToInt(copy(sTime, 4,2))
                    ,StrToInt(copy(sTime, 7,2))
                    ,0 )  ;
  end;
end;


