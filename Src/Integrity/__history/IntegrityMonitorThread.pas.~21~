// IntegrityMonitorThread.pas
unit IntegrityMonitorThread;

interface

uses
  System.Classes, SyncObjs;

/// 주기적으로 파일 무결성 검사와 디버거 탐지를 수행하는 백그라운드 스레드
type
  TIntegrityMonitorThread = class(TThread)
  private
    FTerminateEvent: TEvent;
    FOnTerminateEvent: TGetStrProc;
    FDoWork: boolean;
    FOwner : TObject;
//    function FridaDetectEnhanced(var s: string) : boolean;
  protected
    procedure Execute; override;
    procedure TerminatedSet; override;
  public
    constructor Create(aOwner: TObject);
    destructor  Destroy; override;

    property OnTerminateEvent : TGetStrProc read FOnTerminateEvent write FOnTerminateEvent;
  end;

implementation

uses
  GApp, UTypes,
  Winapi.Windows,
  System.SysUtils,
  Vcl.Forms,
  AntiDebugUtils
  ;

const
  IntervalMs = 1000; // 60초 * ;

constructor TIntegrityMonitorThread.Create(aOwner: TObject);
begin
  inherited Create(true);

  FTerminateEvent := TEvent.Create(nil, True, False, '');
  FreeOnTerminate := False;
  Priority := tpLowest;

  FOwner  := aOwner;
  FDoWork := true;

  Resume;
end;

destructor TIntegrityMonitorThread.Destroy;
begin
  FTerminateEvent.Free;
  inherited;

end;

procedure TIntegrityMonitorThread.Execute;
var
  i, Slices: Integer;
  s: string;
  WaitResult: TWaitResult;
begin
  while not Terminated do
  begin

    if FTerminateEvent.WaitFor(0) = wrSignaled then
      Break;

//{$IFDEF RELEASE}
    // 2) 디버거 탐지
    if FDoWork and IsBeingDebugged(s) then
    begin

      FDoWork := false;

      if FOwner <> nil then begin
        if Assigned(FOnTerminateEvent) then
          FOnTerminateEvent(s);
        PostMessage( (FOwner as TForm).Handle, WM_DETECTEDDEBUGER, 0, 0 );
      end;

    end;
//{$ENDIF}

    WaitResult := FTerminateEvent.WaitFor(IntervalMs);
    if WaitResult = wrSignaled then
      Break;

  end;
end;

procedure TIntegrityMonitorThread.TerminatedSet;
begin
  FTerminateEvent.SetEvent;
end;

end.

