function WaitForWindowClose(TargetHwnd: HWND; TimeoutMS: Integer): Boolean;
var
  Elapsed: Integer;
begin
  Elapsed := 0;
  while (Elapsed < TimeoutMS) and IsWindow(TargetHwnd) do
  begin
    Sleep(100); // 1000ms 단위 체크
    Inc(Elapsed, 100);
  end;
  Result := not IsWindow(TargetHwnd); // True = 닫힘
end;

