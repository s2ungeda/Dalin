procedure TFrmMKPUpdater.AddFile(aFile: TUpdateFile);
begin
  DownList.AddObject(aFile.name, aFile);
//    Format('%s/updates/files/%s/%s', [aFile.path, aFile.name]), aFile

end;

procedure TFrmMKPUpdater.DeleteFiles;
var
  I: Integer;
  Files : TStringDynArray;
begin

  DoLog('Delete Down File');

  Files := TDirectory.GetFiles(FAppDir+'DownTemp');

  for I := 0 to Length(Files)-1 do
    try
      if FileExists(Files[i]) then
        TFile.Delete(Files[i])
    except
      on e: exception do
        DoLog(Format('파일삭제 실패 : %s (%s)', [Files[i], e.Message]) );
    end;
end;

procedure TFrmMKPUpdater.DoLog(sLog: string);
begin
  log.Lines.Insert(0, sLog);
end;

procedure TFrmMKPUpdater.DoPopup(s: string);
begin
  log.Lines.Insert(0, s);
  Exit;
  ShowMessage(s);
end;

procedure TFrmMKPUpdater.DownLoadFilesSelf;
var
  I: Integer;
  aFile, bFile: TUpdateFile;
  bOK : boolean;
  s: string;
begin

  bOK:= false;

  try
    try
      for I := 0 to DownList.Count-1 do
      begin
        aFile := TUpdateFile(DownList.Objects[i]);
        if aFile.name = 'updater.exe' then
        begin
          if DownloadUpdateFile(
            FUrl+Format('/updates/files%s%s',[aFile.path, aFile.name]),
            Format('%s\%s',[FAppDir, aFile.name])) then
            begin
              DoPopup('updater.exe 다운 완료');
              // 다운받은 파일 버전 업데이트.
              UpdateLocalFileVersion(aFile);
              bOK := true;
            end;
          break;
        end else
          continue;
      end;

    except on e: Exception do
    begin
      DoLog('Self 업데이트 도중 에러 발생 : ' + e.Message);
      Exit;
    end;
    end;

  finally
    if bOK then
      PostMessage(Handle, WM_DOWNCOMPLETEDSELF, 0, 0)
    else begin
      ShowMessage('업데이트 도중 에러 발생 : ' + s);
      show;
    end;
  end;
end;

procedure TFrmMKPUpdater.DownLoadFiles;
var
  I: Integer;
  aFile, bFile: TUpdateFile;
  bOK : boolean;
  sDir, s: string;
begin

  bOK:= false;
  sDir := FAppDir + 'DownTemp';
  if not DirectoryExists(sDir) then CreateDir(sDir);

  DoLog('Start Download');

  try
    try
      for I := 0 to DownList.Count-1 do
      begin
        aFile := TUpdateFile(DownList.Objects[i]);
        Label1.Caption  :=  aFile.name;
        if DownloadUpdateFile(
          FUrl+Format('/updates/files%s%s',[aFile.path, aFile.name]),
          Format('%s\%s',[sDir, aFile.name])) then
          begin
          // 다운받은 파일 버전 업데이트.
            UpdateLocalFileVersion(aFile);
            DoLog(aFile.name + ' Download');
          end;
      end;
      bOK := true;
      DoLog('End Download');
    except
      if aFile <> nil then
        s := aFile.name;
      Exit;
    end;

  finally
    if bOK then
      PostMessage(Handle, WM_DOWNCOMPLETED, 0, 0)
    else
      ShowMessage('업데이트 도중 에러 발생 : ' + s);
  end;
end;

function TFrmMKPUpdater.DownloadUpdateFile(FileURL, SavePath: string): boolean;
var
  IdHTTP: TIdHTTP;
  FileStream: TFileStream;
begin

  Result := false;
  FileStream := TFileStream.Create(SavePath, fmCreate);
  try
    try
      http.Get(FileURL, FileStream);
      Result := true;
    except
      on E: Exception do
        ShowMessage('업데이트 파일 다운로드 중 오류 발생: ' + E.Message);
    end;
  finally
    FileStream.Free;
  end;
end;

procedure TFrmMKPUpdater.ExecuteDalin;
begin
  ShellExecute(0{Application.Handle}, nil, PChar(ExtractFilePath(Application.ExeName)+'\Dalin.exe'),
    'execute', nil, SW_SHOW);
  Application.Terminate;
end;

procedure TFrmMKPUpdater.ExecuteUpdater;
begin

  DoPopup('다시 updater.exe 실행');

  ShellExecute(0{Application.Handle}, nil, PChar(ExtractFilePath(Application.ExeName)+'\updater.exe'),
    'execute', nil, SW_SHOW);
  Application.Terminate;
end;

procedure TFrmMKPUpdater.FormClose(Sender: TObject; var Action: TCloseAction);
begin
  Action := caFree;
end;

procedure TFrmMKPUpdater.FormCreate(Sender: TObject);
var
  sName: string;
begin
  SelfUpdate  := false;

  FAppDir := ExtractFilePath(paramStr(0)) ;

  if not ReadConfig then
  begin
    ShowMessage('설정파일을 읽을수 없습니다.');
    Exit;
  end;

  if ParamCount > 0 then begin
    SelfUpdate := true;
  end else
  begin
    sName := FAppDir + 'Tmp' + ExtractFileName(Application.ExeName);
    if FileExists(sName) then
      TFile.Delete(sName);
  end;

  FUrl    := 'https://www.moonkomp.com';
  LocalFiles := TCollection.Create(TUpdateFile);
  RemoteFiles:= TCollection.Create(TUpdateFile);
  DownList   := TStringList.Create;
  // 1. 내가 가지고 있는 파일 버전을 읽는다.
  ReadMyVersion;

  ReadRemoteVersion;

  CompareVersion;

  if DownList.Count <= 0 then
    ExecuteDalin
  else  begin

    if SelfUpdate then
    begin
      // update 만 업데이트 할때.
      DoPopup( Application.ExeName + ' self update');
      selfTimer.Enabled := true;
      Exit;
    end else
      if CheckSelfUpdate then
        Exit;

    if not HaveCloseWindows then
    begin
      PostMessage(Handle, WM_CLOSE, 0, 0);
      Exit;
    end;

    if MessageDlg('새로운 버전의 파일을 업데이트 하시겠습니까?', mtInformation, [mbYes, mbNo], 0) = mrYes then
    begin
      upTimer.Enabled := true;
      Show;
    end else
      ExecuteDalin;
  end;
end;

procedure TFrmMKPUpdater.FormDestroy(Sender: TObject);
begin
  DownList.Free;
  LocalFiles.Free;
  RemoteFiles.Free;
end;


procedure TFrmMKPUpdater.Button1Click(Sender: TObject);
begin
  close;
end;

function TFrmMKPUpdater.HaveCloseWindows: boolean;
var
  I, j, iCnt: Integer;
  aFile: TUpdateFile;
  srcFile: string;
  aH : THandle;

begin
  Result := True;

  try
    iCnt := 0;
    for I := 0 to DownList.Count-1 do
    begin
      aFile:= TUpdateFile(DownList.Objects[i]);
      aH    := 0;

      for j := 0 to High(PrcsInfo) do
        if Uppercase(PrcsInfo[j].AppName) = Uppercase(afile.name) then
        begin
          aH := FindWindow(PChar(PrcsInfo[j].ClassName), nil);
          if aH > 0 then
          begin
            inc(iCnt);
            srcFile := srcFile + sLineBreak + PrcsInfo[j].AppName;
          end;
        end;
    end;

    if iCnt > 0 then
    begin
      ShowMessage('아래 프로그램을 닫고 다시 실행해 주세요' + sLineBreak + srcFile);
      Result := false;
      Exit;
    end;

  finally
  end;
end;

function TFrmMKPUpdater.CheckSelfUpdate: boolean;
var
  i: integer;
  sMine, sTmp : string;
  aFile : TUpdateFile ;
begin
  Result := false;
  sMine := ExtractFileName(Application.ExeName);

  for I := 0 to DownList.Count-1 do
  begin
    aFile := TUpdateFile(DownList.Objects[i]);
    if aFile.name = sMine then
    begin
      Result := true;
      break;
    end;
  end;

  if Result then
  begin
    sTmp := ExtractFilePath(ParamStr(0)) + 'Tmp'+sMine;
    CopyFile(PChar(ParamStr(0)), PChar(sTmp), False);
    ShellExecute(0, 'open', PChar(sTmp), '/selfupdate', PChar(ExtractFilePath(sTmp)), SW_SHOWNORMAL);
    Halt;
    // 2. 본인은 종료 (update를 TempLauncher.exe에 위임)
  end;


end;

procedure TFrmMKPUpdater.CompareVersion;
var
  I, j: Integer;
  rf, lf: TUpdateFile;
  bFind: boolean;
  sMine : string;
begin
  if RemoteFiles.Count <= 0 then Exit;

  for I := 0 to RemoteFiles.Count -1 do
  begin
    rf := TUpdateFile(RemoteFiles.Items[i]);
    bFind := false;
    for j := 0 to LocalFiles.Count-1 do
    begin
      lf := TUpdateFile(LocalFiles.Items[j]);
      if rf.name = lf.name then
      begin
        bFind := true;
        if rf.version <> lf.version then begin
          AddFile(rf);
        end;
        break;
      end;
    end;

    if not bFind then
      AddFile(rf);
  end;

end;

procedure TFrmMKPUpdater.ReadRemoteVersion;
begin
  DownloadUpdateFile(FUrl+'/updates/files.lsg', FAppDir + 'files.lsg');
  ReadFiles(FAppDir + 'files.lsg', RemoteFiles);
end;

procedure TFrmMKPUpdater.SaveUpdateFileVersion;
var
  aFile: TUpdateFile;
  i : integer;
  sFileName, sData: string;
  f: TextFile;
begin

  DoLog('SaveUpdateFileVersion');

  sFileName := FAppDir + 'update.lsg';

  try
    AssignFile(f, sFileName);
    Rewrite(f);
    try
      for I := 0 to LocalFiles.Count-1 do
      begin
        aFile := LocalFiles.Items[i] as TUpdateFile;
        sData := Format('%s:%s:%s', [aFile.name, aFile.version, aFile.path]);
        Writeln(f, sData);
      end;

    finally
      CloseFile(f);
    end;

  except
  end;

end;

procedure TFrmMKPUpdater.selfTimerTimer(Sender: TObject);
begin
  //
  SelfTimer.Enabled := false;
  DownLoadFilesSelf;
end;

procedure TFrmMKPUpdater.UpdateLocalFileVersion(aFile: TUpdateFile);
var
  i: integer;
  lFile: TUpdateFile;
  bFind : boolean;
begin
  //
  bFind := false;
  for I := 0 to LocalFiles.Count-1 do
  begin
    lFile := LocalFiles.Items[i] as TUpdateFile;
    if lFile.name = aFile.name then
    begin
      bFind:= true;
      lFile.version := aFile.version;
      lFile.path    := aFile.path;
      break;
    end;
  end;

  if not bFind then
  begin
    lFile := LocalFiles.Add as TUpdateFile;
    lFile.name  := aFile.name;
    lFile.version := aFile.version;
    lFile.path  := aFile.path;
  end;

end;

procedure TFrmMKPUpdater.upTimerTimer(Sender: TObject);
begin
  //
  upTimer.Enabled := false;
  DownLoadFiles;
end;

procedure TFrmMKPUpdater.WMDowncompleted(var msg: TMessage);
var
  f: TextFile;
begin
  // 다운완료
  // 파일 이동 , 메인창 띄우기
  try
    // 다운받을 파일이 있는 체크하고 있으면 닫자..
    MoveFiles;

    DeleteFiles;

    SaveUpdateFileVersion;

    DoLog('Dalin 실행');
    ExecuteDalin;

  except
  end;
end;

procedure TFrmMKPUpdater.WMDowncompltedeSelf(var msg: TMessage);
begin
  // 자기 자신 버전을 갱신 한다.
  SaveUpdateFileVersion;
  // 업데이트 된 updater.exe 를 실행한다.
  ExecuteUpdater;
end;

