procedure TFrmDalinMain.SaveRegedit( iDiv : integer = 0 );
var
  Reg: TRegistry;
begin
  Reg := TRegistry.Create;
  with Reg do
  try
    RootKey := RegRootKey;
    if OpenKey(RegOpenKeyIni, True) then begin

      with App.Engine.ApiConfig.OrderLimit do
      begin
        // 기본 주문 리스크
        if( iDiv = 0) or ( iDiv = 1 ) then
        begin
          WriteInteger('DefOneTimeLimit_Bin', DefOrderLimit[ekBinance].OneTimeLimit );
          WriteInteger('LestrictArea_Bin', DefOrderLimit[ekBinance].LestrictArea );

          WriteInteger('DefOneTimeLimit_Upt', DefOrderLimit[ekUpbit].OneTimeLimit );
          WriteInteger('LestrictArea_Upt', DefOrderLimit[ekUpbit].LestrictArea );

          WriteInteger('DefOneTimeLimit_Bth', DefOrderLimit[ekBithumb].OneTimeLimit );
          WriteInteger('LestrictArea_Bth', DefOrderLimit[ekBithumb].LestrictArea );
        end;

        // 반자동 주문 리스크
        if( iDiv = 0 ) or ( iDiv = 2 ) then
        begin
          WriteInteger('OneTimeLimit_Bin', OrderLimit[ekBinance].OneTimeLimit );
          WriteInteger('OneDayLimit_Bin', OrderLimit[ekBinance].OneDayLimit );
          WriteInteger('SpreadRate_Bin', OrderLimit[ekBinance].SpreadRate );
          WriteInteger('BusyHogaRate_Bin', OrderLimit[ekBinance].BusyHogaRate );

          WriteInteger('OneTimeLimit_Upt', OrderLimit[ekUpbit].OneTimeLimit );
          WriteInteger('OneDayLimit_Upt', OrderLimit[ekUpbit].OneDayLimit );
          WriteInteger('SpreadRate_Upt', OrderLimit[ekUpbit].SpreadRate );
          WriteInteger('BusyHogaRate_Upt', OrderLimit[ekUpbit].BusyHogaRate );

          WriteInteger('OneTimeLimit_Bth', OrderLimit[ekBithumb].OneTimeLimit );
          WriteInteger('OneDayLimit_Bth', OrderLimit[ekBithumb].OneDayLimit );
          WriteInteger('SpreadRate_Bth', OrderLimit[ekBithumb].SpreadRate );
          WriteInteger('BusyHogaRate_Bth', OrderLimit[ekBithumb].BusyHogaRate );
        end;
      end;

      if iDiv = 3 then
        with App.Engine.ApiConfig do
        begin
          WriteString('QuoteOrderLog1', QuoteOrderLog[0].Code);
          WriteString('QuoteOrderLog2', QuoteOrderLog[1].Code);
        end;

      if iDiv = 4 then
       with App.Engine.ApiConfig.DnwLimit do
       begin
         WriteInteger('DepositLimit_Upt', DepositLimit[ekUpbit] );
         WriteInteger('WithDrawLimit_Upt', WidthDrawLimit[ekUpbit]);

         WriteInteger('DepositLimit_Bth', DepositLimit[ekBithumb]);
         WriteInteger('WithDrawLimit_Bth', WidthDrawLimit[ekBithumb]);
       end;

      if iDiv = 5 then
        with App.Engine.ApiConfig do
        begin
          WriteString('BT_KorName', ExchangeInfo[2].ApiInfo[eaSpot].KorName);
          WriteString('BT_EngName', ExchangeInfo[2].ApiInfo[eaSpot].EngName);
        end;

    end;
  finally
    Free;
  end;
end;


