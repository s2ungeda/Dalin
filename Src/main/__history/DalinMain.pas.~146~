procedure TFrmDalinMain.QryTimerTimer(Sender: TObject);
var
  I, iRow: integer;
  sTmp : string;
  esk  : TExchangeSocketKind;
  dmavg: double;
  dtNow: TDateTime;
  iTmp : array [0..QWS_CNT-1] of integer;
begin

  // 2초에 한번식 환율 읽기
  if FExRate >= 2 then
  begin
    FExRate := 0;
    TTask.Run( procedure
      begin
        GetExRate( false );
      end );

//    DoSiseLog;
  end;
  inc(FExRate);

  TTask.Run(procedure
    begin
      CheckRest;
    end
  );

  if FDnw > 5 then
  begin
    if not App.Config.TradeMod then
      DoSiseLog;
    FDnw := 0;
  end;

  inc(FDnw);    iRow := 0;

  with sg do
  begin

    Cells[1,iRow]  := IntToStr(App.Engine.ApiManager.ExManagers[ekBinance].QuoteSock[1].ConnectTry) + '/ '+
                      IntToStr(App.Engine.ApiManager.ExManagers[ekBinance].QuoteSockPub.ConnectTry);
    Cells[2,iRow]  := IntTostr(App.Engine.ApiManager.ExManagers[ekBinance].QuoteSock[1].RcvCnt) + '/ '+
                      IntToStr(App.Engine.ApiManager.ExManagers[ekBinance].QuoteSockPub.RcvCnt);
    Cells[5,iRow]  := App.Engine.ApiManager.ExManagers[ekBinance].QuoteSock[1].GetSockState[1] + '/ ' +
                      App.Engine.ApiManager.ExManagers[ekBinance].QuoteSockPub.GetSockState[1];
    inc(iRow);
    Cells[1,iRow]  := IntToStr( App.Engine.ApiManager.ExManagers[ekUpbit].QuoteSock[0].ConnectTry );
    Cells[2,iRow]  := IntTostr( App.Engine.ApiManager.ExManagers[ekUpbit].QuoteSock[0].RcvCnt );
    Cells[5,iRow]  := App.Engine.ApiManager.ExManagers[ekUpbit].QuoteSock[0].GetSockState;
    inc(iRow);
    Cells[1,iRow]  := IntToStr( App.Engine.ApiManager.ExManagers[ekBithumb].QuoteSock[0].ConnectTry );
    Cells[2,iRow]  := IntTostr( App.Engine.ApiManager.ExManagers[ekBithumb].QuoteSock[0].RcvCnt );
    Cells[5,iRow]  := App.Engine.ApiManager.ExManagers[ekBithumb].QuoteSock[0].GetSockState;

    //바이낸스
    // --> usdt-m wesocketapi
    iRow := EX_ROW+1;
    Cells[1,iRow]  := IntToStr(TBinanceFutures(App.Engine.ApiManager.ExManagers[ekBinance].Exchanges[eaFutUsdt]).WsApi.ConnectTry );
    Cells[2,iRow]  := IntTostr(TBinanceFutures(App.Engine.ApiManager.ExManagers[ekBinance].Exchanges[eaFutUsdt]).WsApi.RcvCnt );
    Cells[3,iRow]  := IntTostr(TBinanceFutures(App.Engine.ApiManager.ExManagers[ekBinance].Exchanges[eaFutUsdt]).WsApi.LimitCnt(1) );
    Cells[4,iRow]  := IntTostr(TBinanceFutures(App.Engine.ApiManager.ExManagers[ekBinance].Exchanges[eaFutUsdt]).WsApi.LimitCnt(2) );
    Cells[5,iRow]  := TBinanceFutures(App.Engine.ApiManager.ExManagers[ekBinance].Exchanges[eaFutUsdt]).WsApi.GetSockState;
    inc(iRow);
    // usd-m
    Cells[1,iRow]  := IntToStr( App.Engine.ApiManager.ExManagers[ekBinance].TradeSock[1].ConnectTry );
    Cells[2,iRow]  := IntTostr( App.Engine.ApiManager.ExManagers[ekBinance].TradeSock[1].RcvCnt );
    Cells[5,iRow]  := App.Engine.ApiManager.ExManagers[ekBinance].TradeSock[1].GetSockState;
    inc(iRow);
    //upbit 체결
    Cells[1,iRow]  := IntToStr( App.Engine.ApiManager.ExManagers[ekUpbit].TradeSock[0].ConnectTry );
    Cells[2,iRow]  := IntTostr( App.Engine.ApiManager.ExManagers[ekUpbit].TradeSock[0].RcvCnt );
    Cells[5,iRow]  := App.Engine.ApiManager.ExManagers[ekUpbit].TradeSock[0].GetSockState;
    inc(iRow);
    //bithumb 체결
    Cells[1,iRow]  := IntToStr( App.Engine.ApiManager.ExManagers[ekBithumb].TradeSock[0].ConnectTry );
    Cells[2,iRow]  := IntTostr( App.Engine.ApiManager.ExManagers[ekBithumb].TradeSock[0].RcvCnt );
    Cells[5,iRow]  := App.Engine.ApiManager.ExManagers[ekBithumb].TradeSock[0].GetSockState;

    //Cells[1, EX_ROW]  := App.Engine.ApiManager.ExRate.LastUpdateBetween.ToString;
    Cells[2, EX_ROW]  := Format('%.2n', [App.Engine.ApiManager.ExRate.GetExRate]);
    dmavg := App.Engine.ApiManager.ExRate.GetAvgExRate(15);
    if CheckZero(dmavg) then
      Cells[5,EX_ROW]  := Format('%.2f', [ App.Engine.ApiManager.ExRate.GetExRate] )
    else
      Cells[5,EX_ROW]  := Format('%.2f', [ abs(App.Engine.ApiManager.ExRate.GetExRate - dmavg) / dmavg * 100 ] );

    dtNow := now;

//    iTmp[0] := SecondsBetween(dtNow, App.Engine.ApiManager.ExManagers[ekBinance].QuoteSock[0].LiveTime);
    iTmp[0] := SecondsBetween(dtNow, App.Engine.ApiManager.ExManagers[ekBinance].QuoteSock[1].LiveTime);
    iTmp[4] := SecondsBetween(dtNow, App.Engine.ApiManager.ExManagers[ekBinance].QuoteSockPub.LiveTime);
    iTmp[1] := SecondsBetween(dtNow, App.Engine.ApiManager.ExManagers[ekUpbit].QuoteSock[0].LiveTime);
    iTmp[2] := SecondsBetween(dtNow, App.Engine.ApiManager.ExManagers[ekBithumb].QuoteSock[0].LiveTime);
    iTmp[3] := SecondsBetween(dtNow, App.Engine.ApiManager.ExRate.LastTime );

    if App.AppStatus >= asShow then
    begin
      for i := 0 to High(iTmp) do
      begin
        if FMax[i]<iTmp[i] then
          FMax[i] := iTmp[i];
      end;

      Cells[3, 0] := IntToStr(iTmp[0]) + '/ ' + IntTostr(iTmp[4]);
      Cells[4, 0] := IntToStr(FMax[0]) + '/ ' + IntTostr(FMax[4]);

      for i := 1 to High(iTmp)-1 do
      begin
        Cells[3, i]  := IntToStr(iTmp[i]);
        Cells[4, i]  := IntToStr(FMax[i]);
      end;

    end;
  end;

  stsBar.Panels[1].Text := FormatDateTime('yyyy-mm-dd hh:nn:ss', now) ;
  stsBar.Panels[2].Text := Format('S(%d) R(%d)', [
    App.Engine.SharedManager.SndCount, App.Engine.SharedManager.RcvCount
     ]  );

end;

