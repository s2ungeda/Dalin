procedure TFrmDalinMain.FormCreate(Sender: TObject);
begin

  Application.OnException := AppException;
  Application.HintPause := 10;
  FCurrenctID := 0;

  init;

  if not App.LoadConfig then
  begin
    ShowMessage('환경설정 파일을 읽을수 없음');
    PostMessage(Handle, WM_CLOSE, 0, 0);
    Exit;

  end;
  // 필수 디렉토리 생성..
  SetEnv;

  if not CheckDpkFile  then
  begin
    PostMessage(Handle, WM_CLOSE, 0, 0);
    Exit;
  end;

{$IFDEF DEBUG}

  App.Entropy.Assign('0001');

{$ELSE}

  if not GetEntropy then
  begin
    ShowMessage('입력값이 없습니다.');
    PostMessage(Handle, WM_CLOSE, 0, 0);
    Exit;
  end;

{$ENDIF}


  if not App.LoadKeys then
  begin
    ShowMessage('Key 정보를 로드 할수 없음.');
    PostMessage(Handle, WM_CLOSE, 0, 0);
    Exit;
  end;

  FCurrenctID := GetCurrentThreadId;
  App.Log(llInfo, '', '---start---');

  Caption := Format('%s-%s ver.%s', [Caption  , ifThenStr( App.Config.TradeMod, 'T', 'Q'),
    FileVersionToStr(Application.ExeName)]);

  stsBar.Panels[0].Text := FormatDateTime('MM-dd HH:NN',now) ;

  FRestCheck  := true;
  FExRateCheck:= true;

end;

