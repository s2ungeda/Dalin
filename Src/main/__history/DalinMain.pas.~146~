procedure TFrmDalinMain.ExecuteSubApp;
var
  i : integer;
begin
  for I := 0 to High(App.Config.PrcsInfo) do
    if App.Config.PrcsInfo[i].Active then
      ExecuteSubApp(i);
end;

procedure TFrmDalinMain.ExecuteSubApp(idx: integer);
var
  sName : string;
  sMsg  : AnsiString;
begin

  if idx = 1 then begin
    // rest 일때
    sName := Format('DLKP:%s',[FormatDateTime('nn:ss.zzz', now)]);
    TSimpleShareMemory.Write(sName, AnsiString(App.Entropy.Reveal));
    ExecuteApp( Handle, App.Config.PrcsInfo[idx].ClassName, App.Config.PrcsInfo[idx].AppName, sName);
  end else
    ExecuteApp( Handle, App.Config.PrcsInfo[idx].ClassName, App.Config.PrcsInfo[idx].AppName  );
end;


procedure TFrmDalinMain.finMonitorThread;
begin
  if Assigned(FMonitorThread) then
  begin
    FMonitorThread.Terminate;
    FMonitorThread.WaitFor;
    FMonitorThread.Free;
    FMonitorThread  := nil;
  end;
end;

function TFrmDalinMain.CheckDpkFile: boolean;
var
  sDir: string;
begin

  if not FileExists(App.DataDir + '/' + APK_FILE) then
  begin
    //if MessageDlg('Key 파일이 없습니다. Key 파일 만들고 다시 실행하세요', mtInformation, [mbYes, mbNo], 0) = mrYes then
    if MessageBox(0, 'Key 파일이 없습니다. Key 파일 만들고 다시 실행하세요', '알림', MB_YESNO or MB_ICONINFORMATION or MB_TOPMOST) = mrYes then
    begin
      ExecuteApp( Handle, App.Config.PrcsInfo[2].ClassName
        , App.Config.PrcsInfo[2].AppName  );
    end else
    begin
      ShowMessage('Key 파일 없이는 실행불가. 종료합니다..');
      Exit (false);
    end;
  end else
    Result := true;
end;

procedure TFrmDalinMain.CheckRest;
var
  aH : THandle;
begin
  // REST 떠있나 체크..
  if (App.AppStatus >= asShow) then
  begin
    aH := FindWindow( PChar(App.Config.PrcsInfo[1].ClassName), nil );
    if aH <= 0 then
    begin
      if FRestCheck then begin
        FRestCheck := false;
        ShowMessage('Rest.exe 가 실행되지 않았습니다'+#13+#10+'국내 거래소로 주문이 불가한 상태입니다.');
      end;
    end else
      FRestCheck := true;
  end;

  // ExRate 떠있나 체크..
  if (App.AppStatus >= asShow) then
  begin
    aH := FindWindow( PChar(App.Config.PrcsInfo[0].ClassName), nil );
    if aH <= 0 then
    begin
      if FExRateCheck then begin
        FExRateCheck := false;
        ShowMessage('ExRate.exe 가 실행되지 않았습니다'+#13+#10+'환율정보를 알수 없습니다..');
      end;
    end else
      FExRateCheck := true;
  end;

end;

procedure TFrmDalinMain.CloseSubApp;
var
  i : integer;
begin

  for I := 0 to 1 do
    if App.Config.PrcsInfo[i].Active then
      if App.Config.PrcsInfo[i].ClassName <> 'TFrmExRate' then
        CloseApp( App.Config.PrcsInfo[i].ClassName );
