procedure TBithParse.ParseSpotTrade(aJson: TJsonObject);
var
  aArr : TJsonArray;
  aVal : TJsonValue;
  I: Integer;
  sCode, sTmp : string;
  aQuote: TQuote;
  dtTime : TDateTime;
  aSale  : TTimeNSale;
  itime  : int64;
begin

  sCode := GetSymbolCode(aJson.GetValue<string>('code'), 1);
  aQuote  := App.Engine.QuoteBroker.Brokers[FParent.ExchangeKind].Find(sCode)    ;
  if (aQuote = nil) or (aQuote.Symbol = nil ) then Exit;

  iTime   := aJson.GetValue<int64>('trade_timestamp');
  dtTime  := UnixTimeToDateTime(aJson.GetValue<string>('trade_timestamp'));

  with aQuote do
  begin
    aSale := Symbol.Sales.New;
    aSale.LocalTime := now;
    aSale.Time      := dtTime;
    aSale.Price     := aJson.GetValue<double>('trade_price');
    aSale.Volume    := aJson.GetValue<double>('trade_volume');

    aSale.Side      := ifthen( aJson.GetValue<string>('ask_bid') = 'ASK', -1, 1 );

    Symbol.Last := aSale.Price;
    Symbol.Volume := aSale.Volume;
    Symbol.Side   := aSale.Side;

    LastEvent := qtTimeNSale;

    //iTime :=  StrToInt64((IntToStr(DateTimeToUnix(dtTime, False))+copy(sTmp, 21,3)));

    Symbol.SavePrevDepth;
    // ĂĽ°á˝Ă°˘ŔĚ Last Q datetime ˝Ă°Łş¸´Ů Ĺ©¸é ČŁ°ˇ ş¸Á¤ÇŃ´Ů.
    if iTime - Symbol.TrnsTimeQ >= 0 then
      Symbol.AdjustDepth;

    App.QuoteLog(FParent.ExchangeKind, eaSpot, Symbol.Spec.BaseCode,
        ',F, , %d, %d,%s,%s,%s,%s,%s', [
        iTime, iTime - Symbol.TrnsTimeQ,
        ifThenStr(aSale.Side = -1, '¸Ĺµµ','¸ĹĽö'),
        Format('%.*f', [ GetPrecision(Symbol, aSale.Price), Symbol.Last]),
        Format('%.*f', [ Symbol.Spec.QtyPrecision, aSale.Volume]),
        Symbol.DepthLog(false), Symbol.DepthLog(true)
        ]);

    Update(dtTime );
  end;

  Exit;

  aVal := aJson.GetValue('content') ;
  if aVal = nil then Exit;

  aArr := aVal.FindValue('list') as TJsonArray ;
  if aArr = nil then Exit;

  aQuote := nil;

  try

    for I := 0 to aArr.Count-1 do
    begin
      aVal  := aArr.Items[i];
      // BTC_KRW -> BTC
      sCode := GetSymbolCode( aVal.GetValue<string>('symbol') );

      if aQuote = nil then
        aQuote  := App.Engine.QuoteBroker.Brokers[FParent.ExchangeKind].Find(sCode)    ;
      if (aQuote = nil) or (aQuote.Symbol = nil ) then Exit;

      with aQuote do
      begin
        sTmp  := aVal.GetValue<string>('contDtm');

        dtTime:= EncodeDate(  StrToInt(copy(sTmp, 1, 4 ) ) , StrToInt( copy(sTmp, 6, 2 )) , StrToInt( copy(sTmp, 9,2)) )
                + EnCodeTime(StrToInt(copy(sTmp, 12,2))
                          ,StrToInt(copy(sTmp, 15,2))
                          ,StrToInt(copy(sTmp, 18,2))
                          ,StrToInt(copy(sTmp, 21,3)) )  ;

        aSale := Symbol.Sales.New;
        aSale.LocalTime := now;
        aSale.Time      := dtTime;
        aSale.Price     := StrToFloat( aVal.GetValue<string>('contPrice'));
        aSale.Volume    := StrToFloat( aVal.GetValue<string>('contQty'));

        aSale.Side      := ifthen( aVal.GetValue<string>('buySellGb') = '1', -1, 1 );

        Symbol.Last := aSale.Price;
        Symbol.Volume := aSale.Volume;
        Symbol.Side   := aSale.Side;

        LastEvent := qtTimeNSale;

        iTime :=  StrToInt64((IntToStr(DateTimeToUnix(dtTime, False))+copy(sTmp, 21,3)));

        Symbol.SavePrevDepth;
        // ĂĽ°á˝Ă°˘ŔĚ Last Q datetime ˝Ă°Łş¸´Ů Ĺ©¸é ČŁ°ˇ ş¸Á¤ÇŃ´Ů.
        if iTime - Symbol.TrnsTimeQ >= 0 then
          Symbol.AdjustDepth;

        App.QuoteLog(FParent.ExchangeKind, eaSpot, Symbol.Spec.BaseCode,
            ',F, , %d%s, %d,%s,%s,%s,%s,%s', [
            DateTimeToUnix(dtTime, False),  copy(sTmp, 21,3), iTime - Symbol.TrnsTimeQ,
            ifThenStr(aSale.Side = -1, '¸Ĺµµ','¸ĹĽö'),
            Format('%.*f', [ GetPrecision(Symbol, aSale.Price), Symbol.Last]),
            Format('%.*f', [ Symbol.Spec.QtyPrecision, aSale.Volume]),
            Symbol.DepthLog(false), Symbol.DepthLog(true)
            ]);

        Update(dtTime );
      end;

    end;


  except
  end;
  
end;





