procedure TBithParse.ParseDnwState(aData: string);
var
  aObj, aSub : TJsonObject;
  aPair : TJsonPair;
  aArr  : TJsonArray;
  sTmp : string;
  I, iw, id: Integer;
  aSymbol : TSymbol;
  aNetwork : TDnwNetWork;
begin
  if aData = '' then
  begin
    App.Log(llError, '%s ParseDnwState data is empty', [ TExchangeKindDesc[FParent.ExchangeKind] ] ) ;
    Exit;
  end;

  aObj := TJsonObject.ParseJSONValue( aData) as TJsonObject;
  try
    sTmp := aObj.GetValue('status').Value;
    if ( sTmp = '' ) or ( sTmp <> '0000' ) then Exit;

    aArr  := aObj.GetValue('data') as TJsonArray;

    for I := 0 to aArr.Size-1 do
    begin
      aSub := aArr.Get(i) as TJsonObject;

      sTmp := aSub.GetValue<string>('currency');
      if FParent.Codes.IndexOf(sTmp) < 0 then Continue;
      aSymbol := App.Engine.SymbolCore.FindSymbol(FParent.ExchangeKind, sTmp);

      if aSymbol <> nil then
      begin
        aNetwork := aSymbol.NetworkList.New;
        aNetwork.Name := aSub.GetValue<string>('net_type');

        iw := aSub.GetValue<integer>('withdrawal_status');
        id := aSub.GetValue<integer>('deposit_status');

        aNetwork.WithDrawlState := iw=1;
        aNetwork.DepositState   := id=1;

        var iRes : integer;
        iRes := aSymbol.CheckDnwState( id = 1, iw = 1 ) ;
        if iRes > 0 then
          App.Engine.SymbolBroker.DnwEvent( aSymbol, iRes);
      end;
    end;

  finally
    if aObj <> nil then aObj.free;
  end;

end;



procedure TBithParse.ParseSocketData(aMarket: TMarketType; aData: string);
var
  aObj : TJsonObject;
  aPair : TJsonPair;
  sTmp : string;
  aErr : TJsonValue;
begin
  if aData = '' then
  begin
    App.Log(llError, '%s %s ParseSocketData data is empty',
       [ TExchangeKindDesc[FParent.ExchangeKind],  TMarketTypeDesc[aMarket] ] ) ;
    Exit;
  end;

  aObj := TJsonObject.ParseJSONValue( aData) as TJsonObject;
  try
    aPair := aObj.Get('type');
    if aPair <> nil then
    begin
      sTmp := aPair.JsonValue.Value;

      if sTmp.Compare(sTmp, 'myOrder') = 0 then
        ParseSpotMyOrder(aObj)
      else if sTmp.Compare(sTmp, 'ticker')= 0 then
        ParseSpotMiniTickers( aObj )
      //else if sTmp.Compare(sTmp, 'orderbooksnapshot')= 0 then
      else if sTmp.Compare(sTmp, 'orderbook')= 0 then
        ParseSpotOrderBook( aObj )
      //else if sTmp.Compare(sTmp, 'transaction')= 0 then
      else if sTmp.Compare(sTmp, 'trade')= 0 then
        ParseSpotTrade( aObj )
      else if sTmp.Compare(sTmp, 'myAsset') = 0 then
        ParseSpotMyAsset(aObj)
      else Exit;
    end else  begin
      aPair := aObj.Get('status');
      if aPair <> nil then
      begin
        sTmp := aPair.JsonValue.Value;
        if sTmp = '0000' then begin
          if Assigned(FOnSendDone) then
            FOnSendDone( Self );
        end
        else
          App.DebugLog(' %s, %s oops !! ....... %s ', [ TExchangeKindDesc[FParent.ExchangeKind],  TMarketTypeDesc[aMarket], aData ]);
      end else
      begin
        aErr := aObj.GetValue('error');
        if aErr <> nil then
        begin
          App.Log(llError,'%s %s ŔĄĽŇÄĎ żˇ·Ż : %sj', [
            TExchangeKindDesc[FParent.ExchangeKind],  TMarketTypeDesc[aMarket], aErr.GetValue<string>('message', '') ]);
        end;
      end;
    end;
  finally
    aObj.Free;
  end;
end;

