procedure TBithParse.ParseAssets(aData: string);
var
  aObj  : TJsonObject;
  aPair : TJsonPair;
  aVal, aAss  : TJsonValue;
  aArr  : TJsonArray;
  iResult, iLen : integer;
  aAcnt	: TAccount;
  aAsset : TAsset;

  sCode : string;
  I: Integer;

begin

  if aData = '' then
  begin
    App.Log(llError, '%s ParseAssets data is empty', [ TExchangeKindDesc[FParent.ExchangeKind] ] ) ;
    Exit;
  end;

  aAcnt := App.Engine.TradeCore.FindAccount(FParent.ExchangeKind);
  if aAcnt = nil then Exit;

  aArr := nil;    aVal := nil;
  aVal := TJsonObject.ParseJSONValue( aData) ;
  if aVal = nil then Exit;

  try
    if aVal.TryGetValue<TJsonObject>('error', aObj) then
    begin
      App.Log(llError, '%s ParseAssets Á¶Č¸ ˝ÇĆĐ : %s', [
        TExchangeKindDesc[FParent.ExchangeKind], aData] );
      Exit;
    end;

    aAcnt.Assets.init;

    aArr  := aVal as TJsonArray;
    for I := 0 to aArr.Count-1 do
    begin
      aAss  := aArr.Items[i];
      sCode := aAss.GetValue<string>('currency');

      if sCode = 'P' then continue;

      aAsset  := aAcnt.Assets.Find(sCode);
      if aAsset = nil then begin
        aAsset  := aAcnt.Assets.New(sCode, aAcnt);
        if sCode = 'KRW' then
          aAcnt.Asset := aAsset;
      end;

      aAsset.Locked   := aAss.GetValue<double>('locked');
      aAsset.Balance  := aAss.GetValue<double>('balance') + aAsset.Locked;
      aAsset.Available:= aAsset.Balance - aAsset.Locked;
      aAsset.AvgPrice := aAss.GetValue<double>('avg_buy_price');
    end;
  finally
//    if aVal <> nil  then aVal.Free;
    if aArr <> nil then aArr.Free;
  end;

end;

function TBithParse.ParseAsyncBalace(aData: string): boolean;
var
  aObj, aBals : TJsonObject;
  aPair  : TJsonPair;
  iResult, iLen : integer;
  aAcnt	: TAccount;
  aAsset : TAsset;

  sCode : string;
  I: Integer;

begin

  Result := false;
  if aData = '' then
  begin
    App.Log(llError, '%s ParseBalance data is empty', [ TExchangeKindDesc[FParent.ExchangeKind] ] ) ;
    Exit;
  end;

  aObj := nil;
  aObj := TJsonObject.ParseJSONValue( aData) as TJsonObject;

  try
    iResult := StrToInt( aObj.GetValue('status').Value );
    if iResult <> 0 then begin
      App.Log(llError, 'Bithum Request Result %d (ParseBalance)', [ iResult ] );
      Exit;
    end;

    aBals	:= aObj.GetValue('data') as TJsonObject;
    if aBals = nil then Exit;

    aAcnt := App.Engine.TradeCore.FindAccount(FParent.ExchangeKind);
    if aAcnt = nil then Exit;

    for I := 0 to aBals.Count-1 do
    begin
      aPair := aBals.Get(i);
      var sts : TArray<string>;
      sts := aPair.JsonString.Value.Split(['_']);

      iLen  := Length( sts );
      sCode := sts[iLen-1];

      if (sCode <> 'krw') and ( FParent.Codes.IndexOf(sCode) < 0 ) then continue;

      aAsset  := aAcnt.Assets.Find(sCode);
      if aAsset = nil then begin
        aAsset  := aAcnt.Assets.New(sCode, aAcnt);
        if sCode = 'krw' then
          aAcnt.Asset := aAsset;
      end;

      if sts[0] = 'available' then
        aAsset.QueryedAvailable  := StrToFloatDef( aPair.JsonValue.Value, 0 );

      Result := true;
    end;

  finally
    if aObj <> nil  then aObj.Free;
  end;

end;

