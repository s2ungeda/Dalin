procedure TBithParse.ParseTicker(aData: string);
var
  aObj, aSub, master : TJsonObject;
  aArr : TJsonArray;
  aPair : TJsonPair;
  aVal  : TJsonValue;
  i : Integer;
  sBase, sCode, sTmp : string;
  aSymbol : TSymbol;
  bNew : boolean;
  j: Integer;
  aQuote : TQuote;
  dtTime : TDateTime;
  bCalc : boolean;
  dTmp  : double;
  aList : TList;
begin
  master := TJsonObject.ParseJSONValue( aData ) as TJsonObject;
  aObj := master.GetValue('data') as TJsonObject;

  aList := TList.Create;
  try

    try

      dtTime  := UnixTimeToDateTime( aObj.GetValue<int64>('date') );

      for I := 0 to aObj.Size-1 do
      begin
        aPair := aObj.Get(i);
        if aPair.JsonValue.ClassType <> TJSONObject then continue;
        sCode := aPair.JsonString.Value;

        aSymbol := App.Engine.SymbolCore.FindSymbol(FParent.ExchangeKind, sCode );
        if aSymbol <> nil then
        begin

          bCalc := false;
          aVal := aPair.JsonValue;

          aSymbol.DayHigh     := StrToFloatDef( aVal.GetValue<string>( 'max_price' ), 0.0 );
          aSymbol.DayLow      := StrToFloatDef( aVal.GetValue<string>( 'min_price' ), 0.0 );
          aSymbol.DayOpen     := StrToFloatDef( aVal.GetValue<string>( 'opening_price' ), 0.0 );

          aSymbol.PrevClose   := StrToFloatDef( aVal.GetValue<string>( 'prev_closing_price' ), 0.0 );
          aSymbol.DayAmount   := StrToFloatDef( aVal.GetValue<string>( 'acc_trade_value_24H' ), 0.0 ) / 100000000;
          aSymbol.DayVolume   := StrToFloatDef( aVal.GetValue<string>( 'units_traded_24H' ), 0.0 );
          dTmp                := StrToFloatDef( aVal.GetValue<string>( 'closing_price' ), 0.0 );

          if sCode = 'TRX' then
          	sCode := 'TRX';

          if dtTime > aSymbol.LastEventTime then
          begin
            aSymbol.Last          := dTmp ;
            aSymbol.LastEventTime := dtTime;
            aSymbol.LastTime      := now;
            bCalc := true;
          end;
//            App.DebugLog( 'ticker not up : %s -> (%s)%s, %s', [ aSymbol.Code, aSymbol.PriceToStr(aSymbol.Last),
//              aSymbol.PriceToStr( dTmp )
//              , FormatDateTime('hh:nn:ss', dtTime)] );

          if App.AppStatus > asLoad then
          begin
//  ŔĄĽŇÄĎŔĚ şŇľČÇŘĽ­ ŔĎ´Ü ˝Ç˝Ă°Ł ±¸µ¶ÇŃ Áľ¸ńµµ °č»ęÇŃ´Ů. - ŔĄĽŇÄĎ ľČÁ¤Č­ µÇ¸é..»©ľß µĘ.
//            aQuote:= App.Engine.QuoteBroker.Brokers[FParent.ExchangeKind].Find(sCode)    ;
//            if aQuote = nil then
//            begin
	            if bCalc then begin
                App.Engine.SymbolCore.CalcIndex( aSymbol );
                App.Engine.TradeCore.Positions[ aSymbol.Spec.ExchangeType].UpdatePosition( aSymbol);
	            end;
//            end;
          end;

          if ( App.Engine.SymbolCore.MainSymbols[msBTC][ekBithumb] <> aSymbol ) and
            ( App.Engine.SymbolCore.MainSymbols[msETH][ekBithumb] <> aSymbol ) and
            ( App.Engine.SymbolCore.MainSymbols[msXRP][ekBithumb] <> aSymbol ) then
            aList.Add( aSymbol );

        end;
      end;

      aList.Sort(CompareDailyAmount);
      if aList.Count > 2 then
      begin
        App.Engine.SymbolCore.TopAmtSubscribe( ekBithumb, TSymbol( aList.Items[0] ), TSymbol( aList.Items[1] ) );
        App.Engine.ApiManager.ExManagers[ekBithumb].TopAmtSymbols[0] := TSymbol( aList.Items[0] );
        App.Engine.ApiManager.ExManagers[ekBithumb].TopAmtSymbols[1] := TSymbol( aList.Items[1] );
      end;

    except on e : exception do
      App.log( llError,  ' %s ParseTicker Error', [  TExchangeKindDesc[ FParent.ExchangeKind], aData ] ) ;
    end;
  //  if ( GetCodeIndex( sCode ) < 0 ) then Continue;

  finally
    if master <> nil then master.Free ;
    aList.Free;
  end;


end;

procedure TBithParse.ParseSpotOrderBook(aJson: TJsonObject);
var
  aAskArr, aBidArr : TJsonArray;
  aVal : TJsonValue;
  I: Integer;
  sCode, sTmp : string;
  aQuote : TQuote;
  dtTime : TDateTime;
  itime  : int64;

  aUnits : TJsonArray;
begin

  sCode := GetSymbolCode(aJson.GetValue<string>('code'), 1);
  aQuote  := App.Engine.QuoteBroker.Brokers[FParent.ExchangeKind].Find(sCode)    ;
  if (aQuote = nil) or (aQuote.Symbol = nil ) then Exit;

  aUnits  := aJson.GetValue('orderbook_units') as TJsonArray;
  if aUnits = nil then Exit;

  with aQuote do
  begin
    for I := 0 to aUnits.Count-1 do
    begin
      if (i >= Symbol.Asks.Count) or (i >= Symbol.Bids.Count) then break;

      aVal  := aUnits.Get(i);
      Symbol.Asks[i].Price  := aVal.GetValue<double>('ask_price');
      Symbol.Asks[i].Volume := aVal.GetValue<double>('ask_size');
      Symbol.Bids[i].Price  := aVal.GetValue<double>('bid_price');
      Symbol.Bids[i].Volume := aVal.GetValue<double>('bid_size');
    end;

    itime   := aJson.GetValue<int64>('timestamp');
    dtTime  := UnixTimeToDateTime(aJson.GetValue<string>('timestamp'));

    Symbol.TrnsTimeQ  := iTime ;
    LastEvent := qtMarketDepth;

    App.QuoteLog(FParent.ExchangeKind, eaSpot, Symbol.Spec.BaseCode,
      ',Q, %d, , , , , ,%s', [
        itime ,
        Symbol.DepthLog(false)
//          Format('%.*f', [ GetPrecision(Symbol, Symbol.Asks[0].Price), Symbol.Asks[0].Price]),
//          Format('%.*f', [ GetPrecision(Symbol, Symbol.Asks[0].Price), Symbol.Last]),
//          Format('%.*f', [ GetPrecision(Symbol, Symbol.Asks[0].Price), Symbol.Bids[0].Price])
        ]);

//      App.Log(llDebug, sCode+'_BT_quote', ',Q,%s,%s,%s,%s', [
//        '','', '',Symbol.DepthLog(false)
//        ]);

    Symbol.ContiCnt := 0;
    Symbol.SavePrevDepth;

    Update( dtTime );
  end;

  Exit;

  aVal := aJson.GetValue('content') ;
  if aVal = nil then Exit;

  sCode := GetSymbolCode(aVal.GetValue<string>('symbol'));

  aQuote  := App.Engine.QuoteBroker.Brokers[FParent.ExchangeKind].Find(sCode)    ;
  if (aQuote = nil) or (aQuote.Symbol = nil ) then Exit;

  aAskArr := aVal.FindValue('asks') as TJsonArray;
  aBidArr := aVal.FindValue('bids') as TJsonArray;

  if (aAskArr = nil) or ( aBidArr = nil ) then Exit;

  try

    with aQuote do
    begin
      for i := 0 to aAskArr.Count-1 do
      begin
        if i >= Symbol.Asks.Count then break;

        var aArr  : TJsonArray;
        var aVal2 : TJsonValue;
        aArr  := aAskArr.Items[i] as TJsonArray;

        Symbol.Asks[i].Price := StrToFloat( aArr.Get(0).Value );
        Symbol.Asks[i].Volume := StrToFloat( aArr.Get(1).Value );
      end;

      for i := 0 to aBidArr.Count-1 do
      begin
        if i >= Symbol.Bids.Size then break;

        var aArr  : TJsonArray;
        var aVal2 : TJsonValue;
        aArr  := aBidArr.Items[i] as TJsonArray;

        Symbol.Bids[i].Price := StrToFloat( aArr.Items[0].Value );
        Symbol.Bids[i].Volume := StrToFloat( aArr.Items[1].Value );
      end;

      itime   := aVal.GetValue<int64>('datetime') div 1000;
      dtTime  := UnixTimeToDateTime(iTime, 16);

      Symbol.TrnsTimeQ  := iTime ;
      LastEvent := qtMarketDepth;

      App.QuoteLog(FParent.ExchangeKind, eaSpot, Symbol.Spec.BaseCode,
        ',Q, %d, , , , , ,%s', [
          itime ,
          Symbol.DepthLog(false)
//          Format('%.*f', [ GetPrecision(Symbol, Symbol.Asks[0].Price), Symbol.Asks[0].Price]),
//          Format('%.*f', [ GetPrecision(Symbol, Symbol.Asks[0].Price), Symbol.Last]),
//          Format('%.*f', [ GetPrecision(Symbol, Symbol.Asks[0].Price), Symbol.Bids[0].Price])
          ]);

//      App.Log(llDebug, sCode+'_BT_quote', ',Q,%s,%s,%s,%s', [
//        '','', '',Symbol.DepthLog(false)
//        ]);

      Symbol.ContiCnt := 0;
      Symbol.SavePrevDepth;

      Update( dtTime );
    
    end;

  except
  end;
end;

