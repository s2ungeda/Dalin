                begin
                  aFill	 := App.Engine.TradeCore.Fills[ekUpbit].New(aRslt.FillNo, aRslt.Time, now,
                        aOrder.OrderNo, aOrder, aRslt.Volume ,aRslt.Price);
                  aFill.Fee := aRslt.Fee;

                  App.Log(llInfo, 'bithumb Spot Fill - ws : %s, %s, %s, %s, %s, %.8f, %f, %s ', [ aOrder.Symbol.Code,
                    aOrder.SideToStr, '',  aOrder.OrderNo,  aOrder.Symbol.PriceToStr(aFill.Price), aFill.Volume, aFill.Fee, aRslt.FillNo
                  ]);

                  App.Engine.TradeBroker.Fill(aOrder, aFill, aRslt.RVolume <= EPSILON);
                end;
                bRemove := true;
              end;
            rtCancel: begin
                        App.Engine.TradeBroker.Cancel(aOrder, true) ;
                        bRemove := true;
                      end;
            rtWait  : begin
                        App.Engine.TradeBroker.Accept(aOrder, aRslt.Time, true, '0000') ;
                        bRemove := true;
                      end;
            else Continue;
          end;

          if bRemove then
          begin
            FForwardOrderResults.Remove(aRslt);
            App.Log(llInfo,'bithumb Á˘ĽöČÄ żŞŔü Ăł¸® : %s, %s, %s',[aRslt.TypeToStr,
              aOrder.Symbol.QtyToStr(aRslt.Volume), aOrder.Symbol.QtyToStr(aRslt.Price),
              aOrder.Represent ]  );
          end;
        end;
    end;

  finally
    if aObj <> nil then aObj.Free;
  end;

end;


procedure TBithParse.ParseSpotOrderDetail(aData, aRef: string);
var
	aObj : TJsonObject;
  aArr	 : TJsonArray;
  aErr   : TJsonValue;

  aOrder : TOrder;
  sTmp , sStatus : string;
  i : integer;

  procedure ProcFill( aArr : TJsonArray; bComplete : boolean = false );
  var
    aFill : TFill;
    sTrdID, sPrice, sVolume : string;
    dtTime : TDateTime;
    i : integer;
    aVal	 : TJsonValue;
    bDone  : boolean;
    dFee , dTmp : double;
    aList : TList;
  begin
    // ĂÖ˝ĹĂĽ°áŔĚ Á© Ŕ§żˇ..

    aList := TList.Create;
    try

      with  App.Engine.ApiConfig do
        dFee:= ExchangeInfo[integer(ekBithumb)].GetTradeFee(eaSpot, scKrw, ftMaker);

      for I := aArr.Size-1 downto 0 do
      begin

        aVal			:= aArr.Get(i)  ;

        sTrdID	:= aVal.GetValue<string>('uuid');
        sPrice	:= aVal.GetValue<string>('price');
        sVolume := aVal.GetValue<string>('volume');
        dtTime	:= GetStrToTime(aVal.GetValue<string>('created_at'));

        aFill		:= aOrder.Fills.Find( sTrdID );

        if aFill = nil then
        begin
          aFill	:=  App.Engine.TradeCore.Fills[ekBithumb].New( sTrdID, dtTime, now,
            aRef, aOrder, sVolume, sPrice);
          aFill.Fee := aFill.Volume*aFill.Price*(dFee/100) ;    //
          App.DebugLog('Bithumb Spot Fill : %s, %s, %s, %s, %s, %s, %f, %s ', [ aOrder.Symbol.Code,
            aOrder.SideToStr, sTmp, aRef,  sPrice, sVolume, aFill.Fee, sTrdID
          ]);

          aList.Add(aFill);
        end;
      end;  // for

      for i := 0 to aList.Count-1 do
      begin
        bDone   := false;
        aFill := TFill( aList.Items[i] );
        if (i = aList.Count-1) and (bComplete) then
          bDone := true;
        App.Engine.TradeBroker.Fill( aOrder, aFill, bDone );
      end;

    finally
      aList.Free;
    end;
  end;

begin
  if aData = '' then
  begin
    App.Log(llError, '%s %s ParseSoptOrderDetail data is empty',
       [ TExchangeKindDesc[FParent.ExchangeKind],  TMarketTypeDesc[mtSpot] ] ) ;
    Exit;
  end;

  aOrder	:= App.Engine.TradeCore.FindOrder( ekBithumb, aRef, DIV_ORD_NO );
  if aOrder = nil then
  begin
    App.Log(llError, '%s %s not found order : %s',
       [ TExchangeKindDesc[FParent.ExchangeKind],  TMarketTypeDesc[mtSpot], aRef ] ) ;
    Exit;
  end else
    App.Log(llError, '%s %s order info : %s',
       [ TExchangeKindDesc[FParent.ExchangeKind],  TMarketTypeDesc[mtSpot], aOrder.Represent ] ) ;
  //if aOrder.State <> osActive then Exit;

	aObj := TJSONObject.ParseJSONValue(aData) as TJsonObject;
  if aObj = nil then Exit;

  try
    aErr := aObj.GetValue('error');
    if aErr <> nil then
    begin
      App.Log(llError, '%s ParseSpotOrderDetail Error %s, %s',[
        TExchangeKindDesc[FParent.ExchangeKind] , aErr.GetValue<string>('message'), aRef ] );
      Exit;
    end;
{
done : ŔüĂĽ ĂĽ°á żĎ·á
cancel: ÁÖą® ĂëĽŇ
}
    sTmp	:= aObj.GetValue('state').Value;

    if sTmp = 'done' then
    begin
			aArr	:= aObj.GetValue('trades') as TJsonArray;
      ProcFill(aArr, true);
    end else
    if sTmp = 'cancel' then
    begin
      // şÎşĐ ĂĽ°á ¸ŐŔú Ăł¸®.
			aArr	:= aObj.GetValue('trades') as TJsonArray;
      ProcFill(aArr);
      // łŞ¸ÓÁö ĂëĽŇ Ăł¸®.
      App.Engine.TradeBroker.Cancel( aOrder, true);
    end;

  finally
    if aObj <> nil then aObj.Free;
  end;

end;

