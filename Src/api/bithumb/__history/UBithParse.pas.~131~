procedure TBithParse.ParseSpotMyOrder(aJson: TJsonObject);
var
  sOID, sState, sFillNo: string;
  aOrder: TOrder;
  aFill  : TFill;
  dtTime : TDateTime;
  aRslt  : TOrderResult;
  tc, i  : integer;
begin
  App.Log(llDebug,'bithumb_order', '%s', [aJson.ToString]) ;

  aOrder := nil;
  try
    sOID  := aJson.GetValue('uuid').Value;
    aOrder  := App.Engine.TradeCore.FindOrder(FParent.ExchangeKind, sOID, DIV_ORD_NO);
    sState  := aJson.GetValue('state').Value;

    aRslt   := nil;
    if aOrder = nil then
    begin
      if (sState = 'trade') or (sState = 'done') then
      begin
        aRslt := App.Engine.TradeCore.OrderResult[ekBithumb].New(aOrder, rtFill);
        aRslt.OrderNo := sOID;
        aRslt.Volume  := aJson.GetValue<double>('volume');
        aRslt.Price   := aJson.GetValue<double>('price');
        aRslt.FillNo  := aJson.GetValue('trade_uuid').Value;
        aRslt.Time    := UnixTimeToDateTime(aJson.GetValue<string>('trade_timestamp'));
        aRslt.TC      := aJson.GetValue<integer>('trades_count', 0);
        aRslt.RVolume := aJson.GetValue<double>('remaining_volume');
        aRslt.Fee     := aJson.GetValue<double>('paid_fee');
        FForwardOrderResults.Add(aRslt);
      end else
      if ssTate = 'wait' then
      begin
        aRslt := App.Engine.TradeCore.OrderResult[ekBithumb].New(aOrder, rtWait);
        aRslt.OrderNo := sOID;
        aRslt.Time    := UnixTimeToDateTime(aJson.GetValue<string>('order_timestamp'));
        FForwardOrderResults.Add(aRslt);
      end else
      if sState = 'cancel' then
      begin
        aRslt := App.Engine.TradeCore.OrderResult[ekBithumb].New(aOrder, rtCancel);
        aRslt.OrderNo := sOID;
        aRslt.TC      := aJson.GetValue<integer>('trades_count', 0);
        aRslt.RVolume := aJson.GetValue<double>('remaining_volume');
        FForwardOrderResults.Add(aRslt);
      end;

      if aRslt <> nil then
        App.Log(llINfo, 'Bithumb MyOrder %s %s żŞŔü : %d', [aRslt.TypeToStr, aRslt.OrderNo, FForwardOrderResults.Count ]);
      Exit;
    end;

    if sState = 'wait' then
    begin
      // żŞŔüĂł¸®´Â ż©±âĽ­ ľČÇŃ´Ů..
      dtTime := UnixTimeToDateTime(aJson.GetValue<string>('order_timestamp'));
   		App.Engine.TradeBroker.Accept( aOrder, dtTime, true, '0000' ) ;
    end else
    if sState = 'cancel' then
    begin
      tc  := aJson.GetValue<integer>('trades_count', 0);

      var v, rv, ev : double;
      v  := aJson.GetValue<double>('volume');
      rv := aJson.GetValue<double>('remaining_volume');
      ev := aJson.GetValue<double>('executed_volume');

      if ((v - (rv + ev)) <= EPSILON) then
        App.Engine.TradeBroker.Cancel(aOrder, true)
      else begin
        App.Log(llInfo, 'bithumb ĂëĽŇ żŞŔü : (tc:%d>%d) | vol:%.8f > %.8f(%.8f + %.8f), %s ',
           [ tc, aOrder.Fills.Count, v, rv + ev, rv, ev, aOrder.Represent]  );
        aRslt := App.Engine.TradeCore.OrderResult[ExKind].New(aOrder, rtCancel);
        aRslt.Volume  := rv;
        FForwardOrderResults.Add(aRslt);
      end;

    end else
    if (sState = 'trade') or (sState = 'done') then
    begin
      sFillNo := aJson.GetValue('trade_uuid').Value;
      aFill   := aOrder.Fills.Find(sFillNo);

      var  dVolume, dPrice, dRv : double;

      dRv := aJson.GetValue<double>('remaining_volume');
      if aFill = nil then
      begin
        dVolume:= aJson.GetValue<double>('executed_volume');
        dPrice := aJson.GetValue<double>('price');
        dtTime := UnixTimeToDateTime(aJson.GetValue<string>('trade_timestamp'));
        aFill	 := App.Engine.TradeCore.Fills[ekUpbit].New(sFillNo, dtTime, now,
              sOID, aOrder, dVolume, dPrice);
        aFill.Fee := aJson.GetValue<double>('paid_fee',0);

        App.Log(llInfo, 'Bithumb Spot Fill(%s) - ws : %s, %s, %s, %s, %s, %.8f, %f, %s ', [
          sState, aOrder.Symbol.Code, aOrder.SideToStr, '',
          sOID,  aOrder.Symbol.PriceToStr(dPrice), dVolume, aFill.Fee, sFillNo
        ]);

        App.Engine.TradeBroker.Fill( aOrder, aFill, dRv <= EPSILON);
      end;

      //tc  := aJson.GetValue<integer>('trades_count', 0);
      // żŞŔü Ăł¸®..
      var bRemove : boolean;
      for I := FForwardOrderResults.Count-1 downto 0 do
      begin
        aRslt := FForwardOrderResults.Results[i];
        if aRslt <> nil then
          bRemove := false;
          if aRslt.Order = aOrder then
          begin

            case aRslt.ResultType of
              rtCancel: //if tc = aOrder.Fills.Count then şř˝ćŔş TC °ˇ ¸ÂÁö ľĘ´Â´Ů.
                        begin
                          App.Engine.TradeBroker.Cancel( aOrder, true) ;
                          bRemove := true;
                        end;
              else Continue;
            end;

            if bRemove then
            begin
              FForwardOrderResults.Remove(aRslt);
              App.Log(llInfo,'Bithumb Forward Result : %s, %s, %s',[aRslt.TypeToStr,
                aOrder.Symbol.QtyToStr(aRslt.Volume), aOrder.Symbol.QtyToStr(aRslt.Price),
                aOrder.Represent ]  );
            end;
          end;
      end;
    end;
  except
    on e: Exception do
    begin
      var ss := 'nil';
      if aOrder <> nil then
        ss := 'not nil';

      App.Log(llError, '%s myOrder Parse Error: %s, %s, %s', [ExKindToStr(ekBithumb),
        sState, ss, e.Message] );
    end;
  end;

end;

procedure TBithParse.ParseSpotOrderBook(aData: string);
var
  aObj, aSub, master : TJsonObject;
  aArr : TJsonArray;
  aPair : TJsonPair;
  aVal  : TJsonValue;
  i : Integer;
  sBase, sCode, sTmp : string;
  aSymbol : TSymbol;
  bNew : boolean;
  j: Integer;
  aQuote : TQuote;
begin
  master := TJsonObject.ParseJSONValue( aData ) as TJsonObject;
  aObj := master.GetValue('data') as TJsonObject;

  try
    for I := 0 to aObj.Size-1 do
    begin
      aPair := aObj.Get(i);
      if aPair.JsonValue.ClassType <> TJSONObject then continue;
      sCode := aPair.JsonString.Value;

      aSymbol := App.Engine.SymbolCore.FindSymbol(FParent.ExchangeKind, sCode );
      if aSymbol <> nil then
      begin
        aSub  := aPair.JsonValue as TJsonObject;
        aArr  := aSub.Get('bids').JsonValue as TJsonArray;

//        if aArr.Count > 0 then begin
//          aVal  := aArr.Get(0);
//          aSymbol.Bids[0].Price   := StrToFloatDef( aVal.GetValue<string>( 'price' ), 0.0 );
//          aSymbol.Bids[0].Volume  := StrToFloatDef( aVal.GetValue<string>( 'quantity' ), 0.0 );
//        end;

        if aArr <> nil then
          for j := 0 to aArr.Size-1 do
          begin
          	if j >= aSymbol.Bids.Size then Exit;            
            aVal  := aArr.Get(j);
            aSymbol.Bids[j].Price   := StrToFloatDef( aVal.GetValue<string>( 'price' ), 0.0 );
            aSymbol.Bids[j].Volume  := StrToFloatDef( aVal.GetValue<string>( 'quantity' ), 0.0 );
          end;

        aArr  := aSub.Get('asks').JsonValue as TJsonArray;

//        if aArr.Count > 0 then
//        begin
//          aVal  := aArr.Get(0);
//          aSymbol.Asks[0].Price   := StrToFloatDef( aVal.GetValue<string>( 'price' ), 0.0 );
//          aSymbol.Asks[0].Volume  := StrToFloatDef( aVal.GetValue<string>( 'quantity' ), 0.0 );
//        end;

        if aArr <> nil then        
          for j := 0 to aArr.Size-1 do
          begin
          	if j >= aSymbol.Bids.Size then Exit;            
            aVal  := aArr.Get(j);
            aSymbol.Asks[j].Price   := StrToFloatDef( aVal.GetValue<string>( 'price' ), 0.0 );
            aSymbol.Asks[j].Volume  := StrToFloatDef( aVal.GetValue<string>( 'quantity' ), 0.0 );
          end;        

        if App.AppStatus > asLoad then  begin
          App.Engine.SymbolCore.CalcKimp( aSymbol );
          aQuote:= App.Engine.QuoteBroker.Brokers[FParent.ExchangeKind].Find(aSymbol.Code)    ;
          if aQuote <> nil then  begin
            aQuote.LastEvent := qtMarketDepth;
            aQuote.Update(now);
          end;
        end;
      end;

    end;
  //  if ( GetCodeIndex( sCode ) < 0 ) then Continue;

  finally
    if master <> nil then master.Free;
  end;
end;


