procedure TBithParse.ParseActiveOrders(const aList: TList<TOrder>; aData: string);
var
  aObj, aObj2 : TJsonObject;
  aArr : TJsonArray;
  aVal : TJsonValue;

  aOrder : TOrder;

  sCode, sOrderId, sState : string;
  I, tCnt : Integer;
  sts : TArray<string>;
  sUids : TList;

  a : ^TTmpID;
  j: Integer;
begin

  if aData = '' then
  begin
    App.Log(llError, '%s ParseActiveOrders data is empty', [ TExchangeKindDesc[FParent.ExchangeKind] ] ) ;
    Exit;
  end;

  aVal := TJsonObject.ParseJSONValue( aData);// as TJsonObject;
  if aVal = nil then Exit;

  try
    if aVal is TJsonObject then
    begin
      aObj  := aVal.GetValue<TJsonObject>('error');
      if aObj <> nil then
        App.Log(llError, ' %s ParseActiveOrders : %s', [
          TExchangeKindDesc[FParent.ExchangeKind],  aData ] );
      Exit;
    end;

    aArr	:= aVal as TJsonArray;

    if aArr.Count <= 0 then
    begin
      for I := 0 to aList.Count-1 do
      begin
        //
        App.DebugLog('changed state because A : %s', [ aList[i].Represent] );
        TBithManager(App.Engine.ApiManager.ExManagers[ekBithumb]).ThreadPool.PushTask(rttDetail, aList[i]);
      end;
      exit;
    end else
    begin

      sUids := TList.Create;
      try
        for I := 0 to aArr.Count-1 do
        begin
          aVal	:= aArr.Items[i];       New(a);
          a.uuid  := aVal.GetValue<string>('uuid');
          a.state := aVal.GetValue<string>('state');
          a.tcnt  := aVal.GetValue<integer>('trades_count');
          sUids.Add(a);
        end;

        var bFind : boolean;
        for I := 0 to aList.Count-1 do begin
          bFind := false;
          for j := 0 to sUids.Count-1 do begin
            bFind := true;
            if TTmpID(sUids[j]^).uuid = aList[i].OrderNo then
            begin
              if TTmpID(sUids[j]^).tCnt <> aList[i].Fills.Count then begin
                //
                App.DebugLog('changed state because B : %s', [ aList[i].Represent] );
                TBithManager(App.Engine.ApiManager.ExManagers[ekBithumb]).ThreadPool.PushTask(rttDetail, aList[i]);
              end;
              Dispose(sUids[j]);
              sUids.Delete(j);
              break;
            end;
          end;

          if not bFind then begin
            //
            App.DebugLog('changed state because A : %s', [ aList[i].Represent] );
            TBithManager(App.Engine.ApiManager.ExManagers[ekBithumb]).ThreadPool.PushTask(rttDetail, aList[i]);
          end;
        end;

      finally

        while sUids.Count > 0 do
        begin
          Dispose(sUids[sUids.Count-1]);
          sUids.Delete(sUids.Count-1);
        end;
        FreeAndNil(sUids);
      end;
    end;

  finally
    if aVal <> nil  then aVal.Free;
  end;
end;

