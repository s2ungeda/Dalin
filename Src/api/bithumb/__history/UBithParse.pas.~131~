procedure TBithParse.ParseOrders(aData: string);
var
  aObj, aObj2 : TJsonObject;
  aArr : TJsonArray;
  aVal : TJsonValue;

  aAcnt	: TAccount;
  aOrder : TOrder;
  aSymbol: TSymbol;
  sCode, sOrderId : string;
  I, iSide : Integer;
  dPrice , dVolume : double;
  dtTime : TDateTime;

  sts : TArray<string>;

  aList : TList<TTmpID>;
begin

  if aData = '' then
  begin
    App.Log(llError, '%s ParseOrders data is empty', [ TExchangeKindDesc[FParent.ExchangeKind] ] ) ;
    Exit;
  end;

  aVal := TJsonObject.ParseJSONValue( aData);// as TJsonObject;
  if aVal = nil then Exit;

  try
    if aVal is TJsonObject then
    begin
      aObj  := aVal.GetValue<TJsonObject>('error');
      if aObj <> nil then
        App.Log(llError, ' %s ParseOrders : %s', [
          TExchangeKindDesc[FParent.ExchangeKind],  aData ] );
      Exit;
    end;

    aArr	:= aVal as TJsonArray;
    aAcnt := App.Engine.TradeCore.FindAccount(FParent.ExchangeKind);
    if aAcnt = nil then Exit;

    for I := 0 to aArr.Size-1 do
    begin
    	aVal	:= aArr.Get(i);
      sCode	:= aVal.GetValue<string>('market', '');
      if sCode = '' then continue;

      sts := sCode.Split(['-']);
    	aSymbol := App.Engine.SymbolCore.FindSymbol(ekBithumb, sts[1]);
      if aSymbol = nil then continue;

      sOrderId:= aVal.GetValue<string>('uuid');
      aOrder	:= App.Engine.TradeCore.Orders[ekBithumb].Find(aAcnt, aSymbol, sOrderId);
      dtTime  := GetStrToTime(aVal.GetValue<string>('created_at'));

      if aOrder = nil then
      begin
      	iSide	:= ifThen( aVal.GetValue<string>('side') = 'bid', 1, -1 );
        dVolume	:= aVal.GetValue<double>( 'remaining_volume', 0 );
        dPrice	:= aVal.GetValue<double>( 'price', 0 );

        aOrder	:= App.Engine.TradeCore.Orders[ekBithumb].NewOrder( aAcnt
        	, aSymbol, iSide, dVolume, pcLimit, dPrice, tmGTC );

        if aOrder <> nil then
        begin
          aOrder.OrderNo  :=  sOrderId;
          App.Engine.TradeBroker.Accept(aOrder, dtTime, true);
        end;
      end;
    end;

  finally
    if aVal <> nil  then aVal.Free;
  end;

end;

