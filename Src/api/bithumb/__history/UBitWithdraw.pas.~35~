procedure TBitWithdraw.RequestWithdrawList(sCurrency : string; bFirst : boolean);
var
  sRsrc, sVal, sSig, sTmp, sTime, sData : string;
begin

  sRsrc := '/info/user_transactions';
  Req.init(rmPOST, 'https://api.bithumb.com',sRsrc, 'withdrawlist' );

  sTmp := sRsrc+'&searchGb=5&payment_currency=KRW&order_currency='+sCurrency+'&count=1';
  sTime:= GetTimestamp;
  sVal := TBithSpot(App.Engine.ApiManager.ExManagers[ekBithumb].Exchanges[eaSpot]).EncodePath(
    sRsrc, Format('endPoint=%s', [sTmp]), sTime
  );

  sSig  := CalculateHMACSHA512( sVal, App.Engine.ApiConfig.GetSceretKey( ekBithumb, eaSpot));
  sData	:= TIdEncoderMIME.EncodeString( sSig, IndyTextEncoding_UTF8 );

  Req.Client.Params.Clear;
  Req.Req.Params.Clear;

  with Req do
  begin
    Req.AddParameter('Api-Key', App.Engine.ApiConfig.GetApiKey(ekBithumb, eaSpot) , TRESTRequestParameterKind.pkHTTPHEADER );//, [poDoNotEncode]);
    Req.AddParameter('Api-Sign', sData , TRESTRequestParameterKind.pkHTTPHEADER , [poDoNotEncode]);
    Req.AddParameter('Api-Nonce', sTime , TRESTRequestParameterKind.pkHTTPHEADER );

    Req.AddParameter('endPoint', sRsrc, TRESTRequestParameterKind.pkREQUESTBODY);

    Req.AddParameter('searchGb', '5', TRESTRequestParameterKind.pkREQUESTBODY);
    Req.AddParameter('payment_currency', 'KRW', TRESTRequestParameterKind.pkREQUESTBODY);
    Req.AddParameter('order_currency', sCurrency, TRESTRequestParameterKind.pkREQUESTBODY);

    Req.AddParameter('count', '1', TRESTRequestParameterKind.pkREQUESTBODY);
  end;

  Req.Field1  := sCurrency;
  Req.Field2  := ifThenStr( bFirst, 'first', 'multi');

  Req.RequestAsync;
  Param.Clear;
end;

procedure TBitWithdraw.ReuqestWithdraw;
var
  sQuery,sRsrc : string;
  LToken: TJWT;
  mtd: TRESTRequestMethod;
  aBody : TJsonObject;
begin

  LToken:= TJWT.Create(TJWTClaims);
  aBody := nil;

  try
    with Req do
    begin
      Client.Params.Clear;
      Req.Params.Clear;
      Req.Body.ClearBody;
    end;

    if Param.addr2.IsEmpty then
    begin
      sQuery := Format('currency=%s&net_type=%s&amount=%s&address=%s' +
          '&exchange_name=%s&receiver_en_name=%s&receiver_type=%s&receiver_ko_name=%s',
        [
          Param.currency, Param.nettype, Param.qty, Param.addr1,
          Param.exname, Param.engname, 'personal', Param.korname
        ]);
    end else
    begin
      sQuery := Format('currency=%s&net_type=%s&amount=%s&address=%s&secondary_address=%s' +
          '&exchange_name=%s&receiver_en_name=%s&receiver_type=%s&receiver_ko_name=%s',
        [
          Param.currency, Param.nettype, Param.qty, Param.addr1, Param.addr2,
          Param.exname, Param.engname, 'personal', Param.korname
        ]);
    end;

    SetToken(LToken, sQuery);

    sRsrc := '/v1/withdraws/coin';//?' + sQuery;
    aBody := TJSONObject.Create;

    with aBody do
    begin
      AddPair('currency', Param.currency);
      AddPair('net_type', Param.nettype);
      AddPair('amount',   Param.qty);
      AddPair('address',  Param.addr1);
      if not Param.addr2.IsEmpty then
        AddPair('secondary_address', Param.addr2);
      //
      AddPair('exchange_name', Param.exname);
      AddPair('receiver_en_name', Param.engname);
      AddPair('receiver_type', 'personal');
      AddPair('receiver_ko_name', Param.korname);

      Req.Req.Body.Add(aBody);
    end;

    Req.init(rmPOST, 'https://api.bithumb.com', sRsrc, 'withdraw');
    Req.RequestAsync;

    App.Log(llInfo, 'Bithumb %s Ăâ±Ý -> %s, %s(%s)', [Param.currency, Param.qty, Param.addr1, Param.addr2] );

  finally
    FreeAndNil(LToken);
    FreeAndNil(aBody);
  end;
end;

procedure TBitWithdraw.Parse(const aType, aData: string);
var
  aObj, aSub : TJsonObject;
  aVal  : TJsonValue;
  aArr  : TJsonArray;
  sRes : string;
  I, idx, iRes: Integer;
  dQty: double;
begin
  if aDAta = '' then
  begin
    DoNotify( 'Ăâ±Ý żäĂ» ˝ÇĆĐ', 999);
    Exit;
  end;

  if aType = 'status' then
  begin
    aObj := TJsonObject.ParseJSONValue( aData) as TJsonObject;
    try
      if IsError(aObj.GetValue('error')) then Exit;

      aArr  := aObj.GetValue('currency').GetValue<TJsonArray>('wallet_support');
      var bAble := false;
      for I := 0 to aArr.Count-1 do
        if aArr.Items[i].Value = 'withdraw' then
        begin
          bAble := true;
          break;
        end;

      if not bAble then
      begin
        DoNotify(RES_WT,'Ăâ±Ý şŇ°ˇ', 999);
        Exit;
      end else
        ReuqestWithdraw;

    finally
      FreeAndNil(aObj);
    end;
  end else
  if aType = 'address' then
  begin
    aVal := TJsonObject.ParseJSONValue( aData);

    try
      if aVal is TJSONObject then begin
        if IsError(aVal.GetValue<TJsonObject>('error')) then Exit;
        Exit;
      end ;

      aArr := aVal as TJsonArray;

      Address.Clear;

      for I := 0 to aArr.Count-1 do
      begin
        aVal  := aArr.Items[i];

        var Rec := Default(TDepositAddress);
        with Rec do
        begin
          Exchange  := TExchangeKindDesc[ekBithumb];

          Coin      := aVal.GetValue<string>('currency');
          NetType   := aVal.GetValue<string>('net_type');
          NetName   := aVal.GetValue<string>('network_name');
          Address   := aVal.GetValue<string>('withdraw_address');
          Memo      := aVal.GetValue<string>('secondary_address');

          WithdrawExchange  := aVal.GetValue<string>('exchange_name');
          OnwerKorName      := aVal.GetValue<string>('owner_ko_name');
          OnwerEngName      := aVal.GetValue<string>('owner_en_name');
          OwnerType := aVal.GetValue<string>('owner_type');
        end;

        Address.Add(Rec);
      end;

      DoNotify(aType);

    finally
      FreeAndNil(aVal);
    end;

  end else
  if aType = 'bwdmin' then
  begin
    aObj := TJsonObject.ParseJSONValue( aData) as TJsonObject;
    try
      sRes  := aObj.GetValue('status').Value;
      if sRes <> '0000' then begin
        DoNotify( aObj.GetValue('message').Value, 999 );
        Exit;
      end;
      aArr := aObj.GetValue('data') as TJsonArray;
      for I := 0 to aArr.Size-1 do
      begin
        aVal := aArr.Get(i);
        sRes := aVal.GetValue<string>('minimum');
        DoNotify( Format('Ăâ±Ý °ˇ´É, ĂÖĽŇĽö·®:%s', [sRes]) );
      end;
    finally
      FreeAndNil(aObj);
    end;
  end else
  if aType = 'withdraw' then
  begin
    aObj := TJsonObject.ParseJSONValue( aData) as TJsonObject;
    try
      if IsError(aObj.GetValue('error')) then Exit;

      DoNotify( RES_WT, 'Ăâ±ÝĽş°ř' );
      // ŔÜ°í Ăł¸®
      DoUpdateAsset;
      //

    finally
      FreeAndNil(aObj);
    end;
  end else
  if aType = 'depositaddr' then
  begin
    aObj := TJsonObject.ParseJSONValue( aData) as TJsonObject;
    try
      if IsError(aObj.GetValue('error')) then Exit;
      var sTmp := aObj.GetValue('secondary_address').Value;
      if sTmp = 'null' then
        sRes := aObj.GetValue('deposit_address').Value
      else
        sRes := aObj.GetValue('deposit_address').Value + '='+ sTmp;
      DoNotify(sRes);
    finally
      FreeAndNil(aObj);
    end;
  end else
  if aType = 'withdrawlist' then
  begin
    aObj := TJsonObject.ParseJSONValue( aData) as TJsonObject;
    try
      sRes  := aObj.GetValue('status').Value;
      if sRes <> '0000' then begin
        DoNotify( RES_WT_LIST, aObj.GetValue('message').Value, 999 );
        Exit;
      end;

      idx := ifThen( Req.Field2 = 'first', 0, 1);
      FWtData[idx] := '';

      aArr  := aObj.GetValue('data') as TJsonArray;
      for I := 0 to aArr.Count-1 do
      begin
        aVal  := aArr.Get(i);
        FWtData[idx] := aVal.GetValue<string>('transfer_date')+aVal.GetValue<string>('units');
      end;

      if idx = 1 then
      begin
        if FWtData[0] <> FWtData[1] then
          DoNotify(RES_WT_LIST, aType);
      end;

    finally
      FreeAndNil(aObj);
      Req.Field1 := ''; Req.Field2 := '';
    end;
  end
  else
    DoNotify( 'Ŕß¸řµČ żäĂ»', 999 );

end;


end.
