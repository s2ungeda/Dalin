procedure TBitWithdraw.SetToken(var jwt : TJWT; const sQuery: string);
var
  vHash : THashSHA2;
  sToken, sSig: string;
begin
  with jwt do
  begin
    Claims.SetClaimOfType<string>('access_key', App.Engine.ApiConfig.GetApiKey(ekBithumb, eaSpot, 1));
    Claims.SetClaimOfType<string>('nonce', GetUUID );
    Claims.SetClaimOfType<int64>('timestamp', StrToInt64(GetTimestamp) );
    if not sQuery.IsEmpty then
    begin
      Claims.SetClaimOfType<string>('query_hash', vHash.gethashstring( sQuery, SHA512 ) );
      Claims.SetClaimOfType<string>('query_hash_alg', 'SHA512' );
    end;
  end;

  sSig := TJOSE.SerializeCompact(App.Engine.ApiConfig.GetSceretKey(ekBithumb, eaSpot, 1),
                                 TJOSEAlgorithmId.HS512, jwt);
  sToken:= Format('Bearer %s', [sSig]);


  Req.Req.AddParameter('Authorization', sToken, TRESTRequestParameterKind.pkHTTPHEADER, [poDoNotEncode]);
end;


procedure TBitWithdraw.DoUpdateAsset;
begin
  App.Engine.TradeCore.Accounts[ekBithumb].WidthDrawCoin(ekBithumb, UpperCase(Param.currency), Param.qty);
  App.Log(llInfo, 'şř˝ć : %s', [Param.Represent]);
end;

procedure TBitWithdraw.DoWithdraw;
begin
  DoWithdrawAble
end;

procedure TBitWithdraw.DoWithdrawAble;
var
  sQuery,sRsrc : string;
  LToken: TJWT;

begin

  LToken:= TJWT.Create(TJWTClaims);

  try
    with Req do
    begin
      Client.Params.Clear;
      Req.Params.Clear;
      Req.Body.ClearBody;
    end;

    sQuery := 'currency='+Param.currency+'&net_type='+Param.nettype;
    SetToken(LToken, sQuery);
    sRsrc := '/v1/withdraws/chance?' + sQuery;

    Req.init(rmGET, 'https://api.bithumb.com', sRsrc, 'status');

    Req.Field1  := Param.currency;
    Req.Field2  := Param.nettype;
    Req.RequestAsync;

  finally
    FreeAndNil(LToken);
  end;

end;

function TBitWithdraw.IsError(aVal: TObject): boolean;
begin
  if aVal = nil then Exit (false);
  DoNotify((aVal as TJsonValue).GetValue<string>('message') , 999);
  Result := true;
end;

procedure TBitWithdraw.RecvRequest(Sender: TObject);
begin
  Parse( Req.Name, Req.Rsp.Content );
end;


procedure TBitWithdraw.RequestDepositAddress(sCurrency, sNetType: string; iDiv:Integer);
var
  sQuery,sRsrc : string;
  LToken: TJWT;
  mtd: TRESTRequestMethod;
  aBody : TJsonObject;
begin

  LToken:= TJWT.Create(TJWTClaims);
  aBody := nil;
  try
    with Req do
    begin
      Client.Params.Clear;
      Req.Params.Clear;
      Req.Body.ClearBody;
    end;

    sQuery := 'currency='+sCurrency+'&net_type='+sNetType;

    case iDiv of
      NEW_ADDR : // »ýĽş
        begin
          mtd := rmPOST;
          sRsrc := '/v1/deposits/generate_coin_address';//?' + sQuery;
          aBody := TJSONObject.Create;

          with aBody do
          begin
            AddPair('currency', sCurrency);
            AddPair('net_type', sNetType);
            Req.Req.Body.Add(aBody);
          end;
        end;
      REQ_ADDR : // Á¶Č¸
        begin
          mtd := rmGET;
          sRsrc := '/v1/deposits/coin_address?' + sQuery;
        end;
    end;

    SetToken(LToken, sQuery);

    Req.init(mtd, 'https://api.bithumb.com', sRsrc, 'depositaddr');

    Req.Field1  := sCurrency;
    Req.Field2  := sNetType;
    Req.RequestAsync;

  finally
    FreeAndNil(LToken);
    FreeAndNil(aBody);
  end;
end;

procedure TBitWithdraw.RequestDepositAddress(sCurrency, sNetType: string);
begin
  RequestDepositAddress(sCurrency, sNetType, REQ_ADDR);
end;

procedure TBitWithdraw.RequestNewDepositAddress(sCurrency, sNetType: string);
begin
  RequestDepositAddress(sCurrency, sNetType, NEW_ADDR);
end;

