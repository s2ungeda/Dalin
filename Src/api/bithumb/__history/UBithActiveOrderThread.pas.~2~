constructor TGetActOrdThread.Create;
begin
  inherited Create(true);
  FreeOnTerminate := false;
  Priority  := tpNormal;

  FIndex  := 0;
  FCount  := 0;

  FLastBalTime  := 0;
end;

destructor TGetActOrdThread.Destroy;
begin
  FEvent.Free;
  FRest.Free;
  inherited;
end;

procedure TGetActOrdThread.DoResume;
begin
  if Suspended then
    Resume;
end;

procedure TGetActOrdThread.Execute;
var
  idx, i, iGap : integer;
  aOrder, aTmp : TOrder;
  sTime, sVal, sParam1, sSig, sBody : string;
begin
  { Place thread code here }
  FRest.Req.init(App.Engine.ApiConfig.GetBaseUrl(ekBithumb, eaSpot ) );
  FRest.AResource :=  '/info/orders';

  for I := 0 to App.Engine.SymbolCore.Symbols[ekBithumb].Count-1 do
  begin

    sParam1	:= App.Engine.SymbolCore.Symbols[ekBithumb].Symbols[i].Code;

    sTime := GetTimestamp;
    sVal  := EncodePath( FRest.AResource, Format('endPoint=%s&order_currency=%s', [ FRest.AResource, sParam1] ), sTime );
    FRest.SetBithumbSig( sVal, sTime );

    with FRest.Req do
    begin
      SetParam('endPoint', FRest.AResource, TRESTRequestParameterKind.pkREQUESTBODY);
      SetParam('order_currency', sParam1,  TRESTRequestParameterKind.pkREQUESTBODY);

      if not Request( rmPOST, FRest.AResource, '', FRest.JsonData, FRest.OutData) then
      begin
         App.Log( llError, '', 'Failed %s ParseBalance-Thread (%s, %s)',
            [ TExchangeKindDesc[FExKind], FRest.JsonData, FRest.OutData] );
         FData.Clear;
         Continue;
      end;

      FData.OutJson := FRest.JsonData;
      Synchronize( SyncProc );
      FData.Clear;
    end;
  end;

  App.Log(llInfo, '%s', 'TGetActOrdThread thread terminated');
end;


