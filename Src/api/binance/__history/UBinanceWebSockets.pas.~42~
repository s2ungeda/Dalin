procedure TBinanceWebSocket.MakeSubList( var aList : TStrings );
var
  sParam, sData : string;
  k : Integer;
begin
  sParam := '';

  for k := 0 to aList.Count-1 do
  begin
    sParam := sParam + Format('"%s"', [aList[k]]);
    if k < aList.Count-1  then
      sParam := sParam + ','
  end;

  aList.Clear;
  inc(FSubIndex);
  sData := Format('{"method": "SUBSCRIBE","params":[%s],"id": %d}', [ sParam, FSubIndex ] );
  SubList.Add(sData);
end;


