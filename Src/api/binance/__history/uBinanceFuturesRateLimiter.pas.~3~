unit UBinanceFuturesRateLimiter;

interface

uses
  System.SysUtils, System.Classes, System.SyncObjs, System.JSON,
  System.Generics.Collections, System.Math;

type
  TTokenBucket = class
  private
    FMaxTokens: Integer;
    FCurrentTokens: Double;
    FRefillRatePerMs: Double;
    FLastRefillTick: Int64;
    FIntervalMs: Int64;
    FInterval: string;

  public
    constructor Create(AInterval: string; AMaxTokens, AUsedCount: Integer; AIntervalMs: Int64);
    procedure Refill;
    function TryConsume(ACount: Integer): Boolean;
    function CanConsume(ACount: Integer): Boolean;
    function GetWaitTimeMs(ACount: Integer): Int64;
    procedure Reset;
    procedure SyncFromServer(AMaxTokens, AUsedCount: Integer; AIntervalMs: Int64);

    property MaxTokens: Integer read FMaxTokens;
    property CurrentTokens: Double read FCurrentTokens;
    property IntervalMs: Int64 read FIntervalMs;

    property Interval: string read FInterval;
  end;

  TBinanceFuturesRateLimiter = class
  private
    FLock: TCriticalSection;
    FOrderBuckets: TObjectList<TTokenBucket>;
    FCancelBuckets: TObjectList<TTokenBucket>;

    function ParseIntervalMs(const AInterval: string; AIntervalNum: Integer): Int64;
    procedure ParseAndLoadBuckets(const AJSON: TJsonArray;
      ABuckets: TObjectList<TTokenBucket>; const ARateLimitType: string);
    function FindBucketByInterval(ABuckets: TObjectList<TTokenBucket>;
      AInterval: string): TTokenBucket;
  public
    constructor Create;
    destructor Destroy; override;

    procedure LoadOrderLimits(const AJSON: TJsonArray);
    procedure LoadCancelLimits(const AJSON: TJsonArray);

    function TryOrder(ACount: Integer = 1): Boolean;
    function TryCancel(ACount: Integer = 1): Boolean;

    function GetOrderWaitTimeMs(ACount: Integer = 1): Int64;
    function GetCancelWaitTimeMs(ACount: Integer = 1): Int64;

    procedure Reset;

    property OrderBuckets: TObjectList<TTokenBucket> read FOrderBuckets;
    property CancelBuckets: TObjectList<TTokenBucket> read FCancelBuckets;
  end;

implementation

uses
  GApp, UApiTypes, UApiConsts
  , Winapi.Windows
  , System.StrUtils
  ;

{ TTokenBucket }

constructor TTokenBucket.Create(AInterval: string; AMaxTokens, AUsedCount: Integer; AIntervalMs: Int64);
begin
  inherited Create;
  FInterval  := AInterval;
  FMaxTokens := AMaxTokens;
  FIntervalMs := AIntervalMs;
  FRefillRatePerMs := AMaxTokens / AIntervalMs;
  FLastRefillTick := GetTickCount64;

  FCurrentTokens := AMaxTokens - AUsedCount;
  if FCurrentTokens < 0 then
    FCurrentTokens := 0;
end;

procedure TTokenBucket.Refill;
var
  CurrentTick, ElapsedMs: Int64;
  TokensToAdd: Double;
begin
  CurrentTick := GetTickCount64;
  ElapsedMs := CurrentTick - FLastRefillTick;

  if ElapsedMs > 0 then
  begin
    TokensToAdd := ElapsedMs * FRefillRatePerMs;
    FCurrentTokens := Min(FCurrentTokens + TokensToAdd, FMaxTokens);
    FLastRefillTick := CurrentTick;
  end;
end;

function TTokenBucket.CanConsume(ACount: Integer): Boolean;
begin
  Refill;
  Result := FCurrentTokens >= ACount;
end;

function TTokenBucket.TryConsume(ACount: Integer): Boolean;
begin
  Refill;
  Result := FCurrentTokens >= ACount;

  if Result then
    FCurrentTokens := FCurrentTokens - ACount;
end;

function TTokenBucket.GetWaitTimeMs(ACount: Integer): Int64;
var
  NeededTokens: Double;
begin
  Refill;

  if FCurrentTokens >= ACount then
    Result := 0
  else
  begin
    NeededTokens := ACount - FCurrentTokens;
    Result := Ceil(NeededTokens / FRefillRatePerMs);
  end;
end;

procedure TTokenBucket.Reset;
begin
  FCurrentTokens := FMaxTokens;
  FLastRefillTick := GetTickCount64;
end;

procedure TTokenBucket.SyncFromServer(AMaxTokens, AUsedCount: Integer; AIntervalMs: Int64);
var
  ServerTokens: Double;
begin

  if FIntervalMs <> AIntervalMs then
  begin
    FIntervalMs :=  AIntervalMs;
    FRefillRatePerMs := AMaxTokens / FIntervalMs;
  end;

  // limit 변경 감지
  if FMaxTokens <> AMaxTokens then
  begin
    FMaxTokens := AMaxTokens;
    FRefillRatePerMs := AMaxTokens / FIntervalMs;
  end;

  Refill;

  ServerTokens := AMaxTokens - AUsedCount;
  if ServerTokens < 0 then
    ServerTokens := 0;

  // 서버 값이 로컬보다 적으면 서버 값으로 (보수적 접근)
  if ServerTokens < FCurrentTokens then
    FCurrentTokens := ServerTokens;
end;

{ TBinanceFuturesRateLimiter }

constructor TBinanceFuturesRateLimiter.Create;
begin
  inherited Create;
  FLock := TCriticalSection.Create;
  FOrderBuckets := TObjectList<TTokenBucket>.Create(True);
  FCancelBuckets := TObjectList<TTokenBucket>.Create(True);
end;

destructor TBinanceFuturesRateLimiter.Destroy;
begin
  FOrderBuckets.Free;
  FCancelBuckets.Free;
  FLock.Free;
  inherited;
end;

function TBinanceFuturesRateLimiter.ParseIntervalMs(const AInterval: string;
  AIntervalNum: Integer): Int64;
begin
  if SameText(AInterval, 'SECOND') then
    Result := Int64(AIntervalNum) * 1000
  else if SameText(AInterval, 'MINUTE') then
    Result := Int64(AIntervalNum) * 60 * 1000
  else if SameText(AInterval, 'HOUR') then
    Result := Int64(AIntervalNum) * 3600 * 1000
  else if SameText(AInterval, 'DAY') then
    Result := Int64(AIntervalNum) * 86400 * 1000
  else
    Result := Int64(AIntervalNum) * 1000;
end;

function TBinanceFuturesRateLimiter.FindBucketByInterval(
  ABuckets: TObjectList<TTokenBucket>; AInterval: string): TTokenBucket;
var
  I: Integer;
begin
  Result := nil;
  for I := 0 to ABuckets.Count - 1 do
  begin
    if ABuckets[I].Interval = AInterval then
      Exit(ABuckets[I]);
  end;
end;

procedure TBinanceFuturesRateLimiter.ParseAndLoadBuckets(const AJSON: TJsonArray;
  ABuckets: TObjectList<TTokenBucket>; const ARateLimitType: string);
var
  JSONValue: TJSONValue;
  JSONObj: TJSONObject;
  AArray: TJSONArray;
  I: Integer;
  Item: TJSONObject;
  LimitType, Interval: string;
  IntervalNum, Limit, UsedCount: Integer;
  IntervalMs: Int64;
  Bucket: TTokenBucket;
begin


  try
    AArray := AJSON;
//    if JSONValue is TJSONObject then
//    begin
//      JSONObj := TJSONObject(JSONValue);
//      JSONObj.TryGetValue<TJSONArray>('rateLimits', AArray);
//    end
//    else if JSONValue is TJSONArray then
//      AArray := TJSONArray(JSONValue);

    if AArray = nil then
      Exit;

    FLock.Enter;
    try
      for I := 0 to AArray.Count - 1 do
      begin
        if not (AArray.Items[I] is TJSONObject) then
          Continue;

        Item := TJSONObject(AArray.Items[I]);
        LimitType := Item.GetValue<string>('rateLimitType', '');

        if not SameText(LimitType, ARateLimitType) then
          Continue;

        Limit := Item.GetValue<Integer>('limit', -1);
        if Limit <= 0 then
          Continue;

        Interval := Item.GetValue<string>('interval', 'SECOND');
        IntervalNum := Item.GetValue<Integer>('intervalNum', 1);
        UsedCount := Item.GetValue<Integer>('count', 0);
        if UsedCount < 0 then
          UsedCount := 0;

        IntervalMs := ParseIntervalMs(Interval, IntervalNum);

        // 기존 버킷 찾기
        Bucket := FindBucketByInterval(ABuckets, Interval);

        if Bucket <> nil then
          // 기존 버킷 동기화
          Bucket.SyncFromServer(Limit, UsedCount, IntervalMs)
        else begin
          // 새 버킷 생성
          ABuckets.Add(TTokenBucket.Create(Interval, Limit, UsedCount, IntervalMs));
          App.DebugLog('%s 버킷 생성 : %s, %d, %d, %d', [ARateLimitType,
            Interval, Limit, UsedCount, IntervalMs]) ;
        end;
      end;
    finally
      FLock.Leave;
    end;
  finally
 //   JSONValue.Free;
  end;
end;

procedure TBinanceFuturesRateLimiter.LoadOrderLimits(const AJSON: TJsonArray);
begin
  ParseAndLoadBuckets(AJSON, FOrderBuckets, 'ORDERS');
end;

procedure TBinanceFuturesRateLimiter.LoadCancelLimits(const AJSON: TJsonArray);
begin
  ParseAndLoadBuckets(AJSON, FCancelBuckets, 'REQUEST_WEIGHT');
end;

function TBinanceFuturesRateLimiter.TryOrder(ACount: Integer): Boolean;
var
  I: Integer;
begin
  FLock.Enter;
  try
    if FOrderBuckets.Count = 0 then
      Exit(True);

    for I := 0 to FOrderBuckets.Count - 1 do
    begin
      if not FOrderBuckets[I].CanConsume(ACount) then
        Exit(False);
    end;

    for I := 0 to FOrderBuckets.Count - 1 do
      FOrderBuckets[I].TryConsume(ACount);

    Result := True;
  finally

    for I := 0 to FOrderBuckets.Count - 1 do
      App.DebugLog('%02d Orders : %s, %d, %d, %d', [i, IfThen(Result, 'True', 'Fals'),
         FOrderBuckets[I].Interval, FOrderBuckets[i].FMaxTokens, FOrderBuckets[i].CurrentTokens]) ;
    FLock.Leave;
  end;
end;

function TBinanceFuturesRateLimiter.TryCancel(ACount: Integer): Boolean;
var
  I: Integer;
begin
  FLock.Enter;
  try
    if FCancelBuckets.Count = 0 then
      Exit(True);

    for I := 0 to FCancelBuckets.Count - 1 do
    begin
      if not FCancelBuckets[I].CanConsume(ACount) then
        Exit(False);
    end;

    for I := 0 to FCancelBuckets.Count - 1 do
      FCancelBuckets[I].TryConsume(ACount);

    Result := True;
  finally

    for I := 0 to FCancelBuckets.Count - 1 do
      App.DebugLog('%02d Cancel : %s, %d, %d, %d', [i, IfThen(Result, 'True', 'Fals'),
         FCancelBuckets[I].Interval, FCancelBuckets[i].FMaxTokens, FCancelBuckets[i].CurrentTokens]) ;

    FLock.Leave;
  end;
end;

function TBinanceFuturesRateLimiter.GetOrderWaitTimeMs(ACount: Integer): Int64;
var
  I: Integer;
  WaitMs: Int64;
begin
  Result := 0;

  FLock.Enter;
  try
    if FOrderBuckets.Count = 0 then
      Exit(0);

    for I := 0 to FOrderBuckets.Count - 1 do
    begin
      WaitMs := FOrderBuckets[I].GetWaitTimeMs(ACount);
      if WaitMs > Result then
        Result := WaitMs;
    end;
  finally
    FLock.Leave;
  end;
end;

function TBinanceFuturesRateLimiter.GetCancelWaitTimeMs(ACount: Integer): Int64;
var
  I: Integer;
  WaitMs: Int64;
begin
  Result := 0;

  FLock.Enter;
  try
    if FCancelBuckets.Count = 0 then
      Exit(0);

    for I := 0 to FCancelBuckets.Count - 1 do
    begin
      WaitMs := FCancelBuckets[I].GetWaitTimeMs(ACount);
      if WaitMs > Result then
        Result := WaitMs;
    end;
  finally
    FLock.Leave;
  end;
end;

procedure TBinanceFuturesRateLimiter.Reset;
var
  I: Integer;
begin
  FLock.Enter;
  try
    for I := 0 to FOrderBuckets.Count - 1 do
      FOrderBuckets[I].Reset;
    for I := 0 to FCancelBuckets.Count - 1 do
      FCancelBuckets[I].Reset;
  finally
    FLock.Leave;
  end;
end;

end.
