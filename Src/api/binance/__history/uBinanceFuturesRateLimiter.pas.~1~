unit uBinanceFuturesRateLimiter;

interface

uses
  System.SysUtils, System.Classes, System.SyncObjs, System.JSON,
  System.Generics.Collections;

type
  TRateLimitType = (rltRequestWeight, rltOrders);
  TRateLimitInterval = (rliSecond, rliMinute);

  TTokenBucket = record
    MaxTokens: Integer;
    CurrentTokens: Double;
    RefillRate: Double;  // tokens per millisecond
    LastRefillTime: TDateTime;
    IntervalMs: Int64;
  end;

  TBinanceFuturesRateLimiter = class
  private
    FLock: TCriticalSection;
    FOrderBuckets: TList<TTokenBucket>;

    function ParseInterval(const AInterval: string; AIntervalNum: Integer): Int64;
    procedure RefillBucket(var ABucket: TTokenBucket);
    function TryConsumeBucket(var ABucket: TTokenBucket; ACount: Integer): Boolean;
  public
    constructor Create;
    destructor Destroy; override;

    procedure LoadFromJSON(const AJSON: string);
    procedure LoadFromJSONArray(AArray: TJSONArray);

    function CanPlaceOrder(ACount: Integer = 1): Boolean;
    function TryPlaceOrder(ACount: Integer = 1): Boolean;
    function GetWaitTimeMs: Int64;

    procedure Reset;
  end;

implementation

uses
  System.DateUtils;

{ TBinanceFuturesRateLimiter }

constructor TBinanceFuturesRateLimiter.Create;
begin
  inherited Create;
  FLock := TCriticalSection.Create;
  FOrderBuckets := TList<TTokenBucket>.Create;
end;

destructor TBinanceFuturesRateLimiter.Destroy;
begin
  FOrderBuckets.Free;
  FLock.Free;
  inherited;
end;

function TBinanceFuturesRateLimiter.ParseInterval(const AInterval: string;
  AIntervalNum: Integer): Int64;
begin
  if SameText(AInterval, 'SECOND') then
    Result := AIntervalNum * 1000
  else if SameText(AInterval, 'MINUTE') then
    Result := AIntervalNum * 60 * 1000
  else if SameText(AInterval, 'HOUR') then
    Result := AIntervalNum * 60 * 60 * 1000
  else if SameText(AInterval, 'DAY') then
    Result := AIntervalNum * 24 * 60 * 60 * 1000
  else
    Result := AIntervalNum * 1000; // default to seconds
end;

procedure TBinanceFuturesRateLimiter.LoadFromJSON(const AJSON: string);
var
  JSONValue: TJSONValue;
  JSONObj: TJSONObject;
  RateLimitsArray: TJSONArray;
begin
  JSONValue := TJSONObject.ParseJSONValue(AJSON);
  try
    if JSONValue is TJSONObject then
    begin
      JSONObj := TJSONObject(JSONValue);
      if JSONObj.TryGetValue<TJSONArray>('rateLimits', RateLimitsArray) then
        LoadFromJSONArray(RateLimitsArray);
    end
    else if JSONValue is TJSONArray then
      LoadFromJSONArray(TJSONArray(JSONValue));
  finally
    JSONValue.Free;
  end;
end;

procedure TBinanceFuturesRateLimiter.LoadFromJSONArray(AArray: TJSONArray);
var
  I: Integer;
  Item: TJSONObject;
  LimitType, Interval: string;
  IntervalNum, Limit: Integer;
  Bucket: TTokenBucket;
begin
  FLock.Enter;
  try
    FOrderBuckets.Clear;

    for I := 0 to AArray.Count - 1 do
    begin
      Item := AArray.Items[I] as TJSONObject;

      LimitType := Item.GetValue<string>('rateLimitType', '');

      // ORDERS 타입만 처리 (REQUEST_WEIGHT는 limit=-1이므로 무시)
      if not SameText(LimitType, 'ORDERS') then
        Continue;

      Limit := Item.GetValue<Integer>('limit', -1);
      if Limit <= 0 then
        Continue;

      Interval := Item.GetValue<string>('interval', 'SECOND');
      IntervalNum := Item.GetValue<Integer>('intervalNum', 1);

      Bucket.MaxTokens := Limit;
      Bucket.CurrentTokens := Limit;
      Bucket.IntervalMs := ParseInterval(Interval, IntervalNum);
      Bucket.RefillRate := Limit / Bucket.IntervalMs;  // tokens per ms
      Bucket.LastRefillTime := Now;

      FOrderBuckets.Add(Bucket);
    end;
  finally
    FLock.Leave;
  end;
end;

procedure TBinanceFuturesRateLimiter.RefillBucket(var ABucket: TTokenBucket);
var
  CurrentTime: TDateTime;
  ElapsedMs: Int64;
  TokensToAdd: Double;
begin
  CurrentTime := Now;
  ElapsedMs := MilliSecondsBetween(CurrentTime, ABucket.LastRefillTime);

  if ElapsedMs > 0 then
  begin
    TokensToAdd := ElapsedMs * ABucket.RefillRate;
    ABucket.CurrentTokens := ABucket.CurrentTokens + TokensToAdd;

    if ABucket.CurrentTokens > ABucket.MaxTokens then
      ABucket.CurrentTokens := ABucket.MaxTokens;

    ABucket.LastRefillTime := CurrentTime;
  end;
end;

function TBinanceFuturesRateLimiter.TryConsumeBucket(var ABucket: TTokenBucket;
  ACount: Integer): Boolean;
begin
  RefillBucket(ABucket);
  Result := ABucket.CurrentTokens >= ACount;

  if Result then
    ABucket.CurrentTokens := ABucket.CurrentTokens - ACount;
end;

function TBinanceFuturesRateLimiter.CanPlaceOrder(ACount: Integer): Boolean;
var
  I: Integer;
  Bucket: TTokenBucket;
begin
  Result := True;

  FLock.Enter;
  try
    for I := 0 to FOrderBuckets.Count - 1 do
    begin
      Bucket := FOrderBuckets[I];
      RefillBucket(Bucket);
      FOrderBuckets[I] := Bucket;

      if Bucket.CurrentTokens < ACount then
      begin
        Result := False;
        Break;
      end;
    end;
  finally
    FLock.Leave;
  end;
end;

function TBinanceFuturesRateLimiter.TryPlaceOrder(ACount: Integer): Boolean;
var
  I: Integer;
  Bucket: TTokenBucket;
  CanConsume: Boolean;
begin
  FLock.Enter;
  try
    // 먼저 모든 버킷 확인
    CanConsume := True;
    for I := 0 to FOrderBuckets.Count - 1 do
    begin
      Bucket := FOrderBuckets[I];
      RefillBucket(Bucket);
      FOrderBuckets[I] := Bucket;

      if Bucket.CurrentTokens < ACount then
      begin
        CanConsume := False;
        Break;
      end;
    end;

    // 모든 버킷에서 소비 가능하면 실제 소비
    if CanConsume then
    begin
      for I := 0 to FOrderBuckets.Count - 1 do
      begin
        Bucket := FOrderBuckets[I];
        Bucket.CurrentTokens := Bucket.CurrentTokens - ACount;
        FOrderBuckets[I] := Bucket;
      end;
    end;

    Result := CanConsume;
  finally
    FLock.Leave;
  end;
end;

function TBinanceFuturesRateLimiter.GetWaitTimeMs: Int64;
var
  I: Integer;
  Bucket: TTokenBucket;
  NeededTokens: Double;
  WaitMs, MaxWaitMs: Int64;
begin
  MaxWaitMs := 0;

  FLock.Enter;
  try
    for I := 0 to FOrderBuckets.Count - 1 do
    begin
      Bucket := FOrderBuckets[I];
      RefillBucket(Bucket);
      FOrderBuckets[I] := Bucket;

      if Bucket.CurrentTokens < 1 then
      begin
        NeededTokens := 1 - Bucket.CurrentTokens;
        WaitMs := Ceil(NeededTokens / Bucket.RefillRate);

        if WaitMs > MaxWaitMs then
          MaxWaitMs := WaitMs;
      end;
    end;
  finally
    FLock.Leave;
  end;

  Result := MaxWaitMs;
end;

procedure TBinanceFuturesRateLimiter.Reset;
var
  I: Integer;
  Bucket: TTokenBucket;
begin
  FLock.Enter;
  try
    for I := 0 to FOrderBuckets.Count - 1 do
    begin
      Bucket := FOrderBuckets[I];
      Bucket.CurrentTokens := Bucket.MaxTokens;
      Bucket.LastRefillTime := Now;
      FOrderBuckets[I] := Bucket;
    end;
  finally
    FLock.Leave;
  end;
end;

end.
