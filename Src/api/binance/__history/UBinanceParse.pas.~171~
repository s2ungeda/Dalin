function TBinanceParse.GetOrderStatus( const s : string ) : TOrderState;
begin
  if s = 'NEW' then
      Result :=  osActive
  else if (s = 'PARTIALLY_FILLED') or ( s = 'FILLED') then
      Result := osFilled
  else if (s = 'CANCELED') or (s = 'EXPIRED') or (s= 'EXPIRED_IN_MATCH') then
      Result := osCanceled
  else if (s = 'REJECTED') then
      Result := osRejected
end;

