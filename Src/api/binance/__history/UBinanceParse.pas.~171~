procedure TBinanceParse.ParseSpotOrderUpdate(aJson: TJsonObject);
var
  aObj : TJsonObject;
  aVal : TJsonValue;
  cID, sID, sTmp, sCode, sStatus : string;

  aAcnt   : TAccount;
  aSymbol : TSymbol;
  aOrder  : TOrder;

  iTime   : int64;
  dtTime  : TDateTime;
  iSide   : integer;
  dOrderQty , dPrice : double;
  otType   : TOrderType;
  pcValue  : TPriceControl;
  aStatus  : TOrderState;
begin

  App.DebugLog( 'binan Spot order : %s ' , [ aJson.ToJSON ]);

  aVal  := aJson as TJsonValue;

  sCode := aVal.FindValue('s').Value;
  cID   := aVal.FindValue('c').Value; // client id
  sID   := aVal.FindValue('i').Value; // order  id;

  aAcnt := App.Engine.TradeCore.FindAccount(ekBinance, amSpot);
  if aACnt = nil then Exit;

  aSymbol := App.Engine.SymbolCore.FindSymbol( ekBinance, sCode);
  if aSymbol = nil then Exit;

  aOrder  := App.Engine.TradeCore.FindOrder( ekBinance, aAcnt, aSymbol, sID);
  // 주문수량
  dOrderQty := aVal.GetValue<double>('q', 0 );

  if aOrder = nil then
  begin

    aOrder := App.Engine.TradeCore.FindOrder(ekBinance, cID );
    if aOrder = nil then
    begin
      sTmp  := aVal.FindValue('S').Value;
      iSide := 1;
      if sTmp = 'SELL' then
        iSide := -1
      else
        iSide  := 1;

      sTmp  := aVal.FindValue('o').Value;
      if sTmp = 'LIMIT' then
        pcValue := pcLimit
      else if sTmp = 'IOC' then
        pcValue := pcIOC
      else pcValue := pcMarket;

      dPrice    := aVal.GetValue<double>('p', 0 );

      aOrder := App.Engine.TradeCore.Orders[ekBinance].NewOrder( aAcnt, aSymbol,
        iSide, dOrderQty, pcValue, dPrice, tmGTC );

      if aOrder = nil then
      begin
        App.Log(llError, 'biance Spot not found order : %s, %s, %s, %s, %s ',
          [ sID, sCode, ifThenStr( iSide = 1, '매수','매도')
            , aSymbol.PriceToStr(dPrice), aSymbol.QtyToStr(dOrderQty)  ]  );
        Exit;
      end ;

      aOrder.ReduceOnly := false;
    end;
  end;

  iTime := aJson.GetValue<int64>('T');
  dtTime:= UnixTimeToDateTime( iTime );

  sTmp  :=  aVal.FindValue('X').Value;
  aStatus := GetOrderStatus( sTmp );

  aOrder.OrderNo    := sID;

  App.DebugLog('Binance %s : %s, %s, %s, %s, %s, %s, %s ', [ 'Spot'
    , sTmp, sID, sCode
    , ifThenStr( aOrder.Side = 1, '매수','매도')
    , aSymbol.PriceToStr(dPrice), aSymbol.QtyToStr(dOrderQty)
    , ifThenStr( aOrder.ReduceOnly, 'Reduce', 'Limit' )
    ]  );

  case aStatus of
    osActive    :  App.Engine.TradeBroker.Accept( aOrder, dtTime, true ) ;
    osFilled    :
      begin
        var aFill : TFill;
        var dFillVol, dFillPrice, dAvgPrice, dFee : double;
        var sTrdID : string;

        dAvgPrice := 0;//aVal.GetValue<double>('ap', 0 );
        dFillVol  := aVal.GetValue<double>('l', 0);
        dFillPrice:= aVal.GetValue<double>('L', 0);
        dFee      := aVal.GetValue<double>('n', 0);   // 수수료
        sTrdID    := aVal.GetValue<string>('t');

        App.DebugLog('Binance %s Fill : %s, %s, %s, %s, %s, %s ', [
          'Spot', sTmp, sID,
          aSymbol.PriceToStr(dFillPrice), aSymbol.QtyToStr(dFillVol),
          aSymbol.PriceToStr(dAvgPrice),  sTrdID
        ]);

        aFill := App.Engine.TradeCore.Fills[ekBinance].New( sTrdID, dtTime, now,
          sID, aOrder, dFillVol, dFillPrice);
        aFill.Fee := dFee;

        App.Engine.TradeBroker.Fill( aOrder, aFill, sTmp = 'FILLED' );
      end;
    osCanceled  : App.Engine.TradeBroker.Cancel( aOrder, true ) ;
    osRejected  : App.Engine.TradeBroker.Accept( aOrder, dtTime, false );
  end;
end;


