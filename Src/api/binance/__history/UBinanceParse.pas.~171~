procedure TBinanceParse.ParseFutCMBalance(aData: string; bBroad : boolean);
var
  aArr, aArr2  : TJsonArray;
  aObj, aObj2  : TJsonObject;
  i     : integer;
  aAcnt : TAccount;
  sCode : string;
  dTmp, dTmp2, dVol, dTotBal : double;
  aAsset  : TAsset;
  aSymbol : TSymbol;
  aPos    : TPosition;

begin
  if aData = '' then
  begin
    App.Log(llError, 'Binance ParseFutCM Balance data is empty') ;
    Exit;
  end;

  aObj := TJsonObject.ParseJSONValue( aData) as TJsonObject;

  try
    if aObj = nil  then Exit;

    sCode := aObj.GetValue('code','');
    if sCode <> '' then
    begin
      App.Log(llError, 'Failed Binance ParseFutCMBalance %s', [aData]) ;
      Exit;
    end;
    sCode := '';

    aAcnt := App.Engine.TradeCore.FindAccount( ekBinance, amFutureCm);
    if aAcnt = nil then Exit;

    aArr := aObj.GetValue('assets') as TJsonArray;
    aACnt.Assets.init;

    for I := 0 to aArr.Count-1 do
    begin
      aObj2  := aArr.Items[i] as TJsonObject;

      sCode := aObj2.GetValue('asset').Value;
      if sCode = '' then continue;

      aAsset  := aAcnt.Assets.Find(sCode);
      if aAsset = nil then
        aAsset  := aAcnt.Assets.New(sCode, aAcnt);

      if sCode = 'BTC' then
        aAcnt.Asset := aAsset;

//      aAsset.TotBalance := dTotBal;
      aAsset.Balance  := aObj2.GetValue<double>('walletBalance', 0);
      aAsset.Available:= aObj2.GetValue<double>('availableBalance', 0);
      aAsset.Locked   := aAsset.Balance - aAsset.Available;
      aAsset.MainMargin := aObj2.GetValue<double>('maintMargin', 0);
      aAsset.InitMargin := aObj2.GetValue<double>('initialMargin', 0);
    end;

    if bBroad then
      App.Engine.TradeBroker.AccountEvent( aAcnt );

    App.Engine.TradeCore.Positions[ekBinance].Init(aAcnt);
    aArr := aObj.GetValue('positions') as TJsonArray;
    for I := 0 to aArr.Count-1 do
    begin
      aObj2 := aArr.Items[i] as TJsonObject;

      dTmp := aObj2.GetValue<double>('positionAmt', 0);
      if CheckZero( dTmp ) then continue;

      sCode   := aObj2.GetValue('symbol').Value;
      aSymbol := App.Engine.SymbolCore.FindSymbol(ekBinance, sCode)  ;
      if aSymbol = nil then continue;

      aPos  := App.Engine.TradeCore.Positions[ekBinance].FindOrNew( aAcnt, aSymbol);
      aPos.Volume   := dTmp;
      aPos.AvgPrice := aObj2.GetValue<double>('entryPrice');
      aPos.Leverage := aObj2.GetValue<integer>('leverage');
      aPos.Isolated := aObj2.GetValue<boolean>('isolated');
      aPos.CalcOpenPL;

      if bBroad then
        App.Engine.TradeBroker.PositionEvent( aPos, POSITION_UPDATE);
    end;


  finally
    if aObj <> nil then aObj.Free;
  end;

end;


procedure TBinanceParse.ParseFutCMMaster(aData: string);
var
  aVal : TJsonValue;

  aObj, aFil  : TJsonObject;
  aArr, aArr2  : TJsonArray;
  aSymbol : TSymbol;
  I, j, iPre, iQtyPre, iContSize: Integer;
  sTmp, sCode, sAsset, aFiType : string;
  bNew : boolean;
  dSize, dSize2, dUp, dDown : double;
begin
  if aData = '' then
  begin
    App.Log(llError, 'Binance ParseFutMaster data is empty') ;
    Exit;
  end;

  try

  aArr := (TJsonObject.ParseJSONValue( aData ) as TJsonObject).Get('symbols').JsonValue as TJsonArray;

  for I := 0 to aArr.Count-1 do
  begin
    aObj  := aArr.Items[i] as TJsonObject;
    sAsset:= aObj.GetValue('marginAsset').Value;

    if App.Engine.ApiManager.ExManagers[ekBinance].Codes.IndexOf(sAsset) < 0 then
      Continue;

    sTmp  := aObj.GetValue('contractType').Value;
    if sTmp <> 'PERPETUAL' then  begin
      //sCode   := aObj.GetValue('symbol').Value;
      //App.DebugLog( 'binance  fut  not found  : %d , %s ', [i, sCode] );
      Continue;
    end;

    sCode   := aObj.GetValue('symbol').Value;

    aSymbol := App.Engine.SymbolCore.FindSymbol(ekBinance, sCode);
    if aSymbol = nil then
    begin
      bNew := true;
      aSymbol := App.Engine.SymbolCore.RegisterSymbol(ekBinance, sCode );
      if aSymbol = nil then
      begin
        //App.DebugLog( 'binance  fut  not RegisterSymbol  : %d , %s ', [i, sCode] );
        continue;
      end;
    end else
      bNew := false;

    with aSymbol do
    begin
      OrgCode     := lowercase(sCode);
      Spec.BaseCode    := sAsset;
      Spec.QuoteCode   := aObj.GetValue('quoteAsset').Value;  // USTD
      Spec.SettleCode  := sAsset;
    end;

    sTmp := aObj.GetValue('contractStatus').Value;
    if sTmp = 'TRADING' then aSymbol.TradeAble := true  else aSymbol.TradeAble := false;

    iPRe  	:=  aObj.GetValue<integer>('pricePrecision');
    iQtyPre :=  aObj.GetValue<integer>('quantityPrecision');
    iContSize:=  aObj.GetValue<integer>('contractSize');

    aArr2 := aObj.Get('filters').JsonValue as TJsonArray;

    dUp := 1; dDown := 1;

    for j := 0 to aArr2.Count-1 do
    begin
      aFil  := aArr2.Items[j] as TJsonObject;
      aFiType := aFil.GetValue('filterType').Value;
      if aFiType = 'PRICE_FILTER' then
      begin
        sTmp := aFil.GetValue('tickSize').Value;
        dSize := StrToFloatDef( sTmp, 1.0 );
      end else
      if aFiType = 'LOT_SIZE' then
      begin
        //sTmp := aFil.GetValue('minQty').Value;
        sTmp := aFil.GetValue('stepSize').Value;
        dSize2  := StrToFloatDef( sTmp, 1.0);
      end else
      if aFiType = 'PERCENT_PRICE' then
      begin
        dUp   := aFil.GetValue<double>('multiplierUp');
        dDown := aFil.GetValue<double>('multiplierDown');
      end;
    end;

    aSymbol.Spec.SetSpec( iPre, dSize, dSize2, iQtyPre, 0 );
    aSymbol.Spec.SetPoint(iContSize, 1, ftCoin);
    aSymbol.Spec.SetRange(dUp, dDown);

    if bNew then
      App.Engine.SymbolCore.RegisterSymbol( ekBinance, aSymbol );
  end;

  finally
    if aArr <> nil  then aArr.Free;
  end;

end;

procedure TBinanceParse.ParseFutCmPositions(aData, aRef: string);
var
  aTmp, aVal  : TJsonValue;
  aArr  : TJsonArray;
  i     : integer;
  sTmp  : string;

  aAcnt : TAccount;
  aPos  : TPosition;
  aSymbol : TSymbol;

begin
  if aData = '' then
  begin
    App.Log(llError, 'Binance ParseFutCmPositions data is empty : %s, %s',[aData, aRef] ) ;
    Exit;
  end;

  aAcnt := App.Engine.TradeCore.FindAccount(ekBinance, amFutureCm );
  if aACnt = nil then Exit;

  try

    aTmp := TJsonObject.ParseJSONValue( aData);
    if aTmp = nil then Exit;
    if not (aTmp is TJsonArray) then
    begin
      App.Log(llError, 'Failed Binance ParseFutCmPositions : %s', [ aData ] );
      Exit;
    end;

    aArr := aTmp as TJsonArray;

    try
      for I := 0 to aArr.Count-1 do
      begin
        aVal  := aArr.Items[i];
        sTmp  := aVal.GetValue<string>('symbol', '');

        if sTmp <> aRef then continue;

        aSymbol := App.Engine.SymbolCore.FindSymbol(ekBinance, sTmp);
        if aSymbol = nil then continue;

        var bNew : boolean;
        bNew := false;

        aPos  := App.Engine.TradeCore.FindPosition( aAcnt, aSymbol );
        if aPos = nil then
        begin
          aPos  := App.Engine.TradeCore.NewPosition( aAcnt, aSymbol );
          bNew  := true;
        end;

        aPos.Volume   := aVal.GetValue<double>('positionAmt', 0 );
        aPos.AvgPrice := aVal.GetValue<double>('entryPrice', 0 );
        aPos.LiqPrice := aVal.GetValue<double>('liquidationPrice', 0);

        aPos.Leverage := aVal.GetValue<integer>('leverage', 1 );
        sTmp  := aVal.GetValue<string>('marginType');
        if sTmp = 'isolated' then
          aPos.Isolated := true
        else
          aPos.Isolated := false;

        App.Engine.TradeBroker.PositionEvent( aPos, POSITION_UPDATE);

        //App.DebugLog('%d. pos - %s, %s : %.4f, %.4f', [ i, aAcnt.Name, aSymbol.Code, aPos.Volume, aPos.AvgPrice] );

      end;
    finally
      if aArr <> nil then aArr.Free;
    end;
  except
  end;

end;

