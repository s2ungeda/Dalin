procedure TBinanceParse.ParseFutMarkPrice(aJson: TJsonObject; aExApiType : TExchangeApiType);
var
  sCode : string;
  aQuote : TQuote;
  dtTime : TDateTime;
  aSale  : TTimeNSale;
  iTime  : int64;
  bSide  : boolean;
begin
  sCode := GetCode(aJson.GetValue('s').Value, aExApiType);
  aQuote  := App.Engine.QuoteBroker.Brokers[FParent.ExchangeKind].Find(sCode)    ;
  if (aQuote = nil) or (aQuote.Symbol = nil ) then Exit;

  with aQuote do
  begin

    iTime := aJson.GetValue<int64>('T');
    dtTime:= UnixTimeToDateTime( iTime );

    // markprice
    (Symbol as TFuture).MarkPrice := strToFloat( aJson.GetValue('p').Value );
    // funding rate
    (Symbol as TFuture).FundingRate := strToFloat( aJson.GetValue('r').Value );

    Symbol.IndexPrice := StrToFloat( aJson.GetValue('i').Value );

    // calc basis
    if (Symbol.IndexPrice < DOUBLE_EPSILON ) then
      Symbol.Basis := 0
    else
      Symbol.Basis  := ( Symbol.Last - Symbol.IndexPrice ) / Symbol.IndexPrice * 100;
//      Symbol.Basis  := ( (Symbol as TFuture).MarkPrice- Symbol.IndexPrice ) / Symbol.IndexPrice * 100;

//    if sCode = 'BTCUSDT' then
//      App.DebugLog('%s, Basis %s %s( %s)', [ sCode,
//          Symbol.PriceToStr(Symbol.Last ) ,
////          Symbol.PriceToStr( (Symbol as TFuture).MarkPrice ) ,
//          Symbol.PriceToStr(Symbol.IndexPrice ) ,
//          FmtString( 2, Symbol.Basis  , 1) ]
//           );
  end;

end;


procedure TBinanceParse.ParseFutAllOrderBook(aData: string);
var
	aVal : TJsonValue;
	aArr : TJsonArray;
  aObj : TJsonObject;
  sCode : string;
  aSymbol : TSymbol;
  I: Integer;
  iTrns : int64;
begin
	aVal := nil;
  if aData = '' then
  begin
    App.Log(llError, '%s ParseFutAllOrderBook data is empty', [ TExchangeKindDesc[FParent.ExchangeKind] ] ) ;
    Exit;
  end;        
  
  aVal := TJsonObject.ParseJSONValue( aData);// as TJsonArray;
  if aVal = nil then Exit;  
  if not (aVal is TJsonArray) then
  begin
  	App.Log(llError, 'ParseFutAllOrderBook InValid data : %s', [ aData ] );
    Exit;
  end;

  try                       

  	aArr := aVal as TJsonArray;
  
  	for I := 0 to aArr.Size-1 do
		begin
    	aObj	:= aArr.Get(i) as TJsonObject;

		  sCode := aObj.GetValue('symbol').Value;
      aSymbol := App.Engine.SymbolCore.FindSymbol(ekBinance, sCode+Fut_Suf);
      if aSymbol <> nil then
      begin
      	iTrns	:= aObj.GetValue<int64>('time');
      	if iTrns > aSymbol.TrnsTimeQ then
        begin
      
          aSymbol.Asks[0].Price  := aObj.GetValue<double>('askPrice');
          aSymbol.Asks[0].Volume := aObj.GetValue<double>('askQty');
          aSymbol.Bids[0].Price  := aObj.GetValue<double>('bidPrice');
          aSymbol.Bids[0].Volume := aObj.GetValue<double>('bidQty');

          aSymbol.TrnsTimeQ	:= iTrns;
        end;

      end;      
    end;
    
  finally
    if aVal <> nil then aVal.Free;
  end;

end;

procedure TBinanceParse.ParseFutAllTicker(aData: string);
var
	aVal : TJsonValue;
	aArr : TJsonArray;
  aObj : TJsonObject;
  sCode : string;
  aSymbol : TSymbol;
  I: Integer;
  iLast : int64;
begin
	aVal := nil;
  if aData = '' then
  begin
    App.Log(llError, '%s ParseFutAllTicker data is empty', [ TExchangeKindDesc[FParent.ExchangeKind] ] ) ;
    Exit;
  end;
  
  aVal := TJsonObject.ParseJSONValue( aData);// as TJsonArray;  
  if aVal = nil then Exit;  
  if not (aVal is TJsonArray) then
  begin
  	App.Log(llError, 'ParseFutAllTicker InValid data : %s', [ aData ] );
    Exit;
  end;

  try                       

  	aArr := aVal as TJsonArray;
  
  	for I := 0 to aArr.Size-1 do
		begin
    	aObj	:= aArr.Get(i) as TJsonObject;

		  sCode := aObj.GetValue('symbol').Value;
      aSymbol := App.Engine.SymbolCore.FindSymbol(ekBinance, sCode+Fut_Suf);
      if aSymbol <> nil then
      begin
        aSymbol.DayOpen  := aObj.GetValue<double>('openPrice');
        aSymbol.DayHigh  := aObj.GetValue<double>('highPrice');
        aSymbol.DayLow   := aObj.GetValue<double>('lowPrice');
        aSymbol.DayVolume:= aObj.GetValue<double>('volume') ;
        aSymbol.DayAmount:= aObj.GetValue<double>('quoteVolume') * App.Engine.ApiManager.ExRate.Value / 100000000;

       	iLast	:= aObj.GetValue<int64>('lastId');
        if iLast > aSymbol.LastID then
        begin
          aSymbol.Last := aObj.GetValue<double>('lastPrice');

          App.Engine.SymbolCore.CalcIndex( aSymbol );
          App.Engine.TradeCore.Positions[ aSymbol.Spec.ExchangeType].UpdatePosition( aSymbol);
//
//          App.DebugLog('%s : %d > %d %s, %.0f', [ aSymbol.Code, iLast, aSymbol.LastID, 
//          	aSymbol.PriceToStr( aSymbol.Last ), aSymbol.DayAmount
//          	]  );
          aSymbol.LastID	:= iLast;
        end;

      end;      
    end;
    
  finally
    if aVal <> nil then aVal.Free;
  end;
end;


procedure TBinanceParse.ParseFutAssetIndex(aAcnt : TAccount; aJson: TJsonObject);
var
  sAss, sTmp : string;
  iLen : integer;
  aAsset  : TAsset;
begin

  if aACnt = nil then Exit;

  try

    App.Log(llDebug, 'ParseFutAssetIndex', '%s', [aJson.ToString]);

    sTmp  := aJson.GetValue('s').Value;
    iLen  := Length(sTmp)-3;
    sAss  := Copy(sTmp, 1, iLen);

    aAsset  := aAcnt.Assets.Find(sAss);
    if aAsset = nil then
      aAsset  := aAcnt.Assets.New(sAss, aAcnt);

    aAsset.IndexPrice := aJson.GetValue<double>('i',0);
    aAsset.AskRate    := aJson.GetValue<double>('A',1);
    aAsset.BidRate    := aJson.GetValue<double>('B',1);
  except
  end;

end;

function TBinanceParse.GetCode(const sCode : string; aExApiType : TExchangeApiType) : string;
begin
  if aExApiType = eaFutUsdt then
    Result := sCode + Fut_Suf
  else
    Result := sCode;
end;

procedure TBinanceParse.ParseActiveOrder(aData: string);
var
  aArr : TJsonArray;
  aObj : TJsonObject;
  aVal : TJsonValue;
  i : Integer;
  sOID,sTmp, sCode : string;
  aAcnt: TAccount;
  sArr : TArray<string>;
  iSide: integer;
  dOrderQty, dPrice : double;
  dtTime : TDateTime;
  aOrder : TOrder;
  aSymbol: TSymbol;
  tmType : TTimeInForce;
begin
 if aData = '' then
  begin
    App.Log(llError, '%s Usd-M ParseActiveOrder data is empty', [ TExchangeKindDesc[FParent.ExchangeKind] ] ) ;
    Exit;
  end;

  aArr  := TJsonObject.ParseJSONValue(aData) as TJsonArray;

  try
    if aArr = nil then Exit;
    aAcnt := App.Engine.TradeCore.FindAccount(ekBinance, amFuture);
    if aAcnt = nil then Exit;

    for I := 0 to aArr.Count-1 do
    begin
      aVal := aArr.Items[i];

      sTmp := aVal.GetValue<string>('status');
      if sTmp <> 'NEW' then continue;

      sCode := GetCode(aVal.FindValue('symbol').Value, eaFutUsdt);

      aSymbol := App.Engine.SymbolCore.FindSymbol(FParent.ExchangeKind, sCode);
      if aSymbol = nil then Continue;

      sOID  := aVal.FindValue('orderId').Value;
      sTmp  := aVal.GetValue<string>('side');
      if sTmp = 'BUY' then
        iSide := 1
      else
        iSide := -1;

      dOrderQty := aVal.GetValue<double>('origQty') - aVal.GetValue<double>('executedQty');
      dPrice    := aVal.GetValue<double>('price');
      dtTime    := UnixTimeToDateTime(aVal.GetValue<int64>('updateTime'));

      sTmp      := aVal.GetValue<string>('timeInForce');
      if sTmp = 'GTX' then
        tmType := tmGTX
      else
        tmType := tmGTC;

      aOrder    := App.Engine.TradeCore.Orders[FParent.ExchangeKind].NewOrder(
        aAcnt, aSymbol, iSide, dOrderQty, pcLimit, dPrice, tmType);

      if aVal.GetValue<boolean>('reduceOnly') then
        aOrder.ReduceOnly := true;

      if aOrder <> nil then
      begin
        aOrder.OrderNo  := sOID;
        App.Engine.TradeBroker.Accept(aOrder, dtTime, true);
      end;
    end;

  finally
    FreeAndNil(aArr);
  end;
end;

procedure TBinanceParse.ParseAllMiniTicker(aArr: TJsonArray; aExApiType : TExchangeApiType);
var
  I : Integer;
  iLast : int64;
  aVal : TJsonValue;
  aObj : TJsonObject;
  sCode, sTmp : string;
  aSymbol : TSymbol;
  aAcnt   : TAccount;
  aQuote  : TQuote;
begin

  aAcnt := nil;

  for I := 0 to aArr.Count-1 do
  begin
    aObj := aArr.Items[i] as TJsonObject ;
    sTmp := aObj.GetValue('e').Value;

    if aAcnt = nil then
      aAcnt := App.Engine.TradeCore.FindAccount(ekBinance, amFuture);

    if sTmp = 'assetIndexUpdate' then
    begin
      ParseFutAssetIndex( aAcnt, aObj );
      continue;
    end;

    sCode := GetCode(aObj.GetValue('s').Value, aExApiType);

    aSymbol := App.Engine.SymbolCore.FindSymbol(ekBinance, sCode);
    if aSymbol=nil then continue;

    if sTmp = '24hrTicker' then
    begin
        if aSymbol <> nil then
        begin
          aSymbol.DayOpen  := StrToFloat( aObj.GetValue('o').Value );
          aSymbol.DayHigh  := StrToFloat( aObj.GetValue('h').Value );
          aSymbol.DayLow   := StrToFloat( aObj.GetValue('l').Value );
          aSymbol.DayVolume:= StrToFloat( aObj.GetValue('v').Value );
          aSymbol.DayAmount:= StrToFloat( aObj.GetValue('q').Value ) * App.Engine.ApiManager.ExRate.Value / 100000000;

          iLast	:= aObj.GetValue<int64>('L');
          if iLast > aSymbol.LastID then
          begin
            aSymbol.Last := aObj.GetValue<double>('c');
            App.Engine.SymbolCore.CalcKimp( aSymbol );
            App.Engine.SymbolCore.CalcMainKimp( aSymbol );
            App.Engine.SymbolCore.CalcMainWDC(aSymbol);

            aQuote := App.Engine.QuoteBroker.Brokers[ekBinance].Find(aSymbol.Code);

            var bLog : boolean;
            if aQuote <> nil then begin
              aSymbol.SavePrevDepth;
