procedure TBinanceParse.ParseMarginPair(aData: string);
var
  aArr : TJsonArray;
  aVal : TJsonValue;
  I, j: Integer;
  sTmp : string;
  bAble : boolean;
  aSymbol : TSymbol;
begin
  if aData = '' then
  begin
    App.Log(llError, 'Binance ParseMarginPair data is empty') ;
    Exit;
  end;

  try

  aArr := TJsonObject.ParseJSONValue( aData) as TJsonArray;
  j:= 0;

  for I := 0 to aArr.Count-1 do
  begin
    aVal  := aArr.Items[i] ;
    sTmp  := aVal.GetValue<string>('quote');
    //if sTmp <> 'USDT' then continue;
    if not EnableSettleStr(sTmp) then continue;
    bAble := aVal.GetValue<boolean>('isMarginTrade');
    if not bAble then Continue;
    sTmp := aVal.GetValue<string>('symbol');

    aSymbol := App.Engine.SymbolCore.FindSymbol(ekBinance, sTmp);
    if aSymbol <> nil then
    begin
      aSymbol.IsMargin := true;
      inc(j);
//      App.DebugLog('%s Enabled Margin Trade', [ aSymbol.Code] );
    end;

  end;

  App.DebugLog('binance margin count : %d', [j] );
  finally
    if aArr <> nil then aArr.Free;
  end;

end;





procedure TBinanceParse.ParseDNWState(aData: string);
var
  aObj : TJsonObject;
  aTmp, aVal, aVal2 : TJsonValue;
  aArr, aArr2 : TJsonArray;
  aPair: TJsonPair;
  I, j : Integer;
  sTmp : string;
  aSymbol : TSymbol;

begin
  if aData = '' then
  begin
    App.Log(llError, 'Binance ParseDNWState data is empty') ;
    Exit;
  end;

  try

    aTmp := TJsonObject.ParseJSONValue( aData);
    if aTmp = nil then Exit;
    if not (aTmp is TJsonArray) then
    begin
      App.Log(llError, 'Binance ParseDNWState InValid data : %s', [ aData ] );
      Exit;
    end;

    aArr := aTmp as TJsonArray;

    try
      for I := 0 to aArr.Count-1 do
      begin
        aVal  := aArr.Items[i];
        sTmp  := aVal.GetValue<string>('coin', '');
        if ( sTmp = '') or ( FParent.Codes.IndexOf(sTmp) < 0 ) then continue;

        aSymbol := App.Engine.SymbolCore.FindSymbol(FParent.ExchangeKind, sTmp+'USDT' );
        if aSymbol <> nil then
        begin

//  네트워크 리스트를 검토후에 입출금 체크 하자.
          var iRes : integer;
          iRes := aSymbol.CheckDnwState(  aVal.GetValue<boolean>('depositAllEnable')
                                        , aVal.GetValue<boolean>('withdrawAllEnable') ) ;
          if iRes > 0 then
            App.Engine.SymbolBroker.DnwEvent( aSymbol, iRes);

          aSymbol.NetworkList.init;
          aSymbol.NetworkList.Clear;
          // network list
          aArr2 := aVal.GetValue<TJsonArray>('networkList', nil);
          if aArr2 = nil then continue;
          for j := 0 to aArr2.Count-1 do
          begin
            var aNetwork : TDnwNetWork;
            aNetwork := aSymbol.NetworkList.New;
            aVal2 := aArr2.Items[j] ;
            var s := aVal2.GetValue<string>('network', '');
            if s = 'FIAT_MONEY' then continue;

            aNetwork.Name  := s;
            aNetwork.DepositState   := aVal2.GetValue<boolean>('depositEnable');
            aNetwork.WithDrawlState := aVal2.GetValue<boolean>('withdrawEnable');
            aNetwork.WithdrawMin    := aVal2.GetValue<string>('withdrawMin','0');
            aNetwork.WithdrawFee    := aVal2.GetValue<string>('withdrawFee','0');
          end;

//          var iRes : integer;
//          iRes := aSymbol.CheckDnwState(  aVal.GetValue<boolean>('depositAllEnable')
//                                        , aVal.GetValue<boolean>('withdrawAllEnable') ) ;
//          if iRes > 0 then
//            App.Engine.SymbolBroker.DnwEvent( aSymbol, iRes);


        end;
      end;

    finally
      if aTmp <> nil then aTmp.Free;
    end;
  except on e : exception do
    App.Log(llError, 'ParseDNWState parse error : %s, %d, %d, %s ' ,[ e.Message, i, j, aData ] );
  end;
end;





procedure TBinanceParse.ParseSpotBalance(aData, aRef: string);
var
  aObj, aObj2 : TJsonObject;
  aArr : TJsonArray;
  aVal : TJsonValue;
  iRes : integer;
  sTmp : string;
  dTmp, dTmp2, dVol : double;
  i, j : integer;
  //
  aAcnt : TAccount;
  aSymbol : TSymbol;
  aAsset  : TAsset;
//  aPos    : TPosition;
//  aBal    : TBalance;
begin
  if aData = '' then
  begin
    App.Log(llError, 'Binance ParseSpotBalance data is empty') ;
    Exit;
  end;

  aObj := TJsonObject.ParseJSONValue( aData) as TJsonObject;
  try
//    iRes := aObj.GetValue<integer>('code');
//    if iRes <> SUCC_CODE then
//    begin
//      sTmp  := aObj.GetValue('msg').Value;
//      App.Log(llError, '%s ParseSpotBalance Result %d %s',
//        [ TExShortDesc[FParent.ExchangeKind], iRes, sTmp ] );
//      Exit;
//    end;

    aArr  := aObj.GetValue('balances') as TJsonArray;

    aAcnt := App.Engine.TradeCore.FindAccount( Fparent.ExchangeKind, amSpot );
    if aAcnt = nil then Exit;

    aAcnt.Assets.init;
    for I := aArr.Count-1 downto 0 do
    begin

        aVal  := aArr.Items[i];

        sTmp  := aVal.GetValue<string>('asset', '');
        if sTmp = '' then continue;

        dTmp  := aVal.GetValue<double>('free', 0 );
        dTmp2 := aVal.GetValue<double>('locked', 0 );
        dVol  := dTmp + dTmp2 ;

        if CheckZero( dVol ) then
        begin
          if sTmp = 'USDT' then
          begin
            aAsset  := aAcnt.Assets.Find(sTmp);
            if aAsset = nil then
              aAcnt.Asset  := aAcnt.Assets.New(sTmp, aAcnt);
          end else
          if sTmp = 'USDC' then
          begin
            aAsset  := aAcnt.Assets.Find(sTmp);
            if aAsset = nil then
              aAcnt.DCAss  := aAcnt.Assets.New(sTmp, aAcnt);
          end;
          continue;
        end;

        aAsset  := aAcnt.Assets.Find(sTmp);
        if aAsset = nil then begin
          aAsset  := aAcnt.Assets.New(sTmp, aAcnt);
          if sTmp = 'USDT' then
            aAcnt.Asset := aAsset
          else if sTmp = 'USDC' then
            aAcnt.DCAss := aAsset;
        end;

        aAsset.Balance  := dVol;
        aAsset.Locked   := dTmp2;
        aAsset.Available:= dTmp;

        if sTmp = aRef then
          App.Engine.TradeBroker.AssetEvent(aAsset, ASSET_UPDATE);

//        App.DebugLog('Binance Spot balance - %s', [ aAsset.Represet] ) ;
    end;

    aAcnt.Assets.DoLog;

  finally
    if aObj <> nil then aObj.Free;
  end;
end;




procedure TBinanceParse.ParseFutBalance(aData: string);
var
  aArr, aArr2  : TJsonArray;
  aObj, aObj2  : TJsonObject;
  i, j  : integer;
  aAcnt : TAccount;
  sCode : string;
  dTmp, dTmp2, dVol, dTotBal : double;
  aAsset  : TAsset;
  aSymbol : TSymbol;
  aPos    : TPosition;

begin
  if aData = '' then
  begin
    App.Log(llError, 'Binance ParseFutBalance data is empty') ;
    Exit;
  end;

  aObj := TJsonObject.ParseJSONValue( aData) as TJsonObject;

  try
    if aObj = nil  then Exit;

    sCode := aObj.GetValue('code','');
    if sCode <> '' then
    begin
      App.Log(llError, 'Failed Binance ParseFutBalance %s', [aData]) ;
      Exit;
    end;

    sCode := '';
    aAcnt := App.Engine.TradeCore.FindAccount( ekBinance, amFuture);
    if aAcnt = nil then Exit;

    aAcnt.MultiAssetsMode := aObj.GetValue<boolean>('multiAssetsMargin',false);
    aAcnt.TotWalletBalance:= aObj.GetValue<double>('totalWalletBalance', 0);
    aAcnt.TotMainMargin   := aObj.GetValue<double>('totalMaintMargin', 0);

    aArr := aObj.GetValue('assets') as TJsonArray;
    //aACnt.Assets.init;

    {
    Available Balance = Margin Balance - Initial Margin
    Margin Balance = walletBalance + unrealizedProfit (지갑 잔고 + 미실현 손익)
    Initial Margin = positionInitialMargin + openOrderInitialMargin (포지션 증거금 + 주문 증거금)
    }

    for I := 0 to aArr.Count-1 do
    begin
      aObj2  := aArr.Items[i] as TJsonObject;

      sCode := aObj2.GetValue('asset').Value;
      if sCode = '' then continue;

      var dBal : double;

      aAsset  := aAcnt.Assets.Find(sCode);
      if aAsset = nil then
        aAsset  := aAcnt.Assets.New(sCode, aAcnt);

      aAsset.Balance    := aObj2.GetValue<double>('walletBalance', 0);
      aAsset.Available  := aObj2.GetValue<double>('availableBalance', 0);
      aAsset.Locked     := aAsset.Balance - aAsset.Available;
      aAsset.MainMargin := aObj2.GetValue<double>('maintMargin', 0);
      aAsset.InitMargin := aObj2.GetValue<double>('initialMargin', 0);

      if sCode = 'USDT' then
        aAcnt.Asset := aAsset;

      if sCode = 'USDC' then
        aAcnt.DCAss := aAsset;

      for j := 0 to High(FArrAsset) do
        if FArrAsset[j] = sCode then
          aAsset.MarginAvailable  := true;
    end;

    App.Engine.TradeCore.Positions[ekBinance].Init(aAcnt);
    aArr := aObj.GetValue('positions') as TJsonArray;
    for I := 0 to aArr.Count-1 do
    begin
      aObj2 := aArr.Items[i] as TJsonObject;

      dTmp := aObj2.GetValue<double>('positionAmt', 0);
      if CheckZero( dTmp ) then continue;

      sCode   := aObj2.GetValue('symbol').Value;
      aSymbol := App.Engine.SymbolCore.FindSymbol(ekBinance, sCode+Fut_Suf)  ;
      if aSymbol = nil then continue;

      aPos  := App.Engine.TradeCore.Positions[ekBinance].FindOrNew( aAcnt, aSymbol);
      aPos.Volume   := dTmp;
      aPos.AvgPrice := aObj2.GetValue<double>('entryPrice');
      aPos.Leverage := aObj2.GetValue<integer>('leverage');
      aPos.Isolated := aObj2.GetValue<boolean>('isolated');
      aPos.MaxNotional := aObj2.GetValue<double>('maxNotional',0);
      aPos.CalcOpenPL;
    end;


  finally
    if aObj <> nil then aObj.Free;
  end;
end;

