procedure TBinanceParse.ParseFutPositions(aData, aRef: string);
var
  aTmp, aVal  : TJsonValue;
  aArr  : TJsonArray;
  i     : integer;
  sTmp  : string;

  aAcnt : TAccount;
  aPos  : TPosition;
  aSymbol : TSymbol;

begin
  if aData = '' then
  begin
    App.Log(llError, 'Binance ParseFutPositions data is empty : %s, %s',[aData, aRef] ) ;
    Exit;
  end;

  aAcnt := App.Engine.TradeCore.FindAccount(ekBinance, amFuture );
  if aACnt = nil then Exit;

  try

    aTmp := TJsonObject.ParseJSONValue( aData);
    if aTmp = nil then Exit;
    if not (aTmp is TJsonArray) then
    begin
      App.Log(llError, 'Failed Binance ParseFutPositions : %s', [ aData ] );
      Exit;
    end;

    aArr := aTmp as TJsonArray;

    try
      for I := 0 to aArr.Count-1 do
      begin
        aVal  := aArr.Items[i];
        sTmp  := aVal.GetValue<string>('symbol', '');

        if sTmp+Fut_Suf <> aRef then continue;

        aSymbol := App.Engine.SymbolCore.FindSymbol(ekBinance, sTmp+Fut_Suf);
        if aSymbol = nil then continue;

  //      if aVal.GetValue<string>('notional', '') = '0' then continue;

        var bNew : boolean;
        bNew := false;

        aPos  := App.Engine.TradeCore.FindPosition( aAcnt, aSymbol );
        if aPos = nil then
        begin
          aPos  := App.Engine.TradeCore.NewPosition( aAcnt, aSymbol );
          bNew  := true;
        end;

        aPos.Volume   := aVal.GetValue<double>( 'positionAmt', 0 );
        aPos.AvgPrice := aVal.GetValue<double>( 'entryPrice', 0 );
        aPos.LiqPrice := aVal.GetValue<double>('liquidationPrice', 0);
        aPos.MaxNotional  := aVal.GetValue<double>('maxNotionalValue', 0);

        aPos.Leverage := aVal.GetValue<integer>('leverage', 1 );
        sTmp  := aVal.GetValue<string>('marginType');
        if sTmp = 'isolated' then
          aPos.Isolated := true
        else
          aPos.Isolated := false;

        App.Engine.TradeBroker.PositionEvent( aPos, POSITION_UPDATE);

        App.DebugLog('%d. pos - %s, %s : %.4f, %.4f', [ i, aAcnt.Name, aSymbol.Code, aPos.Volume, aPos.AvgPrice] );

      end;
    finally
      if aArr <> nil then aArr.Free;
    end;
  except
  end;

end;


procedure TBinanceParse.ParseFutOrderList(aData, aRef: string);
var
  aTmp, aVal  : TJsonValue;
  aArr  : TJsonArray;
  i, iSide   : integer;
  sTmp, sOID : string;

  aAcnt : TAccount;
  aOrder  : TOrder;
  aSymbol : TSymbol;

  dOrderQty, dPrice : double;
  pcValue : TPriceControl;
  dtTime  : TDateTime;
begin
  if aData = '' then
  begin
    App.Log(llError, 'Binance ParseFutOrderList data is empty : %s, %s',[aData, aRef] ) ;
    Exit;
  end;

  aAcnt := App.Engine.TradeCore.FindAccount(ekBinance, amFuture );
  if aACnt = nil then Exit;

  try

    aTmp := TJsonObject.ParseJSONValue( aData);
    if aTmp = nil then Exit;
    if not (aTmp is TJsonArray) then
    begin
      App.Log(llError, 'Failed Binance ParseFutOrderList : %s', [ aData ] );
      Exit;
    end;

    aArr := aTmp as TJsonArray;

    try
      for I := 0 to aArr.Count-1 do
      begin
        aVal  := aArr.Items[i];
        sTmp  := aVal.GetValue<string>('symbol', '');
        aSymbol := App.Engine.SymbolCore.FindSymbol(ekBinance, sTmp+Fut_Suf);
        if aSymbol = nil then continue;

        sOID  := aVal.GetValue<string>('orderId', '');

        aOrder  := App.Engine.TradeCore.Orders[ekBinance].ActiveOrders.FindOrder( sOID );
        if aOrder = nil then
        begin
          sTmp  := aVal.FindValue('side').Value;
          iSide := 1;
          if sTmp = 'SELL' then
            iSide := -1;

          sTmp  := aVal.FindValue('type').Value;
          if sTmp = 'MARKET' then
            pcValue := pcMarket
          else pcValue := pcLimit;

          dOrderQty := aVal.GetValue<double>('origQty', 0 )
                       - aVal.GetValue<double>('executedQty', 0 )  ;
          dPrice    := aVal.GetValue<double>('price', 0 );

          aOrder := App.Engine.TradeCore.Orders[ekBinance].NewOrder( aAcnt, aSymbol,
            iSide, dOrderQty, pcValue, dPrice, tmGTC );

          aOrder.ReduceOnly := aVal.GetValue<boolean>('reduceOnly', false);

          aOrder.OrderNo  := sOID;
          aOrder.LocalNo  := aVal.GetValue<string>( 'clientOrderId','');

          dtTime:= UnixTimeToDateTime( aVal.GetValue<int64>('time') );

          App.Engine.TradeBroker.Accept( aOrder, dtTime, true );

          App.DebugLog( '%s ', [ aOrder.Represent ]);

        end;

      end;
    finally
      if aArr <> nil then aArr.Free;
    end;
  except
  end;

end;

// 1일치만 조회 했기에 순서에 관계없이 Sum 한다.
// 참고로 데이터는 시간 올림차순 이다. ( 최신 데이터가 마지막 )
procedure TBinanceParse.ParseFutTradeAmt(aData, aRef: string; bReturn : boolean);
var
  aAcnt : TAccount;
  aArr  : TJsonArray;
  aVal  : TJsonValue;
  i : integer;
  dAmt : double;
  uTime : int64;
  ystTime : TDateTime;
begin
  if aData = '' then
  begin
    App.Log(llError, 'Binance ParseFutTradeAmt data is empty : %s, %s',[aData, aRef] ) ;
    Exit;
  end;

  aAcnt := App.Engine.TradeCore.FindAccount(ekBinance, amFuture );
  if aACnt = nil then Exit;

  aArr := TJsonObject.ParseJSONValue( aData) as TJsonArray;
  if aArr = nil then Exit;

  try
    dAmt := 0.0;
    for I := 0 to aArr.Count-1 do
    begin

      var code : string;

      aVal  := aArr.Items[i];

      code := aVal.GetValue<string>('symbol', '');
      if code = '' then continue;

      var aSymbol : TSymbol;
      aSymbol := App.Engine.SymbolCore.FindSymbol(ekBinance, code+Fut_Suf);
      if aSymbol = nil then continue;

      var p, q : double;

      p := aVal.GetValue<double>('price', 0);
      q := aVal.GetValue<double>('qty', 0);

      dAmt := dAmt + ( p * q * aSymbol.Spec.PointValue );
    end;

    uTime:= StrToInt64( aRef );
    ystTime:= UnixTimeToDateTime( uTime, 13 );

    App.DebugLog('binance %s 1일 거래 금액 %.0n', [
        FormatDateTime('yyyy-mm-dd hh:nn:ss', ystTime),
        dAmt ] );
    aAcnt.SetTradeAmt( dAmt, eaFutUsdt);

    if bReturn  then
      App.Engine.TradeBroker.AccountEvent(aAcnt, ACCOUNT_AMT);

  finally
    aArr.Free;
  end;


end;


