procedure TBinanceParse.ParseFutAccountInfochange(aJson: TJsonObject; aExApiType : TExchangeApiType);
var
  aAcnt : TAccount;
  aVal  : TJsonValue;
  bMulti: boolean;
  sCode : string;
begin
  try
    aAcnt := GetAccount(aExApiType);
    if aAcnt = nil then Exit;

    aVal  := aJson.GetValue('ai');
    if aVal <> nil then
    begin
       bMulti := aVal.GetValue<boolean>('j');
       if aAcnt.MultiAssetsMode <> bMulti then
       begin
         App.Log(llInfo, 'Binance %s Asset Mode Change : %s -> %s', [ TExApiTypeDesc[aExApiType],
          ifThenStr( aAcnt.MultiAssetsMode, 'True', 'False' ),
          ifThenStr( bMulti, 'True', 'False' )  ]);

         aAcnt.MultiAssetsMode  := bMulti;
         App.Engine.TradeBroker.AccountEvent(aAcnt, ACCOUNT_ASS_MODE);
       end;
    end;

    aVal := aJson.GetValue('ac');
    if aVal <> nil then
    begin
      sCode := GetCode(  aVal.GetValue<string>('s'), aExApiType);
      var aPos : TPosition;
      var aSymbol : TSymbol;

      aSymbol := App.Engine.SymbolCore.FindSymbol(ekBinance, sCode);
      if aSymbol = nil then Exit;

      aPos    := App.Engine.TradeCore.FindPosition( aAcnt, aSymbol);
      if aPos = nil then
        aPos := App.Engine.TradeCore.NewPosition(aAcnt, aSymbol);

      var iLv : integer;
      iLv := aVal.GetValue<integer>('l');
      if aPos.Leverage <> iLv then
      begin
         App.Log(llInfo, 'Binance %s, %s Leverage Change : %d -> %d', [ TExApiTypeDesc[aExApiType],
          sCode, aPos.Leverage, iLv  ]);

        aPos.Leverage := iLv;
        App.Engine.TradeBroker.PositionEvent(aPos, POSITION_UPDATE);
      end;
    end;

  except
  end;
end;

procedure TBinanceParse.ParseFutAccountUpdate(aJson: TJsonObject; aExApiType : TExchangeApiType);
var
  aVal, aBal, aPos : TJsonValue;
  aArr : TJsonArray;
  I: Integer;
  aAcnt : TAccount;
  sCode : string;
  aAsset: TAsset;
  aPosition  : TPosition;
begin
  //App.DebugLog( 'binan Fut Account : %s ' , [ aJson.ToJSON ]);
  App.Log(llDebug, 'binance_account', '%s', [aJson.ToJSON]);

  aAcnt := GetAccount(aExApiType);
  if aACnt = nil then Exit;

  aVal  := aJson.GetValue('a');
  if aVal = nil then Exit;
  // 주문외 다른 이유로 잔고 변화 됬을때만 처리
  //if aVal.GetValue<string>('m') = 'ORDER' then Exit;

  try
    aArr  := aVal.GetValue<TJsonArray>('B');
    for I := 0 to aArr.Count-1 do
    begin
      aBal := aArr.Items[i];
      sCode:= aBal.GetValue<string>('a');
//      if sCode <> 'USDT' then continue;
      aAsset  := aAcnt.Assets.Find(sCode);
      if aAsset = nil then begin
        aAsset := aAcnt.Assets.New(sCode, aAcnt);
        App.Engine.TradeBroker.AssetEvent(aAsset, ASSET_NEW);
      end;
      //else aAsset.init;
      aAsset.Balance  := aBal.GetValue<double>('wb');
      if aAsset.Available > aAsset.Balance then
        aAsset.Available  := aAsset.Balance;
      App.Engine.TradeBroker.AssetEvent(aAsset, ASSET_UPDATE);
    end;
    {
    aArr := aVal.GetValue<TJsonArray>('P');
    for I := 0 to aArr.Count-1 do
    begin
      aPos := aArr.Items[i];
      sCode:= GetCode(aPos.GetValue<string>('s'), aExApiType);

      aPosition := App.Engine.TradeCore.FindPosition(aAcnt, sCode);
      if aPosition = nil then begin
        var aSymbol := App.Engine.SymbolCore.FindSymbol(ekBinance, sCode);
        if aSymbol = nil then continue;
        aPosition := App.Engine.TradeCore.NewPosition(aAcnt, aSymbol);
      end;

      aPosition.Volume  := aPos.GetValue<double>('pa', 0);
      aPosition.AvgPrice:= aPos.GetValue<double>('ep', 0);
      aPosition.AvgPrice:= aPos.GetValue<double>('ep', 0);
      aPosition.Isolated := aPos.GetValue<string>('mt') = 'isolated';
    end;
    }
  except
    App.Log(llError, 'Error ParseFutAccountUpdate ' );
  end;

end;

procedure TBinanceParse.ParseFutOrderUpdate(aJson: TJsonObject; aExApiType : TExchangeApiType);
var
  aObj : TJsonObject;
  aVal : TJsonValue;
  cID, sID, sTmp, sTmp2, sCode, sStatus : string;

  aAcnt   : TAccount;
  aSymbol : TSymbol;
  aOrder  : TOrder;

  iTime   : int64;
  dtTime  : TDateTime;
  iSide   : integer;
  dOrderQty , dPrice : double;
  otType   : TOrderType;
  pcValue  : TPriceControl;
  aStatus  : TOrderState;
  aTIF     : TTimeInForce;
begin

  App.Log(llDebug,'binance_order', 'R:%s', [aJson.ToString]) ;

  aVal  := aJson.GetValue('o');
  if aVal = nil then Exit;

  sCode := GetCode(aVal.FindValue('s').Value, aExApiType);
  cID   := aVal.FindValue('c').Value; // client id
  sID   := aVal.FindValue('i').Value; // order  id;

  if aExApiType = eaFutUsdt then
    aAcnt := App.Engine.TradeCore.FindAccount(ekBinance, amFuture)
  else
    aAcnt := App.Engine.TradeCore.FindAccount(ekBinance, amFutureCm);
  if aACnt = nil then Exit;

  aSymbol := App.Engine.SymbolCore.FindSymbol( ekBinance, sCode);
  if aSymbol = nil then Exit;

  aOrder  := App.Engine.TradeCore.FindOrder( ekBinance, aAcnt, aSymbol, sID);

  // reduce only  일 경우 주문수량을 수정해준다.
  dOrderQty := aVal.GetValue<double>('q', 0 );

  if aOrder = nil then
  begin

    aOrder := App.Engine.TradeCore.FindOrder(ekBinance, cID );
    if aOrder = nil then
    begin
      App.Log(llDebug, 'binance order oops!! : %s, %s, %s, ', [aSymbol.Code, cID, sID]);
      sTmp  := aVal.FindValue('S').Value;
      iSide := 1;
      if sTmp = 'SELL' then
        iSide := -1
      else
        iSide  := 1;

      sTmp  := aVal.FindValue('o').Value;
      if sTmp = 'LIMIT' then
        pcValue := pcLimit
      else if sTmp = 'IOC' then
        pcValue := pcIOC
      else pcValue := pcMarket;

      dPrice    := aVal.GetValue<double>('p', 0 );

      sTmp := aVal.GetValue<string>('f','');
      aTIF := tmGTC;
      if sTmp = 'GTX' then
        aTIF := tmGTX;

      aOrder := App.Engine.TradeCore.Orders[ekBinance].NewOrder( aAcnt, aSymbol,
        iSide, dOrderQty, pcValue, dPrice, aTIF );

      if aOrder = nil then
      begin
        App.Log(llError, 'biance %s not found order : %s, %s, %s, %s, %s ',
          [ TExApiTypeDesc[aExApiType], sID, sCode, ifThenStr( iSide = 1, '매수','매도')
            , aSymbol.PriceToStr(dPrice), aSymbol.QtyToStr(dOrderQty)  ]  );
        Exit;
      end ;

      aOrder.ReduceOnly := aVal.GetValue<boolean>('R', false);

    end;
  end;

  iTime := aJson.GetValue<int64>('T');
  dtTime:= UnixTimeToDateTime( iTime );

  sTmp  := aVal.FindValue('X').Value;
  sTmp2 := aVal.FindValue('x').Value;
  aStatus := GetOrderStatus(sTmp);

  aOrder.OrderNo    := sID;

  App.DebugLog('Binance %s : %s, %s, %s, %s, %s, %s, %s, %s, %s ', [ TExApiTypeDesc[aExApiType]
    , sTmp2, sTmp, sID, sCode
    , ifThenStr( aOrder.Side = 1, '매수','매도')
    , aSymbol.PriceToStr(dPrice), aSymbol.QtyToStr(dOrderQty)
    , ifThenStr( aOrder.ReduceOnly, 'Reduce', 'Limit' )
    , aOrder.LocalNo
    ]  );

  case aStatus of
    osActive    :
      begin
        case aOrder.OrderType of
          otNormal: begin
            if aOrder.ReduceOnly then
              aOrder.UpdateOrderQty(dOrderQty);
            App.Engine.TradeBroker.Accept( aOrder, dtTime, true ) ;
          end;
          otChange: begin
            if sTmp2 = 'AMENDMENT' then
              App.Engine.TradeBroker.Change(aOrder, true, dtTime, '');
          end;
        end;
      end;
    osFilled    :
      begin
        var aFill : TFill;
        var dFillVol, dFillPrice, dAvgPrice, dFee : double;
        var sTrdID : string;

        dAvgPrice := aVal.GetValue<double>('ap', 0 );
        dFillVol  := aVal.GetValue<double>('l', 0);
        dFillPrice:= aVal.GetValue<double>('L', 0);
        dFee      := aVal.GetValue<double>('n', 0);   // 수수료
        sTrdID    := aVal.GetValue<string>('t');

        sTmp2 := aVal.GetValue<string>('x');
        if (sTmp2 = 'AMENDMENT') and (aOrder.OrderType = otChange) and (dFillVol <= EPSILON) then
        begin
          // 이럴땐 정정 처리
          App.Engine.TradeBroker.Change(aOrder, true, dtTime, '');
          Exit;
        end;

        App.DebugLog('Binance %s Fill : %s, %s, %s, %s, %s, %s ', [
          TExApiTypeDesc[aExApiType], sTmp, sID,
          aSymbol.PriceToStr(dFillPrice), aSymbol.QtyToStr(dFillVol),
          aSymbol.PriceToStr(dAvgPrice),  sTrdID
        ]);

        aFill := App.Engine.TradeCore.Fills[ekBinance].New( sTrdID, dtTime, now,
          sID, aOrder, dFillVol, dFillPrice);
        aFill.Fee := dFee;

        App.Engine.TradeBroker.Fill( aOrder, aFill, sTmp = 'FILLED' );
      end;
    osCanceled  : App.Engine.TradeBroker.Cancel( aOrder, true ) ;
    osRejected  : App.Engine.TradeBroker.Accept( aOrder, dtTime, false );
  end;

end;

