//                Format('%.*f', [ GetPrecision(aSymbol, aSymbol.Last), aSymbol.Last]),
//                '', aSymbol.DepthLog(false), iLast
//                ]);

            aSymbol.LastID	:= iLast;
          end;

        end;
    end else
    if sTmp = 'markPriceUpdate' then
    begin
      (aSymbol as TFuture).MarkPrice := strToFloat( aObj.GetValue('p').Value );
      // funding rate
      (aSymbol as TFuture).FundingRate := strToFloat( aObj.GetValue('r').Value );
      if (aSymbol.IndexPrice < DOUBLE_EPSILON ) then
        aSymbol.Basis := 0
      else
        aSymbol.Basis  := ( aSymbol.Last - aSymbol.IndexPrice ) / aSymbol.IndexPrice * 100;
      aSymbol.IndexPrice := StrToFloat( aObj.GetValue('i').Value );
    end;

  end;

