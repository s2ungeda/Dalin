function TBinanceParse.ParseMarginType(aData: string): boolean;
var
  aObj : TJsonObject;
  stCode : string;
begin

  Result := false;

  if aData = '' then
  begin
    App.Log(llError, 'Binance ParseMarginType data is empty') ;
    Exit;
  end;

  aObj  := TJsonObject.ParseJSONValue( aData ) as TJsonObject;
  try

    stCode := aObj.GetValue<string>('code', '');
    if stCode = '200' then
      Result := true
    else
      // 실패
      App.Log(llError, 'MarginType Request Error : %s', [ aData ]  );

  finally
    if aObj <> nil then aObj.Free;
  end;
end;

