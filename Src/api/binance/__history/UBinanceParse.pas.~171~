    except
    end;
  finally
    if aArr <> nil then aArr.Free;
  end;
end;

procedure TBinanceParse.ParseFutMarketDepth(aJson: TJsonObject; aExApiType : TExchangeApiType);
var
  sCode : string;
  aQuote : TQuote;
  i : integer;
  aVal : TJsonValue;
  aArr, aArr2 : TJsonArray;
  dtTime: TDateTime;
  bReversal : boolean;
  pu, u , g: int64;

  StopWatch: TStopWatch;
//  Elapsed  : array [0..1] of TTimeSpan;
begin

  //StopWatch := TStopWatch.StartNew;

  sCode := GetCode( aJson.GetValue('s').Value, aExApiType);

  aQuote  := App.Engine.QuoteBroker.Brokers[FParent.ExchangeKind].Find(sCode)    ;
  if (aQuote = nil) or (aQuote.Symbol = nil ) then Exit;

  dtTime  := UnixTimeToDateTime( aJson.GetValue<int64>('E') );

  pu := aJson.GetValue<int64>('pu');  // First update ID in event
  u := aJson.GetValue<int64>('u');  // Final update ID in event

  with aQuote do
  begin

    bReversal := false;
    if Symbol.LastEventTime > dtTime then
      bReversal := true;

    aArr := aJson.GetValue('b') as TJsonArray;
    Symbol.Bids.VolumeTotal := 0;
    for I := aArr.Count-1 downto 0 do
    begin
    	if i >= Symbol.Bids.Count then continue;
      aArr2  := aArr.Items[i] as TJsonArray;

			Symbol.Bids[i].Price := StrToFloat( aArr2.Items[0].Value );
      Symbol.Bids[i].Volume := StrToFloat( aArr2.Items[1].Value );
      Symbol.Bids.VolumeTotal := Symbol.Bids.VolumeTotal + Symbol.Bids[i].Volume;
    end;

    aArr := aJson.GetValue('a') as TJsonArray;
    Symbol.Asks.VolumeTotal := 0;
    for I := 0 to aArr.Count-1 do
    begin
    	if i >= Symbol.Asks.Size then continue;
      aArr2  := aArr.Items[i] as TJsonArray;

			Symbol.Asks[i].Price := StrToFloat( aArr2.Items[0].Value );
      Symbol.Asks[i].Volume := StrToFloat( aArr2.Items[1].Value );
      Symbol.Asks.VolumeTotal := Symbol.Asks.VolumeTotal + Symbol.Asks[i].Volume;
    end;

    Symbol.TrnsTimeQ    := aJson.GetValue<int64>('T') ;
    g := Symbol.TrnsTimeQ - Symbol.LastTrnsTime;
    Symbol.LastTrnsTime := Symbol.TrnsTimeQ ;
    LastEvent := qtMarketDepth;

//    if sCode = LOG_CODE then
//      App.Log(llDebug, sCode+'_bn_quote', 'Q,%s,%s,%s,%s,%s', [
//        aJson.GetValue<string>('E'), aJson.GetValue<string>('T') ,
//        Format('%.*f', [ GetPrecision(Symbol, Symbol.Asks[0].Price), Symbol.Asks[0].Price]),
//        Format('%.*f', [ GetPrecision(Symbol, Symbol.Asks[0].Price), Symbol.Last]),
//        Format('%.*f', [ GetPrecision(Symbol, Symbol.Asks[0].Price), Symbol.Bids[0].Price])
//        ]);

    App.QuoteLog(FParent.ExchangeKind, aExApiType, Symbol.Spec.BaseCode,
        ',Q,%s,%d,%d,%s,%s,%s,%s,%d,%d', [
        aJson.GetValue<string>('E'), Symbol.TrnsTimeQ, g,
        ifThenStr(bReversal, 'R',''),'','',Symbol.DepthLog(false),
        pu, u
        ]);

    Symbol.ContiCnt := 0;
    Symbol.SavePrevDepth;

  //  Elapsed[0] := StopWatch.Elapsed;
    Update( dtTime );

  //  Elapsed[1] := StopWatch.Elapsed;
  end;

//  StopWatch.Stop;

//  App.Log(llInfo, '-----speed by binan depth %s, %s ',[ Elapsed[0].TotalMilliseconds.ToString,
//     Elapsed[1].TotalMilliseconds.ToString] )
end;





