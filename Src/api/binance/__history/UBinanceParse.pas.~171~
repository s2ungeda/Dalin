procedure TBinanceParse.ParseFuttMaster(aData: string);
var
  aJson : TJsonValue;
  aVal : TJsonValue;
  aObj, aFil  : TJsonObject;
  aArr, aArr2, aArr3  : TJsonArray;
  aSymbol : TSymbol;
  I, j, iPre, iQtyPre: Integer;
  sTmp, sCode, aFiType : string;
  bNew : boolean;
  dSize, dSize2, dNotion, dUp, dDown : double;
  dInt : TDecimalHelper;
begin
  if aData = '' then
  begin
    App.Log(llError, 'Binance ParseFuttMaster data is empty') ;
    Exit;
  end;

  try

  aJson := TJsonObject.ParseJSONValue(aData);
  if aJson = nil then Exit;

  aArr3:= (aJson as TJsonObject).Get('assets').JsonValue as TJsonArray;

  j := 0;
  SetLength(FArrAsset, aArr3.Count);
  for I := 0 to aArr3.Count-1 do
  begin
    aVal  := aArr3.Items[i];
    if aVal.GetValue<boolean>('marginAvailable',false) then
    begin
      FArrAsset[j]  := aVal.GetValue<string>('asset');
      inc(j);
    end;
  end;

  SetLength(FArrAsset, j);

  aArr := (aJson as TJsonObject).Get('symbols').JsonValue as TJsonArray;

  for I := 0 to aArr.Count-1 do
  begin
    aObj  := aArr.Items[i] as TJsonObject;
    sTmp  := aObj.GetValue('quoteAsset').Value;
    //if sTmp <> 'USDT' then  begin

    if not EnableSettleStr(sTmp) then
      Continue;

    sCode   := aObj.GetValue('symbol').Value;

    sTmp    := sCode + Fut_Suf;  // add perpectual future Suffix;
    aSymbol := App.Engine.SymbolCore.FindSymbol(ekBinance, sTmp);
    if aSymbol = nil then
    begin
      bNew := true;
      aSymbol := App.Engine.SymbolCore.RegisterSymbol(ekBinance, mtFutures, sCode );
      if aSymbol = nil then
      begin
        //App.DebugLog( 'binance  fut  not RegisterSymbol  : %d , %s ', [i, sCode] );
        continue;
      end;
    end else
      bNew := false;

    with aSymbol do
    begin
      OrgCode     := lowercase( sCode );
      Spec.BaseCode    := aObj.GetValue('baseAsset').Value;;
      Spec.QuoteCode   := aObj.GetValue('quoteAsset').Value;  // USTD
      Spec.SettleCode  := aObj.GetValue('marginAsset').Value;;
    end;

    sTmp := aObj.GetValue('status').Value;
    if sTmp = 'TRADING' then aSymbol.TradeAble := true  else aSymbol.TradeAble := false;

    iPRe  	:=  aObj.GetValue<integer>('pricePrecision');
    iQtyPre :=  aObj.GetValue<integer>('quantityPrecision');

    aArr2 := aObj.Get('filters').JsonValue as TJsonArray;

    for j := 0 to aArr2.Count-1 do
    begin
      aFil  := aArr2.Items[j] as TJsonObject;
      aFiType := aFil.GetValue('filterType').Value;
      if aFiType = 'PRICE_FILTER' then
      begin
        sTmp := aFil.GetValue('tickSize').Value;
        dSize := StrToFloatDef( sTmp, 1.0 );

        // pricePrecision 과 tickSize 가 다르다.
        // 실제 주문 소수점은 tickSize 로 해야 한다.
        dInt.convert(sTmp);
//        if iPre <> dInt.Precision then
//          App.DebugLog('diff Precision %s : %d, %d (%s)', [sCode, iPre, dInt.Precision, sTmp]  );
        iPRe := dInt.Precision;

      end else
      if aFiType = 'LOT_SIZE' then
      begin
        //sTmp := aFil.GetValue('minQty').Value;
        sTmp := aFil.GetValue('stepSize').Value;
        dSize2  := StrToFloatDef( sTmp, 1.0);
//        if aFil.GetValue('stepSize').Value <> aFil.GetValue('minQty').Value then
//          App.DebugLog('..........');

      end else
      if aFiType = 'MIN_NOTIONAL' then
      begin
        dNotion := aFil.GetValue<double>('notional', 5 );
      end else
      if aFiType = 'PERCENT_PRICE' then
      begin
        dUp   := aFil.GetValue<double>('multiplierUp');
        dDown := aFil.GetValue<double>('multiplierDown');
      end;
    end;

    aSymbol.Spec.SetSpec( iPre, dSize, dSize2, iQtyPre, dNotion );
    aSymbol.Spec.SetRange(dUp, dDown);

    if bNew then
      App.Engine.SymbolCore.RegisterSymbol( ekBinance, aSymbol );
  end;

  finally
    if aJson <> nil  then aJson.Free;
  end;
end;



