procedure TBinanceWithdraw.Parse(const aType, aData: string);
begin
  if aDAta = '' then
  begin
    DoNotify( '轎旎 蹂羶 褒ぬ', 999);
    Exit;
  end;

  if aType = 'DpstAddr' then
    ParseDepositAddress(aData);
end;

procedure TBinanceWithdraw.ParseDepositAddress(const aData: string);
var
  aObj : TJsonObject;
  iErr : integer;

  addr, tag: string;
begin
  aObj := TJsonObject.ParseJSONValue( aData) as TJsonObject;
  try
    if aObj.TryGetValue<integer>('code', iErr) then
    begin
      DoNotify(aObj.GetValue<string>('msg'), 999 );
      Exit;
    end;

    addr := aObj.GetValue('address').ToString;
    tag  := aObj.GetValue('tag').ToString;

    addr.Replace('"','');
    tag.Replace('"','');

    DoNotify(addr + '=' + tag);

  finally
    FreeAndNil(aObj);
  end;
end;

end.
