{ TBinanceManager }

constructor TBinanceManager.Create(aExType: TExchangeKind);
begin
  inherited Create( aExType );

  FParse:= TBinanceParse.Create(self);
  FSeq	:= 0;
  FListenInterval := 0;
  FDnwStateInterval := 0;
  FListenKeyCheck := 0;
end;

destructor TBinanceManager.Destroy;
begin

  if FDepTimer <> nil then
    FDepTimer.Enabled := false;
  FParse.Free;

  inherited;
end;

function TBinanceManager.InitMarketWebSockets: boolean;
var
  iCount , iMode, i, j, idx : integer;
  aList : TStringList;
  aSymbol : TSymbol;
  sEP, sKey : string;
  k : TExchangeApiType;
begin

  iCount := 3;
  SetLength( QuoteSock, iCount );
  SetLength( TradeSock, iCount );

  for k := eaSpot to High(TExchangeApiType) do
  begin
    idx := integer(k);
    QuoteSock[idx]  := TBinanceWebSocket.Create(QOUTE_SOCK, idx, k ) ;
    if k = eaFutUsdt then
      sEP := App.Engine.ApiConfig.ExchangeInfo[ integer(ekBinance) ].ApiInfo[k].WSUrl + '/market/ws'
    else
      sEP := App.Engine.ApiConfig.ExchangeInfo[ integer(ekBinance) ].ApiInfo[k].WSUrl;
    QuoteSock[idx].init(sEP);
  end;

  // 龱陛 等檜攪諦.
  QuoteSockPub  :=  TBinanceWebSocket.Create(QOUTE_SOCK, 3, eaFutUsdt) ;
  QuoteSock[idx].init(App.Engine.ApiConfig.ExchangeInfo[ integer(ekBinance) ].ApiInfo[k].WSUrl + '/public/ws');

  for k := eaFutUsdt to High(TExchangeApiType) do
  begin
    idx := integer(k);
    sKey  := Exchanges[k].RequestListenKey( true );

    TradeSock[idx]  := TBinanceWebSocket.Create(TRADE_SOCK, idx, k) ;
    if k = eaFutUsdt then
      TradeSock[idx].init(App.Engine.ApiConfig.ExchangeInfo[ integer(ekBinance) ].ApiInfo[k].WSUrl + '/private/ws' + sKey)
    else
      TradeSock[idx].init(App.Engine.ApiConfig.ExchangeInfo[ integer(ekBinance) ].ApiInfo[k].WSUrl + '/' + sKey  );
  end;

  // add websocket api
  TBinanceFutures(Exchanges[eaFutUsdt]).WsApi.init(
    App.Engine.ApiConfig.ExchangeInfo[ integer(ekBinance) ].ApiInfo[eaFutUsdt].WSApiUrl
  );

  Timer.OnTimer := OnTimer;

  Result := true;

  FDepTimer  := App.Engine.QuoteBroker.Timers.New;
  FDepTimer.Enabled  := false;
  FDepTimer.Interval := 500;
  FDepTimer.OnTimer  := OnDepthTimer;
end;



function TBinanceManager.MakeCloseData: boolean;
var
  sTmp : string;
begin
  stmp := App.Engine.SymbolCore.MainSymbols[msBTC][ExchangeKind].OrgCode;
  Result := Exchanges[eaFutUsdt].RequestCandleData('1d', sTmp )
    and Exchanges[eaFutUsdt].RequestCandleData('30m', sTmp )    ;

  stmp := App.Engine.SymbolCore.MainSymbols[msETH][ExchangeKind].OrgCode;
  Result := Exchanges[eaFutUsdt].RequestCandleData('1d', sTmp )
    and Exchanges[eaFutUsdt].RequestCandleData('30m', sTmp )    ;
end;

procedure TBinanceManager.OnDepthTimer(Sender: TObject);
begin
  if Done then
  begin
    FDepTimer.Enabled := false;
    Exit;
  end;

end;

procedure TBinanceManager.OnTimer(Sender: TObject);
var
  j : TMarketType;
  i : TExchangeApiType;
  sKey : string;
begin
  // 1蟾縑 フ廓

  try

    if FDnwStateInterval > 10 then
    begin
      // weight 陛 1M 縑 10
//      Exchanges[mtSpot].RequestDNWState;
      FDnwStateInterval := 0;
    end;

    if FListenInterval > (60 * 20) then
    begin
      FListenInterval := 0;
      Exchanges[eaFutUsdt].RequestListenKey(false);
      Exchanges[eaFutCoin].RequestListenKey(false);
    end;

    // listen key 鼻鷓 薄匐
    if FListenKeyCheck > 15  then
    begin
      FListenKeyCheck := 0;
      for I := eaFutUsdt to High(TExchangeApiType) do
        if Exchanges[i].NeedReCon then begin
          sKey := Exchanges[i].RequestListenKey(true);
          if sKey <> '' then begin
            App.Log(llInfo, 'Binance %s Trade Reconnect with skey (%s)', [TExApiTypeDesc[i], sKey])  ;
            TradeSock[integer(i)].DoConnectWithListenkey(sKey);
            Exchanges[i].NeedReCon  := false;
          end;
        end;
    end;

  finally
    inc( FListenInterval );
    inc( FDnwStateInterval );
    inc( FListenKeyCheck );
  end;

end;

