function TBinanceManager.SubscribeAll: boolean;
var
  i, j : integer;
begin

  if QuoteSockPub <> nil then
    QuoteSockPub.SubscribeAll;

  for I := 0 to High(QuoteSock) do begin
    QuoteSock[i].SubscribeAll;
    sleep(500);
  end;

  result := true;
end;


function TBinanceManager.UnSubscrib(aSymbol: TSymbol): boolean;
begin
  Result := false;
  try
    if QuoteSockPub <> nil then
      (QuoteSockPub as TBinanceWebSocket).UnSubScribe( aSymbol );

    (QuoteSock[integer(aSymbol.Spec.ExApiType)] as TBinanceWebSocket).UnSubScribe( aSymbol );

    Result := true;
  except
  end;
end;

function TBinanceManager.SendOrder(aOrder: TOrder): boolean;
begin
  Result := false;
  if aOrder = nil then Exit;

  case aOrder.Symbol.Spec.Market of
    mtSpot: ;
    mtFutures:  Result := Exchanges[eaFutUsdt].RequestOrder( aOrder ) ;
  end;
end;

procedure TBinanceManager.StopSendTimer;
var
  i : Integer;
begin
  for i := 0 to  High(QuoteSock) do
    (QuoteSock[i] as TBinanceWebSocket).StopSendTimer;
end;

function TBinanceManager.Subscrib(aSymbol: TSymbol): boolean;
begin
  Result := false;
  try
    if QuoteSockPub <> nil then
      (QuoteSockPub as TBinanceWebSocket).SubScribe(aSymbol);

    (QuoteSock[integer(aSymbol.Spec.ExApiType)] as TBinanceWebSocket).SubScribe(aSymbol);
    Result := true;
  except

  end;
end;


procedure TBinanceManager.UnSubscribeAll;
var
  i, j : integer;
begin

  if QuoteSockPub <> nil then
    (QuoteSockPub as TBinanceWebSocket).UnSubScribeAll;

  for I := 0 to High(QuoteSock) do
  begin
   (QuoteSock[i] as TBinanceWebSocket).UnSubScribeAll;
    sleep(500);
  end;

end;

