procedure TBinanceWithdraw.DoWithdraw;
var
  sTime, data, sig : string;
begin

  try
    sTime := GetTimestamp;
    data  := Format('timestamp=%s&coin=%s&network=%s&address=%s&addressTag=%s&amount=%s',
      [sTime, Param.currency, Param.nettype, Param.addr1, Param.addr2, Param.qty ]);
    sig   := CalculateHMACSHA256( data, App.Engine.ApiConfig.GetSceretKey(ekBinance , eaSpot));

    with Req do
    begin
      Req.Params.Clear;
      Req.AddParameter('timestamp', sTime );
      Req.AddParameter('coin', Param.currency, pkGETorPOST);
      Req.AddParameter('network', Param.nettype, pkGETorPOST );
      Req.AddParameter('address', Param.addr1, pkGETorPOST );
      Req.AddParameter('addressTag', Param.addr2, pkGETorPOST );
      Req.AddParameter('amount', Param.qty, pkGETorPOST );

      Req.AddParameter('signature', sig );
      Req.AddParameter('X-MBX-APIKEY', App.Engine.ApiConfig.GetApiKey(ekBinance , eaSpot), pkHTTPHEADER);
    end;

    Req.init(rmPOST, 'https://api.binance.com', '/sapi/v1/capital/withdraw/apply?'+data, 'withdraw' );

    Req.RequestAsync;
  finally

  end;
end;

