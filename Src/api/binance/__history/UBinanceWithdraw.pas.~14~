procedure TBinanceWithdraw.RequestDepositAddress(sCurrency, sNetType: string);
var
  sTime, data, sig : string;
begin
  if sCurrency.IsEmpty or sNetType.IsEmpty then Exit;

  try
    sTime := GetTimestamp;
    data  := Format('timestamp=%s&coin=%s&network=%s', [sTime, sCurrency, sNetType]);
    sig   := CalculateHMACSHA256( data, App.Engine.ApiConfig.GetSceretKey(ekBinance , eaSpot));

    with Req do
    begin
      Req.Params.Clear;
      Req.AddParameter('timestamp', sTime );
      Req.AddParameter('signature', sig );
      Req.AddParameter('X-MBX-APIKEY', App.Engine.ApiConfig.GetApiKey(ekBinance , eaSpot), pkHTTPHEADER);

      Req.AddParameter('coin', sCurrency, pkGETorPOST);
      Req.AddParameter('network', sNetType, pkGETorPOST );
    end;

    Req.init(rmGET, 'https://api.binance.com', '/sapi/v1/capital/deposit/address', 'DpstAddr' );
    Req.Field1  := sCurrency;
    Req.Field2  := sNetType;
    Req.RequestAsync;
  finally

  end;

end;

