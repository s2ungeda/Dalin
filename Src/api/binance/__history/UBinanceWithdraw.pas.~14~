procedure TBinanceWithdraw.Parse(const aType, aData: string);
begin
  if aDAta = '' then
  begin
    DoNotify( '轎旎 蹂羶 褒ぬ', 999);
    Exit;
  end;

  if aType = 'DpstAddr' then
    ParseDepositAddress(aData)
  else if aType = 'withdraw' then
    ParseWithdraw(aData)
  else if aType = 'address' then
    ParseWithdrawAddress(aData);

end;

procedure TBinanceWithdraw.ParseDepositAddress(const aData: string);
var
  aObj : TJsonObject;
  iErr : integer;

  addr, tag: string;
begin
  aObj := TJsonObject.ParseJSONValue( aData) as TJsonObject;
  try
    if aObj.TryGetValue<integer>('code', iErr) then
    begin
      DoNotify(aObj.GetValue<string>('msg'), 999 );
      Exit;
    end;

    addr := aObj.GetValue<string>('address');
    tag  := aObj.GetValue<string>('tag');

    if tag.IsEmpty then
      DoNotify(addr)
    else
      DoNotify(addr + '=' + tag);
  finally
    FreeAndNil(aObj);
  end;
end;

procedure TBinanceWithdraw.ParseWithdraw(const aData: string);
var
  aObj : TJsonObject;
  iErr : integer;
begin
  aObj := TJsonObject.ParseJSONValue( aData) as TJsonObject;
  try
    if aObj.TryGetValue<integer>('code', iErr) then
    begin
      DoNotify(aObj.GetValue<string>('msg'), 999 );
      Exit;
    end;

    var id := aObj.GetValue<string>('id');

    DoNotify( RES_WT, '轎旎撩奢 :' + id );
  finally
    FreeAndNil(aObj);
  end;
end;

procedure TBinanceWithdraw.ParseWithdrawAddress(const aData: string);
var
  aVal, aSub : TJsonValue;
  aArr : TJsonArray;
  i, iErr: integer;
begin

  aVal := TJsonObject.ParseJSONValue(aData);
  try
    if aVal is TJsonObject then
    begin
      if aVal.TryGetValue<integer>('code', iErr) then
      begin
        DoNotify(aVal.GetValue<string>('msg'), 999 );
        Exit;
      end;
      Exit;
    end;

    aArr  := aVal as TJsonArray;

    Address.Clear;

    for I := 0 to aArr.Count-1 do
    begin
      aSub  := aArr.Items[i];

      if not aSub.GetValue<boolean>('whiteStatus') then Continue;

      var Rec := Default(TDepositAddress);
      with Rec do
      begin
        Exchange  := TExchangeKindDesc[ekBinance];

        Coin      := aSub.GetValue<string>('coin');
        NetType   := aSub.GetValue<string>('network');
        NetName   := '';
        Address   := aSub.GetValue<string>('address');
        Memo      := aSub.GetValue<string>('addressTag', '');

        WithdrawExchange  := aSub.GetValue<string>('originType');
      end;

      Address.Add(Rec);
    end;

    DoNotify('address');
  finally
    FreeAndNil(aVal);
  end;

end;

end.
