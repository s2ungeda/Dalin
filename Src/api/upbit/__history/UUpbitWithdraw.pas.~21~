procedure TUpbitWithdraw.Parse(const aType, aData: string);
var
  aObj, aSub : TJsonObject;
  aArr  : TJsonArray;
  aErr, aVal : TJsonValue;
  aPair: TJsonPair;
  i, idx: Integer;
  stTmp : string;
  bOK : boolean;
  aItem : TDpItem;
begin
  if aDAta = '' then
  begin
    DoNotify( '출금 요청 실패', 999);
    Exit;
  end;

  if aType = 'status' then
  begin
    aObj := TJsonObject.ParseJSONValue( aData) as TJsonObject;
    try
      aErr  := aObj.GetValue('error');
      if aErr <> nil then
      begin
        DoNotify(aErr.GetValue<string>('message'), 999 );
        Exit;
      end;

      aSub  := aObj.GetValue('currency') as TJsonObject;
      if aSub = nil then
      begin
        DoNotify('출금 불가', 999 );
        Exit;
      end;

      bOK := false;
      aArr  := aSub.GetValue('wallet_support') as TJsonArray;
      for i := 0 to aArr.Count-1 do
      begin
        stTmp := aArr.Items[i].Value;
        if stTmp = 'withdraw' then
          bOK := true;
      end;

      if not bOK then
      begin
        DoNotify('출금 불가', 999 );
        Exit;
      end else
        ReuqestWithdraw;

    finally
      FreeAndNil(aObj);
    end;

  end else
  if aType = 'withdraw' then
  begin
    aObj := TJsonObject.ParseJSONValue( aData) as TJsonObject;
    try
      aErr  := aObj.GetValue('error');
      if aErr <> nil then
      begin
        DoNotify(aErr.GetValue<string>('message'), 999 );
        Exit;
      end;

      DoNotify('출금 성공');

      DoUpdateAsset;

    finally
      FreeAndNil(aObj);
    end;
  end else
  if aType = 'address' then
  begin
    aArr  := TJsonObject.ParseJSONValue( aData) as TJsonArray;
    try
      Address.Clear;

      aErr  := aObj.GetValue('error');
      if aErr <> nil then
      begin
        DoNotify(aErr.GetValue<string>('message'), 999 );
        Exit;
      end;

      for I := 0 to aArr.Count-1 do
      begin
        aVal  := aArr.Items[i] ;

        if (Req.Field1 = aVal.GetValue<string>('currency')) and ( Req.Field2 = aVal.GetValue<string>('net_type')) then
        begin
          stTmp := aVal.GetValue<string>('secondary_address', '');
          Address.Add(aVal.GetValue<string>('withdraw_address')+','+stTmp);
        end;
      end;

      DoNotify(aType);

    finally
      FreeAndNil(aArr);
      Req.Field1 := ''; Req.Field2 := '';
    end;
  end else
  if aType = 'deposit' then
  begin
    aVal  := TJsonObject.ParseJSONValue( aData);// as TJsonArray;
    if aVal = nil then Exit;

    try
      if not (aVal is TJsonArray) then
      begin
        aErr  := (aVal as TJsonObject).GetValue('error');
        if aErr <> nil then
          DoNotify(aErr.GetValue<string>('message'), 999 );
        Exit;
      end;

      aArr  := aVal as TJsonArray;

      idx := ifThen( Req.Field2 = 'first', 0, 1);
      if idx = 1 then
        FDpList[idx].Clear;

      for I := 0 to aArr.Count-1 do
      begin
        aVal  := aArr.Items[i] ;
        if ( (Req.Field1 = aVal.GetValue<string>('currency'))
          and (aVal.GetValue<string>('type') = 'deposit')
          and (aVal.GetValue<string>('state') = 'ACCEPTED')  ) then
        begin
          aItem := TDpItem.Create;
          aItem.Code  := Req.Field1;
          aItem.UUid  := aVal.GetValue<string>('uuid');
          aItem.Amount:= aVal.GetValue<string>('amount');
          aItem.Time  := GetStrToTime(aVal.GetValue<string>('done_at'));
          FDpList[idx].Add(aItem);
        end;
      end;

      if idx = 1 then
      begin
        bOK := CompareLists;
        if not bOK then
          DoNotify(aType);
      end;

    finally
      FreeAndNil(aVal);
      Req.Field1 := ''; Req.Field2 := '';
    end;
  end else
  if aType = 'depositaddr' then
  begin
    aObj := TJsonObject.ParseJSONValue( aData) as TJsonObject;
    try
      aErr  := aObj.GetValue('error');
      if aErr <> nil then
      begin
        DoNotify(aErr.GetValue<string>('message'), 999 );
        Exit;
      end;

      var bRes : boolean;

      if aObj.TryGetValue<boolean>('success', bRes) then
        DoNotify(RES_WT,  aObj.GetValue<string>('message') )
      else  begin
        var addr1, addr2 : string;
        addr1 := aObj.GetValue('deposit_address').Value;
        addr2 := aObj.GetValue('secondary_address').Value;
        if addr2 <> 'null' then
          addr1 := addr1 + '=' + addr2;
        DoNotify(addr1);
      end;
    finally
      FreeAndNil(aObj);
    end;
  end;
  ;

end;

function TUpbitWithdraw.CompareLists: Boolean;
var
  i: Integer;
  aItem : array [0..1] of TDpItem;
begin
  Result := False;

  // 리스트의 개수가 같은지 확인
  if FDpList[0].Count <> FDpList[1].Count then
    Exit;

  // 각 위치의 원소를 비교
  for i := 0 to FDpList[0].Count - 1 do
  begin
    // 원소가 다를 경우 두 리스트는 다름
    aItem[0] := TDpItem(FDpList[0].Items[i]);
    aItem[1] := TDpItem(FDpList[1].Items[i]);

    if aItem[0].UUid <> aItem[1].UUid then
      Exit;
  end;

  // 모든 원소가 같으면 두 리스트는 동일함
  Result := True;
end;

procedure TUpbitWithdraw.RecvRequest(Sender: TObject);
