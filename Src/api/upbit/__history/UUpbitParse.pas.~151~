    aVal2  := aArr.Items[i];
    aSymbol.Day5MinLow   := aVal2.GetValue<double>('low_price',0);
    aSymbol.Day5MinHigh  := aVal2.GetValue<double>('high_price',0);

    App.Engine.SymbolBroker.SymbolEvent( aSymbol, 0);

  finally
