procedure TUpbitParse.ParseSpotMyTrade(aJson: TJsonObject);
var
  sOID, sState, sLocalNo, sFillNo : string;
  aOrder : TOrder;
  aFill  : TFill;
  dtTime : TDateTime;
  dVolume, dPrice, dFeeRate : double;
  v, rv, ev : double;
  aRslt : TOrderResult;
  tc, i : Integer;
  bRemove : boolean;
begin

  if aJson = nil then Exit;

  App.Log(llDebug,'upbit_order', '%s', [aJson.ToString]) ;

  sOID  := aJson.GetValue('uid').Value;
  sLocalNo  := aJson.GetValue('id').Value;

  aOrder  := App.Engine.TradeCore.FindOrder(FParent.ExchangeKind, sOID, DIV_ORD_NO);
  if aOrder = nil then
    if sLocalNo = 'null' then
    begin
      App.Log(llInfo, '%s 외부 주문 처리 안함', [TExchangeKindDesc[FParent.ExchangeKind]] );
      Exit;
    end else
    begin
      aOrder:= App.Engine.TradeCore.FindOrder(FParent.ExchangeKind, sLocalNo);
      if aOrder <> nil then
        App.Log(llInfo, 'Order Desc : %s', [aOrder.Represent])
      else begin
        aOrder := App.Engine.TradeCore.TotalOrders.FindLocalOrder(sLocalNo);
        if aOrder <> nil then
          App.Log(llInfo, '%s Find from TotalOrer !! : %s', [
            TExchangeKindDesc[FParent.ExchangeKind], aOrder.Represent] )
        else
          App.Log(llInfo,'%s Not Found from TotalOrer !! %s, %s ', [
            TExchangeKindDesc[FParent.ExchangeKind], sOID, sLocalNo]  );
      end;
    end;

  sState  := aJson.GetValue('s').Value;

  aRslt   := nil;
  if aOrder = nil then
  begin

    if sState = 'wait' then begin
      if sLocalNo = 'null' then
      begin
//        // 외부에서 낸 주문.
//        aOrder := MakeNewOrder(aJson.GetValue('uid').Value, aJson.GetValue('cd').Value,
//          aJson.GetValue('p').Value, aJson.GetValue('v').Value,
//          aJson.GetValue('ab').Value, );
//        if aOrder = nil then Exit;
//        var dtTime: TDateTime;
//        dtTime := UnixTimeToDateTime(UnixTimeToDateTime);
//        App.Engine.TradeBroker.Accept(aOrder, dtTime, true);
//
//      end else
//      begin
//        aOrder:= App.Engine.TradeCore.FindOrder(FParent.ExchangeKind, sLocalNo );
//
//        if aOrder = nil then
//        begin
////          App.Log(llError, '%s not found order : %s , %s ', [ TExShortDesc[FParent.ExchangeKind], aData, aRef  ] );
//          Exit;
//        end;
      end;

      aRslt := App.Engine.TradeCore.OrderResult[ekUpbit].New(aOrder, rtWait);
      aRslt.OrderNo := sOID;
      FForwardOrderResults.Insert(0,aRslt);
    end else
    if sState = 'trade' then
    begin
      aRslt := App.Engine.TradeCore.OrderResult[ekUpbit].New(aOrder, rtFill);
      aRslt.OrderNo := sOID;
      aRslt.Volume  := aJson.GetValue<double>('v');
      aRslt.Price   := aJson.GetValue<double>('p');
      aRslt.FillNo  := aJson.GetValue('tuid').Value;
      aRslt.Time    := UnixTimeToDateTime(aJson.GetValue<int64>('ttms'));
      aRslt.Fee     := aJson.GetValue<double>('pf');
      aRslt.TC      := aJson.GetValue<integer>('tc', 0);
      FForwardOrderResults.Insert(0,aRslt);
    end else
    if sState = 'done' then
    begin
      aRslt := App.Engine.TradeCore.OrderResult[ekUpbit].New(aOrder, rtDone);
      aRslt.OrderNo := sOID;
      aRslt.TC      := aJson.GetValue<integer>('tc', 0);
      FForwardOrderResults.Insert(0, aRslt);
    end else
    if sState = 'cancel' then
    begin
      aRslt := App.Engine.TradeCore.OrderResult[ekUpbit].New(aOrder, rtCancel);
      aRslt.OrderNo := sOID;
      FForwardOrderResults.Insert(0, aRslt);
    end;

    if aRslt <> nil then
      App.Log(llINfo, 'MyOrder %s %s 역전 : %d', [aRslt.TypeToStr, aRslt.OrderNo, FForwardOrderResults.Count ]);
    Exit;
  end;

  if sState = 'wait' then begin
    // 패스 : 중복처리 가능성이 높다
    if not aOrder.IsAccept then
    begin
      aOrder.OrderNo  := sOID;
      aOrder.RsvFee   := aJson.GetValue<double>('rsf', 0);
      App.Engine.TradeBroker.Accept( aOrder,
        UnixTimeToDateTime(aJson.GetValue<int64>('otms')), true, '') ;
    end;
  end
  else if sState = 'cancel' then begin
    // 역전 처리 해야 함.
    v   := aJson.GetValue<double>('v');   // tot order qty
    rv  := aJson.GetValue<double>('rv');  // cancled qty
    ev  := aJson.GetValue<double>('ev');  // fillled qty
    tc  := aJson.GetValue<integer>('tc', 0);

    if tc > aOrder.Fills.Count then
    begin
      App.Log(llInfo, 'Upbit 취소 역전 : (tc:%d>%d) | vol:%.8f > %.8f(%.8f + %.8f), %s ',
         [ tc, aOrder.Fills.Count, v, rv + ev, rv, ev, aOrder.Represent]  );
      // 체결
      aRslt := App.Engine.TradeCore.OrderResult[ekUpbit].New(aOrder, rtCancel);
      aRslt.Volume  := rv;
      FForwardOrderResults.Insert(0, aRslt);
    end else
      App.Engine.TradeBroker.Cancel( aOrder, true);

  end
  else if sState = 'trade' then
  begin
    sFillNo := aJson.GetValue('tuid').Value;
    aFill   := aOrder.Fills.Find(sFillNo);
    if aFill = nil then
    begin
      //dFeeRate := App.Engine.ApiConfig.ExchangeInfo[integer(ekUpbit)].ApiInfo[eaSpot].TradeFee;
      dVolume:= aJson.GetValue<double>('v');
      dPrice := aJson.GetValue<double>('p');
      dtTime := UnixTimeToDateTime(aJson.GetValue<int64>('ttms'));
      aFill	 := App.Engine.TradeCore.Fills[ekUpbit].New(sFillNo, dtTime, now,
            sOID, aOrder, dVolume, dPrice);

      aFill.Fee := aJson.GetValue<double>('pf');// aFill.Price * aFill.Volume * dFeeRate / 100;

      App.Log(llInfo, 'Upbit Spot Fill - ws : %s, %s, %s, %s, %s, %.8f, %f, %s ', [ aOrder.Symbol.Code,
        aOrder.SideToStr, '', sOID,  aOrder.Symbol.PriceToStr(dPrice), dVolume, aFill.Fee, sFillNo
      ]);

      App.Engine.TradeBroker.Fill( aOrder, aFill, false );
    end;

    tc  := aJson.GetValue<integer>('tc', 0);

    // 역전 처리..
    for I := FForwardOrderResults.Count-1 downto 0 do
    begin
      aRslt := FForwardOrderResults.Results[i];
      if aRslt <> nil then
        bRemove := false;
        if aRslt.Order = aOrder then
        begin

          case aRslt.ResultType of
            rtCancel: if tc = aOrder.Fills.Count then
                      begin
                        App.Engine.TradeBroker.Cancel( aOrder, true) ;
                        bRemove := true;
                      end;

            rtDone: if tc = aOrder.Fills.Count then
                    begin
                      bRemove := true;
                      if aORder.State <> osFilled then
                        aOrder.Fill;
                    end
            else Continue;
          end;

          if bRemove then
          begin
            FForwardOrderResults.Remove(aRslt);
            App.Log(llInfo,'Forward Result : %s, %s, %s',[aRslt.TypeToStr,
              aOrder.Symbol.QtyToStr(aRslt.Volume), aOrder.Symbol.QtyToStr(aRslt.Price),
              aOrder.Represent ]  );
          end;
        end;
    end;
  end
  else if sState = 'done' then
  begin
    tc := aJson.GetValue<integer>('tc');
    if tc > aOrder.Fills.Count then
    begin
      App.Log(llInfo, 'Upbit Done 역전 : (tc:%d>%d), %s ', [ tc, aOrder.Fills.Count, aOrder.Represent]);
      aRslt := App.Engine.TradeCore.OrderResult[ekUpbit].New(aOrder, rtDone);
      FForwardOrderResults.Insert(0, aRslt);
    end else
      if aORder.State <> osFilled then
        aOrder.Fill
  end else
    Exit;

end;

end.
