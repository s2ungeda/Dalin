procedure TUpbitParse.ParseAccounts(aData: string);
var
  aArr : TJsonArray;
  aObj : TJsonObject;
  aVal : TJsonValue;
  I: Integer;
  aAcnt : TAccount;
  aAsset: TAsset;
  sTmp, sBal, sCode, sCur : string;
  aSCType : TSettleCurType;
  dBal, dLock, dTmp : double;
  iBal : int64;
  //aSymbol : TSymbol;

begin
  if aData = '' then
  begin
    App.Log(llError, '%s ParseBalance data is empty',
       [ TExchangeKindDesc[FParent.ExchangeKind] ] ) ;
    Exit;
  end;

  //App.DebugLog('ParseBalance : %s', [ aData ] );

  aAcnt := App.Engine.TradeCore.Accounts[ FParent.ExchangeKind].Accounts[0];
  if aAcnt = nil then Exit;

  aArr := nil;
  aArr := TJsonObject.ParseJSONValue( aData) as TJsonArray;

  if aArr = nil then Exit;

  try
    aAcnt.Assets.UpdateReady;

    for I := 0 to aArr.Count-1 do
    begin
      aObj  := aArr.Items[i] as TJsonObject;
      sCur  := aObj.GetValue('currency').Value;
      sCode := aObj.GetValue('unit_currency').Value;
      aSCType := GetSettleType( sCur );

      if (sCur = 'SOLO') or (sCur = 'XCORE') then continue;

      aAsset  := aAcnt.Assets.Find(sCur);
      if aAsset = nil then begin
        aAsset := aAcnt.Assets.New(sCur, aAcnt);
        if aSCType = scKRW then
          aAcnt.Asset := aAsset;
        App.Engine.TradeBroker.AssetEvent(aAsset, ASSET_NEW);
      end;

      aAsset.SyncAsset(
        aObj.GetValue<double>('balance'),
        aObj.GetValue<double>('locked'),
        aObj.GetValue<double>('avg_buy_price')
      );
    end;
    aAcnt.Assets.UpdateDone;

  finally
    if aArr <> nil then aArr.Free;
  end;
end;

