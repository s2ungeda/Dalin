procedure TUpbitParse.ParseActiveOrder(aData: string);
var
  aArr : TJsonArray;
  aObj : TJsonObject;
  aVal : TJsonValue;
  i : Integer;
  sOID,sTmp, sCode : string;
  aAcnt: TAccount;
  sArr : TArray<string>;
  iSide: integer;
  dOrderQty, dPrice, dLocked : double;
  dtTime : TDateTime;
  aOrder : TOrder;
  aSymbol: TSymbol;
begin
 if aData = '' then
  begin
    App.Log(llError, '%s ParseActiveOrder data is empty', [ TExchangeKindDesc[FParent.ExchangeKind] ] ) ;
    Exit;
  end;

  aArr  := TJsonObject.ParseJSONValue(aData) as TJsonArray;

  try
    if aArr = nil then Exit;
    aAcnt := App.Engine.TradeCore.FindAccount(FParent.ExchangeKind);
    if aAcnt = nil then Exit;

    for I := 0 to aArr.Count-1 do
    begin
      aVal := aArr.Items[i];

      sTmp := aVal.GetValue<string>('state');
      if sTmp <> 'wait' then continue;

      sCode := GetSymbolCode(aVal.GetValue<string>('market'));
      aSymbol := App.Engine.SymbolCore.FindSymbol(FParent.ExchangeKind, sCode);
      if aSymbol = nil then Continue;

      sOID  := aVal.GetValue<string>('uuid');
      sTmp  := aVal.GetValue<string>('side');
      if sTmp = 'bid' then
        iSide := 1
      else
        iSide := -1;

      dOrderQty := aVal.GetValue<double>('remaining_volume');
      dPrice    := aVal.GetValue<double>('price');
      dtTime    := GetStrToTime(aVal.GetValue<string>('created_at'));
      dLocked   := aVal.GetValue<double>('locked', 0);

      aOrder    := App.Engine.TradeCore.Orders[FParent.ExchangeKind].NewOrder(
        aAcnt, aSymbol, iSide, dOrderQty, pcLimit, dPrice, tmGTC);

      if aOrder <> nil then
      begin
        aOrder.OrderNo  := sOID;
        aOrder.Account.Assets.LoadOrder(iSide, '', sOID, dPrice, dOrderQty, dLocked);
        App.Engine.TradeBroker.Accept(aOrder, dtTime, true, '', true);
      end;
    end;

  finally
    FreeAndNil(aArr);
  end;
end;

procedure TUpbitParse.ParseCandleData(sUnit, aData: string);
var
  aArr : TJsonArray;
  aVal : TJsonValue;
  I, j: Integer;
  bStart : boolean;
  d, dd, h, m, mt : word;
  sTmp, sCode : string;
  dTime, dtime2: TDateTime;
  aSymbol : TSymbol;
  accAmt, aAmt, aPrice, aClose : double;
  aWcd : TWCDData;
  aKind : TMajorSymbolKind;
begin
  if aData = '' then
  begin
    App.Log(llError, '%s ParseDNWSate data is empty',
       [ TExchangeKindDesc[FParent.ExchangeKind] ] ) ;
    Exit;
  end;
  aArr := nil;
  aArr := TJsonObject.ParseJSONValue( aData) as TJsonArray;
  try
    if aArr = nil then Exit;

    try

      dTime2 := Date;
      accAmt := 0;
      j      := 0;

      for I := 0 to aArr.Count-1 do
      begin

        aVal := aArr.Items[i];

        sCode:= GetSymbolCode( aVal.GetValue<string>('market') );

        if sCode = 'BTC' then
          aKind := msBTC
        else
          aKind := msETH;

        sTmp := aVal.GetValue<string>('candle_date_time_kst');
        dTime:= GetStrToTime( sTmp );

        aAmt   := aVal.GetValue<double>('candle_acc_trade_price');
        aPrice := aVal.GetValue<double>('trade_price');

        mt:= MonthOf(dTime);
        d := Dayof(  dTime );
        h := Hourof( dTime );
        m := MinuteOf(dTime);

        if sUnit = '240' then begin

          // 봉이 6개 시간은 05:00 ~ 09:00
          accAmt := accAmt + aAmt;
          // 1일 캔들 시작
          if h = 5 then begin
             // 24시간 종가가 됨
            aClose := aPrice;
            // 1일 캔들 시작 플래그
            bStart := true;
          end
          // 1일 캔들 종료
          else if h = 9 then
          begin
            if bStart then
            begin
              sTmp := Format('%2.2d00', [ d] );
              aWcd := App.Engine.SymbolCore.WCDays.Find( sTmp );
              if aWcd = nil then begin
                aWcd := App.Engine.SymbolCore.WCDays.New( sTmp );
                aWcd.m := mt;  aWcd.d := d;
              end;

              aWcd.Price[ aKind, FParent.ExchangeKind] := aClose;
              aWcd.Amount[aKind, FParent.ExchangeKind] := accAmt;
         //     App.DebugLog('%s %s %s %s %d -> %f, %f', [ sUnit, TExchangeKindDesc[ FParent.ExchangeKind], TMajorSymbolCode[aKind],
         //      sTmp,  App.Engine.SymbolCore.WCDays.Count,  aClose, accAmt ]);
              bStart := false;
              inc(j);
            end;
            accAmt := 0;
            if j >= 25 then break;
          end;

          dd := d;
        end
        else if sUnit = '30' then begin

          if not IsToday( dTime ) then break;

          sTmp := Format('%2.2d%2.2d', [ h,m] );
          aWcd := App.Engine.SymbolCore.WCD30s.Find( sTmp );
          if aWcd = nil then
            aWcd := App.Engine.SymbolCore.WCD30s.New( sTmp );

          aWcd.Price[ aKind, FParent.ExchangeKind] := aPrice;
          aWcd.Amount[aKind, FParent.ExchangeKind] := aAmt;
       //ugLog('%s %s %s %s %d -> %f, %f', [ sUnit, TExchangeKindDesc[ FParent.ExchangeKind], TMajorSymbolCode[aKind],
       //     sTmp,  App.Engine.SymbolCore.WCD30s.Count,  aPrice, aAmt ]);
        end;

      end;

    except
    end;

  finally
    if aArr <> nil  then aArr.Free;
  end;


end;

procedure TUpbitParse.ParseDnwList(aData: string;
  var arr: TArray<TCoinDnwItem>; bDnw: boolean);
var
  aArr : TJsonArray;
  aVal : TJsonValue;
  i, j : Integer;
  sTmp, sCode : string;
  tmp  : TArray<TCoinDnwItem>;
begin
  if aData = '' then
  begin
    App.Log(llError, '%s ParseDnwList data is empty', [ TExchangeKindDesc[FParent.ExchangeKind] ] ) ;
    Exit;
  end;

  aArr := TJsonObject.ParseJSONValue(aData) as TJsonArray;
  try

    SetLength(tmp, aArr.Count);
    j := 0;

    for I := 0 to aArr.Count-1 do
    begin
      aVal  := aArr.Items[i];

      sCode := aVal.GetValue<string>('currency');
      if (not bDnw) and (sCode = 'KRW') then
      begin
        continue;
      end;

      tmp[j].exchange := TExchangeKindDesc[FParent.ExchangeKind];
      tmp[i].exKind :=  FParent.ExchangeKind;
      sTmp := aVal.GetValue<string>('type');
      if sTmp = 'deposit' then
        tmp[j].gubun := '입금'
      else
        tmp[j].gubun := '출금';

      tmp[j].code := aVal.GetValue<string>('currency');
      tmp[j].state:= aVal.GetValue<string>('state');
      tmp[j].time := GetStrToTime(aVal.GetValue<string>('done_at', ''));

      tmp[j].qty := aVal.GetValue<string>('amount');
      tmp[j].fee := aVal.GetValue<string>('fee');

      inc(j);
    end;

    if bDnw then
    begin
      SetLength(arr, Length(tmp));
      TArray.Copy<TCoinDnwItem>(tmp, arr, Length(tmp));
    end else
    begin
      SetLength(arr, j);
      TArray.Copy<TCoinDnwItem>(tmp, arr, j);
    end;

  finally
    FreeAndNil(aArr);
    SetLength(tmp, 0);
    tmp := nil;
  end;

end;

procedure TUpbitParse.ParseDNWSate(aData: string);
var
  aArr : TJsonArray;
  aVal : TJsonValue;
  I: Integer;
  sTmp : string;
  aSymbol : TSymbol;
  aNetwork : TDnwNetWork;
begin
  if aData = '' then
  begin
    App.Log(llError, '%s ParseDNWSate data is empty',
       [ TExchangeKindDesc[FParent.ExchangeKind] ] ) ;
    Exit;
  end;

  try

    aArr := TJsonObject.ParseJSONValue( aData) as TJsonArray;
    try
      if aArr = nil then Exit;

      for I := 0 to aArr.Count-1 do
      begin
        aVal := aArr.Items[i];
        sTmp := aVal.GetValue<string>('currency');
        if FParent.Codes.IndexOf(sTmp) < 0 then continue;

        aSymbol := App.Engine.SymbolCore.FindSymbol( FParent.ExchangeKind, sTmp );
        if aSymbol <> nil then
        begin
          aNetwork  := aSymbol.NetworkList.New;
          // 업비트는 Name 을 NetType 으로 쓴다.
//          aNetwork.NetType := aVal.GetValue<string>('network_name');
//          aNetwork.NetName := aNetwork.NetType;

          aNetwork.NetType := aVal.GetValue<string>('net_type');
          aNetwork.NetName := aVal.GetValue<string>('network_name');

          var iRes : integer ;        iRes := 0;

          sTmp := aVal.GetValue<string>('wallet_state');
          if sTmp = 'working' then
          begin
            aSymbol.CheckDnwState( true,  true );
            continue;
          end else
          if sTmp = 'withdraw_only' then
            iRes := aSymbol.CheckDnwState( false,  true )
          else if sTmp = 'deposit_only' then
            iRes := aSymbol.CheckDnwState( true,  false )
          else if (sTmp = 'paused') or (sTmp = 'unsupported' ) then
            iRes := aSymbol.CheckDnwState( false,  false );

          if iRes > 0 then
            App.Engine.SymbolBroker.DnwEvent( aSymbol, iRes);

        end;

      end;

    finally
      if aArr <> nil then aArr.Free;
    end;
  except on e : exception do
    App.Log(llError, 'Upbit ParseDNWState parse error : %s, %s ' ,[ e.Message, aData ] );
  end;
end;


procedure TUpbitParse.ParseMyAsset(aJson: TJsonObject);
var
  aAcnt  : TAccount;
  aArr   : TJsonArray;
  aVal   : TJsonValue;

  sCrny  : string;

  i : Integer;
  dBal, dLock : double;
  aAsset: TAsset;
begin
  // KRW 는 모든 주문일때(취소포함)
  // 각 코인은 체결, 매도, 매도 취소
  if aJson <> nil then
  begin
  //  App.Log(lldebug, 'upbit_assets', '%s', [aJson.ToString]);
    aAcnt := App.Engine.TradeCore.FindAccount(ekUpbit);
    if aAcnt = nil then Exit;

    aArr := aJson.GetValue('ast') as TJsonArray;
    for I := 0 to aArr.Count-1 do
    begin
      aVal  := aArr.Get(i);

      sCrny := aVal.GetValue<string>('cu');

      aAsset := aAcnt.Assets.Find(sCrny);

      dBal  := aVal.GetValue<double>('b', 0);
      dLock := aVal.GetValue<double>('l', 0);

      if aAsset <> nil then
      begin
        aAsset.Balance2 := dBal + dLock;
        aAsset.Locked2  := dLock;
      end;

      App.Log(llDebug,'upbit_assets', '%s --- B:%s, L:%s', [
        sCrny,
        DoubleToStr(dBal+dLock), DoubleToStr(dLock)  ]);

      Continue;
    end;

  end;
end;

procedure TUpbitParse.ParseOrdersFromLNO(sData: string);
var
  JsonValue: TJSONValue;
  JsonArray: TJSONArray;
  JsonObject: TJSONObject;
  JsonError: TJSONObject;
  Item: TJSONValue;
  I: Integer;
begin
  // 1. JSON 문자열을 TJSONValue 객체로 파싱합니다.
  JsonValue := TJSONObject.ParseJSONValue(sData);
  if not Assigned(JsonValue) then
  begin
    App.Log(llError, '유효하지 않은 JSON 데이터입니다.');
    Exit;
  end;
  try
    // 2. 응답이 배열인지 (성공 케이스) 확인합니다.
    if JsonValue is TJSONArray then
    begin
      JsonArray := JsonValue as TJSONArray;
      for I := 0 to JsonArray.Count - 1 do
      begin
        Item := JsonArray.Items[I];
        if Item is TJSONObject then
        begin
          JsonObject := Item as TJSONObject;
          // 원하는 파라미터 추출 (GetValue<T> 사용 시 기본값 지정 가능)
          Writeln(Format('[%d] UUID: %s', [I + 1, JsonObject.GetValue<string>('uuid', '')]));
          Writeln(Format('    마켓: %s', [JsonObject.GetValue<string>('market', '')]));
          Writeln(Format('    주문종류: %s', [JsonObject.GetValue<string>('side', '')]));
          Writeln(Format('    상태: %s', [JsonObject.GetValue<string>('state', '')]));
          Writeln('--------------------------------------------------');
        end;
      end;
    end
    // 3. 응답이 객체인지 (에러 케이스) 확인합니다.
    else if JsonValue is TJSONObject then
    begin
      JsonObject := JsonValue as TJSONObject;
      // 'error' 키가 존재하는지 확인하고, 해당 값을 TJSONObject로 가져옵니다.
      if JsonObject.TryGetValue<TJSONObject>('error', JsonError) then
      begin
        App.Log(llError, '%s %s ParseOrdersFromLNO error (%s)',
         [ TExchangeKindDesc[FParent.ExchangeKind],  TMarketTypeDesc[mtSpot] , sData] ) ;
      end
      else
      begin
        App.Log(llError, '%s %s ParseOrdersFromLNO error 알 수 없는 형태의 JSON 객체입니다',
         [ TExchangeKindDesc[FParent.ExchangeKind],  TMarketTypeDesc[mtSpot] ] ) ;
      end;
    end;
  finally
    // 4. 생성된 JSON 객체 메모리를 해제합니다 (필수).
    JsonValue.Free;
  end;
end;

function TUpbitParse.GetSymbolCode(sCode: string): string;
var
  sts   : TArray<string>;
begin
  sts := sCode.Split(['-']);
  Result := sts[1];
end;

function TUpbitParse.MakeNewOrder(sUID, sCode, sPrice, sQty, sSide, sTime: string): TOrder;
var
  aAcnt: TAccount;
  aSymbol: TSymbol;
  iSide: integer;
begin

  aSymbol := App.Engine.SymbolCore.FindSymbol(ekUpbit, GetSymbolCode(sCode));
  aACnt   := App.Engine.TradeCore.FindAccount(ekUpbit);
  if (aSymbol = nil) or (aAcnt = nil) then Exit (nil);

  if sSide = 'ASK' then
    iSide := -1
  else iSide := 1;

  Result  := App.Engine.TradeCore.Orders[ekUpbit].NewOrder(aAcnt, aSymbol,
    iSide, sQty, pcLimit, sPrice, tmGTC
  );

  if Result <> nil then
    Result.OrderNo  := sUID;
end;

