procedure TUpbitParse.ParseSpotNewOrder(aData, aRef: string);
var
	aOrder : TOrder;
  aObj   : TJsonObject;
  aErr, aTmp   : TJsonValue;
  sOID, sTmp, sStatus, sMsg  : string;
  bAcpt : boolean;
  dtTime: TDateTime;
  //
  i : integer;
  aRslt : TOrderResult;
  bRemove : boolean;
  aFill   : TFill;
begin
  if aData = '' then
  begin
    App.Log(llError, '%s %s ParseSoptNewOrder data is empty ( %s )',
       [ TExchangeKindDesc[FParent.ExchangeKind],  TMarketTypeDesc[mtSpot], aRef ] ) ;
    ProcEmptyResponse(FParent.ExchangeKind, aRef);
    Exit;
  end;

	aObj := TJsonObject.ParseJSONValue( aData) as TJsonObject;
  try
    aErr := aObj.GetValue('error');
    bAcpt := true;
    dtTime  := now;
    if aErr <> nil then begin
      bAcpt := false;
      sMsg  := aErr.GetValue<string>('message','');
      sStatus := aErr.GetValue<string>('name','9999');
      App.Log( llError, '주문거부 : %s, %s', [aRef, sMsg] );
    end
    else begin
      aTmp  :=  aObj.GetValue('uuid');
      if aTmp = nil then
      begin
        bAcpt := false;
        //sMsg  := aErr.GetValue<string>('message','');
        sStatus := '9999';
        App.Log( llError, '주문거부 : %s, %s', [aRef, aData] );
      end else
      begin
        sOID    := aObj.GetValue('uuid').Value;
        dtTime  := GetStrToTime( aObj.GetValue('created_at').Value );
      end;
    end;

    aOrder:= App.Engine.TradeCore.FindOrder(FParent.ExchangeKind, aRef);

    if aOrder = nil then
    begin
      App.Log(llError, '%s not found order : %s , %s ', [ TExShortDesc[FParent.ExchangeKind], aData, aRef  ] );
      Exit;
    end;

    aOrder.OrderNo  := sOID;
    aOrder.RejectReason := sMsg;
    aOrder.RsvFee  := aObj.GetValue<double>('reserved_fee', 0);

    App.DebugLog('%s Spot : %s, %s, %s, %s, %s, %s, %s, %s ', [  TExShortDesc[FParent.ExchangeKind],
        sMsg, sOID, aOrder.Symbol.Code
      , ifThenStr( aOrder.Side > 0, '매수','매도')
      //, aOrder.PriceBI.OrgVal, aOrder.OrderQtyBI.OrgVal
      , aOrder.Symbol.PriceToStr( aOrder.Price), FloatToStr( aOrder.OrderQty )
      , ifThenStr( aOrder.ReduceOnly, 'Reduce', 'Limit' ), aRef
      ]  );

		App.Engine.TradeBroker.Accept( aOrder, dtTime, bAcpt, sStatus ) ;

    // 이후 역전 처리...

    for I := FForwardOrderResults.Count-1 downto 0 do
    begin
      aRslt := FForwardOrderResults.Results[i];
      if aRslt <> nil then
        bRemove := false;
        if (aRslt.OrderNo = aOrder.OrderNo) and (aRslt.Order = nil) then
        begin

          case aRslt.ResultType of
            rtFill :
              begin
                aFill   := aOrder.Fills.Find(aRslt.FillNo);
                if aFill = nil then
                begin
                  aFill	 := App.Engine.TradeCore.Fills[ekUpbit].New(aRslt.FillNo, aRslt.Time, now,
                        aOrder.OrderNo, aOrder, aRslt.Volume, aRslt.Price);

                  aFill.Fee := aRslt.Fee;// aFill.Price * aFill.Volume * App.Engine.ApiConfig.ExchangeInfo[integer(ekUpbit)].ApiInfo[eaSpot].TradeFee / 100;

                  App.Log(llInfo, 'Upbit Spot Fill - ws : %s, %s, %s, %s, %s, %.8f, %f, %s ', [ aOrder.Symbol.Code,
                    aOrder.SideToStr, '',  aOrder.OrderNo,  aOrder.Symbol.PriceToStr(aFill.Price), aFill.Volume, aFill.Fee, aRslt.FillNo
                  ]);

                  App.Engine.TradeBroker.Fill( aOrder, aFill, false );
                end;
                bRemove := true;
              end;
            rtCancel: {if tc = aOrder.Fills.Count then
                      begin
                        App.Engine.TradeBroker.Cancel( aOrder, true) ;
                        bRemove := true;
                      end};
            rtDone: if aRslt.TC = aOrder.Fills.Count then
                    begin
                      bRemove := true;
                      if aORder.State <> osFilled then
                        aOrder.Fill;
                    end;
            rtWait: bRemove := true;
            else Continue;
          end;

          if bRemove then
          begin
            FForwardOrderResults.Remove(aRslt);
            App.Log(llInfo,'접수후 역전 처리 : %s, %s, %s',[aRslt.TypeToStr,
              aOrder.Symbol.QtyToStr(aRslt.Volume), aOrder.Symbol.QtyToStr(aRslt.Price),
              aOrder.Represent ]  );
          end;
        end;
    end;

  finally
    if aObj <> nil then aObj.Free;
  end;
end;

procedure TUpbitParse.ParseSpotOrderDetail(aData, aRef: string);
var
  aSymbol : TSymbol;  aAcnt : TAccount;
	aOrder  : TOrder;
  aArr    : TJsonArray;
  aObj    : TJsonObject;
  aErr    : TJsonValue;
  I, j: Integer;
  sOID , sTmp  : string;

  aState : TOrderState;
  bDone : boolean;

  procedure ProcFill( aArr : TJsonArray; bComplete : boolean = false );
  var
    aFill : TFill;
    sTrdID, sPrice, sVolume : string;
    dtTime : TDateTime;
    i : integer;
    aVal	 : TJsonValue;
    bDone  : boolean;
    dFeeRate: double;
    aList : TList;
  begin

    aList := TList.Create;
    try
      // maker, taker 구분을 할수가 없다 -> taker 수수료로 체결 수수료 계산
      dFeeRate := App.Engine.ApiConfig.ExchangeInfo[integer(ekUpbit)].
        GetTradeFee(aOrder.Symbol.Spec.ExApiType, aOrder.Symbol.Spec.SettleType, ftTaker);

      for I := 0 to aArr.Size-1 do
      begin
        aVal			:= aArr.Get(i)  ;
        sTrdID  := aVal.GetValue<string>('uuid');
        aFill		:= aOrder.Fills.Find( sTrdID );

        if aFill = nil then
        begin
          dtTime  := GetStrToTime( aObj.GetValue('created_at').Value );
          sVolume := aVal.GetValue<string>('volume');
          sPrice  := aVal.GetValue<string>('price');

          aFill	:=  App.Engine.TradeCore.Fills[ekUpbit].New( sTrdID, dtTime, now,
            sOID, aOrder, sVolume, sPrice);

          aFill.Fee := aFill.Price * aFill.Volume * dFeeRate / 100;

          App.DebugLog('Upbit Spot Fill : %s, %s, %s, %s, %s, %s, %f, %s ', [ aOrder.Symbol.Code,
            aOrder.SideToStr, sTmp, sOID,  sPrice, sVolume, aFill.Fee, sTrdID
          ]);

          aList.Add(aFill);
        end;
      end;  // for

      for i := 0 to aList.Count-1 do
      begin
        bDone   := false;
        aFill := TFill( aList.Items[i] );
        if (i = aList.Count-1) and (bComplete) then
          bDone := true;
        App.Engine.TradeBroker.Fill( aOrder, aFill, bDone );
      end;

    finally
      aList.Free;
    end;
  end;


begin
  if aData = '' then
  begin
    App.Log(llError, '%s %s ParseSpotOrderDetail data is empty',
       [ TExchangeKindDesc[FParent.ExchangeKind],  TMarketTypeDesc[mtSpot] ] ) ;
    Exit;
  end;

  aAcnt		:= App.Engine.TradeCore.FindAccount( FParent.ExchangeKind );
  if aAcnt = nil then Exit;

  aObj  := TJsonObject.ParseJSONValue( aData ) as TJsonObject;
  if aObj = nil then Exit;

  try
    try
        aErr := aObj.GetValue('error');
        if aErr <> nil then
        begin
          App.Log(llError, 'upbit ordetail request error %s %s', [ aData , aRef ] );
          Exit;
        end;

        sOID    := aObj.GetValue('uuid').Value;
        aOrder  := App.Engine.TradeCore.FindOrder( FParent.ExchangeKind, sOID, DIV_ORD_NO  );
        if aOrder = nil then
        begin
          aOrder  := App.Engine.TradeCore.FindOrder(FParent.ExchangeKind, aRef);
          if aOrder = nil then
          begin
            App.Log(llError, 'upbit ordetail not Found Order %s', [ sOID ] );
            Exit;
          end;
        end;

        sTmp  := aObj.GetValue('state').Value;

        if sTmp = 'wait' then
          aState := osActive
        else if sTmp = 'done' then
          aState := osFilled
        else if sTmp = 'cancel' then
          aState := osCanceled
        else
          Exit;

        case aState of
          osCanceled:
            begin
              aArr  := aObj.GetValue('trades') as TJsonArray;
              if aArr <> nil then
                ProcFill(aArr);
              App.Engine.TradeBroker.Cancel( aOrder, true);
            end;
          osActive, osFilled:
            begin
              if not aORder.IsAccept then
              begin
                aOrder.OrderNo  := sOID;
                App.Engine.TradeBroker.Accept(aOrder,
                  GetStrToTime(aObj.GetValue('created_at').Value), true, '0000');
              end else
              begin
                if aOrder.Modify then
                  aOrder.Modify := false;
              end;
              aArr  := aObj.GetValue('trades') as TJsonArray;
              if aArr <> nil then begin
                ProcFill(aArr, aState = osFilled);
                if (aState = osFilled) and (aOrder.State <> osFilled) then
                  aOrder.Fill;
              end;
            end;
        end;

    except
    end;

  finally
    if aObj <> nil then aObj.Free;
  end;

end;

procedure TUpbitParse.ParseSpotOrderList(aData, aRef: string);
var
  aSymbol : TSymbol;  aAcnt : TAccount;
	aOrder  : TOrder;
  aArr    : TJsonArray;
  aObj    : TJsonObject;
  I: Integer;
  sOID , sTmp  : string;
  sts : TArray<string>;
begin
  if aData = '' then
  begin
    App.Log(llError, '%s %s ParseSpotOrderList data is empty',
       [ TExchangeKindDesc[FParent.ExchangeKind],  TMarketTypeDesc[mtSpot] ] ) ;
    Exit;
  end;

  aAcnt		:= App.Engine.TradeCore.FindAccount( FParent.ExchangeKind );
  if aAcnt = nil then Exit;

  aArr  := TJsonObject.ParseJSONValue( aData ) as TJsonArray;
  try
    try
      if aArr <> nil then
        for I := 0 to aArr.Size-1 do
        begin
          aObj    := aArr.Get(i) as TJsonObject;
          sOID    := aObj.GetValue('uuid').Value;
          aOrder  := App.Engine.TradeCore.FindOrder( FParent.ExchangeKind, sOID, DIV_ORD_NO  );

          if aOrder = nil then
          begin
            var iSide : integer;
            var sOrderQty, sPrice,  sMarket : string;
            var dtTime	: TDateTime;

            if aObj.GetValue('side').Value = 'bid' then
              iSide := 1
            else
              iSide := -1;

            sOrderQty := aObj.GetValue('remaining_volume').Value;
            sPrice    := aObj.GetValue('price').Value;
            sMarket   := aObj.GetValue('market').Value;

            sts := sMarket.Split(['-']);

            aSymbol := App.Engine.SymbolCore.FindSymbol( FParent.ExchangeKind, sts[1] );
            if aSymbol = nil then continue;

            aOrder	:= App.Engine.TradeCore.Orders[FParent.ExchangeKind].NewOrder( aAcnt, aSymbol,
              iSide, sOrderQty, pcLimit, sPrice, tmGTC );

            aOrder.OrderNo	:= sOID;
            aOrder.RsvFee   := aObj.GetValue<double>('reserved_fee',0);
            dtTime  := GetStrToTime( aObj.GetValue('created_at').Value );

            App.Engine.TradeBroker.Accept( aOrder, dtTime, true);
          end;
        end;
    except
    end;

  finally
    if aArr <> nil then aArr.Free;
  end;
end;

