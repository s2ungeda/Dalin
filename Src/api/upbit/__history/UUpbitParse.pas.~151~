         [ TExchangeKindDesc[FParent.ExchangeKind],  TMarketTypeDesc[mtSpot] , aData] ) ;
      Exit;
    end ;

    aArr  := aVal as TJsonArray;
    if aArr.Count <= 0 then Exit;

    aSymbol := App.Engine.SymbolCore.Symbols[FParent.ExchangeKind].FindCode( aRef);
    if aSymbol = nil then Exit;

