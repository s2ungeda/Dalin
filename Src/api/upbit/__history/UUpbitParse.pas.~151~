procedure TUpbitParse.ParseSpotOrderDetail( aAcnt : TAccount; aObj: TJsonObject);
var
  aSymbol : TSymbol;
	aOrder  : TOrder;

  iFillCnt: Integer;
  sOID , sTmp  : string;

  aState : TOrderState;
  bDone : boolean;

begin

    try
        sOID    := aObj.GetValue('uuid').Value;
        aOrder  := App.Engine.TradeCore.FindOrder( FParent.ExchangeKind, sOID, DIV_ORD_NO  );

        if aOrder = nil then
        begin
          App.Log(llError, 'upbit ordetail not Found Order %s', [ sOID ] );
          Exit;
        end;

        sTmp  := aObj.GetValue('state').Value;

        if sTmp = 'done' then
          aState := osFilled
        else if sTmp = 'cancel' then
          aState := osCanceled
        else
          Exit;

        iFillCnt := aObj.GetValue<integer>('trades_count');

        case aState of
          osCanceled:
            begin
              if aOrder.Fills.Count = iFillCnt then
                App.Engine.TradeBroker.Cancel( aOrder, true)
              else
                App.Log(llInfo, format('upbit 취소 -> 체결 개수 차이(%d,%d) %s',
                  [ aOrder.Fills.Count, iFillCnt, aOrder.Represent]) );
            end;
          osFilled:
            begin
              if (aOrder.Fills.Count = iFillCnt) and (aOrder.State <> osFilled ) then
              begin
                // 강제로 상태 변경
                App.Log(llInfo, format('upbit 체결 -> 강제 상태 변경 %s',
                  [ aOrder.Fills.Count, iFillCnt, aOrder.Represent]) );

                aOrder.Fill;
              end;
            end;
        end;

    except
    end;

end;

