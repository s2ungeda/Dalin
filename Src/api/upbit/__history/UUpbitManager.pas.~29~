  TUpbitManager = class( TExchangeManager )
  private
    FParse: TUpbitParse;
    FQryTimer: TTimer;
    FQryCount: int64;
    FBalQryCnt: int64;
    procedure OnQryTimer(Sender : TObject );
    procedure OnTimer( Sender : TObject );
  public

    Constructor  Create( aExType : TExchangeKind );
    Destructor  Destroy; override;
//    function RequestMaster : boolean; override;
    function InitMarketWebSockets : boolean ; override;
    function SubscribeAll : boolean; override;
    procedure UnSubscribeAll ; override;
    function MakeCloseData : boolean ; override;

    function RequestBalance : boolean; override;
    function RequestPositons : boolean; override;
    function RequestOrders: boolean; override;

    function Subscrib( aSymbol : TSymbol ) : boolean; override;
    function UnSubscrib( aSymbol : TSymbol ) : boolean; override;

    property Parse : TUpbitParse read FParse;

    procedure OrderDetailRequest( bStart : boolean ); override;

        // 병렬 처리용
    function ASyncRequestTradeAmt( aSymbol : TSymbol ) : boolean; override;
    function ASyncRequest5MinAgo( aSymbol : TSymbol ) : boolean; override;
    function ASyncRequestAvailable( aSymbol : TSymbol ) : boolean; override;
  end;

implementation

uses
  GApp , GLibs
  , UApiConsts
  , UUpbitSpot
  , UUpbitWebSockets
  , URestRequests
  ;

{ TBinanceManager }

constructor TUpbitManager.Create(aExType: TExchangeKind);
begin
  inherited Create( aExType );
  FParse:= TUpbitParse.Create( self );

  // 주문상태를 주기적으로 조회 하기 위해..( wait , done(cancel) 순으로 조회);
  FQryTimer:= TTimer.Create( nil );
  FQryTimer.Enabled   := false;
  FQryTimer.Interval  := 500;
  FQryTimer.OnTimer   := OnQryTimer;
  FQryCount           := 0;
  FBalQryCnt          := 0;
end;

destructor TUpbitManager.Destroy;
begin
  FQryTimer.Enabled := false;
  FQryTimer.OnTimer := nil;
  FQryTimer.Free;

  FParse.Free;
  inherited;
end;



function TUpbitManager.InitMarketWebSockets: boolean;
var
  i, iTot : integer;
begin
  iTot:= 1;
  SetLength( QuoteSock, iTot );
  SetLength( TradeSock, iTot );

  for I := 0 to iTot-1 do begin
    QuoteSock[i]  := TUpbitWebSocket.Create(QOUTE_SOCK,i, mtSpot ) ;
    QuoteSock[i].init( App.Engine.ApiConfig.ExchangeInfo[integer(ekUpbit)].ApiInfo[eaSpot].WSUrl );

    TradeSock[i] := TUpbitWebSocket.Create(TRADE_SOCK,0, mtSpot ) ;
    TradeSock[i].init( App.Engine.ApiConfig.ExchangeInfo[ integer(ekUpbit) ].ApiInfo[eaSpot].WSUrl );
  end;

  Timer.OnTimer := OnTimer;
  Timer.Interval:= 1000;
  Result := true;
end;

function TUpbitManager.MakeCloseData: boolean;
var
  sTmp : string;
begin
  stmp := App.Engine.SymbolCore.MainSymbols[msBTC][ExchangeKind].OrgCode;
  Result := Exchanges[eaSpot].RequestCandleData('240', sTmp )
    and Exchanges[eaSpot].RequestCandleData('30', sTmp )    ;

  stmp := App.Engine.SymbolCore.MainSymbols[msETH][ExchangeKind].OrgCode;
  Result := Exchanges[eaSpot].RequestCandleData('240', sTmp )
    and Exchanges[eaSpot].RequestCandleData('30', sTmp )    ;
end;

procedure TUpbitManager.OnQryTimer(Sender: TObject);
var
  imod : integer;
begin
  imod := FQryCount mod 3;

  // imod = 0 --> 미체결 조회
  // imod = 1 --> done, cancel 조회
  try
    if imod = 0 then
      App.Engine.ApiManager.ExManagers[ekUpbit].RequestOrderList(eaSpot)
    else
      App.Engine.ApiManager.ExManagers[ekUpbit].RequestOrdeDetail(eaSpot);
  finally
    inc(FQryCount);
  end;


end;

procedure TUpbitManager.OnTimer(Sender: TObject);
begin

  // thread 에서 처리로 수정..
  Exit;
//  inherited CheckQuoteState;
  try
    if FBalQryCnt > 60 then begin
      FBalQryCnt := 0;
      if App.Config.TradeMod then
        if App.Engine.SymbolCore.MainSymbols[msBTC][ekUpbit] <> nil then
      	  RequestBalance(App.Engine.SymbolCore.MainSymbols[msBTC][ekUpbit]);//
    end;
  finally
    inc(FBalQryCnt);
  end;
end;


procedure TUpbitManager.OrderDetailRequest(bStart: boolean);
begin
  FQryTimer.Enabled := bStart;
end;

