unit Exchange.AssetManager;

interface

uses
  System.Generics.Collections, System.SyncObjs, System.SysUtils, Exchange.Types;

type
  TAssetManager = class
  private
    FLock: TCriticalSection;
    FBalance: Currency; // KRW 가용 잔고
    FLocked: Currency;  // KRW 묶인 잔고
    FPendingOrders: TObjectDictionary<string, POrderReservation>;
    FStandardFeeRate: Double;
  public
    constructor Create(ADefaultFee: Double = 0.0005);
    destructor Destroy; override;

    { 주문 예약: 주문 전 선차감 }
    procedure ReserveOrder(const AIdentifier: string; APrice, AVolume: Double);

    { 주문 확정: Identifier -> UUID 매핑 }
    procedure ConfirmOrder(const AIdentifier, AActualUUID: string);

    { 체결 처리: 수수료 차액 정산 }
    procedure ProcessTrade(const AUUID: string; ATradePrice, ATradeVolume, APaidFee: Double);

    { 취소 처리: 미체결분 회수 }
    procedure ProcessCancel(const AUUID: string);

    { 서버 동기화 }
    procedure SyncWithServer(AAvailable, ALocked: Currency);

    procedure GetStatus(out ABal, ALock: Currency);
  end;

implementation

{ TAssetManager }

constructor TAssetManager.Create(ADefaultFee: Double);
begin
  FLock := TCriticalSection.Create;
  FPendingOrders := TObjectDictionary<string, POrderReservation>.Create([doOwnsValues]);
  FStandardFeeRate := ADefaultFee;
end;

destructor TAssetManager.Destroy;
begin
  FPendingOrders.Free;
  FLock.Free;
  inherited;
end;

procedure TAssetManager.ReserveOrder(const AIdentifier: string; APrice, AVolume: Double);
var
  NewOrder: POrderReservation;
  TotalReserved: Currency;
begin
  FLock.Enter;
  try
    TotalReserved := (APrice * AVolume) * (1 + FStandardFeeRate);
    FBalance := FBalance - TotalReserved;
    FLocked := FLocked + TotalReserved;

    New(NewOrder);
    NewOrder^.Identifier := AIdentifier;
    NewOrder^.Price := APrice;
    NewOrder^.OriginalVolume := AVolume;
    NewOrder^.RemainingVolume := AVolume;
    NewOrder^.ReservedAmount := TotalReserved;
    NewOrder^.StandardFeeRate := FStandardFeeRate;
    FPendingOrders.Add(AIdentifier, NewOrder);
  finally
    FLock.Leave;
  end;
end;

procedure TAssetManager.ConfirmOrder(const AIdentifier, AActualUUID: string);
var
  Order: POrderReservation;
begin
  FLock.Enter;
  try
    if FPendingOrders.TryGetValue(AIdentifier, Order) then
    begin
      Order^.UUID := AActualUUID;
      FPendingOrders.ExtractPair(AIdentifier);
      FPendingOrders.Add(AActualUUID, Order);
    end;
  finally
    FLock.Leave;
  end;
end;

procedure TAssetManager.ProcessTrade(const AUUID: string; ATradePrice, ATradeVolume, APaidFee: Double);
var
  Order: POrderReservation;
  ReservedPart, ActualCost, Refund: Currency;
begin
  FLock.Enter;
  try
    if FPendingOrders.TryGetValue(AUUID, Order) then
    begin
      ReservedPart := (Order^.Price * ATradeVolume) * (1 + Order^.StandardFeeRate);
      ActualCost := (ATradePrice * ATradeVolume) + APaidFee;
      Refund := ReservedPart - ActualCost;

      FLocked := FLocked - ReservedPart;
      FBalance := FBalance + Refund;
      Order^.RemainingVolume := Order^.RemainingVolume - ATradeVolume;

      if Order^.RemainingVolume < 0.00000001 then
        FPendingOrders.Remove(AUUID);
    end;
  finally
    FLock.Leave;
  end;
end;

procedure TAssetManager.ProcessCancel(const AUUID: string);
var
  Order: POrderReservation;
  RefundAmount: Currency;
begin
  FLock.Enter;
  try
    if FPendingOrders.TryGetValue(AUUID, Order) then
    begin
      RefundAmount := (Order^.Price * Order^.RemainingVolume) * (1 + Order^.StandardFeeRate);
      FLocked := FLocked - RefundAmount;
      FBalance := FBalance + RefundAmount;
      FPendingOrders.Remove(AUUID);
    end;
  finally
    FLock.Leave;
  end;
end;

procedure TAssetManager.SyncWithServer(AAvailable, ALocked: Currency);
begin
  FLock.Enter;
  try
    FBalance := AAvailable;
    FLocked := ALocked;
  finally
    FLock.Leave;
  end;
end;

procedure TAssetManager.GetStatus(out ABal, ALock: Currency);
begin
  FLock.Enter;
  try
    ABal := FBalance;
    ALock := FLocked;
  finally
    FLock.Leave;
  end;
end;

end.
