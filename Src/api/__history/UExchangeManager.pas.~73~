function TExchangeManager.SendOrder(aOrder: TOrder): boolean;
begin
  if aOrder = nil then Exit ( false );

  aOrder.SentTime := now;

  if aOrder.OrderType = otNormal then
  begin
    aOrder.State    := osSent;
    aOrder.NewTime  := GetTickCount64;
  //
    if aOrder.Symbol.Spec.ExchangeType <> ekBinance then
      if not aOrder.Account.Assets.ReserveOrder(aORder.Side, aOrder.Symbol.Spec.BaseCode,
          aOrder.LocalNo, aOrder.Price, aOrder.OrderQty) then
      begin
        App.Engine.TradeBroker.Failed(aOrder, '7777');
        App.Log(llInfo, 'Order Failed : 금액/잔고 부족. %s', [aOrder.SimpleRepresent]);
        Exit;
      end;
  //
  end else
  if aOrder.OrderType = otChange then
  begin

    aOrder.ChgTime  := GetTickCount64;
  end else
  begin
    aOrder.CnlTime  := GetTickCount64;
  end;

  App.Log(llInfo, 'Order Start : %s', [aOrder.Represent]);
  result := Exchanges[aOrder.Symbol.Spec.ExApiType].SenderOrder( aOrder );

  if not Result then
  begin
    if aOrder.OrderType = otNormal then
      aOrder.Account.Assets.ProcessCancel(aORder.LocalNo);
    App.Engine.TradeBroker.Failed(aOrder, '1234');
    App.Log(llInfo, 'Order Failed : %s', [aOrder.SimpleRepresent]);
  end;
end;

