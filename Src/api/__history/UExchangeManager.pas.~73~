procedure TExchangeManager.StartRequest;
var
  I: TExchangeApiType;
begin
  for I := eaSpot to High(TExchangeApiType) do
    if ( Exchanges[i] <> nil ) and ( Exchanges[i].CyclicThreads <> nil )  then 
    	Exchanges[i].CyclicThreads.Resume;
end;





function TExchangeManager.SyncRequestOrderDetail(aOrder: TOrder): string;
begin
  if aOrder = nil then Exit ('');
  Result := Exchanges[aOrder.Symbol.Spec.ExApiType].SyncRequestOrderDetail( aOrder );
end;

