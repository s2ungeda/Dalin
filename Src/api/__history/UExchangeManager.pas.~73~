constructor TExchangeManager.Create(aExType: TExchangeKind);
var
  i : TExchangeApiType;
begin
  FExchangeKind := aExType;

  for I := eaSpot to High(TExchangeApiType) do
  begin
    FExchanges[i] :=  CreateMarket( i);
  end;

  FCodes:= TStringList.Create;

  QuoteSock := nil;
  TradeSock := nil;

  TopAmtSymbols[0] := nil;
  TopAmtSymbols[1] := nil;

  FExchangeThread[aExType]  := TExchangeThread.Create(aExType);

//  FWithdraw := TApiWithdraw.Create;

  FDone := false;
end;

function TExchangeManager.CreateMarket(aMarket: TExchangeApiType): TExchange;
begin
  Result := nil;  
  case FExchangeKind of
    ekBinance:
      begin
        case aMarket of
          eaSpot   : Result := TBinanceSpotNMargin.Create( self, aMarket) ;
          eaFutUsdt: Result := TBinanceFutures.Create( self, aMarket) ;
          eaFutCoin: Result := TBinanceFuturesCM.Create( self, aMarket) ;
        end;
      end;
    ekUpbit:
      begin
        case aMarket of
          eaSpot  : Result := TUpbitSpot.Create( self, aMarket) ;
        end;

      end;
    ekBithumb:
      begin
        case aMarket of
          eaSpot  : Result := TBithSpot.Create( self, aMarket) ;
        end;     
      end;                       
  end;
end;

destructor TExchangeManager.Destroy;
var
  j : integer;
  i : TExchangeApiType;
begin

  if FTimer <> nil then
    FTimer.Enabled := false;

//  FWithdraw.Free;

  FExchangeThread[FExchangeKind].Terminate;
  FExchangeThread[FExchangeKind].WaitFor;
  FreeAndNil(FExchangeThread[FExchangeKind]);

  if QuoteSock <> nil then
    for j := 0 to High(QuoteSock) do
    begin
//      QuoteSock[j].Terminate;
//      QuoteSock[j].WaitFor;
      if QuoteSock[j] <> nil then
        QuoteSock[j].Free;
    end;

  if TradeSock <> nil then
    for j := 0 to High(TradeSock) do
    begin

      if TradeSock[j] <> nil then
      begin
  //      TradeSock[i].Terminate;
  //      TradeSock[i].WaitFor;
        TradeSock[j].Free ;
      end;
    end;

  for i := eaSpot to High(TExchangeApiType) do
    if FExchanges[i] <> nil then
      FExchanges[i].Free;

  FCodes.Free;

  inherited;
end;


procedure TExchangeManager.CheckQuoteState;
var
  iGap, I: Integer;

begin

  if App.Stop then Exit;

  for I := 0 to High(QuoteSock) do
  begin

    iGap  :=  GetTimeGapHour(  QuoteSock[i].ConnectTime );
    if iGap >= App.Config.ReConnInterval then
    begin
      App.Log( llInfo, '%d %s hours later reconnect', [ App.Config.ReConnInterval, TExchangeKindDesc[FExchangeKind]] )   ;
      QuoteSock[i].DoReConnect12 ;
    end else
    begin
      if QuoteSock[i].IsReConnect then
      begin

        QuoteSock[i].SocketCreate;
        QuoteSock[i].DoConnect;
        App.Log( llInfo, '','%s QuoteSock reconnect', [TExchangeKindDesc[FExchangeKind]] )   ;
      end
    end;
  end;
end;

function TExchangeManager.ConnectAll: boolean;
var
  i : integer;
begin
  try
    if QuoteSock <> nil then
      for i := 0 to High(QuoteSock) do
        if QuoteSock[i] <> nil then
          QuoteSock[i].DoConnect;

    if TradeSock <> nil then
      for i := 0 to High(TradeSock) do
        if TradeSock[i] <> nil then
          TradeSock[i].DoConnect;

  except
    on E : Exception do
    begin
      App.Log(llError, '%s %d.th connect error (%s)', [ TExchangeKindDesc[FExchangeKind], i, E.Message ]  );
      exit (false);
    end;
  end;


  FTimer.Enabled  := true;
  Result := true;
end;

function TExchangeManager.DissConnectAll: boolean;
var
  i : integer;
begin

  App.DebugLog('%s %d disconnect all ', [ TExchangeKindDesc[FExchangeKind],  High(QuoteSock) ] );

  if FTimer <> nil then
    FTimer.Enabled  := false;
  FDone := true;

  Result := true;

  if QuoteSock <> nil then
    for i := 0 to High(QuoteSock) do
      QuoteSock[i].DoDisConnect;

  if TradeSock <> nil then
    for I := 0 to High(TradeSock) do
      if TradeSock[i] <> nil then
        TradeSock[i].DoDisConnect;

  Result := true;
end;


function TExchangeManager.GetSndRcvCnt: string;
begin
  Result := GetSndRcvCount;
//  Result := Format('%d, %d (%d)', [ FSndCnt, FRcvCnt, FSndCnt-FRcvCnt] );
end;

function TExchangeManager.GetSndRcvCount : string;
var
  aExApiType : TExchangeApiType;
  i : integer;
  a : TRequest;
begin
  aExApiType := eaSpot;
  if FExchangeKind = ekBinance then
    aExApiType := eaFutUsdt;

  for i:=0 to Exchanges[aExApiType].ReqItems.Count-1 do
  begin
    a := TRequest( Exchanges[aExApiType].ReqItems.Items[i] );
    FSndCnt := FSndCnt + a.SndCnt;
    FRcvCnt := FRcvCnt + a.RcvCnt;
    Result := REsult + Format(' %s:%d,%d(%d)', [a.Name[1], a.SndCnt, a.RcvCnt, a.SndCnt - a.RcvCnt]);
  end;
end;

procedure TExchangeManager.init;
begin
  FTimer  := App.Engine.QuoteBroker.Timers.New;
  FTimer.Interval := 1000;
  FTimer.OnTimer  := nil;
  FTimer.Enabled  := false;
end;

function TExchangeManager.PrepareMaster: boolean;
var
  I: Integer;
  sTmp : string;
begin
  Result := Exchanges[eaSpot].PrepareMaster;

  if Result and ( FExchangeKind = ekBinance ) then
    Result := Exchanges[eaFutUsdt].PrepareMaster
      and Exchanges[eaFutCoin].PrepareMaster    ;

  App.Log(llDebug, '', ' ---------- %s codes count %d -----------',
    [ TExchangeKindDesc[FExchangeKind], Exchanges[eaSpot].Codes.Count ] );

end;

procedure TExchangeManager.ReceivedData(aExApiType : TExchangeApiType;
  aReqType: TRequestType; aData, aRef: string);
begin
	Exchanges[aExApiType].ReceivedData(aReqType, aData, aRef );
end;



function TExchangeManager.RequestMaster: boolean;
var
  I: TExchangeApiType;
begin
  for I := eaSpot to High(TExchangeApiType) do
  begin
    if Exchanges[i] = nil then continue;
    if not Exchanges[i].RequestMaster then
      Exit (false);
  end;

  Result := true;

end;

