procedure TRequestTask.SetCompleted(const Value: TProc<TRequestTask>);
begin
  FOnCompleted := Value;
end;



{ TRequestOrdDetail }

procedure TRequestOrdDetail.SetBithumbSig(const sVal, sTime: string);
var
  sSig, sBody : string;
begin

  sSig	:= CalculateHMACSHA512( sVal, App.Engine.ApiConfig.GetSceretKey(ekBithumb, eaSpot) );
  sBody	:= TIdEncoderMIME.EncodeString( sSig, IndyTextEncoding_UTF8 );

  with FRESTRequest do
  begin
    AddParameter('Api-Key',  App.Engine.ApiConfig.GetApiKey(ekBithumb, eaSpot), TRESTRequestParameterKind.pkHTTPHEADER );//, [poDoNotEncode]);
    AddParameter('Api-Sign', sBody , TRESTRequestParameterKind.pkHTTPHEADER , [poDoNotEncode]);
    AddParameter('Api-Nonce', sTime , TRESTRequestParameterKind.pkHTTPHEADER );
  end;
end;


procedure TRequestOrdDetail.MakeRequest;
var
  sTime, sVal : string;
begin
  case FTaskType of
    rttDetail:
      begin
        FRESTRequest.Resource := '/info/order_detail';
        FRESTRequest.Method   := rmPOST; //
      end;
  end;

  sTime 	:= GetTimestamp;
  sVal		:= EncodePath( FRESTRequest.Resource, Format('endPoint=%s&order_id=%s&order_currency=%s',
    [ FRESTRequest.Resource, FOrderNo, FCode ] ), sTime )  ;

  SetBithumbSig(sVal, sTime);

  with FRESTRequest do
  begin
    AddParameter('endPoint',      FRESTRequest.Resource, TRESTRequestParameterKind.pkREQUESTBODY);
    AddParameter('order_id', 			FOrderNo , TRESTRequestParameterKind.pkREQUESTBODY);
    AddParameter('order_currency',FCode, TRESTRequestParameterKind.pkREQUESTBODY);
  end;

end;

procedure TRequestOrdDetail.OnAysncCompleted(Sender: TCustomRESTRequest);
begin
  TThread.Queue(nil,
    procedure
    begin
      if Assigned(FOnCompleted) then
        FOnCompleted(Self);
    end);
end;

procedure TRequestOrdDetail.SetParam(const sOrderNo, sCode: string);
begin
  FOrderNo := sOrderNo;
  FCode    := sCode;
end;

end.
