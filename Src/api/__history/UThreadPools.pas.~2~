unit UThreadPools;

interface

uses
  System.SysUtils, System.Classes, System.Generics.Collections, System.Threading,

  URequestPools,

  UApiTypes
  ;

type

  TCustomThreadPool = class
  private
    FThreadPool: TThreadPool;
    FExKind: TExchangeKind;
  public
    Constructor Create(MaxCnt : integer; ExKind : TExchangeKind); overload;
    Destructor Destroy; override;

    procedure PushTask(RequestTask: TRequestTask);

    property ThreadPool: TThreadPool read FThreadPool;
    property ExKind : TExchangeKind read FExKind;
  end;

implementation

uses
  GApp, GLibs,
  UTypes
  ;

{ TCustomThreadPool }

constructor TCustomThreadPool.Create(MaxCnt : integer; ExKind : TExchangeKind);
begin
  FThreadPool := TThreadPool.Create;
  FThreadPool.SetMaxWorkerThreads(3); // ÃÖ´ë 3°³ÀÇ ½º·¹µå
  FExKind := ExKind;
end;

destructor TCustomThreadPool.Destroy;
begin
  FThreadPool.Free;
  inherited;
end;

procedure TCustomThreadPool.PushTask(RequestTask: TRequestTask);
begin
  TThreadPool.Default.QueueWorkItem(
    procedure
    begin
      try
        RequestTask.Execute;
      except
        on E: Exception do
          App.Log(llError, 'Error Execute Task : %s', [E.Message] )
      end;
    end
  );
end;

end.
