function GetHitOrderPrice(aSymbol: TSymbol; iSide: integer; scType : TSymbolCountryType): double;
var
  iTick : integer;
begin
  iTick := IfThen(scType = scDomes, gAOConfig.Result.STick, gAOConfig.Result.FTick);

  if iSide > 0 then
    Result := TicksFromPrice(aSymbol, aSymbol.Asks[0].Price , iTick)
  else
    Result := TicksFromPrice(aSymbol, aSymbol.Bids[0].Price , -iTick)
end;

