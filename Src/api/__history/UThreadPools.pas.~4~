      RequestTask : TRequestTask;
    begin

      // task type 에 따라 pool 을 선택해야 한다.
      RequestTask := FTaskPool.Acquire;
      RequestTask.TaskType  := rttType;
      RequestTask.OnCompleted := procedure(aTask : TRequestTask)
        begin
          FTaskPool.Release(aTask);
        end;
