unit UThreadPools;

interface

uses
  System.SysUtils, System.Classes, System.Generics.Collections, System.Threading,

  URequestPools, UOrders,

  UApiTypes
  ;

type

  TCustomThreadPool = class
  private
    FThreadPool: TThreadPool;
    FExKind: TExchangeKind;
    FTaskPool: TObjectPool<TRequestTask>;
  public
    Constructor Create(MaxCnt : integer; ExKind : TExchangeKind); overload;
    Destructor Destroy; override;

    procedure PushTask(rttType: TRequestTaskType); overload;
    procedure PushTask(rttType: TRequestTaskType; pOrder: TOrder); overload;

    property ThreadPool: TThreadPool read FThreadPool;
    property TaskPool :  TObjectPool<TRequestTask> read FTaskPool;
    property ExKind : TExchangeKind read FExKind;
  end;

implementation

uses
  GApp, GLibs,
  UTypes
  ;

{ TCustomThreadPool }

constructor TCustomThreadPool.Create(MaxCnt : integer; ExKind : TExchangeKind);
begin
  FThreadPool := TThreadPool.Create;
  FThreadPool.SetMaxWorkerThreads(MaxCnt); // 최대 3개의 스레드
  FExKind := ExKind;

  // task type 에 따라...달리 해야 할까?
  FTaskPool := TObjectPool<TRequestTask>.Create(
    function: TRequestTask
    begin
      Result := TRequestOrdDetail.Create(0, nil);
    end
  );
end;

destructor TCustomThreadPool.Destroy;
begin
  FTaskPool.Free;
  FThreadPool.Free;
  inherited;
end;

procedure TCustomThreadPool.PushTask(rttType: TRequestTaskType; pOrder: TOrder);
begin
  TThreadPool.Default.QueueWorkItem(
    procedure
    var
      RequestTask : TRequestOrdDetail;
    begin

      // task type 에 따라 pool 을 선택해야 한다.
      RequestTask := FTaskPool.Acquire as TRequestOrdDetail;
      RequestTask.TaskType  := rttType;
      RequestTask.SetParam(pOrder);
      RequestTask.OnCompleted := procedure(aTask : TRequestTask)
        begin
          FTaskPool.Release(aTask);
          if aTask.TaskType = rttDetail then
            (aTask as TRequestOrdDetail).UnFlag;
        end;
      try
        RequestTask.Execute;
      except
        on E: Exception do
          App.Log(llError, 'Error Execute Task : %s', [E.Message] )
      end;
    end
  );
end;

