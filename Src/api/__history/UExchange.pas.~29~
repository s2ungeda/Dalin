function TExchange.PrepareMaster: boolean;
var
  sTmp, sOut, sJson : string;
begin
  sTmp  := App.Engine.ApiConfig.GetBaseUrl( GetExKind, FExApiType );
  SetBaseUrl( sTmp );
  sTmp  := App.Engine.ApiConfig.GetPrepare(GetExKind, FExApiType );
  if Request( rmGET, sTmp , '', sJson, sOut ) then
  begin
    FMasterData := sJson ;
    ParsePrepareMaster;
  end else
  begin
    App.Log( llError, '', 'Failed %s %s PreparMaster (%s, %s)',
      [ TExchangeKindDesc[GetExKind], TExApiTypeDesc[FExApiType], sOut, sJson] );
    Exit( false );
  end;

  Result := FCodes.Count > 0 ;
end;


