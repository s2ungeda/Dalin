unit USharedManager;

interface

uses
  WinApi.Windows,
  System.Classes, System.SysUtils,  System.Variants
  , UApiTypes, UApiConsts ,

  USharedThread, USharedData, USharedConsts
  ;

type

  TSharedManager = class
  private
    FRefCnt : integer;
    FSharedThread: array [TSharedThreadType] of TSharedThread;

    FRcvCount: int64;
    FSndCount: int64;
    function GetExchangeApiType(cMarket: char): TExchangeApiType;
    function GetExchangeKind(cExKind: char): TExchangeKind;
  public
    constructor create;
    destructor  destroy; override;

//    procedure RequestData( aExKind : TExchangeKind;  aMarket : TMarketType;
//      aReqType : TRequestType; aData : string ); overload;

    procedure RequestData( aExKind : TExchangeKind;  aExApiType : TExchangeApiType;
      aReqType : TRequestType; aData : string; aRef : string ); //overload;

    procedure OnSharedDataNotify( aData : TDataItem );

    function GetRequestType( cTrDiv : char ) : TRequestType;

    property SndCount : int64 read FSndCount write FSndCount;
    property RcvCount : int64 read FRcvCount write FRcvCount;
  end;

implementation

uses
  GApp
  ;

{ TSharedManasger }

constructor TSharedManager.create;
var
  i : TSharedThreadType;
begin
  FRefCnt := 0;
  FRcvCount := 0;
  FSndCount := 0;

  for I := stBnSThread to High(TSharedThreadType) do begin
    FSharedThread[i] := TSharedThread.Create( OnSharedDataNotify, true, i);
  //  FSharedThread[i]

  end;
end;

destructor TSharedManager.destroy;
var
  i : TSharedThreadType;
begin
  for I := stBnSThread to High(TSharedThreadType) do
    if FSharedThread[i] <> nil then begin
      FSharedThread[i].Terminate;
//    FSharedThread.WaitFor;
//    FSharedThread.Free;
    end;
  inherited;
end;


procedure TSharedManager.OnSharedDataNotify(aData: TDataItem);
begin
  inc( FRcvCount );
	App.Engine.ApiManager.ExManagers[ GetExchangeKind( aData.exKind) ].ReceivedData(
    	GetExchangeApiType(aData.exApiType), GetRequestType(aData.trDiv), AnsiString( aData.data ), aData.ref )   ;
end;

procedure TSharedManager.RequestData(aExKind: TExchangeKind;
  aExApiType : TExchangeApiType; aReqType: TRequestType; aData, aRef: string);
  var
    c1, c2, c3 : char;
    idx : TSharedThreadType;
begin
  // 시세 모드일때는
  if not App.Config.TradeMod then Exit;

  case aExKind of
    ekBinance:  c1  := EX_BN;
    ekUpbit:    c1  := EX_UP;
    ekBithumb:  c1  := EX_BI;
  end;

  case aExApiType of
    eaSpot:
      begin
        c2 := 'S';
        case aExKind of
          ekBinance:  begin c1  := EX_BN; idx := stBnSThread; end;
          ekUpbit:    begin c1  := EX_UP; idx := stUpSThread; end;
          ekBithumb:  begin c1  := EX_BI; idx := stBtSThread; end;
        end;
      end;
    eaFutUsdt:  begin c2 := 'F';  idx := stBnFThread; end;
    eaFutCoin:  begin c2 := 'P';  idx := stBnCThread; end;
  end;

  case aReqType of
    rtNewOrder:   c3 := TR_NEW_ORD;
    rtCnlOrder:   c3 := TR_CNL_ORD;
    rtOrderList:  c3 := TR_REQ_ORD;
    rtPosition:   c3 := TR_REQ_POS;
    rtBalance:    c3 := TR_REQ_BAL;
    rtOrdDetail : c3 := TR_ORD_DETAIL;
    rtTradeAmt  : c3 := TR_TRD_AMT;
    rtOrderBook : c3 := TR_ORD_BOOK;
    rtDnwState  : c3 := TR_DNW_STATE;
  end;

  if Assigned(FSharedThread[idx]) then
    FSharedThread[idx].PushData( c1, c2, c3, aData, aRef )  ;

  inc ( FSndCount );

end;

function TSharedManager.GetExchangeApiType(cMarket: char): TExchangeApiType;
begin
  case cMarket of
  	'S': Result := eaSpot;
    'F': Result := eaFutUsdt;
    'P': Result := eaFutCoin;
  end;
end;


function TSharedManager.GetExchangeKind(cExKind: char): TExchangeKind;
begin
  case cExKind of
    EX_BN : Result := ekBinance;
    EX_UP : Result := ekUpbit;
    EX_BI : Result := ekBithumb;
  end;
end;

function TSharedManager.GetRequestType(cTrDiv: char): TRequestType;
begin  
  case cTrDiv of
    TR_NEW_ORD : Result := rtNewOrder;     // 신규 주문
    TR_CNL_ORD : Result := rtCnlOrder;     // 취소 주문
    TR_REQ_ORD : Result := rtOrderList;     // 주문 조회..
    TR_REQ_POS : Result := rtPosition;     // 포지션 조회..
    TR_REQ_BAL : Result := rtBalance;     // 잔고 조회...
    TR_ABLE_ORD: Result := rtAbleOrder;			// 주문가능금액..
    TR_ORD_DETAIL : Result := rtOrdDetail;
    TR_TRD_AMT  : Result := rtTradeAmt;
    TR_ORD_BOOK : Result := rtOrderBook;
    TR_DNW_STATE: Result := rtDnwState;
  end;
end;

end.
