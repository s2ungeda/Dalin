unit UWebSockets;
interface
uses
  System.Classes, System.SysUtils, System.DateUtils , Windows
  , sgcBase_Classes, sgcSocket_Classes, sgcTCP_Classes,
    sgcWebSocket_Classes, sgcWebSocket_Classes_Indy, sgcWebSocket_Client,
    sgcWebSocket, sgcWebSocket_API_Binance, sgcWebSocket_APIs
  , UApiTypes
  , System.SyncObjs
  , System.Generics.Collections
  ;

type

  TWebsocket = class(TThread)
  private
    FWebSocket: TsgcWebSocketClient;
    FEndPoint: string;
    FLiveTime: TDateTime;
    FSockDiv: integer;
    FConnectTry: integer;
    FSeq: integer;
    FOnNotify: TGetStrProc;
    FPort: integer;
    FExchangeKind: TExchangeKind;
    FSubData: string;
    FSubList: TStrings;
    FDisConnCnt: integer;
    FRcvCnt: int64;

    FConnectTime: TDateTime;
    FExApiType: TExchangeApiType;
    FMarketType: TMarketType;
    FPublicSock: boolean;

    FQueue: TThreadedQueue<string>;

    function Desc : string;
    function GetDelaySec: integer;
    procedure OnData(sData: string);

  protected
    iStart, iEnd : integer;

    procedure wsConnect(Connection: TsgcWSConnection); virtual;
    procedure wsDisconnect(Connection: TsgcWSConnection; Code: Integer);
    procedure wsError(Connection: TsgcWSConnection; const Error: string);
    procedure wsException(Connection: TsgcWSConnection; E: Exception);
    procedure wsMessage(Connection: TsgcWSConnection; const Text: string);
    procedure wsBinary(Connection: TsgcWSConnection; const Data: TMemoryStream);

    procedure Execute; override;

  public

    constructor Create( iSockDiv, iSeq : integer; aExKind : TExchangeKind;
      aExApiType : TExchangeApiType; bPublic: boolean = false);
    destructor Destroy; override;

    procedure SocketCreate ;
    procedure SubscribeAll; virtual; abstract;
    procedure MakeSubData; virtual; abstract;

    procedure init(sAddr : string; iPort : integer = 443);
    procedure DoConnect;
    procedure DoConnectWithListenkey(sKey : string);
    procedure DoReConnect12;
    procedure DoDisConnect;
    procedure SendData( sData : string );
    procedure SetIndex( i, j : integer );

    function  GetDescript: string;
    function  GetSockType : string;
    function  GetSockState : string;
    function  IsReConnect  : boolean;

    property WebSocket : TsgcWebSocketClient read FWebSocket;
    property EndPoint  : string read FEndPoint;
    property Port      : integer read FPort;
    property SockDiv  : integer read FSockDiv;
    property Seq      : integer read FSeq;
    property RcvCnt   : int64 read FRcvCnt ;

    property DelaySec : integer read GetDelaySec;

    property LiveTime : TDateTime read FLiveTime;
    property ConnectTime : TDateTime read FConnectTime;
    property ExchangeKind   : TExchangeKind read FExchangeKind;
    property ExApiType      : TExchangeApiType read FExApiType;
    property MarketType     : TMarketType read FMarketType;
    // usd-m socket 구분(public/ market)
    property PublicSock: boolean  read FPublicSock;

    property ConnectTry : integer read FConnectTry write FConnectTry;
    property DisConnCnt : integer read FDisConnCnt write FDisConnCnt;
    property OnNotify   : TGetStrProc read FOnNotify write FOnNotify;
          //  시세 구독 JSON -> String
    property SubList  : TStrings  read FSubList write FSubList;



  end;
implementation
 uses
  UTypes
  , Vcl.Forms
  , GApp , GLibs
  , UApiConsts
  , sgcWebSocket_Types
  ;


{ TWebsocket }
constructor TWebsocket.Create( iSockDiv, iSeq : integer; aExKind : TExchangeKind;
  aExApiType : TExchangeApiType; bPublic: boolean );
begin

  FWebSocket := nil;

  SocketCreate;

  FConnectTry := 0;
  FDisConnCnt := 0;
  FSockDiv    := iSockDiv;

  FRcvCnt := 0;

  FSeq    := iSeq;
  FExchangeKind := aExKind;
  FExApiType    := aExApiType;
  FMarketType   := ExApiToMarket(aExApiType);
  FPublicSock   := bPublic;

  FSubList    := TStringList.Create;

  FQueue := TThreadedQueue<string>.Create(65536, INFINITE, 0);
  FreeOnTerminate := False;   // 소유자가 명시적으로 해제/대기
  inherited Create(False);    // 즉시 시작
end;

destructor TWebsocket.Destroy;
begin
  FSubList.Free;

  FWebSocket.OnMessage := nil;
  if FWebSocket <> nil then
    FwebSocket.Free;

  FQueue.Free;
  inherited;
end;

procedure TWebsocket.SocketCreate;
begin
  if ( FWebSocket <> nil ) then
    FWebSocket.Free;

  FWebSocket  :=   TsgcWebSocketClient.Create( nil );

  FWebSocket.OnConnect    := wsConnect;
  FWebSocket.OnDisconnect := wsDisconnect;
  FWebSocket.OnError      := wsError;
  FWebSocket.OnException  := wsException;
  FWebSocket.OnMessage    := wsMessage;
  FWebSocket.OnBinary     := wsBinary;

  FWebSocket.NotifyEvents := neNoSync;

  FWebsocket.WatchDog.Enabled := true;
  FWebSocket.WatchDog.Interval:= 1;
  // 좀비 세션 체크..
  FWebSocket.TCPKeepAlive.Enabled  := true;
  FWebSocket.TCPKeepAlive.Time     := 1000 * 60 * 20;
  FWebSocket.TCPKeepAlive.Interval := 1000 * 5;

end;
// -------------

procedure TWebsocket.wsConnect(Connection: TsgcWSConnection);
begin
  FLiveTime   := now;
  FConnectTime:= now;
  inc( FConnectTry );
end;

procedure TWebsocket.wsDisconnect(Connection: TsgcWSConnection; Code: Integer);
begin

  App.Log(llError, '%s(%d.th) WS closed  error : %d %s ',
    [ GetDescript, FDisConnCnt, Code, GetLastErrorMessage ] );

  inc( FDisConnCnt );
end;

procedure TWebsocket.wsError(Connection: TsgcWSConnection; const Error: string);
begin
  App.Log(llError, '%s(%d.th) WS Error : %s [%s]',
    [ GetDescript, FDisConnCnt,  Error ,  GetLastErrorMessage ] );
end;

procedure TWebsocket.wsException(Connection: TsgcWSConnection; E: Exception);
begin
  App.Log(llError, '%s(%d.th) WS Exception : %s [%s]',
    [ GetDescript, FDisConnCnt, E.Message ,  GetLastErrorMessage ] );
end;

procedure TWebsocket.wsMessage(Connection: TsgcWSConnection;
  const Text: string);
begin
  FQueue.PushItem(Text);

//  Exit;
//
//  TThread.Synchronize(nil,
//    procedure
//    begin
//      OnData(Text);
//    end);
end;

procedure TWebsocket.wsBinary(Connection: TsgcWSConnection;
  const Data: TMemoryStream);
var
  stText : string;
  ss: TStringStream;
begin

  ss := TStringStream.Create('');
  try
    ss.CopyFrom(Data,0);
    stText :=ss.DataString;
  finally
    ss.Free;
  end;

  if not stText.IsEmpty then
    FQueue.PushItem(stText);

//  TThread.Synchronize(nil,
//    procedure
//    begin
//      try
//        OnData(stText);
//      except
//      end;
//    end);
end;

///

procedure TWebsocket.OnData( sData : string);
begin
  if ( sData <> '') and ( Assigned(FOnNotify)) then begin
    FLiveTime := now;
    FOnNotify( sData );

    if FRcvCnt > 99999 then
      FRcvCnt := 0;
    inc(FRcvCnt);
  end;
end;

function TWebsocket.Desc: string;
begin
  Result := Format('%s_%d', [ TExchangeKindDesc[FExchangeKind], FSeq ]);
end;

function TWebsocket.GetDescript: string;
begin
  Result := Format('%s-%s-%s-%d', [TExchangeKindShortDesc[FExchangeKind],
    TExApiTypeDesc[FExApiType], GetSockType, FSeq]);
  if FPublicSock then
    Result := Result + '-Pblc';
end;


procedure TWebsocket.DoConnect;
begin
  DoDisConnect;
  FWebSocket.URL  := 'wss://'+FEndPoint;
  FWebSocket.Active := true;
end;


procedure TWebsocket.DoReConnect12;
begin
  DoDisConnect;
  FConnectTime := now;
  FConnectTry  := 1;
end;


procedure TWebsocket.Execute;
var
  LText: string;
begin
  while not Terminated do
    if FQueue.PopItem(LText) = wrSignaled then
      TThread.Synchronize(nil,
        procedure
        begin
          OnData(LText);   // 기존 그대로. 파싱+계산+UI 다 들어있어도 OK
        end);
end;

procedure TWebsocket.DoConnectWithListenkey(sKey: string);
begin
  DoDisConnect;
  FWebSocket.URL  := 'wss://'+FEndPoint+'/'+sKey;
  FWebSocket.Active := true;
end;

procedure TWebsocket.DoDisConnect;
begin
  try
    if FWebSocket.Active then
      FWebSocket.Active := false;
  except
  end;
end;

function TWebsocket.GetDelaySec: integer;
begin
  Result := SecondsBetween( now, FLiveTime );
end;

function TWebsocket.GetSockState: string;
begin
  if FWebSocket.Active then
    Result := 'Open'
  else
    Result := 'Closed';
end;
function TWebsocket.GetSockType: string;
begin
  case FSockDiv of
    0 : Result := 'Quote';
    1 : Result := 'Trade';
    2 : Result := 'WsApi';
  end;
end;
procedure TWebsocket.init( sAddr: string; iPort : integer);
begin

  FPort := iPort;
  FEndPoint := sAddr;
  //MakeSubData;

end;
function TWebsocket.IsReConnect: boolean;
begin
  if not FWebSocket.Active then
    Result := true
  else
    Result := false;
end;



procedure TWebsocket.SendData(sData: string);
begin
  try
    if (sData <> '') and (FWEbSocket.Active) then begin
      FWebSocket.WriteData(sData);
      App.Log(llInfo, '%s Send Data : %s', [ GetDescript, sData ] );
    end;
  except
    on e : Exception do
    begin
      App.Log(llError, '%s Failed Send Data : %s, %s', [GetDescript, e.Message, sData ] );
    end;
  end;
end;

procedure TWebsocket.SetIndex(i, j: integer);
begin
  iStart := i; iEnd := j;
end;


end.

