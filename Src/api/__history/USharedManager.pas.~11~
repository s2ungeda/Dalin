function TSharedManager.GetExchangeApiType(cMarket: char): TExchangeApiType;
begin
  case cMarket of
  	'S': Result := eaSpot;
    'F': Result := eaFutUsdt;
    'P': Result := eaFutCoin;
  end;
end;


function TSharedManager.GetExchangeKind(cExKind: char): TExchangeKind;
begin
  case cExKind of
    EX_BN : Result := ekBinance;
    EX_UP : Result := ekUpbit;
    EX_BI : Result := ekBithumb;
  end;
end;

function TSharedManager.GetRequestType(cTrDiv: char): TRequestType;
begin  
  case cTrDiv of
    TR_NEW_ORD : Result := rtNewOrder;     // ˝Ĺ±Ô ÁÖą®
    TR_CNL_ORD : Result := rtCnlOrder;     // ĂëĽŇ ÁÖą®
    TR_REQ_ORD : Result := rtOrderList;     // ÁÖą® Á¶Č¸..
    TR_REQ_POS : Result := rtPosition;     // Ć÷ÁöĽÇ Á¶Č¸..
    TR_REQ_BAL : Result := rtBalance;     // ŔÜ°í Á¶Č¸...
    TR_ABLE_ORD: Result := rtAbleOrder;			// ÁÖą®°ˇ´É±Ýľ×..
    TR_ORD_DETAIL : Result := rtOrdDetail;
    TR_TRD_AMT  : Result := rtTradeAmt;
    TR_ORD_BOOK : Result := rtOrderBook;
    TR_DNW_STATE: Result := rtDnwState;
  end;
end;

